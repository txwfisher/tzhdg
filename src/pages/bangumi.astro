---
import { Icon } from "astro-icon/components";
import BangumiSection from "@/components/pages/bangumi/BangumiSection.astro";
import TabNav from "@/components/pages/bangumi/TabNav.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import type { UserSubjectCollection } from "@/types/bangumi";
import { formatDateI18nWithTime } from "@/utils/date-utils";
import { getCollection } from "astro:content";

// 检查页面是否启用
if (!siteConfig.pages.bangumi) {
	return Astro.redirect("/404/");
}

// 获取构建时间
const buildTime = formatDateI18nWithTime(new Date());

// 分类映射
const categoryMap = {
	book: { id: "book", name: i18n(I18nKey.bangumiCategoryBook), subjectType: 1 },
	anime: {
		id: "anime",
		name: i18n(I18nKey.bangumiCategoryAnime),
		subjectType: 2,
	},
	music: {
		id: "music",
		name: i18n(I18nKey.bangumiCategoryMusic),
		subjectType: 3,
	},
	game: { id: "game", name: i18n(I18nKey.bangumiCategoryGame), subjectType: 4 },
	real: { id: "real", name: i18n(I18nKey.bangumiCategoryReal), subjectType: 6 },
};

// 从本地 Content Collection 获取数据
const customBangumi = await getCollection("bangumi");
const allPosts = await getCollection("posts");

// 将本地数据映射到 UserSubjectCollection 类型
const mappedData: UserSubjectCollection[] = customBangumi.map((item) => {
	const { data } = item;
	const categoryInfo = categoryMap[data.category];

	// 尝试匹配博客文章以获取正确的链接
	let rawLink = (data.link || "").trim().replace(/\\/g, "/");
	let finalLink = rawLink;

	// 统一规范化函数
	const normalize = (s: string) =>
		s.toLowerCase().replace(/\\/g, "/").replace(/\/$/, "");

	const matchingPost = allPosts.find((p) => {
		const normalizedId = p.id.replace(/\\/g, "/");
		const slug = normalizedId.replace(/\.(md|mdx|markdown)$/i, "");
		const postUrl = `/posts/${slug}/`;

		const nRaw = normalize(rawLink);
		const nSlug = normalize(slug);
		const nUrl = normalize(postUrl);
		const nId = normalize(normalizedId);

		return (
			nRaw === nUrl ||
			nRaw === nSlug ||
			nRaw === nId ||
			nRaw.endsWith(nSlug) ||
			nRaw.endsWith(nId) ||
			// 同时也按标题匹配作为兜底
			p.data.title === data.title
		);
	});

	if (matchingPost) {
		const normalizedId = matchingPost.id.replace(/\\/g, "/");
		const slug = normalizedId.replace(/\.(md|mdx|markdown)$/i, "");
		finalLink = `/posts/${slug}/`;
	}

	// 确保链接以 / 开头（如果是内部链接）
	if (!finalLink.startsWith("http") && !finalLink.startsWith("/")) {
		finalLink = "/" + finalLink;
	}

	return {
		subject_id: 0,
		subject_type: categoryInfo.subjectType,
		rate: data.score || 0,
		type: data.status as any,
		comment: data.comment || null,
		tags: data.tags || [],
		ep_status: 0,
		vol_status: 0,
		updated_at: data.published?.toISOString() || new Date().toISOString(),
		private: false,
		link: finalLink, // 移除 encodeURI，让浏览器和框架自然处理
		subject: {
			id: 0, // 已经在 link 中处理了
			type: categoryInfo.subjectType,
			name: data.title,
			name_cn: data.name_cn || data.title,
			short_summary: "",
			images: {
				medium: typeof data.image === "string" ? data.image : data.image.src,
				large: typeof data.image === "string" ? data.image : data.image.src,
				common: typeof data.image === "string" ? data.image : data.image.src,
				small: typeof data.image === "string" ? data.image : data.image.src,
				grid: typeof data.image === "string" ? data.image : data.image.src,
			},
			volumes: 0,
			eps: 0,
			collection_total: 0,
			score: data.score || 0,
			rank: 0,
			tags: (data.tags || []).map((t) => ({
				name: t,
				count: 0,
				total_cont: 0,
			})),
		},
	};
});

// 获取所有启用分类的数据
const bangumiData: Record<string, UserSubjectCollection[]> = {};
const tabs: Array<{ id: string; name: string; count: number }> = [];

// 指定要显示的分类顺序和项
const displayCategories = ["anime", "book", "game", "music"];

for (const key of displayCategories) {
	if (categoryMap[key as keyof typeof categoryMap]) {
		const info = categoryMap[key as keyof typeof categoryMap];
		const items = mappedData.filter((d) => d.subject_type === info.subjectType);
		bangumiData[key] = items;
		tabs.push({
			id: key,
			name: info.name,
			count: items.length,
		});
	}
}

const activeTab = tabs[0]?.id || "anime";
---

<MainGridLayout title={i18n(I18nKey.bangumi)} description={i18n(I18nKey.bangumiSubtitle)}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
        <!-- 页面标题 -->
        <div class="relative w-full mb-8">
            <div class="mb-6">
                <div class="flex items-center gap-3 mb-3">
                    <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
                        <Icon name="material-symbols:camera-outdoor" class="text-[1.5rem]"></Icon>
                    </div>
                    <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
                        {i18n(I18nKey.bangumi)}
                    </h1>
                </div>
                <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
                    {i18n(I18nKey.bangumiSubtitle)}
                </p>
                <p class="text-xs text-neutral-500 dark:text-neutral-500 mt-2">
                    {i18n(I18nKey.bangumiLastUpdated)} {buildTime}
                </p>
            </div>

      <!-- Tab 导航和内容 -->
      {tabs.length > 0 ? (
        <>
          <TabNav tabs={tabs} activeTab={activeTab} />

          <!-- 内容区域 -->
          {tabs.map((tab) => (
                      <BangumiSection
            sectionId={tab.id}
            items={bangumiData[tab.id] || []}
            isActive={tab.id === activeTab}
            itemsPerPage={15}
          />
          ))}
        </>
      ) : (
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-(--btn-regular-bg) rounded-full mb-6 border border-(--line-divider)">
            <Icon name="material-symbols:settings" class="text-[2rem] text-(--btn-content)" />
          </div>
          <h2 class="text-xl font-semibold text-black/80 dark:text-white/80 mb-3">
            {i18n(I18nKey.bangumiEmpty)}
          </h2>
          <p class="text-black/60 dark:text-white/60 mb-4 max-w-md mx-auto">
            请在 src/content/bangumi 目录下添加内容文件以显示在此页面
          </p>
        </div>
      )}
    </div>
  </div>
</MainGridLayout>

<style>
  /* 自定义样式 */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>