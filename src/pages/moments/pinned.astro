---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MomentCard from "@/components/moments/MomentCard.astro";
import Comment from "@/components/comment/index.astro";

const moments = await getCollection("moments");
const pinnedMoments = moments
  .filter((m) => m.data.pinned)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());
---

<MainGridLayout title="置顶说说" description="我置顶的说说合集">
  <!-- 页面头部 -->
  <div class="pinned-page-header">
    <a href="/moments/" class="back-btn">
      <Icon name="material-symbols:arrow-back-rounded" class="back-icon" />
      <span>返回说说</span>
    </a>
    <div class="pinned-page-title">
      <Icon name="material-symbols:push-pin" class="pinned-title-icon" />
      <h1>置顶说说</h1>
      <span class="pinned-count">{pinnedMoments.length} 条</span>
    </div>
    <p class="pinned-page-desc">那些我想一直停留在顶部的瞬间</p>
  </div>

  <!-- 置顶说说列表 -->
  <div class="pinned-feed" id="pinned-feed">
    {pinnedMoments.length > 0 ? (
      pinnedMoments.map((moment) => (
        <div class="moment-item-wrapper">
          <MomentCard moment={moment} />
        </div>
      ))
    ) : (
      <div class="empty-state">
        <div class="empty-icon">
          <Icon name="material-symbols:push-pin" />
        </div>
        <h3 class="empty-title">还没有置顶任何说说</h3>
        <p class="empty-desc">在说说的 frontmatter 中添加 pinned: true 即可置顶</p>
        <a href="/moments/" class="empty-link">
          <Icon name="material-symbols:arrow-back-rounded" />
          <span>去看看说说</span>
        </a>
      </div>
    )}
  </div>

  <!-- 评论区 -->
  <div id="moments-comments">
    <Comment customPath="/moments/pinned/" />
  </div>
</MainGridLayout>

<style>
  /* 页面头部 */
  .pinned-page-header {
    padding: 1rem 0 0.5rem;
    margin-bottom: 0.5rem;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    margin-bottom: 1rem;
    background: var(--btn-regular-bg);
    color: var(--btn-content);
    border-radius: var(--radius);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid var(--border);
  }

  .back-btn:hover {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
  }

  .back-icon {
    font-size: 1rem;
  }

  .pinned-page-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .pinned-title-icon {
    font-size: 1.5rem;
    color: var(--primary);
    transform: rotate(-45deg);
  }

  .pinned-page-title h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-color);
    margin: 0;
  }

  .pinned-count {
    font-size: 0.8125rem;
    color: var(--content-meta);
    background: var(--btn-regular-bg);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }

  .pinned-page-desc {
    font-size: 0.875rem;
    color: var(--content-meta);
    margin: 0;
  }

  /* 说说列表 */
  .pinned-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0 2rem;
  }

  .moment-item-wrapper {
    position: relative;
  }

  .moment-item-wrapper + .moment-item-wrapper::before {
    content: '';
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: var(--border);
    opacity: 0.7;
  }

  /* 空状态 */
  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-large);
  }

  .empty-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--btn-regular-bg);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 2rem;
    transform: rotate(-45deg);
  }

  .empty-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 0.375rem;
  }

  .empty-desc {
    font-size: 0.875rem;
    color: var(--content-meta);
    margin-bottom: 1rem;
  }

  .empty-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    background: var(--primary);
    color: #fff;
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .empty-link:hover {
    opacity: 0.85;
  }

  /* 响应式 */
  @media (max-width: 480px) {
    .pinned-page-title h1 {
      font-size: 1.25rem;
    }

    .pinned-feed {
      gap: 1.25rem;
      padding: 0.75rem 0 1.5rem;
    }

    .moment-item-wrapper + .moment-item-wrapper::before {
      top: -0.625rem;
      left: 0.75rem;
      right: 0.75rem;
    }
  }
</style>
