---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
	const albums = await getCollection("album");
	return albums.map((album) => ({
		params: { slug: album.id },
		props: { album },
	}));
}

const { album } = Astro.props;
const PHOTOS_PER_PAGE = 25;

const photos = (album.data.photos || []).map((photo: any, index: number) => {
	let src, alt, caption, width, height;

	if (typeof photo === 'string') {
		src = photo;
		alt = '';
		caption = '';
		width = 1920;
		height = 1080;
	} else {
		src = photo.src || photo;
		alt = photo.alt || `${album.data.title} - 照片 ${index + 1}`;
		caption = photo.caption || '';
		width = photo.width || 1920;
		height = photo.height || 1080;
	}

	const aspectRatio = width / height;
	const page = Math.floor(index / PHOTOS_PER_PAGE) + 1;

	return { src, alt, caption, width, height, aspectRatio, page, index };
});

const totalPages = Math.max(1, Math.ceil(photos.length / PHOTOS_PER_PAGE));

function getTimeAgo(date: Date): string {
	const now = new Date();
	const diff = now.getTime() - date.getTime();
	const months = Math.floor(diff / (1000 * 60 * 60 * 24 * 30));

	if (months < 1) return '创建不到1个月前';
	if (months === 1) return '创建1个月前';
	if (months < 12) return `创建${months}个月前`;
	const years = Math.floor(months / 12);
	return years === 1 ? '创建1年前' : `创建${years}年前`;
}
---

<MainGridLayout title={album.data.title} description={album.data.subtitle || `${album.data.title} - 相册`}>
	<div class="flex flex-col w-full relative min-h-[50vh]">
		<div class="page-nav mb-6">
			<a href="/album/" class="nav-back">
				<Icon name="material-symbols:arrow-left-rounded" class="text-2xl" />
			</a>
		</div>

		<div class="album-header">
			<h1 class="album-title">{album.data.title}</h1>
			{album.data.subtitle && (
				<p class="album-subtitle">{album.data.subtitle}</p>
			)}

			<div class="album-meta">
				<span class="meta-item">
					<Icon name="material-symbols:imagesmode" class="text-lg" />
					{photos.length} 照片
				</span>
				<span class="meta-divider"></span>
				<span class="meta-item">
					<Icon name="material-symbols:calendar-today" class="text-lg" />
					{album.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
				</span>
				<span class="meta-divider"></span>
				<span class="meta-item">
					<Icon name="material-symbols:search" class="text-lg" />
					{getTimeAgo(album.data.date)}
				</span>
			</div>
		</div>

		<div class="photo-section">
			{photos.length > 0 ? (
				<>
					<div class="photo-masonry" id="photo-masonry" data-total-pages={totalPages}>
						{photos.map((photo) => (
							<div
								class="photo-item"
								data-index={photo.index}
								data-page={photo.page}
								data-src={photo.src}
								data-alt={photo.alt}
								data-caption={photo.caption}
								data-width={photo.width}
								data-height={photo.height}
								data-aspect={photo.aspectRatio.toFixed(3)}
							>
								<img
									src={photo.src}
									alt={photo.alt}
									class="photo-img"
									loading="lazy"
								/>
								<div class="photo-overlay">
									<Icon name="material-symbols:zoom-in" class="text-2xl" />
								</div>
								{photo.caption && (
									<div class="photo-caption">{photo.caption}</div>
								)}
							</div>
						))}
					</div>

					{totalPages > 1 && (
						<div id="pagination-controls" class="pagination">
							<button id="paginate-prev" class="paginate-btn" disabled>
								<Icon name="material-symbols:chevron-left" class="text-lg" />
								<span>上一页</span>
							</button>
							<div class="paginate-info" id="paginate-info">
								第 <span id="paginate-current">1</span> / {totalPages} 页
							</div>
							<button id="paginate-next" class="paginate-btn">
								<span>下一页</span>
								<Icon name="material-symbols:chevron-right" class="text-lg" />
							</button>
						</div>
					)}
				</>
			) : (
				<div class="empty-state">
					<Icon name="material-symbols:photo-album-outline" class="text-6xl text-[var(--content-meta)]/50 mx-auto mb-4" />
					<p class="text-[var(--content-meta)]">这个相册还没有照片哦~</p>
				</div>
			)}
		</div>
	</div>
</MainGridLayout>

<div id="photo-lightbox" class="lightbox" aria-hidden="true">
	<div class="lightbox-toolbar">
		<div class="toolbar-left">
			<span id="lightbox-counter" class="counter-text">1 / 1</span>
		</div>
		<div class="toolbar-right">
			<button id="lightbox-info-toggle" class="toolbar-btn" title="显示详情">
				<Icon name="material-symbols:info-outline" class="text-xl" />
			</button>
			<button id="lightbox-close" class="toolbar-btn" title="关闭 (Esc)">
				<Icon name="material-symbols:close" class="text-2xl" />
			</button>
		</div>
	</div>

	<button id="lightbox-prev" class="nav-btn nav-prev" aria-label="上一张">
		<Icon name="material-symbols:chevron-left" class="text-4xl" />
	</button>
	<button id="lightbox-next" class="nav-btn nav-next" aria-label="下一张">
		<Icon name="material-symbols:chevron-right" class="text-4xl" />
	</button>

	<div class="lightbox-content">
		<img id="lightbox-image" src="" alt="" class="lightbox-img" />
	</div>

	<div id="lightbox-info" class="lightbox-info">
		<div class="info-main">
			<span id="lightbox-caption" class="caption-text"></span>
			<span id="lightbox-dimensions" class="dimensions-text"></span>
		</div>
		<div class="info-actions">
			<button id="lightbox-download" class="action-btn" title="下载原图">
				<Icon name="material-symbols:download" class="text-xl" />
			</button>
		</div>
	</div>
</div>

<style>
	.page-nav {
		display: flex;
		align-items: center;
	}

	.nav-back {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--text-color);
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 50%;
		transition: all 0.3s;
	}

	.nav-back:hover {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
		transform: scale(1.05);
	}

	.album-header {
		text-align: left;
		padding: 0 0 24px 0;
		margin-bottom: 24px;
		border-bottom: 1px solid var(--border);
	}

	.album-title {
		font-size: 28px;
		font-weight: 700;
		color: var(--text-color);
		margin-bottom: 8px;
		letter-spacing: -0.5px;
	}

	.album-subtitle {
		font-size: 15px;
		color: var(--content-meta);
		margin-bottom: 16px;
		line-height: 1.6;
	}

	.album-meta {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
	}

	.meta-item {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 14px;
		color: var(--content-meta);
	}

	.meta-item :global(svg) {
		color: var(--primary);
	}

	.meta-divider {
		width: 4px;
		height: 4px;
		background: var(--border);
		border-radius: 50%;
	}

	.photo-section {
		animation: fadeIn 0.5s ease-out;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.photo-masonry {
		column-count: 5;
		column-gap: 6px;
	}

	@media (max-width: 1400px) {
		.photo-masonry {
			column-count: 4;
		}
	}

	@media (max-width: 1024px) {
		.photo-masonry {
			column-count: 3;
		}
	}

	@media (max-width: 640px) {
		.photo-masonry {
			column-count: 2;
			column-gap: 4px;
		}
	}

	.photo-item {
		position: relative;
		border-radius: 4px;
		overflow: hidden;
		cursor: pointer;
		transition: all 0.3s ease;
		background: var(--card-bg);
		border: 1px solid var(--border);
		break-inside: avoid;
		margin-bottom: 6px;
	}

	.photo-item.hidden-page {
		display: none;
	}

	.photo-item:hover {
		transform: scale(1.02);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
	}

	.photo-img {
		width: 100%;
		height: auto;
		display: block;
		transition: transform 0.4s ease;
	}

	.photo-item:hover .photo-img {
		transform: scale(1.05);
	}

	.photo-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.3);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity 0.3s;
		color: white;
	}

	.photo-item:hover .photo-overlay {
		opacity: 1;
	}

	.photo-caption {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 10px;
		background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
		color: white;
		font-size: 12px;
		opacity: 0;
		transform: translateY(5px);
		transition: all 0.3s;
	}

	.photo-item:hover .photo-caption {
		opacity: 1;
		transform: translateY(0);
	}

	/* ---- 分页控件 ---- */
	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 20px;
		margin-top: 32px;
		padding-top: 24px;
		border-top: 1px solid var(--border);
	}

	.paginate-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 18px;
		font-size: 14px;
		font-weight: 500;
		color: var(--text-color);
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 8px;
		cursor: pointer;
		transition: all 0.2s;
	}

	.paginate-btn:hover:not(:disabled) {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
	}

	.paginate-btn:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.paginate-info {
		font-size: 14px;
		color: var(--content-meta);
		min-width: 100px;
		text-align: center;
	}

	.paginate-info span {
		font-weight: 600;
		color: var(--text-color);
	}

	.empty-state {
		text-align: center;
		padding: 60px 20px;
	}

	/* ---- 灯箱 ---- */
	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 9999;
		background: rgba(0, 0, 0, 0.95);
		display: flex;
		flex-direction: column;
		opacity: 0;
		visibility: hidden;
		transition: all 0.3s ease;
	}

	.lightbox.active {
		opacity: 1;
		visibility: visible;
	}

	.lightbox-toolbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 16px 20px;
		background: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		z-index: 10;
	}

	.counter-text {
		color: white;
		font-size: 14px;
		font-weight: 500;
		padding: 6px 14px;
		background: rgba(255,255,255,0.1);
		border-radius: 20px;
		backdrop-filter: blur(8px);
	}

	.toolbar-right {
		display: flex;
		gap: 8px;
	}

	.toolbar-btn {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		background: rgba(255,255,255,0.1);
		border-radius: 50%;
		transition: all 0.2s;
		backdrop-filter: blur(8px);
	}

	.toolbar-btn:hover {
		background: rgba(255,255,255,0.2);
		transform: scale(1.05);
	}

	.nav-btn {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 56px;
		height: 56px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		background: rgba(255,255,255,0.1);
		border-radius: 50%;
		transition: all 0.3s;
		backdrop-filter: blur(8px);
		z-index: 10;
	}

	.nav-btn:hover {
		background: rgba(255,255,255,0.2);
		transform: translateY(-50%) scale(1.1);
	}

	.nav-prev { left: 20px; }
	.nav-next { right: 20px; }

	.lightbox-content {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 80px 100px;
		min-height: 0;
	}

	.lightbox-img {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		border-radius: 8px;
		box-shadow: 0 20px 60px rgba(0,0,0,0.5);
		transition: transform 0.3s ease;
	}

	.lightbox-info {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		padding: 20px;
		background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 10;
	}

	.info-main {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.caption-text {
		color: white;
		font-size: 15px;
		max-width: 600px;
	}

	.dimensions-text {
		color: rgba(255,255,255,0.6);
		font-size: 12px;
	}

	.info-actions {
		display: flex;
		gap: 8px;
	}

	.action-btn {
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		background: rgba(255,255,255,0.15);
		border-radius: 50%;
		transition: all 0.2s;
	}

	.action-btn:hover {
		background: rgba(255,255,255,0.25);
		transform: scale(1.05);
	}

	@media (max-width: 768px) {
		.album-title { font-size: 26px; }
		.album-header { padding: 30px 16px; }
		.album-meta { gap: 12px; }
		.meta-item { font-size: 13px; }

		.lightbox-content { padding: 60px 60px; }
		.nav-btn { width: 44px; height: 44px; }
		.nav-prev { left: 8px; }
		.nav-next { right: 8px; }

		.pagination { gap: 12px; margin-top: 24px; }
		.paginate-btn { padding: 6px 14px; font-size: 13px; }
	}
</style>

<script is:inline>
	(function() {
		const PHOTOS_PER_PAGE = 25;
		let totalPages = 1;

		let currentPage = 1;

		let masonry, allItems, prevBtn, nextBtn, pageCurrent;

		// 灯箱元素引用
		let lightbox, lightboxImage, lightboxCaption, lightboxDimensions,
			lightboxCounter, lightboxClose, lightboxPrev, lightboxNext,
			lightboxDownload, lightboxInfoToggle, lightboxInfo;
		let currentPhotoIndex = 0;
		let isInfoVisible = true;

		function initDOM() {
			masonry = document.getElementById('photo-masonry');
			if (!masonry) return;

			const tp = parseInt(masonry.getAttribute('data-total-pages') || '1', 10);
			totalPages = Math.max(1, tp);

			allItems = masonry.querySelectorAll('.photo-item');
			prevBtn = document.getElementById('paginate-prev');
			nextBtn = document.getElementById('paginate-next');
			pageCurrent = document.getElementById('paginate-current');

			lightbox = document.getElementById('photo-lightbox');
			lightboxImage = document.getElementById('lightbox-image');
			lightboxCaption = document.getElementById('lightbox-caption');
			lightboxDimensions = document.getElementById('lightbox-dimensions');
			lightboxCounter = document.getElementById('lightbox-counter');
			lightboxClose = document.getElementById('lightbox-close');
			lightboxPrev = document.getElementById('lightbox-prev');
			lightboxNext = document.getElementById('lightbox-next');
			lightboxDownload = document.getElementById('lightbox-download');
			lightboxInfoToggle = document.getElementById('lightbox-info-toggle');
			lightboxInfo = document.getElementById('lightbox-info');

			bindEvents();
			showPage(1);
		}

		// ---- 分页 ----
		function showPage(page) {
			if (!allItems) return;
			currentPage = Math.max(1, Math.min(page, totalPages));

			allItems.forEach(item => {
				const itemPage = parseInt(item.getAttribute('data-page') || '1', 10);
				if (itemPage === currentPage) {
					item.classList.remove('hidden-page');
				} else {
					item.classList.add('hidden-page');
				}
			});

			if (pageCurrent) {
				pageCurrent.textContent = String(currentPage);
			}

			if (prevBtn) prevBtn.disabled = currentPage <= 1;
			if (nextBtn) nextBtn.disabled = currentPage >= totalPages;

			closeLightbox();
			scrollToTop();
		}

		function scrollToTop() {
			if (!masonry) return;
			const masonryRect = masonry.getBoundingClientRect();
			const top = masonryRect.top + window.scrollY - 100;
			if (window.scrollY > top) {
				window.scrollTo({ top, behavior: 'smooth' });
			}
		}

		function bindEvents() {
			prevBtn?.addEventListener('click', () => showPage(currentPage - 1));
			nextBtn?.addEventListener('click', () => showPage(currentPage + 1));

			if (masonry) {
				masonry.addEventListener('click', (e) => {
					const item = e.target.closest('.photo-item');
					if (!item) return;
					const pageItems = getCurrentPageItems();
					const idx = pageItems.indexOf(item);
					if (idx >= 0) openLightbox(idx);
				});
			}

			lightboxClose?.addEventListener('click', closeLightbox);
			lightboxPrev?.addEventListener('click', () => {
				const count = getVisibleCount();
				currentPhotoIndex = (currentPhotoIndex - 1 + count) % count;
				updateLightbox();
			});
			lightboxNext?.addEventListener('click', () => {
				const count = getVisibleCount();
				currentPhotoIndex = (currentPhotoIndex + 1) % count;
				updateLightbox();
			});
			lightboxInfoToggle?.addEventListener('click', toggleInfo);

			lightbox?.addEventListener('click', (e) => {
				if (e.target === lightbox) closeLightbox();
			});

			document.addEventListener('keydown', (e) => {
				if (!lightbox?.classList.contains('active')) return;
				const count = getVisibleCount();
				switch (e.key) {
					case 'Escape': closeLightbox(); break;
					case 'ArrowLeft':
						currentPhotoIndex = (currentPhotoIndex - 1 + count) % count;
						updateLightbox();
						break;
					case 'ArrowRight':
						currentPhotoIndex = (currentPhotoIndex + 1) % count;
						updateLightbox();
						break;
					case 'i': toggleInfo(); break;
				}
			});
		}

		// ---- 灯箱 ----
		function getCurrentPageItems() {
			return Array.from(allItems).filter(item => {
				const itemPage = parseInt(item.getAttribute('data-page') || '1', 10);
				return itemPage === currentPage;
			});
		}

		function getVisibleCount() {
			return getCurrentPageItems().length;
		}

		function openLightbox(index) {
			currentPhotoIndex = index;
			updateLightbox();
			lightbox?.classList.add('active');
			lightbox?.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
		}

		function closeLightbox() {
			lightbox?.classList.remove('active');
			lightbox?.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
		}

		function updateLightbox() {
			const pageItems = getCurrentPageItems();
			const photo = pageItems[currentPhotoIndex];
			if (!photo) return;

			const src = photo.getAttribute('data-src') || '';
			const alt = photo.getAttribute('data-alt') || '';
			const caption = photo.getAttribute('data-caption') || '';
			const width = photo.getAttribute('data-width') || '';
			const height = photo.getAttribute('data-height') || '';

			if (lightboxImage) {
				lightboxImage.src = src;
				lightboxImage.alt = alt;
			}

			if (lightboxCaption) {
				lightboxCaption.textContent = caption;
				lightboxCaption.style.display = caption ? 'block' : 'none';
			}

			if (lightboxDimensions) {
				if (width && height) {
					lightboxDimensions.textContent = width + ' × ' + height;
					lightboxDimensions.style.display = 'block';
				} else {
					lightboxDimensions.style.display = 'none';
				}
			}

			if (lightboxCounter) {
				const count = getVisibleCount();
				lightboxCounter.textContent = (currentPhotoIndex + 1) + ' / ' + count;
			}

			if (lightboxDownload) {
				lightboxDownload.onclick = () => {
					const link = document.createElement('a');
					link.href = src;
					link.download = alt || 'photo-' + (currentPhotoIndex + 1);
					link.target = '_blank';
					link.click();
				};
			}
		}

		function toggleInfo() {
			isInfoVisible = !isInfoVisible;
			if (lightboxInfo) {
				lightboxInfo.style.opacity = isInfoVisible ? '1' : '0';
				lightboxInfo.style.pointerEvents = isInfoVisible ? 'auto' : 'none';
			}
		}

		// 首次加载时初始化
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initDOM);
		} else {
			initDOM();
		}

		// Swup 导航后重新初始化
		document.addEventListener('swup:contentReplaced', initDOM);
	})();
</script>
