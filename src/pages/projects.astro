---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

// 获取所有导航数据
const allEntries = await getCollection("daohang");

// 按分类分组
const categoryMap = new Map<string, typeof allEntries>();
const allCategories: string[] = [];

allEntries.forEach((entry) => {
	const cat = entry.data.category || "未分类";
	if (!categoryMap.has(cat)) {
		categoryMap.set(cat, []);
		allCategories.push(cat);
	}
	categoryMap.get(cat)!.push(entry);
});

// 排序
const sortedCategories = allCategories.sort((a, b) => {
	if (a === "我的网站") return -1;
	if (b === "我的网站") return 1;
	return 0;
});

const categoryOrder: Record<string, number> = {
	"我的网站": 0,
	"常用网站": 1,
	"资源网站": 2,
	"工具网站": 3,
	"大佬博客": 4,
	"学习网站": 5,
	"文档": 6,
	"其他网站": 7,
};

const sortedData = new Map(
	[...categoryMap.entries()].sort(([a], [b]) => {
		const orderA = categoryOrder[a] ?? 99;
		const orderB = categoryOrder[b] ?? 99;
		return orderA - orderB;
	}).map(([cat, items]) => [
		cat,
		[...items].sort((a, b) => {
			const orderA = a.data.order ?? 99;
			const orderB = b.data.order ?? 99;
			return orderA - orderB;
		}),
	])
);

// 分类颜色
const categoryColors: Record<string, { color: string; bg: string }> = {
	"我的网站": { color: "#3b82f6", bg: "rgba(59, 130, 246, 0.1)" },
	"常用网站": { color: "#f97316", bg: "rgba(249, 115, 22, 0.1)" },
	"资源网站": { color: "#ec4899", bg: "rgba(236, 72, 153, 0.1)" },
	"工具网站": { color: "#10b981", bg: "rgba(16, 185, 129, 0.1)" },
	"大佬博客": { color: "#8b5cf6", bg: "rgba(139, 92, 246, 0.1)" },
	"学习网站": { color: "#06b6d4", bg: "rgba(6, 182, 212, 0.1)" },
	"文档": { color: "#84cc16", bg: "rgba(132, 204, 22, 0.1)" },
	"其他网站": { color: "#6b7280", bg: "rgba(107, 114, 128, 0.1)" },
};

const getCategoryColor = (cat: string) => {
	return categoryColors[cat] || { color: "#6b7280", bg: "rgba(107, 114, 128, 0.1)" };
};

const categoryIcons: Record<string, string> = {
	"我的网站": "material-symbols:person",
	"常用网站": "material-symbols:star",
	"资源网站": "material-symbols:folder",
	"工具网站": "material-symbols:handyman",
	"大佬博客": "material-symbols:menu-book",
	"学习网站": "material-symbols:menu-book",
	"文档": "material-symbols:description",
	"其他网站": "material-symbols:link",
};

const getCategoryIcon = (cat: string) => {
	return categoryIcons[cat] || "material-symbols:link";
};
---

<MainGridLayout title="网站导航" description="收录个人网站、常用工具和收藏网站">
	<div class="daohang-container">

		<!-- 分类导航：点击筛选，不跳转 -->
		<div class="category-nav">
			<button class="category-tab active" data-category="all">
				<span class="tab-dot"></span>
				全部
			</button>
			{sortedCategories.map((cat) => (
				<button class="category-tab" data-category={cat}>
					<span
						class="tab-dot"
						style={`background: ${getCategoryColor(cat).color};`}
					></span>
					{cat}
				</button>
			))}
		</div>

		<!-- 分类列表 -->
		<div class="categories-container">
			{sortedCategories.map((cat) => {
				const items = sortedData.get(cat)!;
				const catColor = getCategoryColor(cat);
				return (
					<section class="category-section" data-category={cat}>
						<div class="category-header">
							<div class="category-title-wrap">
								<div class="category-icon-wrap" style={`background: ${catColor.bg};`}>
									<Icon name={getCategoryIcon(cat)} class="category-icon" style={`color: ${catColor.color};`} />
								</div>
								<div>
									<h2 class="category-title">{cat}</h2>
									<span class="category-count">{items.length} 个网站</span>
								</div>
							</div>
							<div class="category-line" style={`background: linear-gradient(to right, ${catColor.color}, transparent);`}></div>
						</div>

						<div class="sites-grid">
							{items.map((site) => (
								<a
									href={site.data.url}
									target="_blank"
									rel="noopener noreferrer"
									class="site-card"
								>
									<div class="site-card-accent" style={`background: ${site.data.color || catColor.color};`}></div>
									<div class="site-card-inner">
										<div class="site-icon-wrap" style={`background: ${(site.data.color || catColor.color)}15;`}>
											{site.data.icon ? (
												<Icon name={site.data.icon} class="site-icon" style={`color: ${site.data.color || catColor.color};`} />
											) : site.data.image ? (
												<img src={site.data.image} alt={site.data.name} class="site-image" />
											) : (
												<Icon name="material-symbols:language" class="site-icon" style={`color: ${site.data.color || catColor.color};`} />
											)}
										</div>
										<div class="site-content">
											<div class="site-name">{site.data.name}</div>
											<div class="site-desc">{site.data.description}</div>
											{site.data.tags && site.data.tags.length > 0 && (
												<div class="site-tags">
													{site.data.tags.slice(0, 2).map((tag) => (
														<span class="site-tag">{tag}</span>
													))}
												</div>
											)}
										</div>
										<div class="site-arrow">
											<Icon name="material-symbols:arrow-outward-rounded" class="site-arrow-icon" />
										</div>
									</div>
								</a>
							))}
						</div>
					</section>
				);
			})}
		</div>

		<div class="footer-decoration">
			<span class="footer-text">点击即可跳转到对应网站</span>
		</div>
	</div>
</MainGridLayout>

<script>
		// 分类筛选逻辑
		function handleTabClick(e: Event) {
			const target = e.currentTarget as HTMLElement;
			const category = target.dataset.category;
			const tabs = document.querySelectorAll('.category-tab');
			const sections = document.querySelectorAll('.category-section');

			tabs.forEach((t) => t.classList.remove('active'));
			target.classList.add('active');

			if (category === 'all') {
				sections.forEach((s) => {
					(s as HTMLElement).style.display = '';
				});
			} else {
				sections.forEach((s) => {
					const section = s as HTMLElement;
					section.style.display = section.dataset.category === category ? '' : 'none';
				});
			}
		}

		function initCategoryNav() {
			const tabs = document.querySelectorAll('.category-tab');
			if (tabs.length === 0) return;
			tabs.forEach((tab) => {
				const clone = tab.cloneNode(true) as HTMLElement;
				tab.parentNode!.replaceChild(clone, tab);
				clone.addEventListener('click', handleTabClick);
			});
		}

		document.addEventListener('astro:page-load', initCategoryNav);
		document.addEventListener('swup:contentReplaced', initCategoryNav);

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initCategoryNav);
		} else {
			initCategoryNav();
		}
	</script>

<style>
	.daohang-container {
		position: relative;
		margin: 0 auto;
		padding: 0 4px 40px;
	}

	/* 分类导航 */
	.category-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-bottom: 20px;
		padding: 16px;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 16px;
		z-index: 1;
		position: relative;
	}

	.category-tab {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 8px 14px;
		background: var(--bg-color);
		border: 1px solid var(--border);
		border-radius: 10px;
		font-size: 13px;
		font-weight: 500;
		font-family: inherit;
		color: var(--content-meta);
		transition: all 0.25s ease;
		cursor: pointer;
	}

	.category-tab:hover {
		border-color: var(--primary)/40;
		color: var(--primary);
		background: var(--primary)/5;
	}

	.category-tab.active {
		background: var(--primary);
		border-color: var(--primary);
		color: white;
		box-shadow: 0 4px 12px var(--primary)/25;
	}

	.tab-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--content-meta);
		transition: background 0.25s;
	}

	.category-tab.active .tab-dot {
		background: white;
	}

	/* 分类列表 */
	.categories-container {
		display: flex;
		flex-direction: column;
		gap: 24px;
	}

	.category-section {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 24px;
		z-index: 1;
		position: relative;
	}

	.category-header {
		margin-bottom: 20px;
	}

	.category-title-wrap {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 12px;
	}

	.category-icon-wrap {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		flex-shrink: 0;
	}

	.category-icon {
		font-size: 20px;
	}

	.category-title {
		font-size: 16px;
		font-weight: 700;
		color: var(--text-color);
	}

	.category-count {
		font-size: 12px;
		color: var(--content-meta);
	}

	.category-line {
		height: 2px;
		border-radius: 1px;
		opacity: 0.4;
	}

	/* 网站网格 */
	.sites-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 10px;
	}

	.site-card {
		position: relative;
		display: flex;
		background: var(--bg-color);
		border: 1px solid var(--border);
		border-radius: 14px;
		overflow: hidden;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.site-card:hover {
		border-color: transparent;
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
		transform: translateY(-2px);
	}

	.site-card-accent {
		position: absolute;
		top: 0;
		left: 0;
		width: 3px;
		height: 100%;
		opacity: 0.7;
	}

	.site-card-inner {
		position: relative;
		padding: 16px;
		display: flex;
		align-items: center;
		gap: 14px;
		width: 100%;
	}

	.site-icon-wrap {
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		flex-shrink: 0;
	}

	.site-icon {
		font-size: 22px;
	}

	.site-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 8px;
	}

	.site-content {
		flex: 1;
		min-width: 0;
	}

	.site-name {
		font-size: 14px;
		font-weight: 700;
		color: var(--text-color);
		margin-bottom: 3px;
		transition: color 0.2s;
	}

	.site-card:hover .site-name {
		color: var(--primary);
	}

	.site-desc {
		font-size: 12px;
		color: var(--content-meta);
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.site-tags {
		display: flex;
		gap: 4px;
		margin-top: 6px;
	}

	.site-tag {
		font-size: 10px;
		padding: 2px 6px;
		background: var(--primary)/8;
		color: var(--primary);
		border-radius: 6px;
	}

	.site-arrow {
		flex-shrink: 0;
		opacity: 0;
		transition: all 0.3s ease;
		transform: translateX(-5px);
	}

	.site-card:hover .site-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.site-arrow-icon {
		font-size: 16px;
		color: var(--primary);
	}

	/* 底部装饰 */
	.footer-decoration {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px 0 8px;
	}

	.footer-text {
		font-size: 12px;
		color: var(--content-meta);
		opacity: 0.6;
	}

	/* 响应式 */
	@media (max-width: 640px) {
		.category-nav {
			padding: 12px;
			gap: 6px;
		}

		.category-tab {
			padding: 6px 10px;
			font-size: 12px;
		}

		.sites-grid {
			grid-template-columns: 1fr;
		}

		.category-section {
			padding: 18px;
		}
	}
</style>
