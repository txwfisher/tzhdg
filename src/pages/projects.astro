---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

// 获取所有导航数据
const allEntries = await getCollection("daohang");

// 按分类分组
const categoryMap = new Map<string, typeof allEntries>();
const allCategories: string[] = [];

allEntries.forEach((entry) => {
	const cat = entry.data.category || "未分类";
	if (!categoryMap.has(cat)) {
		categoryMap.set(cat, []);
		allCategories.push(cat);
	}
	categoryMap.get(cat)!.push(entry);
});

// 排序
const categoryOrder: Record<string, number> = {
	我的网站: 0,
	常用网站: 1,
	资源网站: 2,
	工具网站: 3,
	大佬博客: 4,
	学习网站: 5,
	文档: 6,
	其他网站: 7,
};

const sortedCategories = [...allCategories].sort((a, b) => {
	return (categoryOrder[a] ?? 99) - (categoryOrder[b] ?? 99);
});

const sortedData = new Map(
	[...categoryMap.entries()]
		.sort(([a], [b]) => {
			return (categoryOrder[a] ?? 99) - (categoryOrder[b] ?? 99);
		})
		.map(([cat, items]) => [
			cat,
			[...items].sort((a, b) => {
				const orderA = a.data.order ?? 99;
				const orderB = b.data.order ?? 99;
				return orderA - orderB;
			}),
		]),
);

// 分类图标
const categoryIcons: Record<string, string> = {
	我的网站: "material-symbols:person",
	常用网站: "material-symbols:star",
	资源网站: "material-symbols:folder",
	工具网站: "material-symbols:handyman",
	大佬博客: "material-symbols:menu-book",
	学习网站: "material-symbols:school",
	文档: "material-symbols:description",
	其他网站: "material-symbols:link",
};

const getCategoryIcon = (cat: string) => {
	return categoryIcons[cat] || "material-symbols:link";
};

// 计算每个分类的数量
const categoryCounts: Record<string, number> = {};
for (const [cat, items] of sortedData) {
	categoryCounts[cat] = items.length;
}

// 所有启用的网站（扁平列表）
const allSites = sortedCategories.flatMap((cat) => sortedData.get(cat)!);
---

<MainGridLayout title="网站导航" description="收录个人网站、常用工具和收藏网站">

  <script slot="head" is:inline>
    (function() {
      function initToolsTabs() {
        var tabNav = document.querySelector('[data-tools-tab-nav]');
        var tabButtons = document.querySelectorAll('[data-tools-tab]');
        var sections = document.querySelectorAll('[data-tools-section]');
        var indicator = document.querySelector('[data-tools-tab-indicator]');
        if (!tabNav || !tabButtons.length || !indicator) return;

        function updateIndicator(targetBtn) {
          if (!indicator || !targetBtn) return;
          indicator.style.left = targetBtn.offsetLeft + 'px';
          indicator.style.top = targetBtn.offsetTop + 'px';
          indicator.style.width = targetBtn.offsetWidth + 'px';
          indicator.style.height = targetBtn.offsetHeight + 'px';
          indicator.style.opacity = '1';
        }

        function activateTab(targetTab) {
          if (!targetTab) return;
          var targetButton = Array.from(tabButtons).find(function(btn) {
            return btn.dataset.toolsTab === targetTab;
          });
          if (!targetButton) return;

          // 切换按钮激活状态
          tabButtons.forEach(function(btn) {
            btn.classList.remove('tools-tab-btn-active');
            btn.classList.add('tools-tab-btn-inactive');
            btn.disabled = false;
          });
          targetButton.classList.remove('tools-tab-btn-inactive');
          targetButton.classList.add('tools-tab-btn-active');
          targetButton.disabled = true;

          // 更新指示器
          requestAnimationFrame(function() { updateIndicator(targetButton); });

          // 切换内容区域并重置卡片动画
          sections.forEach(function(section) {
            if (section.dataset.toolsSection === targetTab) {
              section.classList.remove('hidden');
              var cards = section.querySelectorAll('.tools-card');
              cards.forEach(function(card) {
                card.style.animation = 'none';
                card.offsetHeight;
                card.style.animation = '';
              });
            } else {
              section.classList.add('hidden');
            }
          });

          var nextHash = '#tools-' + encodeURIComponent(targetTab);
          if (window.location.hash !== nextHash) {
            window.history.replaceState(null, '', nextHash);
          }
        }

        // 绑定点击事件
        tabButtons.forEach(function(button) {
          button.addEventListener('click', function() {
            var targetTab = button.dataset.toolsTab;
            if (targetTab) activateTab(targetTab);
          });
        });

        // 从 hash 恢复 Tab
        function getTabFromHash() {
          var hash = window.location.hash.replace(/^#tools-/, '');
          if (!hash) return '';
          try { return decodeURIComponent(hash); } catch(e) { return ''; }
        }

        var initialTab = getTabFromHash();
        if (initialTab) {
          activateTab(initialTab);
        } else {
          var activeBtn = tabNav.querySelector('.tools-tab-btn-active');
          if (activeBtn) {
            requestAnimationFrame(function() { updateIndicator(activeBtn); });
          }
        }

        window.addEventListener('hashchange', function() {
          var tabFromHash = getTabFromHash();
          if (tabFromHash) activateTab(tabFromHash);
        });

        window.addEventListener('resize', function() {
          var activeBtn = tabNav.querySelector('.tools-tab-btn-active');
          if (activeBtn) updateIndicator(activeBtn);
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initToolsTabs);
      } else {
        initToolsTabs();
      }
      document.addEventListener("astro:page-load", initToolsTabs);
      document.addEventListener("astro:after-swap", initToolsTabs);
      document.addEventListener("swup:contentReplaced", initToolsTabs);
    })();
  </script>

  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">
      <!-- 页面标题 -->
      <div class="mb-6">
        <div class="flex items-center gap-3 mb-3">
          <Icon name="material-symbols:bookmark" class="text-[1.875rem] text-neutral-900 dark:text-neutral-100" />
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            网站导航
          </div>
        </div>
        <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
          收录个人网站、常用工具和收藏网站
        </p>
      </div>

      <!-- Tab 分类导航（椭圆胶囊 + 换行） -->
      {allSites.length > 0 && sortedCategories.length > 1 && (
        <div class="tools-tab-wrapper">
          <div class="tools-tab-pill" data-tools-tab-nav>
            <div class="tools-tab-indicator" data-tools-tab-indicator></div>
            <button data-tools-tab="all" class="tools-tab-btn tools-tab-btn-active">
              全部
              <span class="tools-tab-badge">{allSites.length}</span>
            </button>
            {sortedCategories.map((cat) => (
              <button data-tools-tab={cat} class="tools-tab-btn tools-tab-btn-inactive">
                {cat}
                <span class="tools-tab-badge">{categoryCounts[cat]}</span>
              </button>
            ))}
          </div>
        </div>
      )}

      <!-- 工具卡片内容 -->
      {allSites.length > 0 ? (
        <div>
          <!-- 全部：按分类分组显示 -->
          <div data-tools-section="all">
            {sortedCategories.map((cat) => {
              const catSites = sortedData.get(cat)!;
              if (catSites.length === 0) return null;
              return (
                <div class="tools-category-group mt-8 first:mt-0">
                  <div class="flex items-center gap-3 mb-5">
                    <div class="flex items-center gap-2">
                      <Icon name={getCategoryIcon(cat)} class="text-lg text-neutral-900 dark:text-neutral-100" />
                      <span class="text-base font-bold text-neutral-900 dark:text-neutral-100">{cat}</span>
                    </div>
                    <span class="text-xs text-neutral-400 dark:text-neutral-500">{catSites.length}</span>
                    <div class="flex-1 h-[2px] bg-black dark:bg-white" />
                  </div>
                  <div class="tools-card-grid">
                    {catSites.map((site, index) => (
                      <a
                        href={site.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="tools-card group"
                        data-category={cat}
                        style={`animation-delay: ${index * 60}ms`}
                      >
                        <div class="tools-card-jump-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M7 17L17 7" />
                            <path d="M7 7h10v10" />
                          </svg>
                        </div>
                        <div class="flex items-center gap-2 mb-3">
                          {site.data.icon ? (
                            site.data.icon.startsWith('http') ? (
                              <img src={site.data.icon} alt={site.data.name} class="w-6 h-6 rounded object-contain shrink-0" />
                            ) : (
                              <Icon name={site.data.icon} class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                            )
                          ) : site.data.image ? (
                            <img src={site.data.image} alt={site.data.name} class="w-6 h-6 rounded object-contain shrink-0" />
                          ) : (
                            <Icon name="material-symbols:language" class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                          )}
                          <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 group-hover:translate-x-1 transition-transform duration-300 truncate">
                            {site.data.name}
                          </h3>
                        </div>
                        <p class="tools-card-desc">{site.data.description}</p>
                        <div class="tools-card-footer">
                          <span class="text-xs text-neutral-400 dark:text-neutral-500 truncate">
                            {(() => {
                              try { return new URL(site.data.url).hostname; } catch { return site.data.url; }
                            })()}
                          </span>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>

          <!-- 各分类独立 Tab 内容 -->
          {sortedCategories.map((cat) => {
            const catSites = sortedData.get(cat)!;
            if (catSites.length === 0) return null;
            return (
              <div data-tools-section={cat} class="hidden">
                <div class="tools-card-grid">
                  {catSites.map((site, index) => (
                    <a
                      href={site.data.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="tools-card group"
                      data-category={cat}
                      style={`animation-delay: ${index * 60}ms`}
                    >
                      <div class="tools-card-jump-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M7 17L17 7" />
                          <path d="M7 7h10v10" />
                        </svg>
                      </div>
                      <div class="flex items-center gap-2 mb-3">
                        {site.data.icon ? (
                          site.data.icon.startsWith('http') ? (
                            <img src={site.data.icon} alt={site.data.name} class="w-6 h-6 rounded object-contain shrink-0" />
                          ) : (
                            <Icon name={site.data.icon} class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                          )
                        ) : site.data.image ? (
                          <img src={site.data.image} alt={site.data.name} class="w-6 h-6 rounded object-contain shrink-0" />
                        ) : (
                          <Icon name="material-symbols:language" class="text-2xl text-neutral-600 dark:text-neutral-300 group-hover:text-black dark:group-hover:text-white transition-colors duration-300 shrink-0" />
                        )}
                        <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 group-hover:translate-x-1 transition-transform duration-300 truncate">
                          {site.data.name}
                        </h3>
                      </div>
                      <p class="tools-card-desc">{site.data.description}</p>
                      <div class="tools-card-footer">
                        <span class="text-xs text-neutral-400 dark:text-neutral-500 truncate">
                          {(() => {
                            try { return new URL(site.data.url).hostname; } catch { return site.data.url; }
                          })()}
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <Icon name="material-symbols:bookmark-outline" class="text-5xl text-neutral-300 dark:text-neutral-600 mb-4" />
          <p class="text-neutral-500 dark:text-neutral-400">暂无收录的网站</p>
        </div>
      )}
    </div>
  </div>
</MainGridLayout>

<style>
  /* ===== Tab 外层 ===== */
  .tools-tab-wrapper {
    margin-bottom: 1.5rem;
  }

  /* 胶囊容器（换行） */
  .tools-tab-pill {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding: 0.375rem;
    border-radius: 1rem;
    border: 2px solid #000;
  }
  :root.dark .tools-tab-pill {
    border-color: #fff;
  }

  /* 滑动指示条（填充胶囊背景） */
  .tools-tab-indicator {
    position: absolute;
    border-radius: 9999px;
    background: #000;
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                top 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }
  :root.dark .tools-tab-indicator {
    background: #fff;
  }

  /* Tab 按钮 */
  .tools-tab-btn {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border: none;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    background: transparent;
    transition: color 0.2s;
    flex-shrink: 0;
    font-family: inherit;
  }

  /* 激活态：指示条覆盖时白色文字 */
  .tools-tab-btn-active {
    color: #fff;
    cursor: default;
  }
  :root.dark .tools-tab-btn-active {
    color: #000;
  }

  /* 未激活态：黑色文字 */
  .tools-tab-btn-inactive {
    color: #000;
  }
  .tools-tab-btn-inactive:hover {
    opacity: 0.7;
  }
  :root.dark .tools-tab-btn-inactive {
    color: #fff;
  }

  /* 数量徽章 */
  .tools-tab-badge {
    font-size: 0.65rem;
    padding: 0.0625rem 0.375rem;
    border-radius: 9999px;
    background: oklch(0.92 0 0);
    color: oklch(0.35 0 0);
    line-height: 1.4;
  }
  :root.dark .tools-tab-badge {
    background: oklch(0.25 0 0);
    color: oklch(0.65 0 0);
  }

  /* 激活态徽章反转 */
  .tools-tab-btn-active .tools-tab-badge {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }
  :root.dark .tools-tab-btn-active .tools-tab-badge {
    background: rgba(0, 0, 0, 0.2);
    color: #000;
  }

  /* 分组间距（"全部" Tab） */
  .tools-category-group + .tools-category-group {
    margin-top: 2rem;
  }

  /* 卡片网格 */
  .tools-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 1024px) {
    .tools-card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .tools-card-grid {
      grid-template-columns: 1fr;
    }
  }

  /* 卡片样式 */
  .tools-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border-radius: var(--radius-large, 0.75rem);
    border: 2px solid #000;
    background: #fff;
    text-decoration: none;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    animation: toolsCardSlideIn 0.5s ease-out forwards;
    transition: border-color 300ms ease, box-shadow 300ms ease, transform 300ms ease, background-color 300ms ease;
  }
  :root.dark .tools-card {
    border-color: #fff;
    background: #000;
  }
  .tools-card:hover {
    border-color: #000;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transform: translateY(-2px);
  }
  :root.dark .tools-card:hover {
    border-color: #fff;
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  /* 右上角跳转图标 */
  .tools-card-jump-icon {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    color: oklch(0.55 0 0);
    background: oklch(0.9 0 0);
    opacity: 0;
    transform: scale(0.8) translateY(-4px);
    transition: opacity 250ms cubic-bezier(0.4, 0, 0.2, 1), transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 2;
    pointer-events: none;
  }
  :root.dark .tools-card-jump-icon {
    color: oklch(0.6 0 0);
    background: oklch(0.2 0 0);
  }
  .tools-card:hover .tools-card-jump-icon {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  /* 描述文本 */
  .tools-card-desc {
    margin: 0 0 0.75rem 0;
    font-size: 0.875rem;
    font-weight: 400;
    color: oklch(0.45 0 0);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    min-height: 2.625rem;
  }
  :root.dark .tools-card-desc {
    color: oklch(0.55 0 0);
  }

  /* 底部域名 */
  .tools-card-footer {
    display: flex;
    align-items: center;
    padding-top: 0.75rem;
    border-top: 1px solid oklch(0.9 0 0);
    margin-top: auto;
  }
  :root.dark .tools-card-footer {
    border-color: oklch(0.2 0 0);
  }

  @keyframes toolsCardSlideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
