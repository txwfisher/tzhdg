---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MomentCard from "@/components/moments/MomentCard.astro";
import { commentConfig } from "@/config/commentConfig";

const moments = await getCollection("moments");
const sortedMoments = moments.sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

const albums = await getCollection("album");
const albumCount = albums.length;
const walineConfig = commentConfig.waline;
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
  <div class="moments-container">
    <!-- 顶部用户卡片 -->
    <div class="profile-card">
      <div class="profile-header">
        <div class="avatar-wrapper">
          <img 
            src="https://re.0824.uk/zl/tx.webp" 
            alt="头像" 
            class="avatar-img"
          />
          <div class="online-dot"></div>
        </div>
        
        <div class="profile-info">
          <h1 class="profile-name">我的动态</h1>
          <p class="profile-bio">{sortedMoments.length} 条说说 · {albumCount} 个相册</p>
        </div>
      </div>
    </div>

    <!-- 导航标签 -->
    <div class="nav-tabs">
      <a href="/moments/" class="nav-tab active">
        <Icon name="material-symbols:chat-bubble" class="tab-icon" />
        <span>说说</span>
      </a>
      <a href="/album/" class="nav-tab">
        <Icon name="material-symbols:photo-library" class="tab-icon" />
        <span>相册</span>
      </a>
      <a href="/life/guestbook/" class="nav-tab">
        <Icon name="material-symbols:edit-note" class="tab-icon" />
        <span>留言</span>
      </a>
    </div>

    <!-- 动态列表 -->
    <div class="moments-feed">
      {sortedMoments.length > 0 ? (
        sortedMoments.map((moment) => (
          <MomentCard moment={moment} />
        ))
      ) : (
        <div class="empty-state">
          <div class="empty-icon">
            <Icon name="material-symbols:sentiment-neutral-outline" />
          </div>
          <h3 class="empty-title">还没有发布任何说说</h3>
          <p class="empty-desc">快去记录你的生活点滴吧</p>
        </div>
      )}
    </div>

    <!-- 评论区 -->
    <div class="comment-section">
      <div class="comment-header">
        <Icon name="material-symbols:chat" class="comment-icon" />
        <h2 class="comment-title">评论</h2>
      </div>
      <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
      <div id="waline"></div>
    </div>

    <!-- 访客统计 -->
    <div class="visitor-stat">
      <Icon name="material-symbols:visibility-outline" class="stat-icon" />
      <span class="waline-count" data-path="/moments/">-</span>
      <span class="stat-label">次浏览</span>
    </div>
  </div>
</MainGridLayout>

<script>
  // 访客统计
  const countElements = document.querySelectorAll('.waline-count[data-path="/moments/"]');
  if (countElements.length > 0) {
    const serverURL = "https://co.tsh520.cn";
    
    fetch(`${serverURL}/api/uv?path=/moments/`)
      .then(res => res.json())
      .then(data => {
        const count = data.data?.unique_visitor || data.uv || 0;
        countElements.forEach(el => {
          el.textContent = String(count);
        });
      })
      .catch(() => {
        countElements.forEach(el => {
          el.textContent = "-";
        });
      });
  }

  // 评论按钮滚动到评论区
  document.querySelectorAll('.comment-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('waline')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // 初始化 Waline
  import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
  
  init({
    el: '#waline',
    serverURL: 'https://co.tsh520.cn',
    path: '/moments/',
    dark: 'html.dark',
    wordLimit: [2, 300],
    pageview: true,
  });
</script>

<style>
  .moments-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 16px 40px;
  }

  /* 用户卡片 */
  .profile-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 16px;
  }

  .profile-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .avatar-wrapper {
    position: relative;
    flex-shrink: 0;
  }

  .avatar-img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #4a9eff;
  }

  .online-dot {
    position: absolute;
    bottom: 2px;
    right: 2px;
    width: 12px;
    height: 12px;
    background: #22c55e;
    border: 2px solid var(--card-bg);
    border-radius: 50%;
  }

  .profile-info {
    flex: 1;
    min-width: 0;
  }

  .profile-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-color);
    margin-bottom: 4px;
  }

  .profile-bio {
    font-size: 13px;
    color: var(--content-meta);
  }

  /* 导航标签 */
  .nav-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }

  .nav-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 16px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--content-meta);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }

  .nav-tab:hover {
    border-color: #4a9eff;
    color: #4a9eff;
  }

  .nav-tab.active {
    background: #4a9eff;
    border-color: #4a9eff;
    color: white;
  }

  .tab-icon {
    font-size: 18px;
  }

  /* 动态列表 */
  .moments-feed {
    display: flex;
    flex-direction: column;
  }

  /* 评论区 */
  .comment-section {
    margin-top: 24px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
  }

  .comment-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .comment-icon {
    font-size: 22px;
    color: #4a9eff;
  }

  .comment-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-color);
  }

  /* 空状态 */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
  }

  .empty-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-color);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 32px;
  }

  .empty-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 6px;
  }

  .empty-desc {
    font-size: 14px;
    color: var(--content-meta);
  }

  /* 访客统计 */
  .visitor-stat {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 24px;
    padding: 12px;
    color: var(--content-meta);
    font-size: 13px;
  }

  .stat-icon {
    font-size: 16px;
  }

  .waline-count {
    font-weight: 600;
    color: var(--text-color);
  }

  /* Waline 评论样式覆盖 */
  .comment-section :global(#waline) {
    font-family: inherit;
  }

  .comment-section :global(.wl-panel) {
    background: transparent;
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 16px;
    border: 1px solid var(--border);
  }

  .comment-section :global(.wl-input-wrapper) {
    background: var(--bg-color);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .comment-section :global(.wl-input) {
    background: transparent;
    color: var(--text-color);
  }

  .comment-section :global(.wl-btn) {
    background: #4a9eff;
    border: none;
    border-radius: 8px;
    color: white;
    padding: 8px 20px;
    font-weight: 500;
    transition: all 0.2s;
  }

  .comment-section :global(.wl-btn:hover) {
    background: #3b8ae6;
    transform: translateY(-1px);
  }

  .comment-section :global(.wl-comments) {
    padding-top: 20px;
  }

  .comment-section :global(.wl-comments-title) {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .comment-section :global(.wl-item) {
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }

  .comment-section :global(.wl-item:last-child) {
    border-bottom: none;
  }

  .comment-section :global(.wl-avatar) {
    border-radius: 50%;
    border: 2px solid var(--border);
  }

  .comment-section :global(.wl-user-name) {
    color: #4a9eff;
    font-weight: 600;
    font-size: 14px;
  }

  .comment-section :global(.wl-time) {
    color: var(--content-meta);
    font-size: 12px;
  }

  .comment-section :global(.wl-content) {
    color: var(--text-color);
    line-height: 1.7;
    margin-top: 8px;
  }

  .comment-section :global(.wl-reply) {
    color: #4a9eff;
    font-size: 13px;
    margin-top: 8px;
  }

  .comment-section :global(.wl-reply-btn) {
    color: #4a9eff;
  }

  .comment-section :global(.wl-action) {
    color: var(--content-meta);
  }

  /* 响应式 */
  @media (max-width: 480px) {
    .moments-container {
      padding: 0 12px 32px;
    }

    .profile-card {
      padding: 16px;
      border-radius: 12px;
      margin-bottom: 12px;
    }

    .avatar-img {
      width: 48px;
      height: 48px;
    }

    .profile-name {
      font-size: 16px;
    }

    .nav-tabs {
      gap: 6px;
      margin-bottom: 12px;
    }

    .nav-tab {
      padding: 8px 12px;
      font-size: 13px;
      border-radius: 8px;
    }

    .tab-icon {
      font-size: 16px;
    }

    .comment-section {
      margin-top: 20px;
      padding: 16px;
      border-radius: 12px;
    }
  }
</style>
