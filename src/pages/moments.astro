---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import MomentCard from "@/components/moments/MomentCard.astro";
import MomentsCover from "@/components/moments/MomentsCover.astro";
import Comment from "@/components/comment/index.astro";
import { externalMomentsConfig } from "@/config/externalMomentsConfig";

const moments = await getCollection("moments");
const sortedMoments = moments
  .filter((m) => !m.data.pinned)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

// 置顶说说
const pinnedMoments = moments
  .filter((m) => m.data.pinned)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

// 获取 moments 资产目录下的所有图片
const momentAssets = import.meta.glob<{ default: ImageMetadata }>(
  "../content/moments/assets/*.{jpeg,jpg,png,gif,webp,avif}",
  { eager: true },
);

// 解析图片路径
const parseImages = (imagesData: any): (string | ImageMetadata)[] => {
  let rawPaths: string[] = [];
  if (Array.isArray(imagesData)) {
    rawPaths = imagesData.map((img) =>
      typeof img === "string" ? img : img.src || img,
    );
  } else if (typeof imagesData === "string" && imagesData.trim()) {
    rawPaths = imagesData
      .split(/[,;]/)
      .map((img) => img.trim())
      .filter((img) => img);
  }

  return Array.from(new Set(rawPaths))
    .map((img) => {
      if (
        img.startsWith("http://") ||
        img.startsWith("https://") ||
        img.startsWith("/")
      ) {
        return img;
      }
      const cleanPath = img.replace(/^\.\//, "");
      if (cleanPath.startsWith("assets/")) {
        const fileName = cleanPath.replace("assets/", "");
        for (const path in momentAssets) {
          if (path.endsWith(fileName)) {
            return momentAssets[path].default;
          }
        }
      }
      return img;
    })
    .filter((img) => img);
};

// 预处理置顶说说
const pinnedData = pinnedMoments.map((m) => ({
  images: parseImages(m.data.images),
  body: m.body || "",
  date: m.data.published,
}));

const albums = await getCollection("album");
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
  <!-- 微信朋友圈风格封面 -->
  <MomentsCover />

  <!-- 置顶说说 -->
  {pinnedData.length > 0 && (
    <a href="/moments/pinned/" class="wx-pinned">
      <div class="wx-pinned-tag">
        <span>置顶</span>
      </div>
      <div class="wx-pinned-items">
        {pinnedData.map((item) => (
          <div class="wx-pinned-preview">
            {item.images.length > 0 ? (
              <div class={`wx-pimgs wx-pimgs-${Math.min(item.images.length, 9)}`}>
                {item.images.slice(0, 9).map((img) => (
                  typeof img === "string" ? (
                    <img src={img} alt="" class="wx-pinned-img" loading="lazy" />
                  ) : (
                    <Image src={img} alt="" class="wx-pinned-img" loading="lazy" />
                  )
                ))}
              </div>
            ) : (
              <p class="wx-ptxt">{item.body.slice(0, 60)}{item.body.length > 60 ? '...' : ''}</p>
            )}
          </div>
        ))}
      </div>
    </a>
  )}

  <!-- 外部置顶说说（从 Gist 拉取） -->
  {externalMomentsConfig.enable && externalMomentsConfig.gistId && (
    <div id="ext-pinned-feed" style="display:none;margin-bottom:1.25rem;"></div>
  )}

  <!-- 外部普通说说列表（从 Gist 拉取） -->
  {externalMomentsConfig.enable && externalMomentsConfig.gistId && (
    <div class="wx-feed" id="external-moments-feed"></div>
  )}

  <!-- 说说列表 -->
  <div class="wx-feed" id="moments-feed">
    {sortedMoments.length > 0 ? (
      sortedMoments.map((moment) => (
        <div class="wx-feed-item">
          <MomentCard moment={moment} />
        </div>
      ))
    ) : (
      <div class="wx-empty">
        <div class="wx-empty-icon">
          <Icon name="material-symbols:sentiment-neutral-outline" />
        </div>
        <h3>还没有发布任何说说</h3>
        <p>快去记录你的生活点滴吧</p>
      </div>
    )}
  </div>

  <!-- 评论区 -->
  <div id="moments-comments">
    <Comment customPath="/moments/" />
  </div>

  <!-- 访客统计 -->
  <div class="wx-visitor">
    <Icon name="material-symbols:visibility-outline" class="wx-visitor-icon" />
    <span class="waline-count" data-path="/moments/">-</span>
    <span>次浏览</span>
  </div>
</MainGridLayout>

<script is:inline>
  var countElements = document.querySelectorAll('.waline-count[data-path="/moments/"]');
  if (countElements.length > 0) {
    var serverURL = "https://co.tsh520.cn";
    fetch(serverURL + "/api/uv?path=/moments/")
      .then(function(res) { return res.json(); })
      .then(function(data) {
        var count = data.data ? data.data.unique_visitor || data.uv || 0 : (data.uv || 0);
        countElements.forEach(function(el) { el.textContent = String(count); });
      })
      .catch(function() {
        countElements.forEach(function(el) { el.textContent = "-"; });
      });
  }
</script>

{externalMomentsConfig.enable && externalMomentsConfig.gistId && (
<script is:inline
  data-gist={externalMomentsConfig.gistId}
  data-file={externalMomentsConfig.fileName}
  data-author={externalMomentsConfig.defaultAuthor}
  data-avatar={externalMomentsConfig.defaultAvatar}>
(function() {
  var _s = document.currentScript;
  var gistId = _s.getAttribute("data-gist");
  var fileName = _s.getAttribute("data-file");
  var defaultAuthor = _s.getAttribute("data-author");
  var defaultAvatar = _s.getAttribute("data-avatar");
  var container = document.getElementById("external-moments-feed");
  if (!container) return;

  // 使用缓存避免 Swup 切换页面时重复请求
  var cacheKey = "__externalMomentsCache";

  function formatTimeAgo(date) {
    var now = new Date();
    var diff = now - date;
    var minutes = Math.floor(diff / 60000);
    var hours = Math.floor(diff / 3600000);
    var days = Math.floor(diff / 86400000);
    if (minutes < 1) return "刚刚";
    if (minutes < 60) return minutes + "分钟前";
    if (hours < 24) return hours + "小时前";
    if (days < 30) return days + "天前";
    return date.getFullYear() + "-" + String(date.getMonth()+1).padStart(2,"0") + "-" + String(date.getDate()).padStart(2,"0");
  }

  function escapeHtml(text) {
    var div = document.createElement("div"); div.textContent = text; return div.innerHTML;
  }

  function renderMarkdown(text) {
    // 简单 markdown 渲染：换行、粗体、斜体、链接
    return escapeHtml(text)
      .replace(/\n/g, "<br>")
      .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
      .replace(/\*(.*?)\*/g, "<em>$1</em>")
      .replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" rel="noopener" style="color:var(--primary);text-decoration:underline;">$1</a>');
  }

  function getGridCols(count) {
    if (count === 1) return 1;
    if (count === 2 || count === 4) return 2;
    return 3;
  }

  // 解析图片（兼容数组和逗号/分号分隔的字符串）
  function parseImages(raw) {
    if (!raw) return [];
    if (Array.isArray(raw)) return raw.filter(Boolean);
    if (typeof raw === "string" && raw.trim()) {
      return raw.split(/[,;]/).map(function(s) { return s.trim(); }).filter(Boolean);
    }
    return [];
  }

  function renderCard(m) {
    var author = m.author || defaultAuthor;
    var avatar = m.avatar || defaultAvatar;
    var date = new Date(m.published);
    var timeStr = formatTimeAgo(date);
    var content = renderMarkdown(m.content || "");
    var images = parseImages(m.images);
    var tags = m.tags || [];
    var location = m.location || "";

    // 图片网格 — 和 MomentCard.astro 一致
    var imagesHtml = "";
    if (images.length > 0) {
      var cols = getGridCols(images.length);
      var imgsHtml = images.slice(0, 9).map(function(url, i) {
        var isLast = i === 8 && images.length > 9;
        return '<div class="image-item">' +
          '<img src="' + url + '" alt="" class="image-img" loading="lazy" onerror="this.parentElement.style.display=\'none\'" data-fancybox="gallery-ext-' + m.id + '">' +
          (isLast ? '<div class="more-overlay"><span class="more-text">+' + (images.length - 8) + '</span></div>' : "") +
        '</div>';
      }).join("");
      imagesHtml = '<div class="card-images image-cols-' + cols + '">' + imgsHtml + '</div>';
    }

    // 标签 — 和 MomentCard.astro 一致，带链接
    var tagsHtml = "";
    if (tags.length > 0) {
      tagsHtml = '<div class="card-tags">' + tags.map(function(t) {
        var tagText = t.trim();
        return '<a href="/archive/?tag=' + encodeURIComponent(tagText) + '" class="tag-item">#' + escapeHtml(tagText) + '</a>';
      }).join("") + '</div>';
    }

    // 位置 — 和 MomentCard.astro 一致
    var locationHtml = location
      ? '<span class="meta-dot">·</span><span class="location"><svg class="location-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>' + escapeHtml(location) + '</span>'
      : "";

    // 置顶徽章
    var pinnedBadge = m.pinned
      ? '<span class="pinned-badge"><svg class="pinned-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6a1 1 0 0 1 1-1h1a1 1 0 0 0 0-8H7a1 1 0 0 0 0 8h1a1 1 0 0 1 1 1z"/></svg><span>置顶</span></span>'
      : "";

    // 完整卡片 — 和 MomentCard.astro 结构一致
    return '<div class="moment-card">' +
      '<div class="card-accent-bar"></div>' +
      '<div class="card-header">' +
        '<div class="card-avatar">' +
          '<img src="' + avatar + '" alt="' + escapeHtml(author) + '" class="avatar-img" loading="lazy">' +
        '</div>' +
        '<div class="card-user-info">' +
          '<div class="user-row"><span class="user-name">' + escapeHtml(author) + '</span>' + pinnedBadge + '</div>' +
          '<div class="meta-row"><time>' + timeStr + '</time>' + locationHtml + '</div>' +
        '</div>' +
      '</div>' +
      '<div class="card-content"><div class="moment-markdown" style="color:var(--text-color);font-size:0.9375rem;line-height:1.75;">' + content + '</div></div>' +
      imagesHtml + tagsHtml +
    '</div>';
  }

  function renderMoments(moments) {
    if (!moments || moments.length === 0) { container.style.display = "none"; return; }
    moments.sort(function(a, b) { return new Date(b.published) - new Date(a.published); });

    // 分离置顶和普通
    var pinned = moments.filter(function(m) { return m.pinned; });
    var normal = moments.filter(function(m) { return !m.pinned; });

    // 渲染外部置顶到置顶块
    if (pinned.length > 0) {
      var pinnedContainer = document.getElementById("ext-pinned-feed");
      if (pinnedContainer) {
        pinnedContainer.innerHTML = '<div class="wx-feed">' +
          pinned.map(function(m) {
            return '<div class="wx-feed-item">' + renderCard(m) + '</div>';
          }).join("") + '</div>';
        pinnedContainer.style.display = "";
      }
    }

    // 渲染普通说说
    if (normal.length === 0) { container.style.display = "none"; return; }
    container.innerHTML = normal.map(function(m) {
      return '<div class="wx-feed-item">' + renderCard(m) + '</div>';
    }).join("");
  }

  function fetchMoments() {
    // 检查缓存（5分钟内有效）
    if (window[cacheKey] && window[cacheKey].time > Date.now() - 300000) {
      renderMoments(window[cacheKey].data);
      return;
    }

    // 使用 Token 读取（Secret Gist 需要认证）
    var token = localStorage.getItem("gh_moments_token") || "";
    var headers = { "Accept": "application/vnd.github+json" };
    if (token) headers["Authorization"] = "Bearer " + token;

    fetch("https://api.github.com/gists/" + gistId, { headers: headers })
      .then(function(r) {
        if (!r.ok) throw new Error("HTTP " + r.status);
        return r.json();
      })
      .then(function(gist) {
        var file = gist.files[fileName];
        if (!file) { container.style.display = "none"; return; }
        var moments = JSON.parse(file.content || "[]");
        if (!moments.length) { container.style.display = "none"; return; }
        console.log("[外部说说] 加载到", moments.length, "条，第一条图片:", moments[0] && moments[0].images);
        window[cacheKey] = { data: moments, time: Date.now() };
        renderMoments(moments);
      })
      .catch(function(e) {
        console.warn("[外部说说] 加载失败:", e.message);
        container.style.display = "none";
      });
  }

  // 初始化
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", fetchMoments);
  } else {
    fetchMoments();
  }

  // Swup 页面切换后从缓存恢复
  document.addEventListener("swup:content:replace", function() {
    if (window[cacheKey]) renderMoments(window[cacheKey].data);
  });
})();
</script>
)}

<style>
  /* ============================================
   * 置顶说说
   * ============================================ */
  .wx-pinned {
    display: flex;
    align-items: stretch;
    background: var(--card-bg);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    min-height: 4.5rem;
    text-decoration: none;
    color: var(--text-color);
    border: 1.5px solid transparent;
    transition: border-color 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }

  .wx-pinned:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
  }

  .wx-pinned-tag {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0 0.75rem;
    background: #fff;
    color: #1a1a1a;
    font-size: 1.625rem;
    font-weight: 400;
    flex-shrink: 0;
    white-space: nowrap;
  }

  :root.dark .wx-pinned-tag {
    background: #000;
    color: #fff;
  }

  .wx-pinned-items {
    display: flex;
    flex: 1;
    justify-content: flex-end;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    gap: 0;
  }

  .wx-pinned-items::-webkit-scrollbar {
    display: none;
  }

  .wx-pinned-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    min-width: 4rem;
    max-width: 7.5rem;
    flex: 1;
    border-left: 1px solid var(--border);
    overflow: hidden;
  }

  .wx-pinned-preview:first-child {
    border-left: none;
  }

  /* 图片缩略图网格 */
  .wx-pimgs {
    display: grid;
    gap: 2px;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
  }

  .wx-pimgs-1 { grid-template-columns: 1fr; }
  .wx-pimgs-2 { grid-template-columns: 1fr 1fr; }
  .wx-pimgs-3 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .wx-pimgs-3 .wx-pinned-img:first-child { grid-row: 1 / 3; }
  .wx-pimgs-4 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .wx-pimgs-5,
  .wx-pimgs-6 {
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .wx-pimgs-7,
  .wx-pimgs-8,
  .wx-pimgs-9 {
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr 1fr;
  }

  .wx-pinned-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 无图片文字预览 */
  .wx-ptxt {
    margin: 0;
    font-size: 0.625rem;
    color: var(--content-meta);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    word-break: break-all;
  }

  /* ============================================
   * 说说列表
   * ============================================ */
  .wx-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0 2rem;
  }

  .wx-feed-item {
    position: relative;
  }

  .wx-feed-item + .wx-feed-item::before {
    content: '';
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: var(--border);
    opacity: 0.7;
  }

  /* 空状态 */
  .wx-empty {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .wx-empty-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--btn-regular-bg);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 2rem;
  }

  .wx-empty h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 0.375rem;
  }

  .wx-empty p {
    font-size: 0.875rem;
    color: var(--content-meta);
    margin: 0;
  }

  /* 访客统计 */
  .wx-visitor {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin: 1.5rem auto 0;
    padding: 0.75rem;
    color: var(--content-meta);
    font-size: 0.8125rem;
  }

  .wx-visitor-icon {
    font-size: 1rem;
  }

  /* 响应式 */
  @media (max-width: 480px) {
    .wx-feed {
      gap: 1.25rem;
      padding: 0.75rem 0 1.5rem;
    }

    .wx-feed-item + .wx-feed-item::before {
      top: -0.625rem;
      left: 0.75rem;
      right: 0.75rem;
    }

    .wx-pinned-preview {
      min-width: 3.5rem;
      max-width: 6rem;
      padding: 0.375rem;
    }

    .wx-ptxt {
      font-size: 0.5625rem;
      -webkit-line-clamp: 3;
    }
  }
</style>

<style is:global>
  /* ============================================
   * 外部说说卡片（复用 MomentCard.astro 的结构）
   * 需要 is:global 因为卡片 HTML 由 JS 动态生成
   * ============================================ */
  #external-moments-feed .moment-card {
    position: relative;
    background: var(--card-bg);
    border-radius: var(--radius-large);
    padding: 1.25rem 1.25rem 1.25rem 2.25rem;
    border: 2px solid #000;
    overflow: hidden;
    transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
  }
  :root.dark #external-moments-feed .moment-card { border-color: #3f3f46; }
  #external-moments-feed .moment-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
  :root.dark #external-moments-feed .moment-card:hover {
    border-color: #fff;
    box-shadow: 0 4px 24px rgba(255,255,255,0.08);
  }

  #external-moments-feed .card-accent-bar {
    position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
    background: var(--primary); opacity: 0.35; border-radius: 0 2px 2px 0;
  }

  #external-moments-feed .card-header { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.75rem; }
  #external-moments-feed .card-avatar { flex-shrink: 0; }
  #external-moments-feed .avatar-img {
    width: 2.5rem; height: 2.5rem; border-radius: 50%; object-fit: cover;
    border: 2px solid var(--primary); box-sizing: border-box;
  }
  #external-moments-feed .card-user-info { flex: 1; min-width: 0; }
  #external-moments-feed .user-row { display: flex; align-items: center; gap: 0.375rem; margin-bottom: 0.125rem; }
  #external-moments-feed .pinned-badge {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.125rem 0.5rem; background: var(--btn-regular-bg);
    color: var(--btn-content); border-radius: var(--radius);
    font-size: 0.75rem; font-weight: 600;
  }
  #external-moments-feed .pinned-icon { width: 14px; height: 14px; }
  #external-moments-feed .user-name { font-size: 0.9375rem; font-weight: 600; color: var(--primary); }
  #external-moments-feed .meta-row { display: flex; align-items: center; gap: 0.375rem; font-size: 0.75rem; color: var(--content-meta); }
  #external-moments-feed .meta-dot { opacity: 0.5; }
  #external-moments-feed .location {
    display: inline-flex; align-items: center; gap: 0.125rem;
    max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  #external-moments-feed .location-icon { font-size: 0.875rem; flex-shrink: 0; width: 14px; height: 14px; }

  #external-moments-feed .card-content { margin-bottom: 0.75rem; }
  #external-moments-feed .moment-markdown { word-break: break-word; }
  #external-moments-feed .moment-markdown p { margin-bottom: 0.375rem; }
  #external-moments-feed .moment-markdown p:last-child { margin-bottom: 0; }
  #external-moments-feed .moment-markdown img { border-radius: var(--radius); margin: 0.5rem 0; max-width: 100%; }
  #external-moments-feed .moment-markdown a { color: var(--primary); text-decoration: underline; }

  #external-moments-feed .card-images { display: grid; gap: 0.375rem; margin-bottom: 0.75rem; }
  #external-moments-feed .image-cols-1 { grid-template-columns: 100px; }
