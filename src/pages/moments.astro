---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MomentCard from "@/components/moments/MomentCard.astro";
import Comment from "@/components/comment/index.astro";

const moments = await getCollection("moments");
const sortedMoments = moments.sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

const albums = await getCollection("album");
const albumCount = albums.length;
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
	<!-- 动态列表 -->
	<div class="moments-feed">
		{sortedMoments.length > 0 ? (
			sortedMoments.map((moment) => (
				<MomentCard moment={moment} />
			))
		) : (
			<div class="empty-state">
				<div class="empty-icon">
					<Icon name="material-symbols:sentiment-neutral-outline" />
				</div>
				<h3 class="empty-title">还没有发布任何说说</h3>
				<p class="empty-desc">快去记录你的生活点滴吧</p>
			</div>
		)}
	</div>

	<!-- 评论区 - 使用统一的 Comment 组件 -->
	<Comment customPath="/moments/" />

	<!-- 访客统计 -->
	<div class="visitor-stat">
		<Icon name="material-symbols:visibility-outline" class="stat-icon" />
		<span class="waline-count" data-path="/moments/">-</span>
		<span class="stat-label">次浏览</span>
	</div>
</MainGridLayout>

<script is:inline>
	// 访客统计
	const countElements = document.querySelectorAll(
		'.waline-count[data-path="/moments/"]',
	);
	if (countElements.length > 0) {
		const serverURL = "https://co.tsh520.cn";

		fetch(`${serverURL}/api/uv?path=/moments/`)
			.then((res) => res.json())
			.then((data) => {
				const count = data.data?.unique_visitor || data.uv || 0;
				countElements.forEach((el) => {
					el.textContent = String(count);
				});
			})
			.catch(() => {
				countElements.forEach((el) => {
					el.textContent = "-";
				});
			});
	}
</script>

<style>
	/* 动态列表 */
	.moments-feed {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1rem 0 2rem;
	}

	/* 空状态 */
	.empty-state {
		text-align: center;
		padding: 3rem 1rem;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: var(--radius-large);
	}

	.empty-icon {
		width: 4rem;
		height: 4rem;
		margin: 0 auto 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--btn-regular-bg);
		border-radius: 50%;
		color: var(--content-meta);
		font-size: 2rem;
	}

	.empty-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-color);
		margin-bottom: 0.375rem;
	}

	.empty-desc {
		font-size: 0.875rem;
		color: var(--content-meta);
	}

	/* 访客统计 */
	.visitor-stat {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.375rem;
		margin: 1.5rem auto 0;
		padding: 0.75rem;
		color: var(--content-meta);
		font-size: 0.8125rem;
	}

	.stat-icon {
		font-size: 1rem;
	}

	.waline-count {
		font-weight: 600;
		color: var(--text-color);
	}

	/* 响应式 */
	@media (max-width: 480px) {
		.moments-feed {
			gap: 0.5rem;
			padding: 0.75rem 0 1.5rem;
		}
	}
</style>
