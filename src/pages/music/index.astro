---
import { getCollection } from "astro:content";
import Comment from "@components/comment/index.astro";
import { Icon } from "astro-icon/components";
import { musicPlayerConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const metingApiBase = musicPlayerConfig.meting?.api
	? musicPlayerConfig.meting.api.split("?")[0]
	: "https://mu.tsh520.cn/api";

if (!siteConfig.pages.musicPage) {
	return Astro.redirect("/404/");
}

const customBangumi = await getCollection("bangumi");

const musicEntries = customBangumi
	.filter((item) => item.data.category === "music")
	.map((item) => {
		const { data } = item;
		const imageSrc =
			typeof data.image === "string" ? data.image : data.image.src;
		return {
			title: data.title,
			artist: data.artist || "",
			image: imageSrc,
			audioUrl: data.audioUrl || "",
			lrcUrl: data.lrcUrl || "",
			metingServer: data.metingServer || "",
			metingId: data.metingId || "",
			score: data.score || 0,
			status: data.status,
			comment: data.comment || "",
			published: data.published?.toISOString() || new Date().toISOString(),
		};
	})
	.sort(
		(a, b) => new Date(b.published).getTime() - new Date(a.published).getTime(),
	);

const collectionPlaylist = musicEntries
	.filter((item) => item.audioUrl || item.metingId)
	.map((item) => ({
		name: item.title,
		artist: item.artist,
		url: item.audioUrl,
		pic: item.image,
		lrc: item.lrcUrl,
		metingServer: item.metingServer || "",
		metingId: item.metingId || "",
	}));

const playlistIndexByTitle = new Map<string, number>();
collectionPlaylist.forEach((track, i) =>
	playlistIndexByTitle.set(track.name, i),
);
---

<MainGridLayout title={i18n(I18nKey.musicPageTitle)} description={i18n(I18nKey.musicPageSubtitle)}>
	<div class="music-app" id="music-app">
		<div class="music-bg" id="music-bg"></div>
		<div class="music-bg-overlay"></div>

		<div class="music-layout">
			<!-- Player Panel -->
			<div class="player-panel">
				<div class="player-panel-inner">
					<!-- Vinyl Disc -->
					<div class="vinyl-stage" id="vinyl-stage">
						<div class="vinyl-glow" id="vinyl-glow"></div>
						<div class="vinyl-disc" id="vinyl-disc">
							<div class="vinyl-groove"></div>
							<div class="vinyl-groove vinyl-groove-2"></div>
							<div class="vinyl-groove vinyl-groove-3"></div>
							<div class="vinyl-cover-wrap">
								<img class="vinyl-cover" id="vinyl-cover" src="" alt="Cover" />
							</div>
							<div class="vinyl-hole"></div>
						</div>
						<div class="vinyl-arm" id="vinyl-arm">
							<div class="vinyl-arm-base"></div>
							<div class="vinyl-arm-rod"></div>
							<div class="vinyl-arm-head"></div>
						</div>
					</div>

					<!-- Song Info -->
					<div class="song-info">
						<h2 class="song-title" id="song-title">{i18n(I18nKey.music)}</h2>
						<p class="song-artist" id="song-artist">{i18n(I18nKey.musicNoPlaying)}</p>
					</div>

					<!-- Progress -->
					<div class="progress-area">
						<span class="progress-time" id="time-current">0:00</span>
						<div class="progress-track" id="progress-track">
							<div class="progress-bg"></div>
							<div class="progress-fill" id="progress-fill"></div>
							<div class="progress-thumb" id="progress-thumb"></div>
						</div>
						<span class="progress-time" id="time-total">0:00</span>
					</div>

					<!-- Controls -->
					<div class="controls">
						<button class="ctrl-btn" id="btn-mode" title="播放模式">
							<Icon name="material-symbols:repeat-rounded" class="ctrl-icon icon-repeat" />
							<Icon name="material-symbols:repeat-one-rounded" class="ctrl-icon icon-repeat-one hidden" />
							<Icon name="material-symbols:shuffle-rounded" class="ctrl-icon icon-shuffle hidden" />
						</button>
						<button class="ctrl-btn" id="btn-prev" title="上一曲">
							<Icon name="material-symbols:skip-previous-rounded" class="ctrl-icon-lg" />
						</button>
						<button class="ctrl-btn-play" id="btn-play" title="播放">
							<Icon name="material-symbols:play-arrow-rounded" class="ctrl-icon-xl icon-play" />
							<Icon name="material-symbols:pause-rounded" class="ctrl-icon-xl icon-pause hidden" />
						</button>
						<button class="ctrl-btn" id="btn-next" title="下一曲">
							<Icon name="material-symbols:skip-next-rounded" class="ctrl-icon-lg" />
						</button>
						<button class="ctrl-btn" id="btn-volume" title="音量">
							<Icon name="material-symbols:volume-up-rounded" class="ctrl-icon icon-vol-on" />
							<Icon name="material-symbols:volume-off-rounded" class="ctrl-icon icon-vol-off hidden" />
						</button>
					</div>
				</div>
			</div>

			<!-- Lyrics Section (right of player on desktop) -->
			<div class="lyrics-section" id="lyrics-section">
				<div class="lyrics-scroll" id="lyrics-scroll">
					<div class="lyrics-empty">
						<Icon name="material-symbols:lyrics-outline" class="lyrics-empty-icon" />
						<span>暂无歌词</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Playlist Section (full width below) -->
		<div class="playlist-section">
					<div class="playlist-header">
						<Icon name="material-symbols:queue-music-rounded" class="playlist-header-icon" />
						<span class="playlist-header-text">播放列表</span>
						<span class="playlist-count" id="playlist-count">0 首</span>
					</div>
					<div class="playlist-list" id="playlist-list">
						{musicEntries.length > 0 ? (
							musicEntries.map((item) => {
								const playlistIdx = (item.audioUrl || item.metingId) ? (playlistIndexByTitle.get(item.title) ?? -1) : -1;
								return (
									<div class="playlist-item" data-playlist-index={playlistIdx} data-has-audio={(item.audioUrl || item.metingId) ? "1" : "0"}>
										<div class="playlist-item-cover">
											<img src={item.image} alt={item.title} class="playlist-item-img" loading="lazy" />
											<div class="playlist-item-play-overlay">
												<Icon name="material-symbols:play-arrow-rounded" class="playlist-item-play-icon" />
											</div>
											<div class="playlist-item-eq">
												<span class="eq-bar"></span>
												<span class="eq-bar"></span>
												<span class="eq-bar"></span>
											</div>
										</div>
										<div class="playlist-item-info">
											<div class="playlist-item-title">{item.title}</div>
											<div class="playlist-item-artist">{item.artist}</div>
										</div>
									</div>
								);
							})
						) : (
							<div class="playlist-empty">
								<Icon name="material-symbols:library-music-outline" class="playlist-empty-icon" />
								<span>{i18n(I18nKey.musicPageNoData)}</span>
							</div>
						)}
					</div>
				</div>
	</div>
	<Comment customPath="/music/" />

<style>
	/* ── App Container ── */
	.music-app {
		position: relative;
		overflow: hidden;
		min-height: 60vh;
		background: var(--card-bg);
		border-radius: var(--radius-large);
		width: 100%;
	}
	:root.dark .music-app {
		background: #0a0a0f;
	}

	/* ── Background ── */
	.music-bg {
		display: none;
	}
	.music-bg-overlay {
		display: none;
	}
	:root.dark .music-bg {
		display: block;
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
		filter: blur(100px) saturate(0.5) brightness(0.3);
		transform: scale(1.2);
		transition: background-image 1s ease;
		z-index: 0;
	}
	:root.dark .music-bg-overlay {
		display: block;
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			rgba(10,10,15,0.6) 0%,
			rgba(10,10,15,0.85) 50%,
			rgba(10,10,15,0.95) 100%
		);
		z-index: 1;
	}

	/* ── Layout ── */
	.music-layout {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	@media (min-width: 769px) {
		.music-layout {
			flex-direction: row;
			min-height: 480px;
			align-items: stretch;
		}
	}

	/* ── Player Panel ── */
	.player-panel {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 32px 24px;
	}
	@media (min-width: 769px) {
		.player-panel {
			flex: 0 0 280px;
			border-right: 1px solid var(--line-divider);
			position: sticky;
			top: 0;
			align-self: flex-start;
		}
		:root.dark .player-panel {
			border-right-color: rgba(255,255,255,0.06);
		}
	}
	.player-panel-inner {
		width: 100%;
		max-width: 340px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 28px;
	}

	/* ── Vinyl Stage ── */
	.vinyl-stage {
		position: relative;
		width: 240px;
		height: 240px;
		margin-bottom: 8px;
	}
	.vinyl-glow {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 320px; height: 320px;
		border-radius: 50%;
		background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
		opacity: 0;
		transition: opacity 0.8s ease;
		filter: blur(40px);
	}
	.vinyl-stage.playing .vinyl-glow { opacity: 0.15; }

	.vinyl-disc {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background: linear-gradient(135deg, #1a1a2e 0%, #0d0d1a 50%, #1a1a2e 100%);
		box-shadow:
			0 0 0 3px rgba(0,0,0,0.05),
			0 8px 40px rgba(0,0,0,0.12),
			inset 0 0 60px rgba(0,0,0,0.3);
	}
	:root.dark .vinyl-disc {
		box-shadow:
			0 0 0 3px rgba(255,255,255,0.05),
			0 8px 40px rgba(0,0,0,0.5),
			inset 0 0 60px rgba(0,0,0,0.3);
	}
	.vinyl-disc.spinning {
		animation: vinyl-rotate 20s linear infinite;
	}
	@keyframes vinyl-rotate {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.vinyl-groove {
		position: absolute;
		inset: 20px;
		border-radius: 50%;
		border: 1px solid rgba(255,255,255,0.03);
	}
	.vinyl-groove-2 { inset: 40px; }
	.vinyl-groove-3 { inset: 55px; border-color: rgba(255,255,255,0.05); }

	.vinyl-cover-wrap {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 110px; height: 110px;
		border-radius: 50%;
		overflow: hidden;
		box-shadow: 0 4px 20px rgba(0,0,0,0.4);
		border: 3px solid rgba(255,255,255,0.08);
	}
	.vinyl-cover {
		width: 100%; height: 100%;
		object-fit: cover;
		display: block;
	}

	.vinyl-hole {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 16px; height: 16px;
		border-radius: 50%;
		background: var(--card-bg);
		border: 2px solid rgba(255,255,255,0.1);
		z-index: 2;
	}
	:root.dark .vinyl-hole {
		background: #0a0a0f;
	}

	/* Vinyl Arm */
	.vinyl-arm {
		position: absolute;
		top: -10px;
		right: 30px;
		width: 100px;
		height: 180px;
		z-index: 10;
		transform-origin: 80px 10px;
		transform: rotate(-25deg);
		transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.vinyl-arm.on-record { transform: rotate(0deg); }

	.vinyl-arm-base {
		position: absolute;
		top: 0; right: 10px;
		width: 20px; height: 20px;
		border-radius: 50%;
		background: linear-gradient(135deg, #444, #222);
		border: 2px solid rgba(255,255,255,0.1);
		box-shadow: 0 2px 8px rgba(0,0,0,0.5);
	}
	.vinyl-arm-rod {
		position: absolute;
		top: 10px; right: 18px;
		width: 4px; height: 140px;
		background: linear-gradient(180deg, #555, #333);
		border-radius: 2px;
		transform: rotate(15deg);
		transform-origin: top center;
	}
	.vinyl-arm-head {
		position: absolute;
		bottom: 20px; right: 40px;
		width: 12px; height: 20px;
		background: linear-gradient(180deg, #666, #444);
		border-radius: 2px 2px 4px 4px;
		transform: rotate(15deg);
	}

	/* ── Song Info ── */
	.song-info {
		text-align: center;
		width: 100%;
	}
	.song-title {
		font-size: 20px;
		font-weight: 700;
		color: var(--deep-text);
		margin: 0 0 6px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	:root.dark .song-title {
		color: #f0f0f0;
	}
	.song-artist {
		font-size: 13px;
		color: var(--content-meta);
		margin: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	:root.dark .song-artist {
		color: rgba(255,255,255,0.45);
	}

	/* ── Progress ── */
	.progress-area {
		display: flex;
		align-items: center;
		gap: 12px;
		width: 100%;
	}
	.progress-time {
		font-size: 11px;
		color: var(--content-meta);
		font-variant-numeric: tabular-nums;
		min-width: 36px;
		text-align: center;
	}
	:root.dark .progress-time {
		color: rgba(255,255,255,0.35);
	}
	.progress-track {
		flex: 1;
		height: 4px;
		position: relative;
		cursor: pointer;
		border-radius: 2px;
	}
	.progress-bg {
		position: absolute;
		inset: 0;
		background: var(--btn-regular-bg);
		border-radius: 2px;
	}
	:root.dark .progress-bg {
		background: rgba(255,255,255,0.08);
	}
	.progress-fill {
		position: absolute;
		left: 0; top: 0; bottom: 0;
		width: 0%;
		background: var(--primary);
		border-radius: 2px;
		transition: width 0.15s linear;
	}
	.progress-thumb {
		position: absolute;
		top: 50%;
		transform: translate(-50%, -50%);
		width: 14px; height: 14px;
		background: var(--primary);
		border-radius: 50%;
		box-shadow: 0 2px 8px rgba(0,0,0,0.15);
		left: 0%;
		opacity: 0;
		transition: opacity 0.2s, left 0.15s linear;
	}
	:root.dark .progress-thumb {
		background: #fff;
		box-shadow: 0 2px 8px rgba(0,0,0,0.3);
	}
	.progress-track:hover .progress-thumb { opacity: 1; }
	.progress-track:hover { height: 6px; }

	/* ── Controls ── */
	.controls {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 20px;
		width: 100%;
	}
	.ctrl-btn {
		background: none;
		border: none;
		color: var(--btn-content);
		cursor: pointer;
		padding: 10px;
		border-radius: 50%;
		transition: color 0.2s, transform 0.15s;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.ctrl-btn:hover { color: var(--deep-text); }
	.ctrl-btn:active { transform: scale(0.88); }
	.ctrl-btn.active { color: var(--primary); }
	:root.dark .ctrl-btn {
		color: rgba(255,255,255,0.5);
	}
	:root.dark .ctrl-btn:hover { color: #fff; }

	.ctrl-btn-play {
		background: var(--primary);
		border: none;
		color: #fff;
		cursor: pointer;
		width: 60px; height: 60px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		box-shadow: 0 4px 24px color-mix(in srgb, var(--primary) 40%, transparent);
		transition: transform 0.15s, box-shadow 0.2s;
	}
	:root.dark .ctrl-btn-play {
		color: #111;
	}
	.ctrl-btn-play:hover {
		transform: scale(1.05);
		box-shadow: 0 6px 32px color-mix(in srgb, var(--primary) 50%, transparent);
	}
	.ctrl-btn-play:active { transform: scale(0.92); }

	.ctrl-icon { width: 24px; height: 24px; }
	.ctrl-icon-lg { width: 32px; height: 32px; }
	.ctrl-icon-xl { width: 30px; height: 30px; }

	/* ── Lyrics Section ── */
	.lyrics-section {
		position: relative;
		overflow: hidden;
	}
	@media (min-width: 769px) {
		.lyrics-section {
			flex: 1;
			min-width: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 24px 32px;
		}
		.lyrics-scroll {
			width: 100%;
			max-height: 400px;
		}
	}
	.lyrics-scroll {
		height: 280px;
		overflow-y: auto;
		scroll-behavior: smooth;
		padding: 100px 32px;
		mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			black 20%,
			black 80%,
			transparent 100%
		);
		-webkit-mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			black 20%,
			black 80%,
			transparent 100%
		);
	}
	.lyrics-scroll::-webkit-scrollbar { width: 3px; }
	.lyrics-scroll::-webkit-scrollbar-thumb {
		background: var(--line-divider);
		border-radius: 3px;
	}
	:root.dark .lyrics-scroll::-webkit-scrollbar-thumb {
		background: rgba(255,255,255,0.1);
	}

	:global(.lyrics-empty) {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 12px;
		padding: 60px 0;
		color: var(--content-meta);
		font-size: 14px;
	}
	:root.dark :global(.lyrics-empty) {
		color: rgba(255,255,255,0.2);
	}
	.lyrics-empty-icon {
		width: 36px; height: 36px;
		opacity: 0.3;
	}

	/* Lyric Lines — 3D Depth Effect (global: JS动态创建的元素没有scoped属性) */
	:global(.lyric-line) {
		padding: 10px 0;
		font-size: 15px;
		color: var(--content-meta);
		transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		cursor: pointer;
		line-height: 1.8;
		text-align: center;
		letter-spacing: 0.02em;
		transform: scale(0.88);
		filter: blur(1px);
	}
	:global(.lyric-line.near) {
		color: var(--deep-text) !important;
		transform: scale(0.95) !important;
		filter: blur(0.5px) !important;
		opacity: 0.72 !important;
	}
	:global(.lyric-line.active) {
		color: var(--primary) !important;
		font-size: 22px !important;
		font-weight: 700 !important;
		transform: scale(1) !important;
		filter: blur(0) !important;
		opacity: 1 !important;
		text-shadow:
			0 0 20px color-mix(in srgb, var(--primary) 30%, transparent);
		letter-spacing: 0.04em;
	}
	:global(.lyric-line:hover) {
		color: var(--deep-text);
	}
	:root.dark :global(.lyric-line) {
		color: rgba(255,255,255,0.2);
	}
	:root.dark :global(.lyric-line.near) {
		color: rgba(255,255,255,0.45) !important;
	}
	:root.dark :global(.lyric-line.active) {
		color: #fff !important;
		text-shadow:
			0 0 20px color-mix(in srgb, var(--primary) 50%, transparent),
			0 0 40px color-mix(in srgb, var(--primary) 25%, transparent);
	}
	:root.dark :global(.lyric-line:hover) {
		color: rgba(255,255,255,0.6);
	}

	/* ── Playlist Section ── */
	.playlist-section {
		border-top: 1px solid var(--line-divider);
		max-height: 400px;
		display: flex;
		flex-direction: column;
		position: relative;
		z-index: 2;
	}
	:root.dark .playlist-section {
		border-top-color: rgba(255,255,255,0.06);
	}
	.playlist-header {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 16px 32px 12px;
		flex-shrink: 0;
	}
	.playlist-header-icon {
		width: 18px; height: 18px;
		color: var(--primary);
	}
	.playlist-header-text {
		font-size: 14px;
		font-weight: 600;
		color: var(--deep-text);
		letter-spacing: 0.03em;
	}
	:root.dark .playlist-header-text {
		color: rgba(255,255,255,0.7);
	}
	.playlist-count {
		font-size: 12px;
		color: var(--content-meta);
		margin-left: auto;
	}
	:root.dark .playlist-count {
		color: rgba(255,255,255,0.3);
	}

	.playlist-list {
		overflow-y: auto;
		padding: 0 24px 24px;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.playlist-list::-webkit-scrollbar { width: 4px; }
	.playlist-list::-webkit-scrollbar-thumb {
		background: var(--line-divider);
		border-radius: 4px;
	}
	:root.dark .playlist-list::-webkit-scrollbar-thumb {
		background: rgba(255,255,255,0.08);
	}

	.playlist-item {
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 10px 12px;
		border-radius: 12px;
		cursor: pointer;
		transition: background 0.2s;
	}
	.playlist-item:hover {
		background: var(--btn-regular-bg);
	}
	.playlist-item.active {
		background: color-mix(in srgb, var(--primary) 8%, transparent);
	}
	:root.dark .playlist-item:hover {
		background: rgba(255,255,255,0.05);
	}
	:root.dark .playlist-item.active {
		background: rgba(255,255,255,0.08);
	}

	.playlist-item-cover {
		position: relative;
		width: 48px; height: 48px;
		border-radius: 8px;
		overflow: hidden;
		flex-shrink: 0;
		background: var(--btn-regular-bg);
	}
	:root.dark .playlist-item-cover {
		background: rgba(255,255,255,0.05);
	}
	.playlist-item-img {
		width: 100%; height: 100%;
		object-fit: cover;
		display: block;
	}

	.playlist-item-play-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0,0,0,0.35);
		opacity: 0;
		transition: opacity 0.2s;
	}
	.playlist-item:hover .playlist-item-play-overlay { opacity: 1; }
	.playlist-item.active .playlist-item-play-overlay { opacity: 0; }
	.playlist-item-play-icon {
		width: 24px; height: 24px;
		color: #fff;
	}
	:root.dark .playlist-item-play-overlay {
		background: rgba(0,0,0,0.5);
	}

	.playlist-item-eq {
		position: absolute;
		bottom: 4px; right: 4px;
		display: none;
		gap: 1.5px;
		align-items: flex-end;
		height: 12px;
	}
	.playlist-item.active .playlist-item-eq { display: flex; }
	.eq-bar {
		width: 2px;
		background: var(--primary);
		border-radius: 1px;
		animation: eq-bounce 0.55s ease-in-out infinite alternate;
	}
	.eq-bar:nth-child(1) { height: 5px; }
	.eq-bar:nth-child(2) { height: 10px; animation-delay: 0.18s; }
	.eq-bar:nth-child(3) { height: 7px; animation-delay: 0.36s; }
	@keyframes eq-bounce { to { transform: scaleY(0.3); } }

	.playlist-item-info {
		flex: 1;
		min-width: 0;
	}
	.playlist-item-title {
		font-size: 14px;
		font-weight: 600;
		color: var(--deep-text);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		line-height: 1.4;
	}
	.playlist-item.active .playlist-item-title {
		color: var(--primary);
	}
	.playlist-item-artist {
		font-size: 12px;
		color: var(--content-meta);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		margin-top: 2px;
	}
	:root.dark .playlist-item-title {
		color: rgba(255,255,255,0.8);
	}
	:root.dark .playlist-item-artist {
		color: rgba(255,255,255,0.35);
	}

	.playlist-empty {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		padding: 40px 0;
		color: var(--content-meta);
		font-size: 13px;
	}
	:root.dark .playlist-empty {
		color: rgba(255,255,255,0.2);
	}
	.playlist-empty-icon {
		width: 32px; height: 32px;
		opacity: 0.3;
	}

	/* ── Responsive: Mobile ── */
	@media (max-width: 768px) {
		.player-panel {
			padding: 24px 16px;
		}
		.player-panel-inner {
			max-width: 280px;
		}
		.vinyl-stage { width: 200px; height: 200px; }
		.vinyl-cover-wrap { width: 90px; height: 90px; }

		.song-title { font-size: 18px; }
		.controls { gap: 16px; }
		.ctrl-btn-play { width: 52px; height: 52px; flex-shrink: 0; }

		.lyrics-scroll { height: 200px; padding: 60px 16px; }
		.lyric-line.active { font-size: 18px; }

		.playlist-list { padding: 0 16px 16px; }
		.playlist-header { padding: 14px 20px 10px; }
		.playlist-item { padding: 8px 10px; gap: 12px; }
		.playlist-item-cover { width: 42px; height: 42px; border-radius: 6px; }
	}
</style>

<script is:inline define:vars={{ collectionPlaylistJson: JSON.stringify(collectionPlaylist), metingApiUrl: metingApiBase }}>
(function() {
	var bg = document.getElementById('music-bg');
	var vinylDisc = document.getElementById('vinyl-disc');
	var vinylStage = document.querySelector('.vinyl-stage');
	var vinylArm = document.getElementById('vinyl-arm');
	var vinylCover = document.getElementById('vinyl-cover');
	var songTitle = document.getElementById('song-title');
	var songArtist = document.getElementById('song-artist');
	var progressFill = document.getElementById('progress-fill');
	var progressThumb = document.getElementById('progress-thumb');
	var timeCurrent = document.getElementById('time-current');
	var timeTotal = document.getElementById('time-total');
	var progressTrack = document.getElementById('progress-track');
	var btnPlay = document.getElementById('btn-play');
	var iconPlay = document.querySelector('#btn-play .icon-play');
	var iconPause = document.querySelector('#btn-play .icon-pause');

	if (!btnPlay || !vinylCover || !songTitle) return;

	var lyricsScroll = document.getElementById('lyrics-scroll');
	var playlistList = document.getElementById('playlist-list');
	var playlistCount = document.getElementById('playlist-count');

	var collectionPlaylist = JSON.parse(collectionPlaylistJson);
	if (playlistCount) playlistCount.textContent = collectionPlaylist.length + ' 首';

	var metingApi = metingApiUrl;

	function bindManager(mgr) {

	if (!mgr.getState().initialized) mgr.init();

	function updatePlayState(isPlaying) {
		if (isPlaying) {
			vinylDisc.classList.add('spinning');
			vinylStage.classList.add('playing');
			vinylArm.classList.add('on-record');
			iconPlay.classList.add('hidden');
			iconPause.classList.remove('hidden');
		} else {
			vinylDisc.classList.remove('spinning');
			vinylStage.classList.remove('playing');
			vinylArm.classList.remove('on-record');
			iconPlay.classList.remove('hidden');
			iconPause.classList.add('hidden');
		}
	}

	function updateTrack(track) {
		if (!track) return;
		songTitle.textContent = track.name;
		songArtist.textContent = track.artist;
		if (track.pic) {
			vinylCover.src = track.pic;
			bg.style.backgroundImage = 'url(' + track.pic + ')';
		}
	}

	function updateProgress(progress, currentStr, durationStr) {
		progressFill.style.width = progress + '%';
		progressThumb.style.left = progress + '%';
		timeCurrent.textContent = currentStr;
		timeTotal.textContent = durationStr;
	}

	document.getElementById('btn-mode')?.addEventListener('click', function() { mgr.cyclePlayMode(); });
	document.getElementById('btn-prev')?.addEventListener('click', function() { mgr.playPrev(); });
	btnPlay.addEventListener('click', function() { mgr.togglePlay(); });
	document.getElementById('btn-next')?.addEventListener('click', function() { mgr.playNext(); });
	document.getElementById('btn-volume')?.addEventListener('click', function() { mgr.toggleMute(); });

	progressTrack?.addEventListener('click', function(e) {
		var rect = progressTrack.getBoundingClientRect();
		var pct = (e.clientX - rect.left) / rect.width;
		mgr.seek(Math.max(0, Math.min(1, pct)));
	});

	playlistList?.addEventListener('click', async function(e) {
		var item = e.target.closest('.playlist-item');
		if (!item) return;
		var idx = parseInt(item.getAttribute('data-playlist-index') || '-1');
		if (idx < 0) return;
		var state = mgr.getState();
		var track = state.playlist[idx];
		if (!track) return;
		if (!track.url && track.metingServer && track.metingId) {
			try {
				var s = encodeURIComponent(track.metingServer);
				var id = encodeURIComponent(track.metingId);
				var res = await fetch(metingApi + '?server=' + s + '&type=song&id=' + id);
				if (res.ok) {
					var raw = await res.json();
					var data = Array.isArray(raw) ? raw[0] : raw;
					if (data) {
						if (data.url) track.url = data.url;
						if (data.pic && !track.pic) track.pic = data.pic;
						if (data.lrc && !track.lrc) track.lrc = data.lrc;
					}
				}
			} catch(err) { console.warn('Meting on-demand failed:', err); }
		}
		if (track.url) { mgr.playTrackByIndex(idx); }
	});

	function updateActiveItem(currentIndex) {
		var items = playlistList?.querySelectorAll('.playlist-item') || [];
		for (var i = 0; i < items.length; i++) {
			var itemIdx = parseInt(items[i].getAttribute('data-playlist-index') || '-1');
			if (itemIdx === currentIndex) { items[i].classList.add('active'); }
			else { items[i].classList.remove('active'); }
		}
	}

	function updateMode(playMode) {
		var iconRepeat = document.querySelector('#btn-mode .icon-repeat');
		var iconRepeatOne = document.querySelector('#btn-mode .icon-repeat-one');
		var iconShuffle = document.querySelector('#btn-mode .icon-shuffle');
		var btnMode = document.getElementById('btn-mode');
		if (!iconRepeat || !btnMode) return;
		iconRepeat.classList.add('hidden');
		iconRepeatOne.classList.add('hidden');
		iconShuffle.classList.add('hidden');
		btnMode.classList.remove('active');
		if (playMode === 0) { iconRepeat.classList.remove('hidden'); }
		else if (playMode === 1) { iconRepeatOne.classList.remove('hidden'); btnMode.classList.add('active'); }
		else { iconShuffle.classList.remove('hidden'); btnMode.classList.add('active'); }
	}

	function updateVolume(volume, isMuted) {
		var iv1 = document.querySelector('#btn-volume .icon-vol-on');
		var iv2 = document.querySelector('#btn-volume .icon-vol-off');
		if (!iv1 || !iv2) return;
		if (isMuted || volume === 0) { iv1.classList.add('hidden'); iv2.classList.remove('hidden'); }
		else { iv1.classList.remove('hidden'); iv2.classList.add('hidden'); }
	}

	// Lyrics
	var currentLrcIdx = -1;
	function renderLyrics(lyrics) {
		if (!lyricsScroll) return;
		lyricsScroll.innerHTML = '';
		if (!lyrics || lyrics.length === 0) {
			lyricsScroll.innerHTML = '<div class="lyrics-empty"><svg class="lyrics-empty-icon" viewBox="0 0 24 24" fill="currentColor" style="width:36px;height:36px;opacity:0.3"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg><span>暂无歌词</span></div>';
			return;
		}
		for (var i = 0; i < lyrics.length; i++) {
			var line = document.createElement('div');
			line.className = 'lyric-line';
			line.textContent = lyrics[i].text;
			line.setAttribute('data-index', i.toString());
			line.addEventListener('click', function() {
				var lrc = mgr.getState().lyrics;
				var idx = parseInt(this.getAttribute('data-index') || '0');
				if (lrc[idx]) mgr.seekToTime(lrc[idx].time);
			});
			lyricsScroll.appendChild(line);
		}
	}

	function updateLrcHighlight(index) {
		if (index === currentLrcIdx) return;
		currentLrcIdx = index;
		var lines = lyricsScroll?.querySelectorAll('.lyric-line') || [];
		for (var i = 0; i < lines.length; i++) {
			var dist = Math.abs(i - index);
			lines[i].classList.remove('active', 'near');
			if (dist === 0) {
				lines[i].classList.add('active');
			} else if (dist <= 2) {
				lines[i].classList.add('near');
			}
		}
		if (index >= 0 && lines[index] && lyricsScroll) {
			var line = lines[index];
			var paddingTop = parseInt(getComputedStyle(lyricsScroll).paddingTop) || 0;
			var targetScroll = line.offsetTop - paddingTop - lyricsScroll.clientHeight / 2 + line.offsetHeight / 2;
			lyricsScroll.scrollTo({ top: Math.max(0, targetScroll), behavior: "smooth" });
		}
	}

	// Event listeners
	window.addEventListener('fm:init', function(e) {
		var d = e.detail;
		updateMode(d.playMode);
		updateVolume(d.volume, d.isMuted);
	});
	window.addEventListener('fm:track', function(e) { updateTrack(e.detail.track); updateActiveItem(e.detail.index); });
	window.addEventListener('fm:play-state', function(e) { updatePlayState(e.detail.isPlaying); });
	window.addEventListener('fm:time', function(e) { updateProgress(e.detail.progress, e.detail.currentTimeStr, e.detail.durationStr); });
	window.addEventListener('fm:volume', function(e) { updateVolume(e.detail.volume, e.detail.isMuted); });
	window.addEventListener('fm:mode', function(e) { updateMode(e.detail.playMode); });
	window.addEventListener('fm:lyrics', function(e) { renderLyrics(e.detail.lyrics); if (e.detail.lyrics && e.detail.lyrics.length > 0) { var idx = mgr.getState().currentLrcIndex; if (idx >= 0) updateLrcHighlight(idx); } });
	window.addEventListener('fm:lrc-index', function(e) { updateLrcHighlight(e.detail.index); });

	function syncAll() {
		var s = mgr.getState();
		if (!s.initialized || s.playlist.length === 0) return;
		if (s.track) updateTrack(s.track);
		updatePlayState(s.isPlaying);
		updateMode(s.playMode);
		updateVolume(s.volume, s.isMuted);
		if (s.duration > 0) updateProgress(s.progress, s.currentTimeStr, s.durationStr);
		renderLyrics(s.lyrics);
		if (s.currentLrcIndex >= 0) updateLrcHighlight(s.currentLrcIndex);
		updateActiveItem(s.currentIndex);
	}

	var metingApi = metingApiUrl;

	async function resolveMetingTracks(playlist) {
		var base = metingApi + '?server=';
		for (var i = 0; i < playlist.length; i++) {
			var track = playlist[i];
			if (track.metingServer && track.metingId && !track.url) {
				try {
					var s = encodeURIComponent(track.metingServer);
					var id = encodeURIComponent(track.metingId);
					var res = await fetch(base + s + '&type=song&id=' + id);
					if (!res.ok) throw new Error('HTTP ' + res.status);
					var raw = await res.json();
					var data = Array.isArray(raw) ? raw[0] : raw;
					if (data) {
						if (data.url) track.url = data.url;
						if (data.pic && !track.pic) track.pic = data.pic;
						if (data.lrc && !track.lrc) track.lrc = data.lrc;
						track.artist = track.artist || data.author || data.artist || "";
						track.name = (track.name && track.name !== track.metingId) ? track.name : (data.title || track.name);
					}
				} catch(e) {
					console.warn('[Meting] failed:', track.name, e);
				}
			}
		}
		return playlist;
	}

	async function initPlaylist() {
		var resolved = await resolveMetingTracks(collectionPlaylist);
		if (resolved.length > 0) {
			mgr.loadExternalPlaylist(resolved);
		}
		syncAll();
	}

	if (mgr.getState().initialized) {
		if (mgr._externalLoaded) {
			syncAll();
		} else {
			initPlaylist();
		}
	} else {
		window.addEventListener('fm:init', function handler() {
			window.removeEventListener('fm:init', handler);
			initPlaylist();
		});
		mgr.init();
	}
	} // end bindManager

	// Wait for MusicManager to be available
	var mgr = window.__fireflyMusic;
	if (mgr) {
		bindManager(mgr);
	} else {
		var attempts = 0;
		var timer = setInterval(function() {
			mgr = window.__fireflyMusic;
			if (mgr || ++attempts > 50) {
				clearInterval(timer);
				if (mgr) bindManager(mgr);
			}
		}, 100);
	}
})();
</script>
</MainGridLayout>
