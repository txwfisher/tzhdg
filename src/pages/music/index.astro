---
import { Icon } from "astro-icon/components";
import MusicCard from "@/components/pages/music/MusicCard.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import type { UserSubjectCollection } from "@/types/bangumi";
import Comment from "@components/comment/index.astro";
import { getCollection } from "astro:content";

if (!siteConfig.pages.musicPage) {
	return Astro.redirect("/404/");
}

const customBangumi = await getCollection("bangumi");

const musicItems: UserSubjectCollection[] = customBangumi
	.filter((item) => item.data.category === "music")
	.map((item) => {
		const { data } = item;
		const imageSrc = typeof data.image === "string" ? data.image : data.image.src;
		return {
			subject_id: 0, subject_type: 3, rate: data.score || 0,
			type: data.status as any, comment: data.comment || null,
			tags: data.tags || [], ep_status: 0, vol_status: 0,
			updated_at: data.published?.toISOString() || new Date().toISOString(),
			private: false, link: "",
			subject: {
				id: 0, type: 3, name: data.title,
				name_cn: data.name_cn || data.title, short_summary: "",
				images: { medium: imageSrc, large: imageSrc, common: imageSrc, small: imageSrc, grid: imageSrc },
				volumes: 0, eps: 0, collection_total: 0,
				score: data.score || 0, rank: 0, tags: [],
			},
		};
	})
	.sort((a, b) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());

const statusMap: Record<number, string> = { 1: "wish", 2: "collect", 3: "doing", 4: "on_hold", 5: "dropped" };
---

<MainGridLayout title={i18n(I18nKey.musicPageTitle)} description={i18n(I18nKey.musicPageSubtitle)}>
	<div data-pagefind-body class="music-app" id="music-app">
		<div class="music-bg" id="music-bg"></div>
		<div class="music-bg-overlay"></div>

		<div class="music-content">
			<header class="music-header">
				<h1 data-pagefind-meta="title" data-pagefind-weight="10" class="">{i18n(I18nKey.musicPageTitle)}</h1>
			</header>

			<!-- Player Card -->
			<div class="player-card" id="player-card">
				<div class="player-art-area">
					<div class="disc-container" id="disc-container">
						<div class="disc-ring"></div>
						<div class="disc-cover-wrap">
							<img class="disc-cover" id="disc-cover" src="" alt="Cover" />
						</div>
						<div class="disc-center"></div>
					</div>
				</div>

				<div class="player-info">
					<h2 class="player-title" id="player-title">{i18n(I18nKey.music)}</h2>
					<p class="player-artist" id="player-artist">{i18n(I18nKey.musicNoPlaying)}</p>
				</div>

				<div class="player-progress" id="player-progress">
					<span class="progress-time" id="progress-current">0:00</span>
					<div class="progress-bar-wrap" id="progress-bar-wrap">
						<div class="progress-bar-bg"></div>
						<div class="progress-bar-fill" id="progress-fill"></div>
						<div class="progress-thumb" id="progress-thumb"></div>
					</div>
					<span class="progress-time" id="progress-total">0:00</span>
				</div>

				<div class="player-controls">
					<button class="ctrl-btn" id="btn-mode" title="切换模式">
						<Icon name="material-symbols:repeat-rounded" class="ctrl-icon icon-repeat" />
						<Icon name="material-symbols:repeat-one-rounded" class="ctrl-icon icon-repeat-one hidden" />
						<Icon name="material-symbols:shuffle-rounded" class="ctrl-icon icon-shuffle hidden" />
					</button>
					<button class="ctrl-btn" id="btn-prev" title="上一曲">
						<Icon name="material-symbols:skip-previous-rounded" class="ctrl-icon-lg" />
					</button>
					<button class="ctrl-btn-play" id="btn-play" title="播放">
						<Icon name="material-symbols:play-arrow-rounded" class="ctrl-icon-xl icon-play" />
						<Icon name="material-symbols:pause-rounded" class="ctrl-icon-xl icon-pause hidden" />
					</button>
					<button class="ctrl-btn" id="btn-next" title="下一曲">
						<Icon name="material-symbols:skip-next-rounded" class="ctrl-icon-lg" />
					</button>
					<button class="ctrl-btn" id="btn-volume" title="音量">
						<Icon name="material-symbols:volume-up-rounded" class="ctrl-icon icon-vol-on" />
						<Icon name="material-symbols:volume-off-rounded" class="ctrl-icon icon-vol-off hidden" />
					</button>
				</div>

				<div class="player-tabs">
					<button class="player-tab active" data-tab="playlist">歌单</button>
					<button class="player-tab" data-tab="lyrics">歌词</button>
				</div>

				<div class="swipe-container" id="swipe-container">
					<div class="swipe-track" id="swipe-track">
						<div class="swipe-panel" id="panel-playlist">
							<div class="playlist-scroll" id="playlist-scroll"></div>
						</div>
						<div class="swipe-panel" id="panel-lyrics">
							<div class="lyrics-scroll" id="lyrics-scroll">
								<div class="lyrics-placeholder">暂无歌词</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Music Collection -->
			<section class="music-collection">
				<div class="collection-header">
					<h2 class="collection-title">我的音乐收藏</h2>
				</div>
				{musicItems.length > 0 ? (
					<div class="collection-grid">
						{musicItems.map((item) => (
							<div data-item-status={statusMap[item.type as number] || "unknown"}>
								<MusicCard item={item} />
							</div>
						))}
					</div>
				) : (
					<div class="flex flex-col items-center justify-center py-16 text-center">
						<Icon name="material-symbols:library-music-outline" class="w-10 h-10 text-[var(--content-meta)] mb-3" />
						<p class="text-sm text-[var(--content-meta)]">{i18n(I18nKey.musicPageNoData)}</p>
					</div>
				)}
			</section>
		</div>
	</div>
<Comment customPath="/music/" />
</MainGridLayout>

<style>
	.music-app {
		position: relative;
		border-radius: var(--radius-large);
		overflow: hidden;
		min-height: 100vh;
		background: var(--card-bg);
	}
	.music-bg {
		position: absolute;
		inset: 0;
		background-color: var(--card-bg);
		background-size: cover;
		background-position: center;
		filter: blur(80px) saturate(0.6);
		transform: scale(1.1);
		transition: background-image 0.8s ease;
		z-index: 0;
		opacity: 0.4;
	}
	html.dark .music-bg {
		filter: blur(80px) brightness(0.35) saturate(0.6);
		opacity: 0.7;
	}
	.music-bg-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, var(--card-bg) 0%, color-mix(in srgb, var(--card-bg) 90%, transparent) 50%, var(--card-bg) 100%);
		z-index: 1;
	}
	.music-content {
		position: relative;
		z-index: 2;
		padding: 24px 24px 40px;
		max-width: 500px;
		margin: 0 auto;
	}

	/* Header */
	.music-header { text-align: center; margin-bottom: 24px; }
	.music-page-title {
		font-size: 18px; font-weight: 700;
		color: var(--deep-text);
		letter-spacing: 0.04em;
	}
	html.dark .music-page-title { color: var(--title-active); }

	/* Player Card */
	.player-card {
		background: var(--card-bg);
		border-radius: 24px;
		padding: 32px 24px 16px;
		border: 1px solid var(--line-divider);
		overflow: hidden;
		box-shadow: 0 2px 12px rgba(0,0,0,0.05);
	}
	html.dark .player-card {
		box-shadow: 0 2px 12px rgba(0,0,0,0.15);
	}

	/* Album Art */
	.player-art-area {
		display: flex;
		justify-content: center;
		margin-bottom: 28px;
	}
	.disc-container {
		position: relative;
		width: 220px; height: 220px;
	}
	.disc-ring {
		position: absolute;
		inset: -8px;
		border-radius: 50%;
		border: 2px solid rgba(255,255,255,0.25);
		box-shadow: 0 0 30px rgba(0,0,0,0.06);
	}
	html.dark .disc-ring {
		border-color: rgba(255,255,255,0.1);
		box-shadow: 0 0 40px rgba(0,0,0,0.3);
	}
	.disc-cover-wrap {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		overflow: hidden;
		box-shadow: 0 8px 30px rgba(0,0,0,0.1);
	}
	html.dark .disc-cover-wrap {
		box-shadow: 0 8px 32px rgba(0,0,0,0.4);
	}
	.disc-cover {
		width: 100%; height: 100%;
		object-fit: cover;
	}
	.disc-center {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 14px; height: 14px;
		border-radius: 50%;
		background: var(--card-bg);
		border: 2px solid rgba(255,255,255,0.25);
	}
	html.dark .disc-center {
		background: rgba(20,20,30,0.9);
		border-color: rgba(255,255,255,0.12);
	}
	.disc-container.playing .disc-cover-wrap {
		animation: disc-spin 20s linear infinite;
	}
	@keyframes disc-spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* Song Info */
	.player-info { text-align: center; margin-bottom: 20px; }
	.player-title {
		font-size: 20px; font-weight: 700;
		color: var(--deep-text);
		margin: 0 0 6px;
		overflow: hidden; text-overflow: ellipsis;
		white-space: nowrap; padding: 0 8px;
	}
	html.dark .player-title { color: #fff; }
	.player-artist {
		font-size: 14px; color: var(--content-meta); margin: 0;
	}
	html.dark .player-artist { color: rgba(255,255,255,0.5); }

	/* Progress */
	.player-progress {
		display: flex; align-items: center;
		gap: 10px; margin-bottom: 24px; padding: 0 4px;
	}
	.progress-time {
		font-size: 11px; color: var(--content-meta);
		font-variant-numeric: tabular-nums;
		min-width: 34px; text-align: center;
	}
	html.dark .progress-time { color: rgba(255,255,255,0.35); }
	.progress-bar-wrap {
		flex: 1; height: 4px; position: relative;
		cursor: pointer;
		display: flex; align-items: center;
	}
	.progress-bar-bg {
		position: absolute; inset: 0;
		background: var(--btn-regular-bg); border-radius: 2px;
	}
	html.dark .progress-bar-bg { background: rgba(255,255,255,0.1); }
	.progress-bar-fill {
		position: absolute; left: 0; top: 0; bottom: 0;
		width: 0%;
		background: var(--primary); border-radius: 2px;
		transition: width 0.15s linear;
	}
	.progress-thumb {
		position: absolute; top: 50%;
		transform: translate(-50%, -50%);
		width: 12px; height: 12px;
		background: var(--primary); border-radius: 50%;
		box-shadow: 0 2px 6px rgba(0,0,0,0.15);
		left: 0%; opacity: 0;
		transition: opacity 0.2s, left 0.15s linear;
	}
	html.dark .progress-thumb { background: #fff; }
	.progress-bar-wrap:hover .progress-thumb { opacity: 1; }

	/* Controls */
	.player-controls {
		display: flex; align-items: center;
		justify-content: center; gap: 16px;
		margin-bottom: 24px;
	}
	.ctrl-btn {
		background: none; border: none;
		color: var(--btn-content);
		cursor: pointer; padding: 8px;
		border-radius: 50%;
		transition: color 0.2s, transform 0.15s;
		display: flex; align-items: center; justify-content: center;
	}
	.ctrl-btn:hover { color: var(--deep-text); }
	html.dark .ctrl-btn { color: rgba(255,255,255,0.6); }
	html.dark .ctrl-btn:hover { color: #fff; }
	.ctrl-btn:active { transform: scale(0.9); }
	.ctrl-btn-play {
		background: var(--primary); border: none;
		color: #fff; cursor: pointer;
		width: 56px; height: 56px;
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		box-shadow: 0 4px 18px rgba(0,0,0,0.12);
		transition: transform 0.15s, box-shadow 0.2s;
	}
	html.dark .ctrl-btn-play {
		box-shadow: 0 4px 20px color-mix(in srgb, var(--primary) 50%, transparent);
	}
	.ctrl-btn-play:hover { box-shadow: 0 6px 26px rgba(0,0,0,0.2); }
	.ctrl-btn-play:active { transform: scale(0.92); }
	.ctrl-icon { width: 22px; height: 22px; }
	.ctrl-icon-lg { width: 30px; height: 30px; }
	.ctrl-icon-xl { width: 28px; height: 28px; }

	/* Tabs */
	.player-tabs {
		display: flex; gap: 0;
		margin-bottom: 0;
		border-bottom: 1px solid var(--line-divider);
	}
	html.dark .player-tabs { border-color: rgba(255,255,255,0.06); }
	.player-tab {
		flex: 1; background: none; border: none;
		color: var(--content-meta);
		font-size: 14px; font-weight: 500;
		padding: 12px 0; cursor: pointer;
		position: relative;
		transition: color 0.2s;
	}
	.player-tab.active { color: var(--deep-text); }
	html.dark .player-tab { color: rgba(255,255,255,0.35); }
	html.dark .player-tab.active { color: #fff; }
	.player-tab.active::after {
		content: ''; position: absolute;
		bottom: -1px; left: 50%;
		transform: translateX(-50%);
		width: 24px; height: 2px;
		background: var(--primary); border-radius: 1px;
	}

	/* Swipe */
	.swipe-container {
		overflow: hidden; position: relative;
	}
	.swipe-track {
		display: flex; width: 200%;
		transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}
	.swipe-track.show-lyrics { transform: translateX(-50%); }
	.swipe-panel { width: 50%; flex-shrink: 0; }

	/* Playlist */
	.playlist-scroll {
		max-height: 300px;
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		padding: 4px 0;
	}
	.playlist-scroll::-webkit-scrollbar { width: 3px; }
	.playlist-scroll::-webkit-scrollbar-thumb {
		background: var(--line-divider); border-radius: 3px;
	}
	html.dark .playlist-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }

	.playlist-item {
		display: flex; align-items: center; gap: 12px;
		padding: 10px 8px; border-radius: 10px;
		cursor: pointer;
		transition: background 0.15s;
	}
	.playlist-item:hover { background: var(--btn-regular-bg); }
	html.dark .playlist-item:hover { background: rgba(255,255,255,0.04); }
	.playlist-item.active { background: color-mix(in srgb, var(--primary) 10%, transparent); }
	html.dark .playlist-item.active { background: color-mix(in srgb, var(--primary) 18%, transparent); }

	.playlist-item-cover {
		width: 36px; height: 36px; border-radius: 5px;
		object-fit: cover; flex-shrink: 0;
		background: var(--btn-regular-bg);
	}
	html.dark .playlist-item-cover { background: rgba(255,255,255,0.06); }
	.playlist-item-info { flex: 1; min-width: 0; }
	.playlist-item-title {
		font-size: 14px; font-weight: 500;
		color: var(--deep-text);
		overflow: hidden; text-overflow: ellipsis;
		white-space: nowrap;
	}
	html.dark .playlist-item-title { color: #e0e0e0; }
	.playlist-item-artist {
		font-size: 11px; color: var(--content-meta); margin-top: 2px;
	}
	html.dark .playlist-item-artist { color: rgba(255,255,255,0.35); }
	.playlist-item.active .playlist-item-title { color: var(--primary); }
	html.dark .playlist-item.active .playlist-item-title { color: #fff; }

	.playlist-item-eq {
		display: none; gap: 2px;
		align-items: flex-end; height: 16px;
		flex-shrink: 0;
	}
	.playlist-item.active .playlist-item-eq { display: flex; }
	.eq-bar {
		width: 2px; background: var(--primary); border-radius: 1px;
		animation: eq-bounce 0.55s ease-in-out infinite alternate;
	}
	.eq-bar:nth-child(1) { height: 6px; animation-delay: 0s; }
	.eq-bar:nth-child(2) { height: 14px; animation-delay: 0.18s; }
	.eq-bar:nth-child(3) { height: 9px; animation-delay: 0.36s; }
	@keyframes eq-bounce { to { transform: scaleY(0.35); } }

	/* Lyrics */
	.lyrics-scroll {
		height: 300px; overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		scroll-behavior: smooth;
		text-align: center;
		padding: 100px 16px;
	}
	.lyrics-scroll::-webkit-scrollbar { width: 3px; }
	.lyrics-scroll::-webkit-scrollbar-thumb {
		background: var(--line-divider); border-radius: 3px;
	}
	.lyrics-placeholder {
		color: var(--content-meta); font-size: 14px;
	}
	.lyric-line {
		padding: 7px 0; font-size: 14px;
		color: var(--content-meta);
		transition: all 0.35s ease;
		cursor: pointer; line-height: 1.6;
	}
	html.dark .lyric-line { color: rgba(255,255,255,0.3); }
	.lyric-line.active {
		color: var(--deep-text); font-size: 16px; font-weight: 600;
	}
	html.dark .lyric-line.active { color: #fff; }
	.lyric-line:hover { color: var(--deep-text); }
	html.dark .lyric-line:hover { color: rgba(255,255,255,0.55); }

	/* Collection */
	.music-collection { margin-top: 28px; }
	.collection-header { margin-bottom: 16px; }
	.collection-title {
		font-size: 16px; font-weight: 600;
		color: var(--deep-text); margin: 0;
	}
	html.dark .collection-title { color: rgba(255,255,255,0.75); }
	.collection-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px 12px;
	}

	/* Responsive */
	@media (min-width: 640px) { .collection-grid { grid-template-columns: repeat(4, 1fr); } }
	@media (min-width: 768px) {
		.collection-grid { grid-template-columns: repeat(5, 1fr); }
		.player-card { padding: 40px 32px 20px; }
		.disc-container { width: 260px; height: 260px; }
	}
	@media (min-width: 1024px) {
		.music-content {
			max-width: 900px;
			display: grid;
			grid-template-columns: 420px 1fr;
			gap: 32px;
			align-items: start;
		}
		.music-header { grid-column: 1 / -1; }
		.player-card { position: sticky; top: 24px; }
		.collection-grid { grid-template-columns: repeat(4, 1fr); }
	}
	@media (max-width: 640px) {
		.music-content { padding: 16px 12px 32px; }
		.player-card { padding: 24px 16px 12px; border-radius: 20px; }
		.disc-container { width: 180px; height: 180px; }
		.collection-grid { grid-template-columns: repeat(3, 1fr); gap: 14px 10px; }
	}
</style>

<script is:inline>
(function() {
	var mgr = window.__fireflyMusic;
	if (!mgr) return;

	var bg = document.getElementById('music-bg');
	var discContainer = document.getElementById('disc-container');
	var discCover = document.getElementById('disc-cover');
	var playerTitle = document.getElementById('player-title');
	var playerArtist = document.getElementById('player-artist');
	var progressFill = document.getElementById('progress-fill');
	var progressThumb = document.getElementById('progress-thumb');
	var progressCurrent = document.getElementById('progress-current');
	var progressTotal = document.getElementById('progress-total');
	var progressWrap = document.getElementById('progress-bar-wrap');
	var btnPlay = document.getElementById('btn-play');
	var iconPlay = document.querySelector('.icon-play');
	var iconPause = document.querySelector('.icon-pause');

	if (!btnPlay || !discCover || !playerTitle) return;

	if (!mgr.getState().initialized) mgr.init();

	function updatePlayState(isPlaying) {
		if (isPlaying) {
			discContainer.classList.add('playing');
			iconPlay.classList.add('hidden');
			iconPause.classList.remove('hidden');
		} else {
			discContainer.classList.remove('playing');
			iconPlay.classList.remove('hidden');
			iconPause.classList.add('hidden');
		}
	}

	function updateTrack(track) {
		if (!track) return;
		playerTitle.textContent = track.name;
		playerArtist.textContent = track.artist;
		if (track.pic) {
			discCover.src = track.pic;
			bg.style.backgroundImage = 'url(' + track.pic + ')';
		}
	}

	function updateProgress(progress, currentStr, durationStr) {
		progressFill.style.width = progress + '%';
		progressThumb.style.left = progress + '%';
		progressCurrent.textContent = currentStr;
		progressTotal.textContent = durationStr;
	}

	// Buttons
	document.getElementById('btn-mode')?.addEventListener('click', function() { mgr.cyclePlayMode(); });
	document.getElementById('btn-prev')?.addEventListener('click', function() { mgr.playPrev(); });
	btnPlay.addEventListener('click', function() { mgr.togglePlay(); });
	document.getElementById('btn-next')?.addEventListener('click', function() { mgr.playNext(); });
	document.getElementById('btn-volume')?.addEventListener('click', function() { mgr.toggleMute(); });

	progressWrap?.addEventListener('click', function(e) {
		var rect = progressWrap.getBoundingClientRect();
		var pct = (e.clientX - rect.left) / rect.width;
		mgr.seek(Math.max(0, Math.min(1, pct)));
	});

	// Playlist rendering
	var playlistScroll = document.getElementById('playlist-scroll');
	var lyricsScroll = document.getElementById('lyrics-scroll');

	function renderPlaylist(playlist, currentIndex) {
		if (!playlistScroll) return;
		playlistScroll.innerHTML = '';
		for (var i = 0; i < playlist.length; i++) {
			var track = playlist[i];
			var isActive = i === currentIndex;
			var div = document.createElement('div');
			div.className = 'playlist-item' + (isActive ? ' active' : '');
			div.setAttribute('data-index', i.toString());
			div.style.cssText = 'display:flex;align-items:center;gap:12px;padding:10px 8px;border-radius:10px;cursor:pointer;transition:background 0.15s;' +
				(isActive ? 'background:color-mix(in srgb, var(--primary) 10%, transparent);' : '');
			div.innerHTML =
				'<img src="' + (track.pic || '') + '" alt="" style="width:36px;height:36px;border-radius:5px;object-fit:cover;flex-shrink:0;background:var(--btn-regular-bg)" onerror="this.style.display=\'none\'" />' +
				'<div style="flex:1;min-width:0">' +
					'<div style="font-size:14px;font-weight:500;color:var(--deep-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + (track.name || '') + '</div>' +
					'<div style="font-size:11px;color:var(--content-meta);margin-top:2px">' + (track.artist || '') + '</div>' +
				'</div>' +
				'<div style="' + (isActive ? '' : 'display:none;') + 'display:flex;gap:2px;align-items:flex-end;height:16px;flex-shrink:0">' +
					'<span style="width:2px;height:8px;background:var(--primary);border-radius:1px;animation:eq-bounce 0.55s ease-in-out infinite alternate"></span>' +
					'<span style="width:2px;height:14px;background:var(--primary);border-radius:1px;animation:eq-bounce 0.55s ease-in-out 0.18s infinite alternate"></span>' +
					'<span style="width:2px;height:10px;background:var(--primary);border-radius:1px;animation:eq-bounce 0.55s ease-in-out 0.36s infinite alternate"></span>' +
				'</div>';
			div.addEventListener('click', function() {
				mgr.playTrackByIndex(parseInt(this.getAttribute('data-index') || '0'));
			});
			playlistScroll.appendChild(div);
		}
	}

	function updatePlaylistActive(currentIndex) {
		var items = document.querySelectorAll('.playlist-item');
		for (var i = 0; i < items.length; i++) {
			var el = items[i];
			var eqDiv = el.querySelector('div:last-child');
			if (i === currentIndex) {
				el.classList.add('active');
				el.style.background = 'color-mix(in srgb, var(--primary) 10%, transparent)';
				if (eqDiv) eqDiv.style.display = 'flex';
			} else {
				el.classList.remove('active');
				el.style.background = '';
				if (eqDiv) eqDiv.style.display = 'none';
			}
		}
	}

	// Mode update
	function updateMode(playMode) {
		var iconRepeat = document.querySelector('.icon-repeat');
		var iconRepeatOne = document.querySelector('.icon-repeat-one');
		var iconShuffle = document.querySelector('.icon-shuffle');
		var btnMode = document.getElementById('btn-mode');
		if (!iconRepeat || !btnMode) return;
		iconRepeat.classList.add('hidden');
		iconRepeatOne.classList.add('hidden');
		iconShuffle.classList.add('hidden');
		if (playMode === 0) { iconRepeat.classList.remove('hidden'); }
		else if (playMode === 1) { iconRepeatOne.classList.remove('hidden'); }
		else { iconShuffle.classList.remove('hidden'); }
	}

	function updateVolume(volume, isMuted) {
		var iv1 = document.querySelector('.icon-vol-on');
		var iv2 = document.querySelector('.icon-vol-off');
		if (!iv1 || !iv2) return;
		if (isMuted || volume === 0) { iv1.classList.add('hidden'); iv2.classList.remove('hidden'); }
		else { iv1.classList.remove('hidden'); iv2.classList.add('hidden'); }
	}

	// Lyrics
	var currentLrcIdx = -1;
	function renderLyrics(lyrics) {
		if (!lyricsScroll) return;
		lyricsScroll.innerHTML = '';
		if (!lyrics || lyrics.length === 0) {
			lyricsScroll.innerHTML = '<div class="lyrics-placeholder">暂无歌词</div>';
			return;
		}
		for (var i = 0; i < lyrics.length; i++) {
			var line = document.createElement('div');
			line.className = 'lyric-line';
			line.textContent = lyrics[i].text;
			line.setAttribute('data-index', i.toString());
			line.addEventListener('click', function() {
				var idx = parseInt(this.getAttribute('data-index') || '0');
				mgr.seekToTime(lyrics[idx].time);
			});
			lyricsScroll.appendChild(line);
		}
	}

	function updateLrcHighlight(index) {
		if (index === currentLrcIdx) return;
		currentLrcIdx = index;
		var lines = lyricsScroll?.querySelectorAll('.lyric-line') || [];
		for (var i = 0; i < lines.length; i++) {
			if (i === index) { lines[i].classList.add('active'); }
			else { lines[i].classList.remove('active'); }
		}
		if (index >= 0) {
			var activeLine = lyricsScroll?.querySelector('.lyric-line.active');
			if (activeLine) {
				lyricsScroll.scrollTo({ top: activeLine.offsetTop - lyricsScroll.clientHeight / 2 + activeLine.offsetHeight / 2, behavior: 'smooth' });
			}
		}
	}

	// Event listeners
	window.addEventListener('fm:init', function(e) {
		var d = e.detail;
		if (d.playlist.length > 0) { renderPlaylist(d.playlist, 0); updateMode(d.playMode); updateVolume(d.volume, d.isMuted); }
	});
	window.addEventListener('fm:track', function(e) { updateTrack(e.detail.track); updatePlaylistActive(e.detail.index); });
	window.addEventListener('fm:play-state', function(e) { updatePlayState(e.detail.isPlaying); });
	window.addEventListener('fm:time', function(e) { updateProgress(e.detail.progress, e.detail.currentTimeStr, e.detail.durationStr); });
	window.addEventListener('fm:volume', function(e) { updateVolume(e.detail.volume, e.detail.isMuted); });
	window.addEventListener('fm:mode', function(e) { updateMode(e.detail.playMode); });
	window.addEventListener('fm:lyrics', function(e) { renderLyrics(e.detail.lyrics); });
	window.addEventListener('fm:lrc-index', function(e) { updateLrcHighlight(e.detail.index); });

	// Tabs & swipe
	var swipeTrack = document.getElementById('swipe-track');
	var tabs = document.querySelectorAll('.player-tab');
	var currentTab = 'playlist';

	tabs.forEach(function(tab) {
		tab.addEventListener('click', function() {
			var target = this.getAttribute('data-tab');
			if (target === currentTab) return;
			currentTab = target;
			tabs.forEach(function(t) { t.classList.remove('active'); });
			this.classList.add('active');
			if (target === 'lyrics') { swipeTrack.classList.add('show-lyrics'); }
			else { swipeTrack.classList.remove('show-lyrics'); }
		});
	});

	var touchStartX = 0;
	var swipeContainer = document.getElementById('swipe-container');
	if (swipeContainer) {
		swipeContainer.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; });
		swipeContainer.addEventListener('touchend', function(e) {
			var diff = touchStartX - e.changedTouches[0].clientX;
			if (Math.abs(diff) > 50) {
				if (diff > 0 && currentTab === 'playlist') {
					currentTab = 'lyrics'; swipeTrack.classList.add('show-lyrics');
					tabs.forEach(function(t) {
						t.classList.remove('active');
						if (t.getAttribute('data-tab') === 'lyrics') t.classList.add('active');
					});
				} else if (diff < 0 && currentTab === 'lyrics') {
					currentTab = 'playlist'; swipeTrack.classList.remove('show-lyrics');
					tabs.forEach(function(t) {
						t.classList.remove('active');
						if (t.getAttribute('data-tab') === 'playlist') t.classList.add('active');
					});
				}
			}
		});
	}

	// Sync on load
	function syncAll() {
		var s = mgr.getState();
		if (!s.initialized || s.playlist.length === 0) return;
		renderPlaylist(s.playlist, s.currentIndex);
		if (s.track) updateTrack(s.track);
		updatePlayState(s.isPlaying);
		updateMode(s.playMode);
		updateVolume(s.volume, s.isMuted);
		if (s.duration > 0) updateProgress(s.progress, s.currentTimeStr, s.durationStr);
		renderLyrics(s.lyrics);
		if (s.currentLrcIndex >= 0) updateLrcHighlight(s.currentLrcIndex);
	}

	if (mgr.getState().initialized) { syncAll(); }
	else { mgr.init(); }
})();
</script>
