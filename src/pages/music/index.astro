---
import { Icon } from "astro-icon/components";
import { siteConfig, musicPlayerConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import Comment from "@components/comment/index.astro";
import { getCollection } from "astro:content";

const metingApiBase = musicPlayerConfig.meting?.api
	? musicPlayerConfig.meting.api.split("?")[0]
	: "https://mu.tsh520.cn/api";

if (!siteConfig.pages.musicPage) {
	return Astro.redirect("/404/");
}

const customBangumi = await getCollection("bangumi");

const musicEntries = customBangumi
	.filter((item) => item.data.category === "music")
	.map((item) => {
		const { data } = item;
		const imageSrc = typeof data.image === "string" ? data.image : data.image.src;
		return {
			title: data.title,
			artist: data.artist || "",
			image: imageSrc,
			audioUrl: data.audioUrl || "",
			lrcUrl: data.lrcUrl || "",
			metingServer: data.metingServer || "",
			metingId: data.metingId || "",
			score: data.score || 0,
			status: data.status,
			comment: data.comment || "",
			published: data.published?.toISOString() || new Date().toISOString(),
		};
	})
	.sort((a, b) => new Date(b.published).getTime() - new Date(a.published).getTime());

// Build playlist from entries that have audioUrl
const collectionPlaylist = musicEntries
	.filter((item) => item.audioUrl || item.metingId)
	.map((item) => ({
		name: item.title,
		artist: item.artist,
		url: item.audioUrl,
		pic: item.image,
		lrc: item.lrcUrl,
		metingServer: item.metingServer || "",
		metingId: item.metingId || "",
	}));

// Map title → playlist index for each playable entry
const playlistIndexByTitle = new Map<string, number>();
collectionPlaylist.forEach((track, i) => playlistIndexByTitle.set(track.name, i));

const getStatusText = (type: number) => {
	switch (type) {
		case 1: return i18n(I18nKey.bangumiStatusMusicWish);
		case 2: return i18n(I18nKey.bangumiStatusMusicListened);
		case 3: return i18n(I18nKey.bangumiStatusMusicListening);
		case 4: return i18n(I18nKey.bangumiStatusOnHold);
		case 5: return i18n(I18nKey.bangumiStatusDropped);
		default: return "";
	}
};
---

<MainGridLayout title={i18n(I18nKey.musicPageTitle)} description={i18n(I18nKey.musicPageSubtitle)}>
	<div data-pagefind-body class="music-app" id="music-app">
		<div class="music-bg" id="music-bg"></div>
		<div class="music-bg-overlay"></div>

		<div class="music-content">
			<header class="music-header">
				<h1 data-pagefind-meta="title" data-pagefind-weight="10" class="music-page-title">{i18n(I18nKey.musicPageTitle)}</h1>
			</header>

			<!-- Player Card -->
			<div class="player-card" id="player-card">
				<div class="player-art-area">
					<div class="disc-container" id="disc-container">
						<div class="disc-ring"></div>
						<div class="disc-cover-wrap">
							<img class="disc-cover" id="disc-cover" src="" alt="Cover" />
						</div>
						<div class="disc-center"></div>
					</div>
				</div>

				<div class="player-info">
					<h2 class="player-title" id="player-title">{i18n(I18nKey.music)}</h2>
					<p class="player-artist" id="player-artist">{i18n(I18nKey.musicNoPlaying)}</p>
				</div>

				<div class="player-progress" id="player-progress">
					<span class="progress-time" id="progress-current">0:00</span>
					<div class="progress-bar-wrap" id="progress-bar-wrap">
						<div class="progress-bar-bg"></div>
						<div class="progress-bar-fill" id="progress-fill"></div>
						<div class="progress-thumb" id="progress-thumb"></div>
					</div>
					<span class="progress-time" id="progress-total">0:00</span>
				</div>

				<div class="player-controls">
					<button class="ctrl-btn" id="btn-mode" title="切换模式">
						<Icon name="material-symbols:repeat-rounded" class="ctrl-icon icon-repeat" />
						<Icon name="material-symbols:repeat-one-rounded" class="ctrl-icon icon-repeat-one hidden" />
						<Icon name="material-symbols:shuffle-rounded" class="ctrl-icon icon-shuffle hidden" />
					</button>
					<button class="ctrl-btn" id="btn-prev" title="上一曲">
						<Icon name="material-symbols:skip-previous-rounded" class="ctrl-icon-lg" />
					</button>
					<button class="ctrl-btn-play" id="btn-play" title="播放">
						<Icon name="material-symbols:play-arrow-rounded" class="ctrl-icon-xl icon-play" />
						<Icon name="material-symbols:pause-rounded" class="ctrl-icon-xl icon-pause hidden" />
					</button>
					<button class="ctrl-btn" id="btn-next" title="下一曲">
						<Icon name="material-symbols:skip-next-rounded" class="ctrl-icon-lg" />
					</button>
					<button class="ctrl-btn" id="btn-volume" title="音量">
						<Icon name="material-symbols:volume-up-rounded" class="ctrl-icon icon-vol-on" />
						<Icon name="material-symbols:volume-off-rounded" class="ctrl-icon icon-vol-off hidden" />
					</button>
				</div>
			</div>

			<!-- Lyrics Section -->
			<div class="lyrics-section" id="lyrics-section">
				<div class="lyrics-header">
					<Icon name="material-symbols:lyrics-outline" class="lyrics-header-icon" />
					<span class="lyrics-header-text">歌词</span>
				</div>
				<div class="lyrics-scroll" id="lyrics-scroll">
					<div class="lyrics-placeholder">
						<Icon name="material-symbols:library-music-outline" class="lyrics-placeholder-icon" />
						<span>暂无歌词</span>
					</div>
				</div>
			</div>

			<!-- Music Collection -->
			<section class="music-collection">
				<div class="collection-header">
					<h2 class="collection-title">我的音乐收藏</h2>
				</div>
				<div class="collection-grid" id="collection-grid">
					{musicEntries.length > 0 ? (
						musicEntries.map((item) => {
							const playlistIdx = (item.audioUrl || item.metingId) ? (playlistIndexByTitle.get(item.title) ?? -1) : -1;
							return (
								<div class="music-card" data-playlist-index={playlistIdx} data-has-audio={(item.audioUrl || item.metingId) ? "1" : "0"}>
									<div class="music-card-cover">
										<img src={item.image} alt={item.title} class="music-card-img" loading="lazy" />
										<span class="music-card-status">{getStatusText(item.status)}</span>
										{item.score > 0 && (
											<span class="music-card-score">
												<svg class="music-card-star" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
												{`${item.score}`.replace(/\.0$/, "")}
											</span>
										)}
										<div class="music-card-gradient"></div>
										<div class="music-card-info">
											<div class="music-card-title">{item.title}</div>
											{item.artist && <div class="music-card-artist">{item.artist}</div>}
										</div>
										{(item.audioUrl || item.metingId) && (
											<div class="music-card-play-overlay">
												<svg class="music-card-play-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.14v14l11-7-11-7z"/></svg>
											</div>
										)}
										{(item.audioUrl || item.metingId) && (
											<div class="music-card-eq">
												<span class="music-card-eq-bar"></span>
												<span class="music-card-eq-bar"></span>
												<span class="music-card-eq-bar"></span>
											</div>
										)}
										{item.comment && !item.audioUrl && !item.metingId && (
											<div class="music-card-comment-overlay">
												<p class="music-card-comment">{item.comment}</p>
											</div>
										)}
									</div>
								</div>
							);
						})
					) : (
						<div class="flex flex-col items-center justify-center py-16 text-center" style="grid-column:1/-1">
							<Icon name="material-symbols:library-music-outline" class="w-10 h-10 text-[var(--content-meta)] mb-3" />
							<p class="text-sm text-[var(--content-meta)]">{i18n(I18nKey.musicPageNoData)}</p>
						</div>
					)}
				</div>
			</section>
		</div>
	</div>
	<Comment customPath="/music/" />
</MainGridLayout>

<style>
	.music-app {
		position: relative;
		border-radius: var(--radius-large);
		overflow: hidden;
		min-height: 100vh;
		background: var(--card-bg);
	}
	.music-bg {
		position: absolute;
		inset: 0;
		background-color: var(--card-bg);
		background-size: cover;
		background-position: center;
		filter: blur(80px) saturate(0.6);
		transform: scale(1.1);
		transition: background-image 0.8s ease;
		z-index: 0;
		opacity: 0.4;
	}
	html.dark .music-bg {
		filter: blur(80px) brightness(0.35) saturate(0.6);
		opacity: 0.7;
	}
	.music-bg-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, var(--card-bg) 0%, color-mix(in srgb, var(--card-bg) 90%, transparent) 50%, var(--card-bg) 100%);
		z-index: 1;
	}
	.music-content {
		position: relative;
		z-index: 2;
		padding: 24px 24px 40px;
		max-width: 500px;
		margin: 0 auto;
	}

	/* Header */
	.music-header { text-align: center; margin-bottom: 24px; }
	.music-page-title {
		font-size: 18px; font-weight: 700;
		color: var(--deep-text);
		letter-spacing: 0.04em;
	}
	html.dark .music-page-title { color: var(--title-active); }

	/* Lyrics Section */
	.lyrics-section {
		margin-bottom: 20px;
		border-radius: 20px;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		overflow: hidden;
		box-shadow: 0 2px 12px rgba(0,0,0,0.04);
	}
	html.dark .lyrics-section {
		box-shadow: 0 2px 12px rgba(0,0,0,0.12);
	}
	.lyrics-header {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 14px 20px 0;
	}
	.lyrics-header-icon {
		width: 16px; height: 16px;
		color: var(--primary);
	}
	.lyrics-header-text {
		font-size: 13px;
		font-weight: 600;
		color: var(--deep-text);
		letter-spacing: 0.03em;
	}
	html.dark .lyrics-header-text { color: rgba(255,255,255,0.7); }

	.lyrics-scroll {
		height: 280px;
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		scroll-behavior: smooth;
		text-align: center;
		padding: 130px 16px 130px;
		mask-image: linear-gradient(to bottom, transparent 0%, black 25%, black 75%, transparent 100%);
		-webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 25%, black 75%, transparent 100%);
	}
	.lyrics-scroll::-webkit-scrollbar { width: 3px; }
	.lyrics-scroll::-webkit-scrollbar-thumb {
		background: var(--line-divider); border-radius: 3px;
	}
	html.dark .lyrics-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }

	.lyrics-placeholder {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		color: var(--content-meta);
		font-size: 14px;
		padding-top: 20px;
	}
	.lyrics-placeholder-icon {
		width: 28px; height: 28px;
		opacity: 0.4;
	}

	.lyric-line {
		padding: 8px 0;
		font-size: 14px;
		color: var(--content-meta);
		transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		cursor: pointer;
		line-height: 1.7;
		opacity: 0.45;
		transform: scale(0.92);
		filter: blur(0px);
		letter-spacing: 0.02em;
	}
	html.dark .lyric-line { color: rgba(255,255,255,0.25); }

	.lyric-line.near {
		opacity: 0.72;
		transform: scale(0.97);
		color: var(--deep-text);
	}
	html.dark .lyric-line.near { color: rgba(255,255,255,0.55); }

	.lyric-line.active {
		color: #3b82f6 !important;
		font-size: 17px;
		font-weight: 700;
		opacity: 1;
		transform: scale(1);
		text-shadow: 0 0 20px rgba(59,130,246,0.25);
		letter-spacing: 0.04em;
	}
	html.dark .lyric-line.active {
		color: #60a5fa !important;
		text-shadow: 0 0 24px rgba(96,165,250,0.40),
		             0 0 48px rgba(96,165,250,0.15);
	}

	.lyric-line:hover {
		color: var(--deep-text);
		opacity: 0.9;
	}
	html.dark .lyric-line:hover { color: rgba(255,255,255,0.65); }
	.lyric-line.active:hover {
		color: #3b82f6;
	}
	html.dark .lyric-line.active:hover { color: #60a5fa; }

	/* Player Card */
	.player-card {
		background: var(--card-bg);
		border-radius: 24px;
		padding: 32px 24px 24px;
		border: 1px solid var(--line-divider);
		overflow: hidden;
		box-shadow: 0 2px 12px rgba(0,0,0,0.05);
	}
	html.dark .player-card {
		box-shadow: 0 2px 12px rgba(0,0,0,0.15);
	}

	/* Album Art */
	.player-art-area {
		display: flex; justify-content: center; margin-bottom: 28px;
	}
	.disc-container { position: relative; width: 220px; height: 220px; }
	.disc-ring {
		position: absolute; inset: -8px; border-radius: 50%;
		border: 2px solid rgba(255,255,255,0.25);
		box-shadow: 0 0 30px rgba(0,0,0,0.06);
	}
	html.dark .disc-ring {
		border-color: rgba(255,255,255,0.1);
		box-shadow: 0 0 40px rgba(0,0,0,0.3);
	}
	.disc-cover-wrap {
		position: absolute; inset: 0; border-radius: 50%;
		overflow: hidden;
		box-shadow: 0 8px 30px rgba(0,0,0,0.1);
	}
	html.dark .disc-cover-wrap { box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
	.disc-cover { width: 100%; height: 100%; object-fit: cover; }
	.disc-center {
		position: absolute; top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 14px; height: 14px; border-radius: 50%;
		background: var(--card-bg);
		border: 2px solid rgba(255,255,255,0.25);
	}
	html.dark .disc-center {
		background: rgba(20,20,30,0.9);
		border-color: rgba(255,255,255,0.12);
	}
	.disc-container.playing .disc-cover-wrap {
		animation: disc-spin 20s linear infinite;
	}
	@keyframes disc-spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* Song Info */
	.player-info { text-align: center; margin-bottom: 20px; }
	.player-title {
		font-size: 20px; font-weight: 700;
		color: var(--deep-text);
		margin: 0 0 6px;
		overflow: hidden; text-overflow: ellipsis;
		white-space: nowrap; padding: 0 8px;
	}
	html.dark .player-title { color: #fff; }
	.player-artist { font-size: 14px; color: var(--content-meta); margin: 0; }
	html.dark .player-artist { color: rgba(255,255,255,0.5); }

	/* Progress */
	.player-progress {
		display: flex; align-items: center;
		gap: 10px; margin-bottom: 24px; padding: 0 4px;
	}
	.progress-time {
		font-size: 11px; color: var(--content-meta);
		font-variant-numeric: tabular-nums;
		min-width: 34px; text-align: center;
	}
	html.dark .progress-time { color: rgba(255,255,255,0.35); }
	.progress-bar-wrap {
		flex: 1; height: 4px; position: relative;
		cursor: pointer;
		display: flex; align-items: center;
	}
	.progress-bar-bg {
		position: absolute; inset: 0;
		background: var(--btn-regular-bg); border-radius: 2px;
	}
	html.dark .progress-bar-bg { background: rgba(255,255,255,0.1); }
	.progress-bar-fill {
		position: absolute; left: 0; top: 0; bottom: 0;
		width: 0%;
		background: var(--primary); border-radius: 2px;
		transition: width 0.15s linear;
	}
	.progress-thumb {
		position: absolute; top: 50%;
		transform: translate(-50%, -50%);
		width: 12px; height: 12px;
		background: var(--primary); border-radius: 50%;
		box-shadow: 0 2px 6px rgba(0,0,0,0.15);
		left: 0%; opacity: 0;
		transition: opacity 0.2s, left 0.15s linear;
	}
	html.dark .progress-thumb { background: #fff; }
	.progress-bar-wrap:hover .progress-thumb { opacity: 1; }

	/* Controls */
	.player-controls {
		display: flex; align-items: center;
		justify-content: center; gap: 16px;
		margin-bottom: 4px;
	}
	.ctrl-btn {
		background: none; border: none;
		color: var(--btn-content);
		cursor: pointer; padding: 8px;
		border-radius: 50%;
		transition: color 0.2s, transform 0.15s;
		display: flex; align-items: center; justify-content: center;
	}
	.ctrl-btn:hover { color: var(--deep-text); }
	html.dark .ctrl-btn { color: rgba(255,255,255,0.6); }
	html.dark .ctrl-btn:hover { color: #fff; }
	.ctrl-btn:active { transform: scale(0.9); }
	.ctrl-btn-play {
		background: var(--primary); border: none;
		color: #fff; cursor: pointer;
		width: 56px; height: 56px;
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		box-shadow: 0 4px 18px rgba(0,0,0,0.12);
		transition: transform 0.15s, box-shadow 0.2s;
	}
	html.dark .ctrl-btn-play {
		box-shadow: 0 4px 20px color-mix(in srgb, var(--primary) 50%, transparent);
	}
	.ctrl-btn-play:hover { box-shadow: 0 6px 26px rgba(0,0,0,0.2); }
	.ctrl-btn-play:active { transform: scale(0.92); }
	.ctrl-icon { width: 22px; height: 22px; }
	.ctrl-icon-lg { width: 30px; height: 30px; }
	.ctrl-icon-xl { width: 28px; height: 28px; }

	/* Unified Music Cards */
	.music-card {
		border-radius: var(--radius-large);
		overflow: hidden;
		cursor: pointer;
		transition: transform 0.22s cubic-bezier(.23,1,.32,1),
		            box-shadow 0.22s cubic-bezier(.23,1,.32,1);
	}
	.music-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 25px -6px rgba(0,0,0,.12), 0 0 0 2px var(--primary);
	}
	html.dark .music-card:hover {
		box-shadow: 0 8px 25px -6px rgba(0,0,0,.35), 0 0 0 2px var(--primary);
	}
	.music-card.playing {
		box-shadow: 0 0 0 2px var(--primary), 0 4px 16px color-mix(in srgb, var(--primary) 30%, transparent);
	}
	.music-card-cover {
		position: relative;
		aspect-ratio: 1/1;
		background: var(--btn-regular-bg);
		overflow: hidden;
	}
	.music-card-img {
		width: 100%; height: 100%;
		object-fit: cover; display: block;
		transition: transform 0.5s cubic-bezier(.23,1,.32,1);
	}
	.music-card:hover .music-card-img { transform: scale(1.06); }
	.music-card-status {
		position: absolute; top: 8px; left: 8px;
		padding: 3px 10px; border-radius: 9999px;
		font-size: 10px; font-weight: 600;
		letter-spacing: .04em; color: #fff;
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		z-index: 3;
		background: rgba(0,0,0,.45);
	}
	.music-card-score {
		position: absolute; top: 8px; right: 8px;
		display: flex; align-items: center; gap: 3px;
		padding: 3px 8px 3px 6px; border-radius: 9999px;
		background: rgba(0,0,0,.48);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		font-size: 11px; font-weight: 700; color: #fff;
		z-index: 3;
	}
	.music-card-star {
		width: 11px; height: 11px; color: #fbbf24; flex-shrink: 0;
	}
	.music-card-gradient {
		position: absolute; inset: auto 0 0 0;
		height: 60%;
		background: linear-gradient(to top, rgba(0,0,0,.7) 0%, rgba(0,0,0,.15) 50%, transparent 100%);
		pointer-events: none; z-index: 1;
	}
	.music-card-info {
		position: absolute; inset: auto 0 0 0;
		z-index: 2; padding: 0 10px 10px;
		pointer-events: none;
	}
	.music-card-title {
		font-size: 14px; font-weight: 700;
		line-height: 1.3; color: #fff;
		text-shadow: 0 1px 3px rgba(0,0,0,.4);
		overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
	}
	.music-card.playing .music-card-title { color: var(--primary); }
	.music-card-artist {
		font-size: 11px; color: rgba(255,255,255,.75);
		margin-top: 2px;
		overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
	}
	.music-card-play-overlay {
		position: absolute; inset: 0;
		display: flex; align-items: center; justify-content: center;
		background: rgba(0,0,0,.35);
		opacity: 0; transition: opacity .25s ease;
		z-index: 10; pointer-events: none;
	}
	.music-card:hover .music-card-play-overlay { opacity: 1; }
	.music-card.playing .music-card-play-overlay { opacity: 0; }
	.music-card-play-icon {
		width: 40px; height: 40px; color: #fff;
		filter: drop-shadow(0 2px 6px rgba(0,0,0,.3));
	}
	.music-card-eq {
		position: absolute; bottom: 10px; right: 10px;
		display: none; gap: 2px;
		align-items: flex-end; height: 16px;
		z-index: 5;
	}
	.music-card.playing .music-card-eq { display: flex; }
	.music-card-eq-bar {
		width: 2px; background: var(--primary); border-radius: 1px;
		animation: eq-bounce 0.55s ease-in-out infinite alternate;
	}
	.music-card-eq-bar:nth-child(1) { height: 6px; }
	.music-card-eq-bar:nth-child(2) { height: 14px; animation-delay: 0.18s; }
	.music-card-eq-bar:nth-child(3) { height: 9px; animation-delay: 0.36s; }
	@keyframes eq-bounce { to { transform: scaleY(0.35); } }

	.music-card-comment-overlay {
		position: absolute; inset: 0;
		background: rgba(0,0,0,.76);
		backdrop-filter: blur(3px);
		-webkit-backdrop-filter: blur(3px);
		opacity: 0; transition: opacity .25s ease;
		display: flex; align-items: flex-start; justify-content: center;
		padding: 16px; pointer-events: none; z-index: 20;
	}
	.music-card:hover .music-card-comment-overlay { opacity: 1; }
	.music-card-comment {
		font-size: 12px; line-height: 1.7;
		color: rgba(255,255,255,.92);
		margin: auto 0 0; width: 100%;
		display: -webkit-box;
		-webkit-line-clamp: 5;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* Collection */
	.music-collection { margin-top: 28px; }
	.collection-header { margin-bottom: 16px; }
	.collection-title {
		font-size: 16px; font-weight: 600;
		color: var(--deep-text); margin: 0;
	}
	html.dark .collection-title { color: rgba(255,255,255,0.75); }
	.collection-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px 12px;
	}

	/* Responsive */
	@media (min-width: 640px) { .collection-grid { grid-template-columns: repeat(4, 1fr); } }
	@media (min-width: 768px) {
		.collection-grid { grid-template-columns: repeat(5, 1fr); }
		.player-card { padding: 40px 32px 24px; }
		.disc-container { width: 260px; height: 260px; }
		.lyrics-scroll { height: 240px; padding: 60px 24px 80px; }
	}
	@media (min-width: 1024px) {
		.music-content {
			max-width: 900px;
			display: grid;
			grid-template-columns: 420px 1fr;
			gap: 32px;
			align-items: start;
		}
		.music-header { grid-column: 1 / -1; }
		.lyrics-section { grid-column: 1; }
		.player-card { grid-column: 1; position: sticky; top: 24px; }
		.music-collection { grid-column: 2; grid-row: 2 / 5; margin-top: 0; }
		.collection-grid { grid-template-columns: repeat(3, 1fr); }
		.lyrics-scroll { height: 180px; padding: 50px 16px 70px; }
	}
	@media (min-width: 1280px) {
		.music-content { max-width: 1100px; grid-template-columns: 440px 1fr; gap: 40px; }
		.collection-grid { grid-template-columns: repeat(4, 1fr); }
	}
	@media (max-width: 640px) {
		.music-content { padding: 16px 12px 32px; }
		.player-card { padding: 24px 16px 16px; border-radius: 20px; }
		.disc-container { width: 180px; height: 180px; }
		.collection-grid { grid-template-columns: repeat(3, 1fr); gap: 14px 10px; }
		.lyrics-section { border-radius: 16px; }
		.lyrics-scroll { height: 160px; padding: 50px 12px 70px; }
		.music-card-status { top: 5px; left: 5px; padding: 2px 7px; font-size: 9px; }
		.music-card-score { top: 5px; right: 5px; padding: 2px 7px 2px 5px; font-size: 10px; }
		.music-card-info { padding: 0 8px 8px; }
		.music-card-title { font-size: 13px; }
	}
</style>

<script is:inline define:vars={{ collectionPlaylistJson: JSON.stringify(collectionPlaylist), metingApiUrl: metingApiBase }}>
(function() {
	var mgr = window.__fireflyMusic;
	if (!mgr) return;

	var bg = document.getElementById('music-bg');
	var discContainer = document.getElementById('disc-container');
	var discCover = document.getElementById('disc-cover');
	var playerTitle = document.getElementById('player-title');
	var playerArtist = document.getElementById('player-artist');
	var progressFill = document.getElementById('progress-fill');
	var progressThumb = document.getElementById('progress-thumb');
	var progressCurrent = document.getElementById('progress-current');
	var progressTotal = document.getElementById('progress-total');
	var progressWrap = document.getElementById('progress-bar-wrap');
	var btnPlay = document.getElementById('btn-play');
	var iconPlay = document.querySelector('#btn-play .icon-play');
	var iconPause = document.querySelector('#btn-play .icon-pause');

	if (!btnPlay || !discCover || !playerTitle) return;

	var lyricsScroll = document.getElementById('lyrics-scroll');
	var collectionGrid = document.getElementById('collection-grid');

	// Load content-collection playlist data (injected via define:vars)
	var collectionPlaylist = JSON.parse(collectionPlaylistJson);

	if (!mgr.getState().initialized) mgr.init();

	function updatePlayState(isPlaying) {
		if (isPlaying) {
			discContainer.classList.add('playing');
			iconPlay.classList.add('hidden');
			iconPause.classList.remove('hidden');
		} else {
			discContainer.classList.remove('playing');
			iconPlay.classList.remove('hidden');
			iconPause.classList.add('hidden');
		}
	}

	function updateTrack(track) {
		if (!track) return;
		playerTitle.textContent = track.name;
		playerArtist.textContent = track.artist;
		if (track.pic) {
			discCover.src = track.pic;
			bg.style.backgroundImage = 'url(' + track.pic + ')';
		}
	}

	function updateProgress(progress, currentStr, durationStr) {
		progressFill.style.width = progress + '%';
		progressThumb.style.left = progress + '%';
		progressCurrent.textContent = currentStr;
		progressTotal.textContent = durationStr;
	}

	// Buttons
	document.getElementById('btn-mode')?.addEventListener('click', function() { mgr.cyclePlayMode(); });
	document.getElementById('btn-prev')?.addEventListener('click', function() { mgr.playPrev(); });
	btnPlay.addEventListener('click', function() { mgr.togglePlay(); });
	document.getElementById('btn-next')?.addEventListener('click', function() { mgr.playNext(); });
	document.getElementById('btn-volume')?.addEventListener('click', function() { mgr.toggleMute(); });

	progressWrap?.addEventListener('click', function(e) {
		var rect = progressWrap.getBoundingClientRect();
		var pct = (e.clientX - rect.left) / rect.width;
		mgr.seek(Math.max(0, Math.min(1, pct)));
	});

	// Card click delegation — resolve meting tracks on-demand
	collectionGrid?.addEventListener('click', async function(e) {
		var card = e.target.closest('.music-card');
		if (!card) return;
		var idx = parseInt(card.getAttribute('data-playlist-index') || '-1');
		if (idx < 0) return;
		var state = mgr.getState();
		var track = state.playlist[idx];
		if (!track) return;
		// If track has meting info but no URL, resolve on-demand via type=song
		if (!track.url && track.metingServer && track.metingId) {
			try {
				var s = encodeURIComponent(track.metingServer);
				var id = encodeURIComponent(track.metingId);
				var res = await fetch(metingApi + '?server=' + s + '&type=song&id=' + id);
				if (res.ok) {
					var raw = await res.json();
					var data = Array.isArray(raw) ? raw[0] : raw;
					if (data) {
						if (data.url) track.url = data.url;
						if (data.pic && !track.pic) track.pic = data.pic;
						if (data.lrc && !track.lrc) track.lrc = data.lrc;
					}
				}
			} catch(err) { console.warn('Meting on-demand failed:', err); }
		}
		if (track.url) { mgr.playTrackByIndex(idx); }
	});

	function updateActiveCard(currentIndex) {
		var cards = collectionGrid?.querySelectorAll('.music-card') || [];
		for (var i = 0; i < cards.length; i++) {
			var cardIdx = parseInt(cards[i].getAttribute('data-playlist-index') || '-1');
			if (cardIdx === currentIndex) { cards[i].classList.add('playing'); }
			else { cards[i].classList.remove('playing'); }
		}
	}

	// Mode update
	function updateMode(playMode) {
		var iconRepeat = document.querySelector('#btn-mode .icon-repeat');
		var iconRepeatOne = document.querySelector('#btn-mode .icon-repeat-one');
		var iconShuffle = document.querySelector('#btn-mode .icon-shuffle');
		var btnMode = document.getElementById('btn-mode');
		if (!iconRepeat || !btnMode) return;
		iconRepeat.classList.add('hidden');
		iconRepeatOne.classList.add('hidden');
		iconShuffle.classList.add('hidden');
		if (playMode === 0) { iconRepeat.classList.remove('hidden'); }
		else if (playMode === 1) { iconRepeatOne.classList.remove('hidden'); }
		else { iconShuffle.classList.remove('hidden'); }
	}

	function updateVolume(volume, isMuted) {
		var iv1 = document.querySelector('#btn-volume .icon-vol-on');
		var iv2 = document.querySelector('#btn-volume .icon-vol-off');
		if (!iv1 || !iv2) return;
		if (isMuted || volume === 0) { iv1.classList.add('hidden'); iv2.classList.remove('hidden'); }
		else { iv1.classList.remove('hidden'); iv2.classList.add('hidden'); }
	}

	// Lyrics
	var currentLrcIdx = -1;
	function renderLyrics(lyrics) {
		if (!lyricsScroll) return;
		lyricsScroll.innerHTML = '';
		if (!lyrics || lyrics.length === 0) {
			lyricsScroll.innerHTML = '<div class="lyrics-placeholder"><svg class="lyrics-placeholder-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg><span>暂无歌词</span></div>';
			return;
		}
		for (var i = 0; i < lyrics.length; i++) {
			var line = document.createElement('div');
			line.className = 'lyric-line';
			line.textContent = lyrics[i].text;
			line.setAttribute('data-index', i.toString());
			line.addEventListener('click', function() {
				var lrc = mgr.getState().lyrics;
				var idx = parseInt(this.getAttribute('data-index') || '0');
				if (lrc[idx]) mgr.seekToTime(lrc[idx].time);
			});
			lyricsScroll.appendChild(line);
		}
	}

	function updateLrcHighlight(index) {
		if (index === currentLrcIdx) return;
		currentLrcIdx = index;
		var lines = lyricsScroll?.querySelectorAll('.lyric-line') || [];
		for (var i = 0; i < lines.length; i++) {
			var dist = Math.abs(i - index);
			lines[i].classList.remove('active', 'near');
			if (dist === 0) {
				lines[i].classList.add('active');
				lines[i].style.color = '#3b82f6';
			} else if (dist === 1) {
				lines[i].classList.add('near');
				lines[i].style.color = '';
			} else {
				lines[i].style.color = '';
			}
		}
			if (index >= 0 && lines[index]) {
				lines[index].scrollIntoView({ block: "center", behavior: "smooth" });
			}
		}

	// Event listeners
	window.addEventListener('fm:init', function(e) {
		var d = e.detail;
		updateMode(d.playMode);
		updateVolume(d.volume, d.isMuted);
	});
	window.addEventListener('fm:track', function(e) { updateTrack(e.detail.track); updateActiveCard(e.detail.index); });
	window.addEventListener('fm:play-state', function(e) { updatePlayState(e.detail.isPlaying); });
	window.addEventListener('fm:time', function(e) { updateProgress(e.detail.progress, e.detail.currentTimeStr, e.detail.durationStr); });
	window.addEventListener('fm:volume', function(e) { updateVolume(e.detail.volume, e.detail.isMuted); });
	window.addEventListener('fm:mode', function(e) { updateMode(e.detail.playMode); });
	window.addEventListener('fm:lyrics', function(e) { renderLyrics(e.detail.lyrics); if (e.detail.lyrics && e.detail.lyrics.length > 0) { var idx = mgr.getState().currentLrcIndex; if (idx >= 0) updateLrcHighlight(idx); } });
	window.addEventListener('fm:lrc-index', function(e) { updateLrcHighlight(e.detail.index); });

	// Sync on load
	function syncAll() {
		var s = mgr.getState();
		if (!s.initialized || s.playlist.length === 0) return;
		if (s.track) updateTrack(s.track);
		updatePlayState(s.isPlaying);
		updateMode(s.playMode);
		updateVolume(s.volume, s.isMuted);
		if (s.duration > 0) updateProgress(s.progress, s.currentTimeStr, s.durationStr);
		renderLyrics(s.lyrics);
		if (s.currentLrcIndex >= 0) updateLrcHighlight(s.currentLrcIndex);
		updateActiveCard(s.currentIndex);
	}

	// Meting API resolution (URL injected via define:vars)
	var metingApi = metingApiUrl;

	async function resolveMetingTracks(playlist) {
		var base = metingApi + '?server=';
		for (var i = 0; i < playlist.length; i++) {
			var track = playlist[i];
			if (track.metingServer && track.metingId && !track.url) {
				try {
					var s = encodeURIComponent(track.metingServer);
					var id = encodeURIComponent(track.metingId);
					// type=song returns array with {title, author, url, pic, lrc}
					var res = await fetch(base + s + '&type=song&id=' + id);
					if (!res.ok) throw new Error('HTTP ' + res.status);
					var raw = await res.json();
					// Response is an array, grab first match
					var data = Array.isArray(raw) ? raw[0] : raw;
					if (data) {
						if (data.url) track.url = data.url;
						if (data.pic && !track.pic) track.pic = data.pic;
						if (data.lrc && !track.lrc) track.lrc = data.lrc;
						track.artist = track.artist || data.author || data.artist || "";
						track.name = (track.name && track.name !== track.metingId) ? track.name : (data.title || track.name);
					}
				} catch(e) {
					console.warn('[Meting] failed:', track.name, e);
				}
			}
		}
		return playlist;
	}

	async function initPlaylist() {
		console.log("[MusicPage] initPlaylist, playlist length:", collectionPlaylist.length);
		var resolved = await resolveMetingTracks(collectionPlaylist);
		console.log("[MusicPage] resolved, tracks with url:", resolved.filter(function(t){return t.url;}).length);
		if (resolved.length > 0) {
			mgr.loadExternalPlaylist(resolved);
		}
		syncAll();
	}

	if (mgr.getState().initialized) {
		initPlaylist();
	} else {
		window.addEventListener('fm:init', function handler() {
			window.removeEventListener('fm:init', handler);
			initPlaylist();
		});
		mgr.init();
	}
})();
</script>
