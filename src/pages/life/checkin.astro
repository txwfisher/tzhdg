---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import ActivityHeatmap from "@/components/life/ActivityHeatmap.astro";

const checkinEntries = await getCollection("checkin");

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();
const currentMonthStart = new Date(currentYear, currentMonth, 1);
const currentMonthEnd = new Date(currentYear, currentMonth + 1, 0);

const isInCurrentMonth = (date: Date) => {
	return date >= currentMonthStart && date <= currentMonthEnd;
};

const items = checkinEntries.map((entry) => {
	const checkins = entry.data.checkins || [];
	const monthCheckins = checkins.filter((d: Date) => isInCurrentMonth(d));
	return {
		id: entry.id,
		name: entry.data.name || "未命名",
		description: entry.data.description || "",
		checkins,
		totalCount: checkins.length,
		monthCount: monthCheckins.length,
		lastCheckin: checkins.length > 0 ? checkins[checkins.length - 1] : null,
	};
});

const totalCount = items.reduce((acc, item) => acc + item.totalCount, 0);
const totalMonthCount = items.reduce((acc, item) => acc + item.monthCount, 0);

// 构建所有打卡的热力图数据
const allCheckins: { date: string; count: number }[] = [];
items.forEach(item => {
	item.checkins.forEach((d: Date) => {
		const dateStr = d.toISOString().split('T')[0];
		const existing = allCheckins.find(c => c.date === dateStr);
		if (existing) {
			existing.count++;
		} else {
			allCheckins.push({ date: dateStr, count: 1 });
		}
	});
});
---

<MainGridLayout title="打卡记录" description="记录完成次数">
	<div class="checkin-page flex w-full flex-col gap-5">
		<!-- 标题区 -->
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h1 class="mb-2 text-3xl font-bold text-[var(--primary)]">✅ 打卡记录</h1>
			<p class="text-sm text-[var(--content-meta)]">记录一件事情的完成次数和完成日期。在 <code class="px-1.5 py-0.5 rounded bg-[var(--btn-regular-bg)] font-mono text-xs">life/checkin/</code> 下新建 md 即可添加。</p>

			<!-- 统计卡片 -->
			<div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4">
				<div class="stat-card">
					<div class="text-xs text-[var(--content-meta)]">总打卡天数</div>
					<div class="mt-1 text-2xl font-bold text-[var(--primary)]">{totalCount}</div>
					<div class="mt-1 text-xs text-[var(--content-meta)]">天</div>
				</div>
				<div class="stat-card">
					<div class="text-xs text-[var(--content-meta)]">本月完成</div>
					<div class="mt-1 text-2xl font-bold text-emerald-500">{totalMonthCount}</div>
					<div class="mt-1 text-xs text-[var(--content-meta)]">天</div>
				</div>
				<div class="stat-card">
					<div class="text-xs text-[var(--content-meta)]">记录项目</div>
					<div class="mt-1 text-2xl font-bold text-amber-500">{items.length}</div>
					<div class="mt-1 text-xs text-[var(--content-meta)]">个</div>
				</div>
				<div class="stat-card">
					<div class="text-xs text-[var(--content-meta)]">平均完成</div>
					<div class="mt-1 text-2xl font-bold text-purple-500">{items.length > 0 ? Math.round(totalCount / items.length) : 0}</div>
					<div class="mt-1 text-xs text-[var(--content-meta)]">天/项</div>
				</div>
			</div>
		</section>

		<!-- 打卡热力图 -->
		{items.length > 0 && (
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-[var(--text-color)]">
					<span>📊</span> 打卡热力图
				</h2>
				<ActivityHeatmap data={allCheckins} label="总打卡情况" weeks={20} />
			</section>
		)}

		<!-- 打卡列表 -->
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-[var(--text-color)]">
				<span>📋</span> 打卡列表
			</h2>

			{items.length === 0 ? (
				<div class="rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-8 text-center">
					<div class="text-5xl mb-4">📝</div>
					<p class="text-[var(--content-meta)]">还没有打卡记录</p>
					<p class="mt-2 text-sm text-[var(--content-meta)] opacity-70">
						在 <code class="px-1.5 py-0.5 rounded bg-[var(--btn-regular-bg)] font-mono">life/checkin/</code> 下新建 md 文件即可
					</p>
				</div>
			) : (
				<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
					{items.map((item) => (
						<article class="checkin-card group rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-5 transition-all hover:border-[var(--primary)] hover:shadow-lg hover:shadow-[var(--primary)]/10">
							<div class="flex items-start justify-between">
								<div class="flex-1">
									<h3 class="text-lg font-semibold text-[var(--text-color)] group-hover:text-[var(--primary)]">
										{item.name}
									</h3>
									<p class="mt-1 text-sm text-[var(--content-meta)] line-clamp-2">
										{item.description || "暂无描述"}
									</p>
								</div>
							</div>
							<div class="mt-4 flex items-end justify-between">
								<div>
									<div class="text-3xl font-bold text-[var(--primary)]">{item.totalCount}</div>
									<div class="text-xs text-[var(--content-meta)]">总天数</div>
								</div>
								<div class="text-right">
									<div class="text-lg font-semibold text-emerald-500">{item.monthCount}</div>
									<div class="text-xs text-[var(--content-meta)]">本月</div>
								</div>
							</div>
							{item.lastCheckin && (
								<div class="mt-2 text-xs text-[var(--content-meta)]">
									上次打卡: {new Date(item.lastCheckin).toLocaleDateString('zh-CN')}
								</div>
							)}
						</article>
					))}
				</div>
			)}
		</section>

		<!-- 使用说明 -->
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-[var(--text-color)]">
				<span>💡</span> 使用说明
			</h2>
			<div class="space-y-4 text-sm text-[var(--content-meta)]">
				<div class="rounded-lg border border-[var(--line-divider)] bg-[var(--card-bg)] p-4">
					<h3 class="mb-2 font-semibold text-[var(--text-color)]">创建打卡项目</h3>
					<p>在 <code class="px-1.5 py-0.5 rounded bg-[var(--btn-regular-bg)] font-mono text-xs">src/content/life/checkin/</code> 下创建 md 文件：</p>
					<pre class="mt-2 overflow-x-auto rounded bg-[var(--btn-regular-bg)] p-3 text-xs"><code>---
name: 早睡早起
description: 23点前入睡，7点前起床
checkins:
  - 2026-04-01
  - 2026-04-02
  - 2026-04-05
---

每次打卡后，在 checkins 数组中添加当天的日期。</code></pre>
				</div>
				<div class="rounded-lg border border-[var(--line-divider)] bg-[var(--card-bg)] p-4">
					<h3 class="mb-2 font-semibold text-[var(--text-color)]">打卡格式说明</h3>
					<ul class="list-disc list-inside space-y-1">
						<li>日期格式: <code class="px-1.5 py-0.5 rounded bg-[var(--btn-regular-bg)] font-mono text-xs">YYYY-MM-DD</code></li>
						<li>每次打卡后，在 <code class="px-1.5 py-0.5 rounded bg-[var(--btn-regular-bg)] font-mono text-xs">checkins</code> 数组中添加新日期</li>
						<li>日期会自动去重和排序</li>
					</ul>
				</div>
			</div>
		</section>
	</div>
</MainGridLayout>

<style>
	.checkin-page {
		--checkin-border: color-mix(in srgb, var(--line-divider) 86%, transparent);
	}

	.stat-card {
		border: 1px solid var(--checkin-border);
		background: linear-gradient(140deg, color-mix(in srgb, var(--primary) 9%, transparent) 0%, transparent 45%), var(--card-bg);
		padding: 1rem;
		border-radius: var(--radius-base);
	}

	.stat-card > div:first-child {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		opacity: 0.9;
	}

	.checkin-card {
		transition: all 0.2s ease;
	}

	.checkin-card:hover {
		transform: translateY(-2px);
	}

	:global(html.dark) .stat-card {
		background: linear-gradient(140deg, color-mix(in srgb, var(--primary) 12%, transparent) 0%, transparent 46%), color-mix(in srgb, var(--card-bg) 84%, #000);
	}

	pre {
		white-space: pre-wrap;
		word-wrap: break-word;
	}
</style>
