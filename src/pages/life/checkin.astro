---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import ActivityHeatmap from "@/components/life/ActivityHeatmap.astro";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

const navItems = [
  { label: "笔记本", icon: "material-symbols:book-outline", href: "/life/notebooks/", color: "#ec4899" },
  { label: "规划", icon: "material-symbols:schedule-outline", href: "/life/routines/", color: "#06b6d4" },
  { label: "想法", icon: "material-symbols:lightbulb-outline", href: "/life/ideas/", color: "#f59e0b" },
  { label: "足迹", icon: "material-symbols:location-on-outline", href: "/life/places/", color: "#10b981" },
  { label: "健康", icon: "material-symbols:favorite-outline", href: "/life/health/", color: "#3b82f6" },
  { label: "打卡", icon: "material-symbols:check-circle-outline", href: "/life/checkin/", color: "#84cc16" },
];

const checkinEntries = await getCollection("checkin");

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();
const currentMonthStart = new Date(currentYear, currentMonth, 1);
const currentMonthEnd = new Date(currentYear, currentMonth + 1, 0);

const isInCurrentMonth = (date: Date) => {
	return date >= currentMonthStart && date <= currentMonthEnd;
};

const items = checkinEntries.map((entry) => {
	const checkins = entry.data.checkins || [];
	const monthCheckins = checkins.filter((d: Date) => isInCurrentMonth(d));
	return {
		id: entry.id,
		name: entry.data.name || "未命名",
		description: entry.data.description || "",
		checkins,
		totalCount: checkins.length,
		monthCount: monthCheckins.length,
		lastCheckin: checkins.length > 0 ? checkins[checkins.length - 1] : null,
	};
});

const totalCount = items.reduce((acc, item) => acc + item.totalCount, 0);
const totalMonthCount = items.reduce((acc, item) => acc + item.monthCount, 0);

// 构建所有打卡的热力图数据
const allCheckins: { date: string; count: number }[] = [];
items.forEach(item => {
	item.checkins.forEach((d: Date) => {
		const dateStr = d.toISOString().split('T')[0];
		const existing = allCheckins.find(c => c.date === dateStr);
		if (existing) {
			existing.count++;
		} else {
			allCheckins.push({ date: dateStr, count: 1 });
		}
	});
});
---

<MainGridLayout title="打卡记录" description="记录完成次数">
	<div class="checkin-page flex w-full flex-col gap-5">
		<a href="/life/" class="back-btn mb-2 inline-flex items-center gap-1 text-sm text-[var(--content-meta)] hover:text-[var(--primary)]">
			<span>←</span> 返回生活
		</a>
		<!-- 导航栏 -->
		<div class="nav-tabs-wrapper" id="life-nav-wrapper">
			<div class="nav-container">
				<a href={url("/life/")} class="nav-tab nav-tab-home" data-category-name="生活">
					<Icon name="material-symbols:favorite" class="tab-icon" />
					<span class="tab-label">生活</span>
				</a>
				<div class="nav-tabs-scroll" id="life-nav-tabs-scroll">
					<div class="nav-tabs" id="life-nav-tabs">
						{navItems.map(item => (
							<a href={url(item.href)} class="nav-tab" data-category-name={item.label}>
								<Icon name={item.icon} class="tab-icon" />
								<span class="tab-label">{item.label}</span>
							</a>
						))}
					</div>
				</div>
			</div>
		</div>
		<!-- 标题区 -->
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h1 class="mb-2 text-3xl font-bold text-[var(--primary)]">✅ 打卡记录</h1>
			<p class="text-sm text-[var(--content-meta)]">记录一件事情的完成次数和完成日期。</p>

			<!-- 统计卡片 -->
			<div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4">
				<div class="stat-card">
					<div class="text-xs text-[var(--content-meta)]">总打卡天数</div>
					<div class="mt-1 text-2xl font-bold text-[var(--primary)]">{totalCount}</div>
					<div class="mt-1 text-xs text-[var(--content-meta)]">天</div>
				</div>
				<div class="stat-card">
					<div class="text-xs text-[var(--content-meta)]">本月完成</div>
					<div class="mt-1 text-2xl font-bold text-emerald-500">{totalMonthCount}</div>
					<div class="mt-1 text-xs text-[var(--content-meta)]">天</div>
				</div>
				<div class="stat-card">
					<div class="text-xs text-[var(--content-meta)]">记录项目</div>
					<div class="mt-1 text-2xl font-bold text-amber-500">{items.length}</div>
					<div class="mt-1 text-xs text-[var(--content-meta)]">个</div>
				</div>
				<div class="stat-card">
					<div class="text-xs text-[var(--content-meta)]">平均完成</div>
					<div class="mt-1 text-2xl font-bold text-purple-500">{items.length > 0 ? Math.round(totalCount / items.length) : 0}</div>
					<div class="mt-1 text-xs text-[var(--content-meta)]">天/项</div>
				</div>
			</div>
		</section>

		<!-- 打卡热力图 -->
		{items.length > 0 && (
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-[var(--text-color)]">
					<span>📊</span> 打卡热力图
				</h2>
				<ActivityHeatmap data={allCheckins} label="总打卡情况" weeks={20} />
			</section>
		)}

		<!-- 打卡列表 -->
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-[var(--text-color)]">
				<span>📋</span> 打卡列表
			</h2>

			{items.length === 0 ? (
				<div class="rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-8 text-center">
					<div class="text-5xl mb-4">📝</div>
					<p class="text-[var(--content-meta)]">还没有打卡记录</p>
				</div>
			) : (
				<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
					{items.map((item) => (
						<article class="checkin-card group rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-5 transition-all hover:border-[var(--primary)] hover:shadow-lg hover:shadow-[var(--primary)]/10">
							<div class="flex items-start justify-between">
								<div class="flex-1">
									<h3 class="text-lg font-semibold text-[var(--text-color)] group-hover:text-[var(--primary)]">
										{item.name}
									</h3>
									<p class="mt-1 text-sm text-[var(--content-meta)] line-clamp-2">
										{item.description || "暂无描述"}
									</p>
								</div>
							</div>
							<div class="mt-4 flex items-end justify-between">
								<div>
									<div class="text-3xl font-bold text-[var(--primary)]">{item.totalCount}</div>
									<div class="text-xs text-[var(--content-meta)]">总天数</div>
								</div>
								<div class="text-right">
									<div class="text-lg font-semibold text-emerald-500">{item.monthCount}</div>
									<div class="text-xs text-[var(--content-meta)]">本月</div>
								</div>
							</div>
							{item.lastCheckin && (
								<div class="mt-2 text-xs text-[var(--content-meta)]">
									上次打卡: {new Date(item.lastCheckin).toLocaleDateString('zh-CN')}
								</div>
							)}
						</article>
					))}
				</div>
			)}
		</section>

	</div>
</MainGridLayout>

<style>
	.checkin-page {
		--checkin-border: color-mix(in srgb, var(--line-divider) 86%, transparent);
	}

	.stat-card {
		border: 1px solid var(--checkin-border);
		background: linear-gradient(140deg, color-mix(in srgb, var(--primary) 9%, transparent) 0%, transparent 45%), var(--card-bg);
		padding: 1rem;
		border-radius: var(--radius-base);
	}

	.stat-card > div:first-child {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		opacity: 0.9;
	}

	.checkin-card {
		transition: all 0.2s ease;
	}

	.checkin-card:hover {
		transform: translateY(-2px);
	}

	:global(html.dark) .stat-card {
		background: linear-gradient(140deg, color-mix(in srgb, var(--primary) 12%, transparent) 0%, transparent 46%), color-mix(in srgb, var(--card-bg) 84%, #000);
	}

	pre {
		white-space: pre-wrap;
		word-wrap: break-word;
	}

	/* ========== 导航栏样式 ========== */
	.nav-tabs-wrapper {
		margin-bottom: 0;
		overflow: hidden;
		position: relative;
	}
	.nav-tabs-wrapper::before,
	.nav-tabs-wrapper::after {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		width: 32px;
		z-index: 2;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.2s;
	}
	.nav-tabs-wrapper::before {
		left: 0;
		background: linear-gradient(to right, var(--card-bg), transparent);
	}
	.nav-tabs-wrapper::after {
		right: 0;
		background: linear-gradient(to left, var(--card-bg), transparent);
	}
	.nav-tabs-wrapper.show-left::before { opacity: 1; }
	.nav-tabs-wrapper.show-right::after { opacity: 1; }

	.nav-container {
		display: flex;
		align-items: center;
		gap: 0;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		border-radius: 12px;
		padding: 6px;
	}

	.nav-tab-home {
		flex-shrink: 0;
		background: var(--card-bg);
	}

	.nav-tabs-scroll {
		flex: 1;
		min-width: 0;
		position: relative;
		overflow: hidden;
	}

	.nav-tabs {
		display: flex;
		gap: 6px;
		padding: 2px;
		overflow-x: auto;
		scroll-behavior: smooth;
		scrollbar-width: none;
		-ms-overflow-style: none;
		-webkit-overflow-scrolling: touch;
	}
	.nav-tabs::-webkit-scrollbar { display: none; }

	.nav-tab {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		padding: 6px 14px;
		border-radius: 8px;
		font-size: 14px;
		font-weight: 500;
		text-decoration: none;
		transition: all 0.2s ease;
		white-space: nowrap;
		background: transparent;
		border: 1.5px solid var(--line-divider);
		color: var(--btn-content);
	}
	.nav-tab:hover {
		border-color: var(--primary);
		color: var(--primary);
		background: transparent;
	}
	.nav-tab[data-active] {
		background: var(--primary);
		border-color: var(--primary);
		color: white;
	}
	.nav-tab[data-active]:hover {
		opacity: 0.9;
		transform: none;
		box-shadow: none;
	}
	.nav-tab:active {
		transform: scale(0.98);
	}
	.tab-icon { font-size: 18px; }

	@media (max-width: 480px) {
		.nav-tab {
			padding: 6px 10px;
			font-size: 13px;
		}
		.tab-icon { font-size: 16px; }
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', initNavTabs);
	document.addEventListener('astro:page-load', initNavTabs);

	function initNavTabs() {
		const wrapper = document.getElementById('life-nav-wrapper');
		const tabsScroll = document.getElementById('life-nav-tabs-scroll');
		const tabs = document.getElementById('life-nav-tabs');

		if (!wrapper || !tabsScroll || !tabs) return;
		if (tabs.dataset.initialized) return;
		tabs.dataset.initialized = 'true';

		const navContainer = tabsScroll.closest('.nav-container');

		function updateActiveNav() {
			const pathname = window.location.pathname;
			const navPills = tabs.querySelectorAll('.nav-tab:not(.nav-tab-home)');

			navPills.forEach(pill => {
				pill.removeAttribute('data-active');
				const href = pill.getAttribute('href');
				if (href && pathname.startsWith(href)) {
					pill.setAttribute('data-active', '');
				}
			});

			const homeTab = tabs.querySelector('.nav-tab-home');
			if (homeTab) {
				homeTab.removeAttribute('data-active');
				if (pathname === '/life/' || pathname === '/life') {
					homeTab.setAttribute('data-active', '');
				}
			}
		}

		updateActiveNav();
		document.addEventListener('swup:contentReplaced', updateActiveNav);

		function scrollToActiveTab() {
			const activeTab = tabs.querySelector('.nav-tab[data-active]');
			if (activeTab) {
				const scrollLeft = activeTab.offsetLeft - tabsScroll.offsetLeft - (tabsScroll.clientWidth - activeTab.offsetWidth) / 2;
				tabs.scrollTo({ left: Math.max(0, scrollLeft), behavior: 'smooth' });
			}
		}

		const originalUpdateActiveNav = updateActiveNav;
		updateActiveNav = function() {
			originalUpdateActiveNav();
			scrollToActiveTab();
		};

		function updateScrollIndicators() {
			const scrollLeft = tabs.scrollLeft;
			const scrollWidth = tabs.scrollWidth;
			const clientWidth = tabs.clientWidth;

			wrapper.classList.toggle('show-left', scrollLeft > 10);
			wrapper.classList.toggle('show-right', scrollLeft < scrollWidth - clientWidth - 10);
		}

		tabs.addEventListener('scroll', updateScrollIndicators);
		window.addEventListener('resize', updateScrollIndicators);
		updateScrollIndicators();

		if (navContainer) {
			navContainer.addEventListener('mouseenter', () => {
				document.body.style.overflow = 'hidden';
			});

			navContainer.addEventListener('mouseleave', () => {
				document.body.style.overflow = '';
			});

			navContainer.addEventListener('wheel', (e) => {
				if (tabs.scrollWidth > tabs.clientWidth) {
					e.stopPropagation();
					tabs.scrollLeft += e.deltaY + e.deltaX;
					updateScrollIndicators();
				}
			}, { capture: true, passive: false });
		}

		let touchStartX = 0;
		let touchScrollLeft = 0;

		tabs.addEventListener('touchstart', (e) => {
			touchStartX = e.touches[0].pageX;
			touchScrollLeft = tabs.scrollLeft;
		}, { passive: true });

		tabs.addEventListener('touchmove', (e) => {
			const touchX = e.touches[0].pageX;
			const walk = (touchStartX - touchX) * 1.5;
			tabs.scrollLeft = touchScrollLeft + walk;
			updateScrollIndicators();
		}, { passive: true });
	}
</script>
