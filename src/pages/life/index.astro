---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

// 获取所有生活相关数据
const allLifeEntries = await getCollection("life");
// 过滤掉 README 文件
const ideas = allLifeEntries.filter((entry) => !entry.id.toLowerCase().includes("readme"));
const workoutEntries = await getCollection("lifeWorkout");
const sleepEntries = await getCollection("lifeSleep");
const foodEntries = await getCollection("lifeFood");
const notebooks = await getCollection("notebooks");
const checkinEntries = await getCollection("checkin");
const routinesEntries = await getCollection("routines");

// 从 life 集合中过滤出 places
const places = allLifeEntries.filter((entry) =>
	entry.id.replace(/\\\\/g, "/").startsWith("places/") &&
	!entry.id.toLowerCase().includes("readme")
);

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();
const currentWeek = Math.ceil(now.getDate() / 7);

// 辅助函数
const isSameMonth = (date?: Date) => {
	if (!date) return false;
	return date.getFullYear() === currentYear && date.getMonth() === currentMonth;
};

const isSameYear = (date?: Date) => {
	if (!date) return false;
	return date.getFullYear() === currentYear;
};

// ========== 想法统计 ==========
const ideasCount = ideas.length;
const ideasDone = ideas.filter((item) => item.data.status === "done");
const ideasDoneCount = ideasDone.length;
const ideasTodoCount = ideas.length - ideasDoneCount;
const thisMonthDoneIdeas = ideasDone.filter((item) => isSameMonth(item.data.completedAt)).length;
const recentIdeas = [...ideas].sort((a, b) => {
	const aTime = a.data.completedAt?.getTime() || a.data.createdAt?.getTime() || 0;
	const bTime = b.data.completedAt?.getTime() || b.data.createdAt?.getTime() || 0;
	return bTime - aTime;
}).slice(0, 3);

// ========== 运动统计 ==========
const sortedWorkouts = [...workoutEntries].sort((a, b) => {
	const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
	const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
	return bTime - aTime;
});
const monthWorkout = sortedWorkouts.filter((item) => isSameMonth(item.data.date));
const yearWorkout = sortedWorkouts.filter((item) => isSameYear(item.data.date));
const workoutCount = sortedWorkouts.length;
const monthWorkoutDays = monthWorkout.length;
const totalRunKm = sortedWorkouts.reduce((acc, item) => acc + (item.data.runKm || 0), 0);
const monthRunKm = monthWorkout.reduce((acc, item) => acc + (item.data.runKm || 0), 0);
const yearRunKm = yearWorkout.reduce((acc, item) => acc + (item.data.runKm || 0), 0);
const recentWorkout = sortedWorkouts[0];

// ========== 睡眠统计 ==========
const sortedSleep = [...sleepEntries].sort((a, b) => {
	const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
	const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
	return bTime - aTime;
});
const monthSleep = sortedSleep.filter((item) => isSameMonth(item.data.date));
const sleepCount = sortedSleep.length;
const avgSleepHours = sleepCount > 0
	? sortedSleep.reduce((acc, item) => acc + (item.data.sleepHours || 0), 0) / sleepCount
	: 0;
const thisMonthAvgSleep = monthSleep.length > 0
	? monthSleep.reduce((acc, item) => acc + (item.data.sleepHours || 0), 0) / monthSleep.length
	: 0;
const thisMonthSleepDays = monthSleep.length;

// ========== 饮食统计 ==========
const sortedFood = [...foodEntries].sort((a, b) => {
	const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
	const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
	return bTime - aTime;
});
const monthFood = sortedFood.filter((item) => isSameMonth(item.data.date));
const foodCount = sortedFood.length;
const thisMonthFoodDays = monthFood.length;

// ========== 地点统计 ==========
const sortedPlaces = [...places].sort((a, b) => {
	const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
	const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
	return bTime - aTime;
});
const placesCount = places.length;
const uniqueProvinces = new Set(places.map(p => p.data.province).filter(Boolean)).size;
const totalVisitCount = places.reduce((acc, p) => acc + (p.data.visitCount || 1), 0);
const recentPlace = sortedPlaces[0];

// ========== 打卡统计 ==========
const checkinTotalCount = checkinEntries.reduce((acc, item) => acc + (item.data.count || 0), 0);
const checkinCount = checkinEntries.length;
const checkinItems = checkinEntries.slice(0, 3);

// ========== 规划统计 ==========
const routinesCount = routinesEntries.length;
const routinesByTime = routinesEntries.reduce((acc, item) => {
	const time = item.data.time || "";
	let period = "其他";
	if (time.includes("早晨") || time.includes("早上")) period = "早晨";
	else if (time.includes("上午")) period = "上午";
	else if (time.includes("中午")) period = "中午";
	else if (time.includes("下午")) period = "下午";
	else if (time.includes("傍晚")) period = "傍晚";
	else if (time.includes("晚上")) period = "晚上";
	acc[period] = (acc[period] || 0) + 1;
	return acc;
}, {} as Record<string, number>);

// ========== 笔记本统计（排除 _index 文件）==========
const notebookFolders = new Map<string, { count: number; latestDate: Date | null }>();
notebooks.forEach((entry) => {
	const id = entry.id.replace(/\\/g, "/");
	// 跳过 _index 文件
	if (id.endsWith("/_index") || id.endsWith("/_index.md") || id.endsWith("/_index.json")) {
		return;
	}
	// 提取文件夹名
	const match = id.match(/^([^/]+)\//);
	if (match) {
		const folderName = match[1];
		if (!notebookFolders.has(folderName)) {
			notebookFolders.set(folderName, { count: 0, latestDate: null });
		}
		const info = notebookFolders.get(folderName)!;
		info.count++;
		const entryDate = entry.data.date instanceof Date ? entry.data.date : null;
		if (entryDate && (!info.latestDate || entryDate.getTime() > info.latestDate.getTime())) {
			info.latestDate = entryDate;
		}
	}
});
const notebookCount = notebookFolders.size;
const totalNotebookEntries = Array.from(notebookFolders.values()).reduce((acc, info) => acc + info.count, 0);
// 找到最新更新的笔记本
const recentNotebook = Array.from(notebookFolders.entries())
	.map(([name, info]) => {
		// 找到这个文件夹中最近更新的条目
		const folderEntries = notebooks.filter((e) => {
			const id = e.id.replace(/\\/g, "/");
			return id.startsWith(`${name}/`) && !id.endsWith("/_index") && !id.endsWith("/_index.md") && !id.endsWith("/_index.json");
		});
		const sortedByDate = folderEntries.sort((a, b) => {
			const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
			const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
			return bTime - aTime;
		})[0];
		return {
			name,
			latestDate: info.latestDate,
			data: {
				name: sortedByDate?.data.name || name,
				entries: { length: info.count },
				updatedAt: info.latestDate
			}
		};
	})
	.filter((item) => item.latestDate)
	.sort((a, b) => (b.latestDate?.getTime() || 0) - (a.latestDate?.getTime() || 0))[0];

// ========== 最近动态 ==========
// 获取笔记本条目（排除 _index）
const notebookEntriesList = notebooks
	.filter((e) => {
		const id = e.id.replace(/\\/g, "/");
		return !id.endsWith("/_index") && !id.endsWith("/_index.md") && !id.endsWith("/_index.json");
	})
	.sort((a, b) => {
		const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
		const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
		return bTime - aTime;
	});

const recentUpdates = [
	...(sortedWorkouts.slice(0, 2).map(e => ({ date: e.data.date, type: "运动", detail: e.data.workoutType || "锻炼", icon: "💪" }))),
	...(sortedSleep.slice(0, 2).map(e => ({ date: e.data.date, type: "睡眠", detail: `${e.data.sleepHours}小时`, icon: "😴" }))),
	...(sortedFood.slice(0, 1).map(e => ({ date: e.data.date, type: "饮食", detail: e.data.allowedFoods?.length || 0 + "种食物", icon: "🍎" }))),
	...(ideasDone.slice(0, 1).map(e => ({ date: e.data.completedAt, type: "想法", detail: e.data.content?.slice(0, 15) + "...", icon: "✨" }))),
	...(notebookEntriesList.slice(0, 2).map(e => ({ date: e.data.date, type: "笔记", detail: e.data.name || "未命名", icon: "📔" }))),
	...(sortedPlaces.slice(0, 1).map(e => ({ date: e.data.date, type: "足迹", detail: `${e.data.city || "未知"}${e.data.district ? " " + e.data.district : ""}`, icon: "📍" }))),
	...(routinesEntries.slice(0, 1).map(e => ({ date: e.data.updatedAt, type: "规划", detail: e.data.name || "日常安排", icon: "📋" }))),
	...(checkinEntries.slice(0, 1).map(e => ({ date: e.data.updatedAt, type: "打卡", detail: e.data.name || "打卡项", icon: "✅" }))),
].sort((a, b) => {
	const aTime = a.date instanceof Date ? a.date.getTime() : 0;
	const bTime = b.date instanceof Date ? b.date.getTime() : 0;
	return bTime - aTime;
}).slice(0, 5);
---

<MainGridLayout title="生活" description="生活记录总览">
	<div class="life-page flex w-full flex-col gap-6">
		{/* 头部概览 */}
		<section class="hero-section card-base relative overflow-hidden rounded-[var(--radius-large)] p-6 md:p-8">
			<div class="absolute -right-8 -top-8 h-48 w-48 rounded-full bg-[var(--primary)]/5 blur-3xl"></div>
			<div class="absolute -bottom-8 -right-8 h-64 w-64 rounded-full bg-blue-500/5 blur-3xl"></div>
			<h1 class="mb-2 text-3xl font-bold text-[var(--primary)] md:text-4xl">🌿 生活总览</h1>
			<p class="max-w-2xl text-sm text-[var(--content-meta)] md:text-base">
				记录 {workoutCount} 次运动、{sleepCount} 晚睡眠、{ideasCount} 个想法、{placesCount} 个足迹。
				本月已完成 {thisMonthDoneIdeas} 个想法，跑了 {monthRunKm.toFixed(1)} 公里。
			</p>

			{/* 核心指标卡片 */}
			<div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4">
				<a href={url("/life/health/")} class="stat-card group relative overflow-hidden rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4 transition-all hover:border-[var(--primary)] hover:shadow-lg hover:shadow-[var(--primary)]/10">
					<div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-transparent opacity-0 transition-opacity group-hover:opacity-100 dark:from-blue-900/20"></div>
					<div class="relative">
						<div class="mb-2 flex items-center gap-2">
							<span class="text-2xl">💪</span>
							<span class="text-xs font-medium text-[var(--content-meta)]">运动</span>
						</div>
						<div class="text-2xl font-bold text-[var(--text-color)]">{workoutCount}</div>
						<div class="mt-1 text-xs text-[var(--content-meta)]">本月 {monthWorkoutDays} 天</div>
						<div class="mt-1 text-xs text-emerald-600 dark:text-emerald-400">累计 {totalRunKm.toFixed(0)} km</div>
					</div>
				</a>

				<a href={url("/life/health/")} class="stat-card group relative overflow-hidden rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4 transition-all hover:border-[var(--primary)] hover:shadow-lg hover:shadow-[var(--primary)]/10">
					<div class="absolute inset-0 bg-gradient-to-br from-purple-50 to-transparent opacity-0 transition-opacity group-hover:opacity-100 dark:from-purple-900/20"></div>
					<div class="relative">
						<div class="mb-2 flex items-center gap-2">
							<span class="text-2xl">😴</span>
							<span class="text-xs font-medium text-[var(--content-meta)]">睡眠</span>
						</div>
						<div class="text-2xl font-bold text-[var(--text-color)]">{sleepCount}</div>
						<div class="mt-1 text-xs text-[var(--content-meta)]">平均 {avgSleepHours.toFixed(1)}h</div>
						<div class="mt-1 text-xs text-purple-600 dark:text-purple-400">本月 {thisMonthSleepDays} 天</div>
					</div>
				</a>

				<a href={url("/life/ideas/")} class="stat-card group relative overflow-hidden rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4 transition-all hover:border-[var(--primary)] hover:shadow-lg hover:shadow-[var(--primary)]/10">
					<div class="absolute inset-0 bg-gradient-to-br from-amber-50 to-transparent opacity-0 transition-opacity group-hover:opacity-100 dark:from-amber-900/20"></div>
					<div class="relative">
						<div class="mb-2 flex items-center gap-2">
							<span class="text-2xl">💡</span>
							<span class="text-xs font-medium text-[var(--content-meta)]">想法</span>
						</div>
						<div class="text-2xl font-bold text-[var(--text-color)]">{ideasCount}</div>
						<div class="mt-1 text-xs text-[var(--content-meta)]">完成 {ideasDoneCount} 个</div>
						<div class="mt-1 text-xs text-rose-600 dark:text-rose-400">待办 {ideasTodoCount} 个</div>
					</div>
				</a>

				<a href={url("/life/checkin/")} class="stat-card group relative overflow-hidden rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4 transition-all hover:border-[var(--primary)] hover:shadow-lg hover:shadow-[var(--primary)]/10">
					<div class="absolute inset-0 bg-gradient-to-br from-emerald-50 to-transparent opacity-0 transition-opacity group-hover:opacity-100 dark:from-emerald-900/20"></div>
					<div class="relative">
						<div class="mb-2 flex items-center gap-2">
							<span class="text-2xl">✅</span>
							<span class="text-xs font-medium text-[var(--content-meta)]">打卡</span>
						</div>
						<div class="text-2xl font-bold text-[var(--text-color)]">{checkinTotalCount}</div>
						<div class="mt-1 text-xs text-[var(--content-meta)]">{checkinCount} 个项目</div>
						<div class="mt-1 text-xs text-emerald-600 dark:text-emerald-400">记录完成</div>
					</div>
				</a>

				<a href={url("/life/routines/")} class="stat-card group relative overflow-hidden rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4 transition-all hover:border-[var(--primary)] hover:shadow-lg hover:shadow-[var(--primary)]/10">
					<div class="absolute inset-0 bg-gradient-to-br from-amber-50 to-transparent opacity-0 transition-opacity group-hover:opacity-100 dark:from-amber-900/20"></div>
					<div class="relative">
						<div class="mb-2 flex items-center gap-2">
							<span class="text-2xl">📅</span>
							<span class="text-xs font-medium text-[var(--content-meta)]">规划</span>
						</div>
						<div class="text-2xl font-bold text-[var(--text-color)]">{routinesCount}</div>
						<div class="mt-1 text-xs text-[var(--content-meta)]">个日常安排</div>
						<div class="mt-1 text-xs text-amber-600 dark:text-amber-400">作息规划</div>
					</div>
				</a>
			</div>
		</section>

		{/* 详细信息网格 */}
		<div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
			{/* 最近想法 */}
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="flex items-center gap-2 text-lg font-bold text-[var(--text-color)]">
						<span>💡</span> 最近想法
					</h2>
					<a href={url("/life/ideas/")} class="text-xs text-[var(--primary)] hover:underline">全部 →</a>
				</div>
				<div class="space-y-2">
					{recentIdeas.map((idea) => (
						<div class="rounded-lg border border-[var(--line-divider)] bg-[var(--card-bg)] p-3 transition-colors hover:border-[var(--primary)]/30">
							<div class="flex items-start gap-2">
								<span class={`mt-0.5 h-2 w-2 shrink-0 rounded-full ${idea.data.status === "done" ? "bg-emerald-500" : "bg-amber-500"}`}></span>
								<div class="flex-1">
									<p class="text-sm leading-relaxed text-[var(--text-color)] line-clamp-2">
										{idea.data.content}
									</p>
									<div class="mt-2 flex items-center gap-2 text-xs text-[var(--content-meta)]">
										{idea.data.completedAt && (
											<span class="flex items-center gap-1">
												<Icon name="material-symbols:check-circle-outline" class="text-xs" />
												{idea.data.completedAt.toISOString().split("T")[0]}
											</span>
										)}
										{!idea.data.completedAt && idea.data.createdAt && (
											<span class="flex items-center gap-1">
												<Icon name="material-symbols:schedule-outline" class="text-xs" />
												{idea.data.createdAt.toISOString().split("T")[0]}
											</span>
										)}
									</div>
								</div>
							</div>
						</div>
					))}
				</div>
			</section>

			{/* 运动详情 */}
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="flex items-center gap-2 text-lg font-bold text-[var(--text-color)]">
						<span>💪</span> 运动详情
					</h2>
					<a href={url("/life/health/")} class="text-xs text-[var(--primary)] hover:underline">全部 →</a>
				</div>
				<div class="space-y-4">
					<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-blue-50 to-transparent p-3 dark:from-blue-900/20">
						<div>
							<div class="text-sm font-medium text-[var(--text-color)]">累计跑量</div>
							<div class="text-xs text-[var(--content-meta)]">所有记录</div>
						</div>
						<div class="text-right">
							<div class="text-xl font-bold text-blue-600 dark:text-blue-400">{totalRunKm.toFixed(1)} <span class="text-sm font-normal">km</span></div>
							<div class="text-xs text-[var(--content-meta)]">共 {workoutCount} 次</div>
						</div>
					</div>
					<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-emerald-50 to-transparent p-3 dark:from-emerald-900/20">
						<div>
							<div class="text-sm font-medium text-[var(--text-color)]">本月跑量</div>
							<div class="text-xs text-[var(--content-meta)]">{currentMonth + 1}月</div>
						</div>
						<div class="text-right">
							<div class="text-xl font-bold text-emerald-600 dark:text-emerald-400">{monthRunKm.toFixed(1)} <span class="text-sm font-normal">km</span></div>
							<div class="text-xs text-[var(--content-meta)]">{monthWorkoutDays} 次</div>
						</div>
					</div>
					<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-amber-50 to-transparent p-3 dark:from-amber-900/20">
						<div>
							<div class="text-sm font-medium text-[var(--text-color)]">今年跑量</div>
							<div class="text-xs text-[var(--content-meta)]">{currentYear}年</div>
						</div>
						<div class="text-right">
							<div class="text-xl font-bold text-amber-600 dark:text-amber-400">{yearRunKm.toFixed(1)} <span class="text-sm font-normal">km</span></div>
							<div class="text-xs text-[var(--content-meta)]">{yearWorkout.length} 次</div>
						</div>
					</div>
				</div>
				{recentWorkout && (
					<div class="mt-4 border-t border-[var(--line-divider)] pt-3">
						<div class="flex items-center justify-between text-xs text-[var(--content-meta)]">
							<span>最近运动：{recentWorkout.data.workoutType}</span>
							<span>{recentWorkout.data.date.toISOString().split("T")[0]}</span>
						</div>
					</div>
				)}
			</section>

			{/* 睡眠趋势 */}
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="flex items-center gap-2 text-lg font-bold text-[var(--text-color)]">
						<span>😴</span> 睡眠质量
					</h2>
					<a href={url("/life/health/")} class="text-xs text-[var(--primary)] hover:underline">全部 →</a>
				</div>
				<div class="space-y-4">
					<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-purple-50 to-transparent p-3 dark:from-purple-900/20">
						<div>
							<div class="text-sm font-medium text-[var(--text-color)]">平均睡眠</div>
							<div class="text-xs text-[var(--content-meta)]">所有记录</div>
						</div>
						<div class="text-right">
							<div class="text-xl font-bold text-purple-600 dark:text-purple-400">{avgSleepHours.toFixed(1)} <span class="text-sm font-normal">h</span></div>
							<div class="text-xs text-[var(--content-meta)]">{sleepCount} 个夜晚</div>
						</div>
					</div>
					<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-pink-50 to-transparent p-3 dark:from-pink-900/20">
						<div>
							<div class="text-sm font-medium text-[var(--text-color)]">本月平均</div>
							<div class="text-xs text-[var(--content-meta)]">{currentMonth + 1}月</div>
						</div>
						<div class="text-right">
							<div class="text-xl font-bold text-pink-600 dark:text-pink-400">{thisMonthAvgSleep.toFixed(1)} <span class="text-sm font-normal">h</span></div>
							<div class="text-xs text-[var(--content-meta)]">{thisMonthSleepDays} 晚</div>
						</div>
					</div>
					{sortedSleep.length >= 2 && (
						<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-blue-50 to-transparent p-3 dark:from-blue-900/20">
							<div>
								<div class="text-sm font-medium text-[var(--text-color)]">最近睡眠</div>
								<div class="text-xs text-[var(--content-meta)]">last entry</div>
							</div>
							<div class="text-right">
								<div class="text-xl font-bold text-blue-600 dark:text-blue-400">{sortedSleep[0].data.sleepHours.toFixed(1)} <span class="text-sm font-normal">h</span></div>
								<div class="text-xs text-[var(--content-meta)]">质量 {sortedSleep[0].data.sleepQuality || "N/A"}</div>
							</div>
						</div>
					)}
				</div>
			</section>

			{/* 打卡记录 */}
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="flex items-center gap-2 text-lg font-bold text-[var(--text-color)]">
						<span>✅</span> 打卡记录
					</h2>
					<a href={url("/life/checkin/")} class="text-xs text-[var(--primary)] hover:underline">全部 →</a>
				</div>
				{checkinEntries.length === 0 ? (
					<div class="rounded-lg bg-gradient-to-r from-emerald-50 to-transparent p-4 text-center dark:from-emerald-900/20">
						<div class="text-sm text-[var(--content-meta)]">暂无打卡记录</div>
						<div class="mt-2 text-xs text-[var(--content-meta)] opacity-70">在 life/checkin/ 下创建 md 文件即可添加</div>
					</div>
				) : (
					<div class="space-y-3">
						<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-emerald-50 to-transparent p-3 dark:from-emerald-900/20">
							<div>
								<div class="text-sm font-medium text-[var(--text-color)]">总完成次数</div>
								<div class="text-xs text-[var(--content-meta)]">{checkinCount} 个项目</div>
							</div>
							<div class="text-xl font-bold text-emerald-600 dark:text-emerald-400">{checkinTotalCount}</div>
						</div>
						{checkinItems.map((item) => (
							<div class="flex items-center justify-between rounded-lg border border-[var(--line-divider)] bg-[var(--card-bg)] p-3">
								<div>
									<div class="text-sm font-medium text-[var(--text-color)]">{item.data.name}</div>
									<div class="text-xs text-[var(--content-meta)]">{item.data.description}</div>
								</div>
								<div class="text-lg font-bold text-[var(--primary)]">{item.data.count || 0}</div>
							</div>
						))}
					</div>
				)}
			</section>

			{/* 日常规划 */}
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="flex items-center gap-2 text-lg font-bold text-[var(--text-color)]">
						<span>📅</span> 日常规划
					</h2>
					<a href={url("/life/routines/")} class="text-xs text-[var(--primary)] hover:underline">全部 →</a>
				</div>
				{routinesEntries.length === 0 ? (
					<div class="rounded-lg bg-gradient-to-r from-amber-50 to-transparent p-4 text-center dark:from-amber-900/20">
						<div class="text-sm text-[var(--content-meta)]">暂无日常规划</div>
						<div class="mt-2 text-xs text-[var(--content-meta)] opacity-70">在 life/routines/ 下创建 md 文件即可添加</div>
					</div>
				) : (
					<div class="space-y-3">
						<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-amber-50 to-transparent p-3 dark:from-amber-900/20">
							<div>
								<div class="text-sm font-medium text-[var(--text-color)]">规划项目</div>
								<div class="text-xs text-[var(--content-meta)]">{Object.keys(routinesByTime).length} 个时间段</div>
							</div>
							<div class="text-xl font-bold text-amber-600 dark:text-amber-400">{routinesCount}</div>
						</div>
						{Object.entries(routinesByTime).slice(0, 3).map(([period, count]) => (
							<div class="flex items-center justify-between rounded-lg border border-[var(--line-divider)] bg-[var(--card-bg)] p-3">
								<span class="text-sm text-[var(--text-color)]">{period}</span>
								<span class="text-lg font-bold text-[var(--primary)]">{count}</span>
							</div>
						))}
					</div>
				)}
			</section>

			{/* 足迹地图 */}
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="flex items-center gap-2 text-lg font-bold text-[var(--text-color)]">
						<span>🗺️</span> 足迹地图
					</h2>
					<a href={url("/life/places/")} class="text-xs text-[var(--primary)] hover:underline">全部 →</a>
				</div>
				<div class="space-y-4">
					<div class="flex items-center justify-between">
						<div>
							<div class="text-sm font-medium text-[var(--text-color)]">到访城市</div>
							<div class="text-xs text-[var(--content-meta)]">去过的地方</div>
						</div>
						<div class="text-right">
							<div class="text-xl font-bold text-blue-600 dark:text-blue-400">{placesCount} <span class="text-sm font-normal">个</span></div>
							<div class="text-xs text-[var(--content-meta)]">覆盖 {uniqueProvinces} 省</div>
						</div>
					</div>
					{recentPlace && (
						<div class="rounded-lg border border-[var(--line-divider)] bg-gradient-to-r from-blue-50 to-transparent p-3 dark:from-blue-900/20">
							<div class="text-sm font-medium text-[var(--text-color)]">最近到访</div>
							<div class="mt-1 flex items-center justify-between">
								<div>
									<span class="font-bold">{recentPlace.data.city}</span>
									<span class="text-xs text-[var(--content-meta)]"> ({recentPlace.data.province})</span>
								</div>
								<div class="text-xs text-[var(--content-meta)]">
									{recentPlace.data.visitCount} 次到访
								</div>
							</div>
							{recentPlace.data.experience && (
								<p class="mt-2 text-xs leading-relaxed text-[var(--content-meta)] line-clamp-2">
									{recentPlace.data.experience}
								</p>
							)}
						</div>
					)}
				</div>
			</section>

			{/* 笔记本 */}
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="flex items-center gap-2 text-lg font-bold text-[var(--text-color)]">
						<span>📔</span> 笔记本
					</h2>
					<a href={url("/life/notebooks/")} class="text-xs text-[var(--primary)] hover:underline">全部 →</a>
				</div>
				<div class="space-y-3">
					<div class="flex items-center justify-between rounded-lg bg-gradient-to-r from-amber-50 to-transparent p-3 dark:from-amber-900/20">
						<div class="flex items-center gap-3">
							<span class="text-xl">📝</span>
							<div>
								<div class="text-sm font-medium text-[var(--text-color)]">总笔记数</div>
								<div class="text-xs text-[var(--content-meta)]">{notebookCount} 个笔记本</div>
							</div>
						</div>
						<div class="text-xl font-bold text-amber-600 dark:text-amber-400">{totalNotebookEntries}</div>
					</div>
					{recentNotebook && (
						<div class="rounded-lg border border-[var(--line-divider)] bg-[var(--card-bg)] p-3">
							<div class="text-sm font-medium text-[var(--text-color)]">{recentNotebook.data.name}</div>
							<div class="mt-1 flex items-center justify-between text-xs text-[var(--content-meta)]">
								<span>{recentNotebook.data.entries?.length || 0} 条记录</span>
								<span>{recentNotebook.data.updatedAt?.toISOString().split("T")[0]}</span>
							</div>
						</div>
					)}
				</div>
			</section>

			{/* 饮食记录 */}
			<section class="card-base rounded-[var(--radius-large)] p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="flex items-center gap-2 text-lg font-bold text-[var(--text-color)]">
						<span>🍎</span> 饮食记录
					</h2>
					<a href={url("/life/health/")} class="text-xs text-[var(--primary)] hover:underline">全部 →</a>
				</div>
				<div class="space-y-3">
					<div class="flex items-center justify-between">
						<div>
							<div class="text-sm font-medium text-[var(--text-color)]">记录天数</div>
							<div class="text-xs text-[var(--content-meta)]">持续记录</div>
						</div>
						<div class="text-xl font-bold text-orange-600 dark:text-orange-400">{foodCount} <span class="text-sm font-normal">天</span></div>
					</div>
					<div class="flex items-center justify-between">
						<div>
							<div class="text-sm font-medium text-[var(--text-color)]">本月记录</div>
							<div class="text-xs text-[var(--content-meta)]">饮食追踪</div>
						</div>
						<div class="text-xl font-bold text-orange-500">{thisMonthFoodDays} <span class="text-sm font-normal">天</span></div>
					</div>
					{sortedFood[0] && (
						<div class="mt-3 rounded-lg border border-[var(--line-divider)] bg-gradient-to-r from-orange-50 to-transparent p-3 dark:from-orange-900/20">
							<div class="text-xs font-medium text-[var(--text-color)]">最新记录</div>
							<div class="mt-2 text-xs text-[var(--content-meta)]">
								{sortedFood[0].data.allowedFoods?.length || 0} 种推荐食物，
								{sortedFood[0].data.avoidFoods?.length || 0} 种避免食物
							</div>
						</div>
					)}
				</div>
			</section>
		</div>

		{/* 最近动态时间线 */}
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-[var(--text-color)]">
				<span class="rounded-lg bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">🕐</span>
				最近动态
			</h2>
			<div class="space-y-3">
				{recentUpdates.length === 0 ? (
					<div class="py-8 text-center text-sm text-[var(--content-meta)]">
						暂无动态，开始记录你的生活吧！
					</div>
				) : (
					<div class="relative">
						{/* 时间线竖线 */}
						<div class="absolute left-[1.125rem] top-2 bottom-2 w-0.5 bg-gradient-to-b from-[var(--primary)]/30 via-[var(--primary)]/20 to-transparent"></div>
						{recentUpdates.map((update, index) => (
							<div class="relative flex gap-3">
								<div class="z-10 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--card-bg)] shadow-lg ring-2 ring-[var(--primary)]/20 text-base">
									{update.icon}
								</div>
								<div class="flex-1 rounded-lg border border-[var(--line-divider)] bg-[var(--card-bg)] p-4 transition-all hover:border-[var(--primary)]/30 hover:shadow-md">
									<div class="mb-1 flex items-center justify-between">
										<span class="text-sm font-bold text-[var(--primary)]">{update.type}</span>
										<span class="text-xs text-[var(--content-meta)]">
											{update.date instanceof Date ? update.date.toISOString().split("T")[0] : "未知日期"}
										</span>
									</div>
									<p class="text-sm leading-relaxed text-[var(--text-color)]">{update.detail}</p>
								</div>
							</div>
						))}
					</div>
				)}
			</div>
		</section>
	</div>
</MainGridLayout>

<style>
	.life-page {
		--life-border: color-mix(in srgb, var(--line-divider) 86%, transparent);
	}

	.life-section {
		border: 1px solid var(--life-border);
		box-shadow: 0 10px 30px rgb(0 0 0 / 6%);
		background: color-mix(in srgb, var(--card-bg) 92%, transparent);
	}

	.stat-card {
		position: relative;
		overflow: hidden;
		transition: all 0.2s ease-out;
	}

	.stat-card:hover {
		transform: translateY(-2px);
	}

	.stat-card:hover .absolute {
		opacity: 1;
	}

	.plan-item {
		margin-bottom: 0.75rem;
	}

	.plan-item:last-child {
		margin-bottom: 0;
	}

	/* 隐藏滚动条但保持滚动功能 */
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* 深色模式优化 */
	:global(html.dark) .life-section {
		box-shadow: 0 10px 26px rgb(0 0 0 / 28%);
	}

	:global(html.dark) .stat-card {
		background: color-mix(in srgb, var(--card-bg) 84%, #000);
	}
</style>
