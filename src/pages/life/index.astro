---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

const allLifeEntries = await getCollection("life");
const isIn = (entryId, folder) => entryId.replace(/\\/g, "/").startsWith(folder + "/");

const routinesRaw = await getCollection("routines");
const routinesFiltered = routinesRaw.filter(e => !e.id.toLowerCase().includes("readme"));
const routinesData = await Promise.all(routinesFiltered.map(async e => {
  const bodyText = e.body ? e.body.split("\n").filter(l => !l.trim().match(/^-{3}$/)).join("\n").trim() : "";
  return {
    id: e.id, type: "规划", icon: undefined, emoji: e.data.icon,
    color: e.data.color || "#06b6d4", bgColor: "rgba(6, 182, 212, 0.1)",
    date: e.data.updatedAt, name: e.data.name || "规划",
    time: e.data.time, description: e.data.description, body: bodyText,
    href: "/life/routines/",
  };
}));

const placesData = allLifeEntries
  .filter(e => isIn(e.id, "places") && !e.id.toLowerCase().includes("readme"))
  .map(e => ({
    id: e.id, type: "足迹", icon: "material-symbols:location-on-outline",
    color: "#10b981", bgColor: "rgba(16, 185, 129, 0.1)",
    date: e.data.date, province: e.data.province, city: e.data.city,
    district: e.data.district, visitCount: e.data.visitCount || 1,
    experience: e.data.experience, href: "/life/places/",
  }));

const notebooksRaw = await getCollection("notebooks");

// 首先收集所有笔记本文件夹的名称映射
const notebookNameMap = new Map();
notebooksRaw.forEach(entry => {
  const normalizedId = entry.id.replace(/\\/g, "/");
  // 匹配 _index 文件来获取笔记本名称
  const isIndexFile = normalizedId.match(/^([^/]+)\/(_index|_index\.md|_index\.json)$/);
  if (isIndexFile) {
    const folderName = isIndexFile[1];
    notebookNameMap.set(folderName, entry.data.name || folderName);
  }
});

const notebookEntries = notebooksRaw
  .filter(e => { const id = e.id.replace(/\\/g, "/"); return !id.endsWith("/_index"); })
  .sort((a, b) => { const aT = a.data.date instanceof Date ? a.data.date.getTime() : 0; const bT = b.data.date instanceof Date ? b.data.date.getTime() : 0; return bT - aT; });

const notebookData = notebookEntries.map(e => {
  const normalizedId = e.id.replace(/\\/g, "/");
  const folderName = normalizedId.split("/")[0];
  const notebookName = notebookNameMap.get(folderName) || folderName;
  return {
    id: e.id,
    notebookName,  // 笔记本名称，如"我的宝宝"
    type: "笔记",
    icon: "material-symbols:edit-note",
    color: "#ec4899",
    bgColor: "rgba(236, 72, 153, 0.1)",
    date: e.data.date,
    entryName: e.data.name || "未命名",  // 日记标题，如"我和宝宝"
    href: `/life/notebooks/${folderName}/`,
  };
});

const allItems = [...routinesData, ...placesData, ...notebookData]
  .filter(i => i.date instanceof Date && !Number.isNaN(i.date.getTime()))
  .sort((a, b) => { const aT = a.date instanceof Date ? a.date.getTime() : 0; const bT = b.date instanceof Date ? b.date.getTime() : 0; return bT - aT; });

function formatDate(date) { if (!date) return ""; const d = date instanceof Date ? date : new Date(String(date)); if (Number.isNaN(d.getTime())) return ""; return d.toISOString().split("T")[0]; }
function formatTimeAgo(date) { const now = new Date(); const diff = now.getTime() - date.getTime(); const mins = Math.floor(diff / 60000); const hrs = Math.floor(diff / 3600000); const days = Math.floor(diff / 86400000); if (mins < 1) return "刚刚"; if (mins < 60) return mins + " 分钟前"; if (hrs < 24) return hrs + " 小时前"; if (days < 30) return days + " 天前"; return formatDate(date); }

const navItems = [
  { label: "笔记本", icon: "material-symbols:book-outline", href: "/life/notebooks/", color: "#ec4899" },
  { label: "规划", icon: "material-symbols:schedule-outline", href: "/life/routines/", color: "#06b6d4" },
  { label: "足迹", icon: "material-symbols:location-on-outline", href: "/life/places/", color: "#10b981" },
];

---

<MainGridLayout title="生活" description="用心记录每一天">
  <div class="life-container">
    <div class="nav-tabs-wrapper" id="life-nav-wrapper">
      <div class="nav-container">
        <!-- 左侧固定的"生活"按钮 -->
        <a href={url("/life/")} class="nav-tab nav-tab-home" data-category-name="生活">
          <Icon name="material-symbols:favorite" class="tab-icon" />
          <span class="tab-label">生活</span>
        </a>
        <!-- 右侧可滚动区域 -->
        <div class="nav-tabs-scroll" id="life-nav-tabs-scroll">
          <div class="nav-tabs" id="life-nav-tabs">
            {navItems.map(item => (
              <a
                href={url(item.href)}
                class="nav-tab"
                data-category-name={item.label}
              >
                <Icon name={item.icon} class="tab-icon" />
                <span class="tab-label">{item.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
    <div class="life-feed">
      {allItems.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">
            <Icon name="material-symbols:sentiment-neutral-outline" />
          </div>
          <h3 class="empty-title">还没有生活记录</h3>
          <p class="empty-desc">选择一个模块，开始记录你的生活吧！</p>
        </div>
      ) : (
        allItems.map(item => {
          let summary = "";
          let subInfo = "";
          let typeLabel = item.type;

          if (item.type === "规划") {
            summary = item.name || "规划";
            subInfo = item.time || "";
          } else if (item.type === "足迹") {
            summary = [item.province, item.city, item.district].filter(Boolean).join(" ");
            subInfo = item.experience?.slice(0, 30) || `到访 ${item.visitCount} 次`;
          } else if (item.type === "笔记") {
            summary = item.entryName || "未命名";
            subInfo = "";
          }

          return (
            <a href={url(item.href)} class="life-card">
              <span class="life-dot" style={`background: ${item.color}`} aria-hidden="true" />
              <div class="life-card-body">
                <div class="life-card-top">
                  <span class="life-type-tag">{typeLabel}</span>
                  <time class="life-card-time" datetime={item.date instanceof Date ? item.date.toISOString() : String(item.date)}>
                    {formatTimeAgo(item.date)}
                  </time>
                </div>
                <div class="life-card-title">{summary}</div>
                {subInfo && (
                  <div class="life-card-sub">{subInfo}</div>
                )}
              </div>
              <span class="life-card-arrow">
                <Icon name="material-symbols:chevron-right-rounded" size={18} />
              </span>
            </a>
          );
        })
      )}
    </div>
  </div>
</MainGridLayout>

<style>
  .life-container { margin: 0 auto; padding: 0 4px 40px; }

  .nav-tabs-wrapper { margin-bottom: 16px; overflow: hidden; position: relative; }
  .nav-tabs-wrapper::before,
  .nav-tabs-wrapper::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 32px;
    z-index: 2; pointer-events: none; opacity: 0; transition: opacity 0.2s;
  }
  .nav-tabs-wrapper::before {
    left: 0;
    background: linear-gradient(to right, var(--card-bg), transparent);
  }
  .nav-tabs-wrapper::after {
    right: 0;
    background: linear-gradient(to left, var(--card-bg), transparent);
  }
  .nav-tabs-wrapper.show-left::before { opacity: 1; }
  .nav-tabs-wrapper.show-right::after { opacity: 1; }

  .nav-container {
    display: flex; align-items: center; gap: 0;
    background: var(--card-bg);
    border: 1px solid var(--line-divider);
    border-radius: 12px; padding: 6px;
  }

  .nav-tab-home { flex-shrink: 0; background: var(--card-bg); }
  .nav-tabs-scroll { flex: 1; min-width: 0; position: relative; overflow: hidden; }

  .nav-tabs {
    display: flex; gap: 6px; padding: 2px; overflow-x: auto;
    scroll-behavior: smooth; scrollbar-width: none;
    -ms-overflow-style: none; -webkit-overflow-scrolling: touch;
  }
  .nav-tabs::-webkit-scrollbar { display: none; }

  .nav-tab {
    flex-shrink: 0; display: flex; align-items: center; justify-content: center;
    gap: 6px; padding: 6px 14px; border-radius: 8px; font-size: 14px;
    font-weight: 500; text-decoration: none; transition: all 0.2s ease;
    white-space: nowrap; background: transparent;
    border: 1.5px solid var(--line-divider); color: var(--btn-content);
  }
  .nav-tab:hover { border-color: var(--primary); color: var(--primary); background: transparent; }
  .nav-tab[data-active] {
    background: var(--primary); border-color: var(--primary); color: white;
  }
  .nav-tab[data-active]:hover { opacity: 0.9; transform: none; box-shadow: none; }
  .nav-tab:active { transform: scale(0.98); }
  .tab-icon { font-size: 18px; }

  /* ===== 博客流卡片 ===== */
  .life-feed {
    display: flex; flex-direction: column; gap: 8px;
  }

  .life-card {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 12px 16px;
    background: var(--card-bg);
    border: 1px solid var(--line-divider);
    border-radius: var(--radius-large);
    text-decoration: none; color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    position: relative;
  }
  .life-card:hover {
    border-color: color-mix(in srgb, var(--primary) 40%, transparent);
    box-shadow: 0 2px 12px rgba(0,0,0,.04);
    transform: translateX(2px);
  }

  /* 左侧小色点 */
  .life-dot {
    flex-shrink: 0; width: 8px; height: 8px; border-radius: 50%;
    margin-top: 6px; opacity: .65;
  }

  .life-card-body {
    flex: 1; min-width: 0;
    display: flex; flex-direction: column; gap: 3px;
  }

  /* 顶行：类型标签 + 时间 */
  .life-card-top {
    display: flex; align-items: center; gap: 10px; margin-bottom: 1px;
  }
  .life-type-tag {
    font-size: 11px; font-weight: 600; letter-spacing: .03em;
    color: var(--content-meta); text-transform: uppercase;
  }
  .life-card-time {
    font-size: 11px; color: var(--content-meta); opacity: .65;
  }

  /* 标题 */
  .life-card-title {
    font-size: 15px; font-weight: 600; color: var(--text-color);
    line-height: 1.45; word-break: break-word;
  }

  /* 摘要行 */
  .life-card-sub {
    font-size: 13px; color: var(--content-meta);
    line-height: 1.45; overflow: hidden; text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* 箭头 */
  .life-card-arrow {
    flex-shrink: 0; margin-top: 4px;
    color: var(--content-meta); opacity: 0; transition: all .2s ease;
  }
  .life-card:hover .life-card-arrow { opacity: .55; }

  /* 空状态 */
  .empty-state {
    text-align: center; padding: 48px 20px; background: var(--card-bg);
    border: 1px solid var(--line-divider); border-radius: var(--radius-large);
  }
  .empty-icon {
    width: 56px; height: 56px; margin: 0 auto 12px;
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-color); border-radius: 50%;
    color: var(--content-meta); font-size: 28px; opacity: .45;
  }
  .empty-title { font-size: 15px; font-weight: 600; color: var(--text-color); margin-bottom: 4px; }
  .empty-desc  { font-size: 13px; color: var(--content-meta); }

  /* 暗色模式微调 */
  :global(html.dark) .life-card:hover {
    box-shadow: 0 2px 16px rgba(0,0,0,.18);
  }

  /* ── 移动端 ── */
  @media (max-width: 768px) {
    .life-card { padding: 10px 14px; gap: 10px; }
    .life-card-title { font-size: 14px; }
    .life-card-sub { font-size: 12px; }
    .life-type-tag { font-size: 10px; }
    .life-card-time { font-size: 10px; }
  }
  @media (max-width: 480px) {
    .life-container { padding: 0 12px 32px; }
    .life-card-arrow { display: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', initNavTabs);
  document.addEventListener('astro:page-load', initNavTabs);

  function initNavTabs() {
    const wrapper = document.getElementById('life-nav-wrapper');
    const tabsScroll = document.getElementById('life-nav-tabs-scroll');
    const tabs = document.getElementById('life-nav-tabs');

    if (!wrapper || !tabsScroll || !tabs) return;
    if (tabs.dataset.initialized) return;
    tabs.dataset.initialized = 'true';

    // 获取整体容器
    const navContainer = tabsScroll.closest('.nav-container');

    // 高亮当前导航项
    function updateActiveNav() {
      const pathname = window.location.pathname;
      const navPills = tabs.querySelectorAll('.nav-tab:not(.nav-tab-home)');

      navPills.forEach(pill => {
        pill.removeAttribute('data-active');
        const href = pill.getAttribute('href');
        if (href && pathname.startsWith(href)) {
          pill.setAttribute('data-active', '');
        }
      });

      // 生活主页高亮
      const homeTab = tabs.querySelector('.nav-tab-home');
      if (homeTab) {
        homeTab.removeAttribute('data-active');
        if (pathname === '/life/' || pathname === '/life') {
          homeTab.setAttribute('data-active', '');
        }
      }
    }

    // 初始化高亮
    updateActiveNav();
    document.addEventListener('swup:contentReplaced', updateActiveNav);

    // 滚动到当前高亮的标签
    function scrollToActiveTab() {
      const activeTab = tabs.querySelector('.nav-tab[data-active]');
      if (activeTab) {
        const scrollLeft = activeTab.offsetLeft - tabsScroll.offsetLeft - (tabsScroll.clientWidth - activeTab.offsetWidth) / 2;
        tabs.scrollTo({ left: Math.max(0, scrollLeft), behavior: 'smooth' });
      }
    }

    // 高亮更新后滚动到当前标签
    const originalUpdateActiveNav = updateActiveNav;
    updateActiveNav = function() {
      originalUpdateActiveNav();
      scrollToActiveTab();
    };

    // 更新滚动阴影指示器
    function updateScrollIndicators() {
      const scrollLeft = tabs.scrollLeft;
      const scrollWidth = tabs.scrollWidth;
      const clientWidth = tabs.clientWidth;

      wrapper.classList.toggle('show-left', scrollLeft > 10);
      wrapper.classList.toggle('show-right', scrollLeft < scrollWidth - clientWidth - 10);
    }

    // 监听滚动
    tabs.addEventListener('scroll', updateScrollIndicators);
    window.addEventListener('resize', updateScrollIndicators);
    updateScrollIndicators();

    // 桌面端：鼠标悬停时滚轮水平滚动
    if (navContainer) {
      navContainer.addEventListener('mouseenter', () => {
        document.body.style.overflow = 'hidden';
      });

      navContainer.addEventListener('mouseleave', () => {
        document.body.style.overflow = '';
      });

      // 滚轮事件 - 水平滚动
      navContainer.addEventListener('wheel', (e) => {
        if (tabs.scrollWidth > tabs.clientWidth) {
          e.stopPropagation();
          tabs.scrollLeft += e.deltaY + e.deltaX;
          updateScrollIndicators();
        }
      }, { capture: true, passive: false });
    }

    // 移动端：触摸滑动
    let touchStartX = 0;
    let touchScrollLeft = 0;

    tabs.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].pageX;
      touchScrollLeft = tabs.scrollLeft;
    }, { passive: true });

    tabs.addEventListener('touchmove', (e) => {
      const touchX = e.touches[0].pageX;
      const walk = (touchStartX - touchX) * 1.5;
      tabs.scrollLeft = touchScrollLeft + walk;
      updateScrollIndicators();
    }, { passive: true });
  }
</script>
