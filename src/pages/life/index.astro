---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";
import { marked } from "marked";

const allLifeEntries = await getCollection("life");
const isIn = (entryId, folder) => entryId.replace(/\\/g, "/").startsWith(folder + "/");

const ideas = allLifeEntries
  .filter(e => isIn(e.id, "ideas") && !e.id.toLowerCase().includes("readme"))
  .map(e => ({
    id: e.id, type: "想法", icon: "material-symbols:lightbulb-outline",
    color: "#f59e0b", bgColor: "rgba(245, 158, 11, 0.1)",
    date: e.data.completedAt || e.data.createdAt,
    createdAt: e.data.createdAt, completedAt: e.data.completedAt,
    isCompleted: !!e.data.completedAt,
    content: e.data.content || "无内容",
    label: e.data.label, href: "/life/ideas/",
  }));

const workouts = await getCollection("lifeWorkout");
const workoutEntries = workouts.map(e => ({
  id: e.id, type: "运动", icon: "material-symbols:directions-run",
  color: "#3b82f6", bgColor: "rgba(59, 130, 246, 0.1)",
  date: e.data.date, workoutType: e.data.workoutType || "运动",
  runKm: e.data.runKm || 0, workoutMinutes: e.data.workoutMinutes || 0,
  stepsToday: e.data.stepsToday || 0, note: e.data.note, href: "/life/health/",
}));

const sleepEntries = await getCollection("lifeSleep");
const sleepData = sleepEntries.map(e => ({
  id: e.id, type: "睡眠", icon: "material-symbols:bedtime-outline",
  color: "#8b5cf6", bgColor: "rgba(139, 92, 246, 0.1)",
  date: e.data.date, sleepHours: e.data.sleepHours || 0,
  sleepQuality: e.data.sleepQuality || 3, sleepTime: e.data.sleepTime,
  wakeTime: e.data.wakeTime, dream: e.data.dream, note: e.data.note,
  href: "/life/health/",
}));

const foodEntries = await getCollection("lifeFood");
const foodData = foodEntries.map(e => ({
  id: e.id, type: "饮食", icon: "material-symbols:lunch-dining",
  color: "#f97316", bgColor: "rgba(249, 115, 22, 0.1)",
  date: e.data.date, name: e.data.name || "饮食记录",
  breakfast: e.data.breakfast, lunch: e.data.lunch, dinner: e.data.dinner,
  snack: e.data.snack, allowedFoods: e.data.allowedFoods || [],
  avoidFoods: e.data.avoidFoods || [], water: e.data.water,
  weight: e.data.weight, note: e.data.note, href: "/life/health/",
}));

const checkinEntries = await getCollection("checkin");
const checkinData = checkinEntries
  .filter(e => !e.id.toLowerCase().includes("readme"))
  .map(e => ({
    id: e.id, type: "打卡", icon: "material-symbols:check-circle-outline",
    color: "#84cc16", bgColor: "rgba(132, 204, 22, 0.1)",
    date: e.data.updatedAt || e.data.checkins?.[e.data.checkins.length - 1],
    updatedAt: e.data.updatedAt, name: e.data.name || "打卡",
    description: e.data.description, checkins: e.data.checkins || [],
    href: "/life/checkin/",
  }));

const routinesRaw = await getCollection("routines");
const routinesFiltered = routinesRaw.filter(e => !e.id.toLowerCase().includes("readme"));
const routinesData = await Promise.all(routinesFiltered.map(async e => {
  const bodyText = e.body ? e.body.split("\n").filter(l => !l.trim().match(/^-{3}$/)).join("\n").trim() : "";
  return {
    id: e.id, type: "规划", icon: undefined, emoji: e.data.icon,
    color: e.data.color || "#06b6d4", bgColor: "rgba(6, 182, 212, 0.1)",
    date: e.data.updatedAt, name: e.data.name || "规划",
    time: e.data.time, description: e.data.description, body: bodyText,
    href: "/life/routines/",
  };
}));

const placesData = allLifeEntries
  .filter(e => isIn(e.id, "places") && !e.id.toLowerCase().includes("readme"))
  .map(e => ({
    id: e.id, type: "足迹", icon: "material-symbols:location-on-outline",
    color: "#10b981", bgColor: "rgba(16, 185, 129, 0.1)",
    date: e.data.date, province: e.data.province, city: e.data.city,
    district: e.data.district, visitCount: e.data.visitCount || 1,
    experience: e.data.experience, href: "/life/places/",
  }));

const notebooksRaw = await getCollection("notebooks");
const notebookEntries = notebooksRaw
  .filter(e => { const id = e.id.replace(/\\/g, "/"); return !id.endsWith("/_index"); })
  .sort((a, b) => { const aT = a.data.date instanceof Date ? a.data.date.getTime() : 0; const bT = b.data.date instanceof Date ? b.data.date.getTime() : 0; return bT - aT; });

const notebookData = await Promise.all(notebookEntries.map(async e => {
  const bodyText = e.body ? e.body.split("\n").filter(l => !l.trim().match(/^-{3}$/)).join("\n").trim() : "";
  const normalizedId = e.id.replace(/\\/g, "/");
  const folderName = normalizedId.split("/")[0];
  return {
    id: e.id, type: "笔记", icon: "material-symbols:edit-note",
    color: "#ec4899", bgColor: "rgba(236, 72, 153, 0.1)",
    date: e.data.date, name: e.data.name || "未命名",
    summary: e.data.summary, tags: e.data.tags || [], body: bodyText,
    href: `/life/notebooks/${folderName}/`,
  };
}));

const allItems = [...ideas, ...workoutEntries, ...sleepData, ...foodData, ...checkinData, ...routinesData, ...placesData, ...notebookData]
  .filter(i => i.date instanceof Date && !Number.isNaN(i.date.getTime()))
  .sort((a, b) => { const aT = a.date instanceof Date ? a.date.getTime() : 0; const bT = b.date instanceof Date ? b.date.getTime() : 0; return bT - aT; });

function formatDate(date) { if (!date) return ""; const d = date instanceof Date ? date : new Date(String(date)); if (Number.isNaN(d.getTime())) return ""; return d.toISOString().split("T")[0]; }
function formatTimeAgo(date) { const now = new Date(); const diff = now.getTime() - date.getTime(); const mins = Math.floor(diff / 60000); const hrs = Math.floor(diff / 3600000); const days = Math.floor(diff / 86400000); if (mins < 1) return "刚刚"; if (mins < 60) return mins + " 分钟前"; if (hrs < 24) return hrs + " 小时前"; if (days < 30) return days + " 天前"; return formatDate(date); }

const navItems = [
  { label: "健康", icon: "material-symbols:favorite-outline", href: "/life/health/", color: "#3b82f6" },
  { label: "想法", icon: "material-symbols:lightbulb-outline", href: "/life/ideas/", color: "#f59e0b" },
  { label: "打卡", icon: "material-symbols:check-circle-outline", href: "/life/checkin/", color: "#84cc16" },
  { label: "规划", icon: "material-symbols:schedule-outline", href: "/life/routines/", color: "#06b6d4" },
  { label: "足迹", icon: "material-symbols:location-on-outline", href: "/life/places/", color: "#10b981" },
  { label: "笔记", icon: "material-symbols:book-outline", href: "/life/notebooks/", color: "#ec4899" },
];

const totalWorkouts = workoutEntries.length;
const totalRunKm = workoutEntries.reduce((acc, i) => acc + i.runKm, 0);
const totalIdeas = ideas.length;
const totalCheckins = checkinEntries.reduce((acc, i) => acc + (i.data?.checkins?.length || 0), 0);
---

<MainGridLayout title="生活" description="用心记录每一天">
  <div class="life-container">
    <div class="profile-card">
      <div class="profile-header">
        <div class="avatar-wrapper">
          <img src="https://re.0824.uk/zl/tx.webp" alt="头像" class="avatar-img" />
        </div>
        <div class="profile-info">
          <h1 class="profile-name">我的生活</h1>
          <p class="profile-bio">用心记录每一天，发现生活的美好</p>
        </div>
      </div>
      <div class="profile-stats">
        <div class="stat-item">
          <span class="stat-value">{totalWorkouts}</span>
          <span class="stat-label">运动</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value">{totalIdeas}</span>
          <span class="stat-label">想法</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value">{totalCheckins}</span>
          <span class="stat-label">打卡</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-value">{totalRunKm.toFixed(0)}</span>
          <span class="stat-label">km</span>
        </div>
      </div>
    </div>
    <div class="nav-tabs-wrapper">
      <div class="nav-tabs">
        {navItems.map(item => (
          <a href={url(item.href)} class="nav-tab">
            <Icon name={item.icon} class="tab-icon" style={`color: ${item.color}`} />
            <span class="tab-label">{item.label}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="life-feed">
      {allItems.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">
            <Icon name="material-symbols:sentiment-neutral-outline" />
          </div>
          <h3 class="empty-title">还没有生活记录</h3>
          <p class="empty-desc">选择一个模块，开始记录你的生活吧！</p>
        </div>
      ) : (
        allItems.map(item => {
          const cardStyle = `color: ${item.color}; background: ${item.bgColor}`;
          const iconStyle = `background: ${item.bgColor}`;
          const iconColorStyle = `color: ${item.color}`;
          const showCompleted = "isCompleted" in item;
          const showRunKm = "runKm" in item;
          const showSleepHours = "sleepHours" in item && !showRunKm;
          const showAvoidFoods = "avoidFoods" in item;
          const showCheckins = "checkins" in item && !showAvoidFoods;
          const showBodyTime = "body" in item && "time" in item;
          const showPlace = "province" in item && "city" in item && !("body" in item);
          const showSummary = "summary" in item && !("province" in item);
          return (
            <div class="life-card">
              <div class="card-icon" style={iconStyle}>
                {item.emoji ? (
                  <span class="emoji-icon">{item.emoji}</span>
                ) : (
                  <Icon name={item.icon} style={iconColorStyle} />
                )}
              </div>
              <div class="card-body">
                <div class="card-header">
                  <span class="card-type" style={cardStyle}>{item.type}</span>
                  <span class="card-time">{formatTimeAgo(item.date)}</span>
                  <a href={url(item.href)} class="card-link">
                    查看详情
                    <Icon name="material-symbols:chevron-right-rounded" class="link-icon" />
                  </a>
                </div>
                {showCompleted && (
                  <div class="card-content-full">
                    <div class="content-text">{item.content}</div>
                    <div class="content-meta-row">
                      <span class="meta-tag" style={cardStyle}>{item.isCompleted ? "已完成" : "待完成"}</span>
                      <span class="meta-date">创建: {formatDate(item.createdAt)}</span>
                    </div>
                  </div>
                )}
                {showRunKm && (
                  <div class="card-content-full">
                    <div class="content-title">{item.workoutType}</div>
                    <div class="content-grid">
                      <div class="grid-item">
                        <span class="grid-label">距离</span>
                        <span class="grid-value" style={iconColorStyle}>{item.runKm.toFixed(2)} km</span>
                      </div>
                      <div class="grid-item">
                        <span class="grid-label">时长</span>
                        <span class="grid-value">{item.workoutMinutes} 分钟</span>
                      </div>
                      <div class="grid-item">
                        <span class="grid-label">步数</span>
                        <span class="grid-value">{item.stepsToday}</span>
                      </div>
                    </div>
                    <div class="content-meta-row">
                      <span class="meta-date">{formatDate(item.date)}</span>
                    </div>
                  </div>
                )}
                {showSleepHours && (
                  <div class="card-content-full">
                    <div class="content-grid">
                      <div class="grid-item">
                        <span class="grid-label">睡眠时长</span>
                        <span class="grid-value" style={iconColorStyle}>{item.sleepHours} 小时</span>
                      </div>
                      <div class="grid-item">
                        <span class="grid-label">睡眠质量</span>
                        <span class="grid-value">{"★".repeat(item.sleepQuality)}{"☆".repeat(5 - item.sleepQuality)}</span>
                      </div>
                    </div>
                    <div class="content-meta-row">
                      <span class="meta-date">{formatDate(item.date)}</span>
                    </div>
                  </div>
                )}
                {showAvoidFoods && (
                  <div class="card-content-full">
                    <div class="food-summary">
                      {item.breakfast && <div class="food-meal"><span class="food-label">早餐</span><span class="food-value">{item.breakfast}</span></div>}
                      {item.lunch && <div class="food-meal"><span class="food-label">午餐</span><span class="food-value">{item.lunch}</span></div>}
                      {item.dinner && <div class="food-meal"><span class="food-label">晚餐</span><span class="food-value">{item.dinner}</span></div>}
                      {item.snack && <div class="food-meal"><span class="food-label">零食</span><span class="food-value">{item.snack}</span></div>}
                    </div>
                    {(item.allowedFoods?.length > 0 || item.avoidFoods?.length > 0 || item.water || item.weight) && (
                      <div class="content-meta-row">
                        {item.allowedFoods?.length > 0 && <span class="meta-tag" style="color: #22c55e; background: rgba(34, 197, 94, 0.1)">宜: {item.allowedFoods.join(", ")}</span>}
                        {item.avoidFoods?.length > 0 && <span class="meta-tag" style="color: #ef4444; background: rgba(239, 68, 68, 0.1)">忌: {item.avoidFoods.join(", ")}</span>}
                        {item.water && <span class="meta-date">饮水: {item.water}</span>}
                        {item.weight && <span class="meta-date">体重: {item.weight}</span>}
                      </div>
                    )}
                    {item.note && <div class="food-note">{item.note}</div>}
                    <div class="content-meta-row">
                      <span class="meta-date">{formatDate(item.date)}</span>
                    </div>
                  </div>
                )}
                {showCheckins && (
                  <div class="card-content-full">
                    <div class="content-title">{item.name}</div>
                    <div class="content-meta-row">
                      <span class="meta-stat">累计 <strong style={iconColorStyle}>{item.checkins.length}</strong> 天</span>
                    </div>
                  </div>
                )}
                {showBodyTime && (
                  <div class="card-content-full">
                    <div class="content-title">{item.name}</div>
                    <div class="content-meta-row">
                      {item.time && <span class="meta-item">时间: {item.time}</span>}
                      <span class="meta-date">{formatDate(item.date)}</span>
                    </div>
                    {item.body && (
                      <div class="notebook-content" set:html={marked.parse(item.body.slice(0, 300))} />
                    )}
                  </div>
                )}
                {showPlace && (
                  <div class="card-content-full">
                    <div class="content-title" style={iconColorStyle}>{item.province || "未知"}{item.city && " - " + item.city}</div>
                    <div class="content-meta-row">
                      <span class="meta-stat">到访 <strong style={iconColorStyle}>{item.visitCount}</strong> 次</span>
                      <span class="meta-date">{formatDate(item.date)}</span>
                    </div>
                  </div>
                )}
                {showSummary && (
                  <div class="card-content-full">
                    <div class="content-title">{item.name}</div>
                    <div class="content-meta-row">
                      <span class="meta-date">{formatDate(item.date)}</span>
                    </div>
                    {item.body && (
                      <div class="notebook-content" set:html={marked.parse(item.body.slice(0, 300))} />
                    )}
                  </div>
                )}
              </div>
            </div>
          );
        })
      )}
    </div>
  </div>
</MainGridLayout>

<style>
  .life-container { max-width: 720px; margin: 0 auto; padding: 0 16px 40px; }
  .profile-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 20px; margin-bottom: 16px; }
  .profile-header { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .avatar-wrapper { flex-shrink: 0; }
  .avatar-img { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; border: 2px solid #4a9eff; }
  .profile-info { flex: 1; min-width: 0; }
  .profile-name { font-size: 18px; font-weight: 700; color: var(--text-color); margin-bottom: 4px; }
  .profile-bio { font-size: 13px; color: var(--content-meta); }
  .profile-stats { display: flex; align-items: center; justify-content: center; gap: 20px; padding: 14px; background: var(--bg-color); border-radius: 12px; border: 1px solid var(--border); }
  .stat-item { display: flex; flex-direction: column; align-items: center; gap: 3px; }
  .stat-value { font-size: 18px; font-weight: 700; color: var(--primary); }
  .stat-label { font-size: 11px; color: var(--content-meta); }
  .stat-divider { width: 1px; height: 28px; background: var(--border); }
  .nav-tabs-wrapper { margin-bottom: 16px; overflow-x: auto; scrollbar-width: none; }
  .nav-tabs { display: flex; gap: 8px; padding: 4px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px; }
  .nav-tab { flex-shrink: 0; display: flex; align-items: center; gap: 6px; padding: 10px 16px; border-radius: 10px; color: var(--content-meta); font-size: 14px; font-weight: 500; text-decoration: none; transition: all 0.2s; white-space: nowrap; }
  .nav-tab:hover { background: var(--bg-color); color: var(--text-color); }
  .tab-icon { font-size: 18px; }
  .life-feed { display: flex; flex-direction: column; gap: 12px; }
  .life-card { display: flex; align-items: flex-start; gap: 16px; padding: 18px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; transition: all 0.2s ease; }
  .card-icon { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; flex-shrink: 0; font-size: 24px; }
  .emoji-icon { font-size: 24px; }
  .card-body { flex: 1; min-width: 0; }
  .card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
  .card-type { display: inline-flex; align-items: center; padding: 3px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
  .card-time { font-size: 12px; color: var(--content-meta); }
  .card-link { display: inline-flex; align-items: center; gap: 2px; margin-left: auto; padding: 4px 10px; border-radius: 6px; background: var(--bg-color); color: var(--content-meta); font-size: 12px; text-decoration: none; transition: all 0.2s; }
  .card-link:hover { background: var(--primary); color: white; }
  .link-icon { font-size: 14px; }
  .card-content-full { display: flex; flex-direction: column; gap: 8px; }
  .content-title { font-size: 18px; font-weight: 700; color: var(--text-color); line-height: 1.4; }
  .content-text { font-size: 15px; color: var(--text-color); line-height: 1.7; padding: 12px 14px; background: var(--bg-color); border-radius: 10px; border-left: 3px solid var(--primary); }
  .content-meta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .meta-tag { padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
  .meta-date { font-size: 13px; color: var(--content-meta); }
  .meta-item { font-size: 13px; color: var(--content-meta); }
  .meta-stat { font-size: 14px; color: var(--content-meta); }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 10px; }
  .grid-item { display: flex; flex-direction: column; gap: 2px; padding: 10px 12px; background: var(--bg-color); border-radius: 8px; }
  .grid-label { font-size: 11px; color: var(--content-meta); text-transform: uppercase; }
  .grid-value { font-size: 15px; font-weight: 600; color: var(--text-color); }
  .notebook-content { font-size: 14px; color: var(--text-color); line-height: 1.7; padding: 12px 14px; background: var(--bg-color); border-radius: 10px; border-left: 3px solid #ec4899; word-break: break-word; }
  .notebook-content h1, .notebook-content h2, .notebook-content h3, .notebook-content h4 { margin: 0.5em 0; font-weight: 600; }
  .notebook-content h1 { font-size: 1.2em; }
  .notebook-content h2 { font-size: 1.1em; }
  .notebook-content h3, .notebook-content h4 { font-size: 1em; }
  .notebook-content p { margin: 0.5em 0; }
  .notebook-content ul, .notebook-content ol { margin: 0.5em 0; padding-left: 1.5em; }
  .notebook-content li { margin: 0.25em 0; }
  .notebook-content code { background: rgba(0,0,0,0.1); padding: 0.15em 0.3em; border-radius: 4px; font-size: 0.9em; font-family: var(--font-mono); }
  .notebook-content strong { font-weight: 600; }
  .notebook-content a { color: var(--primary); text-decoration: none; }
  .notebook-content a:hover { text-decoration: underline; }
  .food-summary { display: flex; flex-direction: column; gap: 6px; }
  .food-meal { display: flex; align-items: flex-start; gap: 8px; padding: 8px 10px; background: var(--bg-color); border-radius: 8px; }
  .food-label { flex-shrink: 0; min-width: 40px; font-size: 12px; font-weight: 600; color: var(--content-meta); }
  .food-value { font-size: 14px; color: var(--text-color); }
  .food-note { font-size: 13px; color: var(--content-meta); padding: 8px 0; font-style: italic; }
  .empty-state { text-align: center; padding: 60px 20px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; }
  .empty-icon { width: 64px; height: 64px; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; background: var(--bg-color); border-radius: 50%; color: var(--content-meta); font-size: 32px; opacity: 0.5; }
  .empty-title { font-size: 16px; font-weight: 600; color: var(--text-color); margin-bottom: 6px; }
  .empty-desc { font-size: 14px; color: var(--content-meta); }
  @media (max-width: 480px) {
    .life-container { padding: 0 12px 32px; }
    .profile-card { padding: 16px; border-radius: 12px; margin-bottom: 12px; }
    .avatar-img { width: 48px; height: 48px; }
    .profile-name { font-size: 16px; }
    .profile-stats { gap: 14px; padding: 12px; }
    .stat-value { font-size: 16px; }
    .life-card { padding: 14px; border-radius: 12px; gap: 12px; }
    .card-icon { width: 42px; height: 42px; font-size: 20px; border-radius: 10px; }
    .content-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
