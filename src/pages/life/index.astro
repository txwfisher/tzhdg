---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

// 辅助函数
const isIn = (entryId: string, folder: string) =>
	entryId.replace(/\\/g, "/").startsWith(`${folder}/`);

// 获取所有生活相关数据
const allLifeEntries = await getCollection("life");
const ideas = allLifeEntries.filter((entry) =>
	isIn(entry.id, "ideas") && !entry.id.toLowerCase().includes("readme")
);
const workoutEntries = await getCollection("lifeWorkout");
const sleepEntries = await getCollection("lifeSleep");
const foodEntries = await getCollection("lifeFood");
const notebooks = await getCollection("notebooks");
const checkinEntries = await getCollection("checkin");
const routinesEntries = await getCollection("routines");
const places = allLifeEntries.filter((entry) =>
	isIn(entry.id, "places") && !entry.id.toLowerCase().includes("readme")
);

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();

const isSameMonth = (date?: Date) => {
	if (!date) return false;
	return date.getFullYear() === currentYear && date.getMonth() === currentMonth;
};

const isSameYear = (date?: Date) => {
	if (!date) return false;
	return date.getFullYear() === currentYear;
};

// ========== 想法 ==========
const ideasDone = ideas.filter((item) => item.data.completedAt);
const ideasTodoCount = ideas.length - ideasDone.length;
const thisMonthDoneIdeas = ideasDone.filter((item) => isSameMonth(item.data.completedAt)).length;
const recentIdeas = [...ideas].sort((a, b) => {
	const aTime = a.data.completedAt?.getTime() || a.data.createdAt?.getTime() || 0;
	const bTime = b.data.completedAt?.getTime() || b.data.createdAt?.getTime() || 0;
	return bTime - aTime;
}).slice(0, 3);

// ========== 运动 ==========
const sortedWorkouts = [...workoutEntries].sort((a, b) => {
	const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
	const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
	return bTime - aTime;
});
const monthWorkout = sortedWorkouts.filter((item) => isSameMonth(item.data.date));
const totalRunKm = sortedWorkouts.reduce((acc, item) => acc + (item.data.runKm || 0), 0);
const monthRunKm = monthWorkout.reduce((acc, item) => acc + (item.data.runKm || 0), 0);
const recentWorkout = sortedWorkouts[0];

// ========== 睡眠 ==========
const sortedSleep = [...sleepEntries].sort((a, b) => {
	const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
	const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
	return bTime - aTime;
});
const monthSleep = sortedSleep.filter((item) => isSameMonth(item.data.date));
const sleepCount = sortedSleep.length;
const avgSleepHours = sleepCount > 0
	? sortedSleep.reduce((acc, item) => acc + (item.data.sleepHours || 0), 0) / sleepCount
	: 0;
const thisMonthAvgSleep = monthSleep.length > 0
	? monthSleep.reduce((acc, item) => acc + (item.data.sleepHours || 0), 0) / monthSleep.length
	: 0;

// ========== 饮食 ==========
const sortedFood = [...foodEntries].sort((a, b) => {
	const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
	const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
	return bTime - aTime;
});

// ========== 地点 ==========
const sortedPlaces = [...places].sort((a, b) => {
	const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
	const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
	return bTime - aTime;
});
const recentPlace = sortedPlaces[0];

// ========== 打卡 ==========
const checkinTotalCount = checkinEntries.reduce((acc, item) => acc + (item.data.checkins?.length || 0), 0);

// ========== 规划 ==========
const routinesCount = routinesEntries.length;

// ========== 笔记本 ==========
const notebookEntriesList = notebooks
	.filter((e) => {
		const id = e.id.replace(/\\/g, "/");
		return !id.endsWith("/_index") && !id.endsWith("/_index.md") && !id.endsWith("/_index.json");
	})
	.sort((a, b) => {
		const aTime = a.data.date instanceof Date ? a.data.date.getTime() : 0;
		const bTime = b.data.date instanceof Date ? b.data.date.getTime() : 0;
		return bTime - aTime;
	});
const recentNotebook = notebookEntriesList[0];

// ========== 最近动态时间线 ==========
const recentUpdates = [
	...(sortedWorkouts.slice(0, 2).map(e => ({ date: e.data.date, type: "运动", detail: e.data.workoutType || "锻炼", icon: "💪", color: "#3b82f6" }))),
	...(sortedSleep.slice(0, 2).map(e => ({ date: e.data.date, type: "睡眠", detail: `${e.data.sleepHours}小时`, icon: "😴", color: "#8b5cf6" }))),
	...(ideasDone.slice(0, 1).map(e => ({ date: e.data.completedAt, type: "想法", detail: e.data.content?.slice(0, 20) + (e.data.content?.length > 20 ? "..." : ""), icon: "💡", color: "#f59e0b" }))),
	...(notebookEntriesList.slice(0, 2).map(e => ({ date: e.data.date, type: "笔记", detail: e.data.name || "未命名", icon: "📔", color: "#ec4899" }))),
	...(sortedPlaces.slice(0, 1).map(e => ({ date: e.data.date, type: "足迹", detail: `${e.data.city || "未知"}${e.data.district ? " " + e.data.district : ""}`, icon: "📍", color: "#10b981" }))),
	...(routinesEntries.slice(0, 1).map(e => ({ date: e.data.updatedAt, type: "规划", detail: e.data.name || "日常安排", icon: "📋", color: "#06b6d4" }))),
	...(checkinEntries.slice(0, 1).map(e => ({ date: e.data.updatedAt, type: "打卡", detail: e.data.name || "打卡项", icon: "✅", color: "#84cc16" }))),
].sort((a, b) => {
	const aTime = a.date instanceof Date ? a.date.getTime() : 0;
	const bTime = b.date instanceof Date ? b.date.getTime() : 0;
	return bTime - aTime;
}).slice(0, 6);

// 导航卡片配置
const navCards = [
	{
		title: "健康",
		desc: "运动、睡眠、饮食",
		icon: "material-symbols:favorite-outline",
		href: "/life/health/",
		color: "#3b82f6",
		bgGradient: "linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%)",
		darkBgGradient: "linear-gradient(135deg, #1e3a5f 0%, #1e3a5f 100%)",
		stats: [
			{ label: "本月跑步", value: `${monthRunKm.toFixed(1)} km` },
			{ label: "平均睡眠", value: `${avgSleepHours.toFixed(1)} h` },
		],
	},
	{
		title: "想法",
		desc: "灵感与创意记录",
		icon: "material-symbols:lightbulb-outline",
		href: "/life/ideas/",
		color: "#f59e0b",
		bgGradient: "linear-gradient(135deg, #fef3c7 0%, #fffbeb 100%)",
		darkBgGradient: "linear-gradient(135deg, #451a03 0%, #451a03 100%)",
		stats: [
			{ label: "待完成", value: String(ideasTodoCount) },
			{ label: "本月完成", value: String(thisMonthDoneIdeas) },
		],
	},
	{
		title: "打卡",
		desc: "记录完成次数",
		icon: "material-symbols:check-circle-outline",
		href: "/life/checkin/",
		color: "#84cc16",
		bgGradient: "linear-gradient(135deg, #ecfccb 0%, #f7fee7 100%)",
		darkBgGradient: "linear-gradient(135deg, #1a2e05 0%, #1a2e05 100%)",
		stats: [
			{ label: "总打卡", value: String(checkinTotalCount) },
			{ label: "项目", value: String(checkinEntries.length) },
		],
	},
	{
		title: "规划",
		desc: "日常作息与安排",
		icon: "material-symbols:schedule-outline",
		href: "/life/routines/",
		color: "#06b6d4",
		bgGradient: "linear-gradient(135deg, #cffafe 0%, #ecfeff 100%)",
		darkBgGradient: "linear-gradient(135deg, #164e63 0%, #164e63 100%)",
		stats: [
			{ label: "规划数", value: String(routinesCount) },
		],
	},
	{
		title: "足迹",
		desc: "到过的地方",
		icon: "material-symbols:location-on-outline",
		href: "/life/places/",
		color: "#10b981",
		bgGradient: "linear-gradient(135deg, #d1fae5 0%, #ecfdf5 100%)",
		darkBgGradient: "linear-gradient(135deg, #064e3b 0%, #064e3b 100%)",
		stats: [
			{ label: "城市", value: String(sortedPlaces.length) },
			{ label: "最近", value: recentPlace?.data.city || "-" },
		],
	},
	{
		title: "笔记本",
		desc: "日记与随笔",
		icon: "material-symbols:book-outline",
		href: "/life/notebooks/",
		color: "#ec4899",
		bgGradient: "linear-gradient(135deg, #fce7f3 0%, #fdf2f8 100%)",
		darkBgGradient: "linear-gradient(135deg, #500724 0%, #500724 100%)",
		stats: [
			{ label: "条目", value: String(notebookEntriesList.length) },
			{ label: "最近", value: recentNotebook?.data.name?.slice(0, 6) || "-" },
		],
	},
];
---

<MainGridLayout title="生活" description="记录生活中的点点滴滴">
	<div class="life-container">
		<!-- 侧边装饰光晕 -->
		<div class="sidebar-glow left"></div>
		<div class="sidebar-glow right"></div>

		<!-- 顶部用户卡片 -->
		<div class="profile-card">
			<div class="profile-bg"></div>
			<div class="profile-content">
				<!-- 用户信息 -->
				<div class="profile-info">
					<p class="profile-bio">用心记录每一天，发现生活的美好</p>
				</div>

				<!-- 快速统计 -->
				<div class="profile-stats">
					<div class="stat-item">
						<span class="stat-value">{workoutEntries.length}</span>
						<span class="stat-label">运动</span>
					</div>
					<div class="stat-divider"></div>
					<div class="stat-item">
						<span class="stat-value">{ideas.length}</span>
						<span class="stat-label">想法</span>
					</div>
					<div class="stat-divider"></div>
					<div class="stat-item">
						<span class="stat-value">{checkinTotalCount}</span>
						<span class="stat-label">打卡</span>
					</div>
					<div class="stat-divider"></div>
					<div class="stat-item">
						<span class="stat-value">{totalRunKm.toFixed(0)}</span>
						<span class="stat-label">km</span>
					</div>
				</div>
			</div>
		</div>

		<!-- 导航网格 -->
		<div class="nav-grid">
			{navCards.map((card) => (
				<a href={url(card.href)} class="nav-card group">
					<div
						class="card-accent"
						style={`background: ${card.color};`}
					></div>
					<div class="card-inner">
						<div class="card-icon-wrap">
							<Icon name={card.icon} class="card-icon" />
						</div>
						<div class="card-text">
							<h3 class="card-title">{card.title}</h3>
							<p class="card-desc">{card.desc}</p>
						</div>
						<div class="card-stats">
							{card.stats.map((stat) => (
								<div class="mini-stat">
									<span class="mini-stat-value">{stat.value}</span>
									<span class="mini-stat-label">{stat.label}</span>
								</div>
							))}
						</div>
						<div class="card-arrow">
							<Icon name="material-symbols:chevron-right-rounded" class="arrow-icon" />
						</div>
					</div>
				</a>
			))}
		</div>

		<!-- 最近动态时间线 -->
		<div class="timeline-section">
			<div class="timeline-header">
				<div class="timeline-title-wrap">
					<Icon name="material-symbols:history" class="timeline-icon" />
					<h2 class="timeline-title">最近动态</h2>
				</div>
			</div>

			<div class="timeline-container">
				<div class="timeline-line"></div>

				{recentUpdates.length === 0 ? (
					<div class="empty-state">
						<div class="empty-icon">
							<Icon name="material-symbols:sentiment-neutral-outline" class="text-5xl" />
						</div>
						<h3 class="empty-title">还没有任何生活记录</h3>
						<p class="empty-desc">选择一个模块，开始记录你的生活吧！</p>
					</div>
				) : (
					<div class="timeline-feed">
						{recentUpdates.map((update, index) => (
							<div class="timeline-item" style={`--delay: ${index * 60}ms`}>
								<div class="timeline-dot" style={`background: ${update.color}; box-shadow: 0 0 0 4px ${update.color}20;`}>
									<span class="dot-icon">{update.icon}</span>
								</div>
								<div class="timeline-card">
									<div class="timeline-card-header">
										<span class="timeline-type" style={`color: ${update.color};`}>{update.type}</span>
										<span class="timeline-date">
											{update.date instanceof Date ? update.date.toISOString().split("T")[0] : "未知日期"}
										</span>
									</div>
									<p class="timeline-detail">{update.detail}</p>
								</div>
							</div>
						))}
					</div>
				)}
			</div>
		</div>

		<!-- 健康快速概览（精简版） -->
		{(workoutEntries.length > 0 || sleepEntries.length > 0 || foodEntries.length > 0) && (
			<div class="quick-overview">
				<div class="overview-header">
					<Icon name="material-symbols:widgets-outline" class="overview-icon" />
					<h2 class="overview-title">本月概览</h2>
				</div>
				<div class="overview-grid">
					{workoutEntries.length > 0 && (
						<div class="overview-card workout">
							<div class="overview-card-icon">
								<Icon name="material-symbols:directions-run" class="text-2xl" />
							</div>
							<div class="overview-card-content">
								<div class="overview-card-value">{monthRunKm.toFixed(1)} <span>km</span></div>
								<div class="overview-card-label">本月跑步</div>
							</div>
							<div class="overview-card-sub">
								共 {monthWorkout.length} 次 · {totalRunKm.toFixed(0)} km 累计
							</div>
						</div>
					)}
					{sleepEntries.length > 0 && (
						<div class="overview-card sleep">
							<div class="overview-card-icon">
								<Icon name="material-symbols:bedtime-outline" class="text-2xl" />
							</div>
							<div class="overview-card-content">
								<div class="overview-card-value">{thisMonthAvgSleep > 0 ? thisMonthAvgSleep.toFixed(1) : avgSleepHours.toFixed(1)} <span>h</span></div>
								<div class="overview-card-label">平均睡眠</div>
							</div>
							<div class="overview-card-sub">
								{sleepEntries.length} 夜记录
							</div>
						</div>
					)}
					{foodEntries.length > 0 && (
						<div class="overview-card food">
							<div class="overview-card-icon">
								<Icon name="material-symbols:lunch-dining" class="text-2xl" />
							</div>
							<div class="overview-card-content">
								<div class="overview-card-value">{sortedFood.length}</div>
								<div class="overview-card-label">饮食记录</div>
							</div>
							<div class="overview-card-sub">
								本月 {sortedFood.filter(f => isSameMonth(f.data.date)).length} 条
							</div>
						</div>
					)}
					{recentWorkout && (
						<div class="overview-card recent">
							<div class="overview-card-icon">
								<Icon name="material-symbols:fitness-center" class="text-2xl" />
							</div>
							<div class="overview-card-content">
								<div class="overview-card-value" style="font-size: 1rem;">{recentWorkout.data.workoutType || "锻炼"}</div>
								<div class="overview-card-label">最近运动</div>
							</div>
							<div class="overview-card-sub">
								{recentWorkout.data.date instanceof Date ? recentWorkout.data.date.toISOString().split("T")[0] : ""}
							</div>
						</div>
					)}
				</div>
			</div>
		)}
	</div>
</MainGridLayout>

<script>
	// 悬停效果保持不变，移除页面加载时的动画逻辑
	// 因为内容应该在首次加载时就可见
</script>

<style>
	.life-container {
		position: relative;
		max-width: 720px;
		margin: 0 auto;
		padding: 0 16px 40px;
	}

	/* 侧边装饰光晕 */
	.sidebar-glow {
		position: fixed;
		top: 50%;
		transform: translateY(-50%);
		width: 400px;
		height: 400px;
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}

	.sidebar-glow.left {
		left: -200px;
		background: radial-gradient(circle, #10b981 0%, transparent 70%);
		opacity: 0.12;
	}

	.sidebar-glow.right {
		right: -200px;
		background: radial-gradient(circle, #ec4899 0%, transparent 70%);
		opacity: 0.08;
	}

	/* 用户卡片 */
	.profile-card {
		position: relative;
		background: transparent;
		border: none;
		border-radius: 24px;
		overflow: visible;
		margin-bottom: 20px;
		z-index: 1;
	}

	.profile-bg {
		display: none;
	}

	.profile-content {
		position: relative;
		padding: 28px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.avatar-wrapper {
		margin-bottom: 14px;
	}

	.avatar-img {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		object-fit: cover;
		border: 3px solid var(--card-bg);
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.12);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.avatar-img:hover {
		transform: scale(1.05);
		box-shadow: 0 10px 32px rgba(0, 0, 0, 0.18);
	}

	.profile-info {
		margin-bottom: 18px;
	}

	.profile-name {
		font-size: 22px;
		font-weight: 700;
		color: var(--text-color);
		margin-bottom: 6px;
	}

	.profile-bio {
		font-size: 14px;
		color: var(--content-meta);
	}

	.profile-stats {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 20px;
		padding: 14px 24px;
		background: var(--bg-color);
		border-radius: 16px;
		border: 1px solid var(--border);
	}

	.stat-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
	}

	.stat-value {
		font-size: 18px;
		font-weight: 700;
		color: var(--primary);
	}

	.stat-label {
		font-size: 11px;
		color: var(--content-meta);
	}

	.stat-divider {
		width: 1px;
		height: 28px;
		background: var(--border);
	}

	/* 导航网格 */
	.nav-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
		margin-bottom: 20px;
		z-index: 1;
		position: relative;
	}

	.nav-card {
		position: relative;
		display: flex;
		flex-direction: column;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 20px;
		overflow: hidden;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease, transform 0.4s ease;
	}

	.nav-card:hover {
		border-color: transparent;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
		transform: translateY(-3px);
	}

	.card-accent {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		opacity: 0.8;
	}

	.card-inner {
		padding: 18px 16px 16px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.card-icon-wrap {
		width: 42px;
		height: 42px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--bg-color);
		border-radius: 12px;
		margin-bottom: 12px;
		border: 1px solid var(--border);
		transition: all 0.3s ease;
	}

	.card-icon {
		font-size: 22px;
		color: var(--text-color);
		transition: color 0.3s;
	}

	.nav-card:hover .card-icon-wrap {
		background: var(--card-bg);
		border-color: transparent;
	}

	.card-text {
		margin-bottom: 12px;
	}

	.card-title {
		font-size: 15px;
		font-weight: 700;
		color: var(--text-color);
		margin-bottom: 3px;
		transition: color 0.3s;
	}

	.nav-card:hover .card-title {
		color: var(--primary);
	}

	.card-desc {
		font-size: 11px;
		color: var(--content-meta);
	}

	.card-stats {
		display: flex;
		gap: 12px;
		margin-bottom: 8px;
	}

	.mini-stat {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}

	.mini-stat-value {
		font-size: 14px;
		font-weight: 700;
		color: var(--text-color);
		line-height: 1;
	}

	.mini-stat-label {
		font-size: 10px;
		color: var(--content-meta);
	}

	.card-arrow {
		align-self: flex-end;
		margin-top: auto;
	}

	.arrow-icon {
		font-size: 18px;
		color: var(--content-meta);
		transition: all 0.3s ease;
	}

	.nav-card:hover .arrow-icon {
		transform: translateX(3px);
		color: var(--primary);
	}

	/* 时间线区域 */
