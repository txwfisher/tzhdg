---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

const navItems = [
  { label: "笔记本", icon: "material-symbols:book-outline", href: "/life/notebooks/", color: "#ec4899" },
  { label: "规划", icon: "material-symbols:schedule-outline", href: "/life/routines/", color: "#06b6d4" },
  { label: "想法", icon: "material-symbols:lightbulb-outline", href: "/life/ideas/", color: "#f59e0b" },
  { label: "足迹", icon: "material-symbols:location-on-outline", href: "/life/places/", color: "#10b981" },
  { label: "健康", icon: "material-symbols:favorite-outline", href: "/life/health/", color: "#3b82f6" },
  { label: "打卡", icon: "material-symbols:check-circle-outline", href: "/life/checkin/", color: "#84cc16" },
];

const lifeEntries = await getCollection("life");

const isIn = (entryId: string, folder: string) =>
	entryId.replace(/\\/g, "/").startsWith(`${folder}/`);

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();

const formatDate = (dateText?: string | Date) => {
	if (!dateText) return "未填写";
	const d = dateText instanceof Date ? dateText : new Date(dateText);
	if (Number.isNaN(d.getTime())) return "未填写";
	return d.toISOString().split("T")[0];
};

const isSameMonth = (dateText?: string | Date) => {
	if (!dateText) return false;
	const d = dateText instanceof Date ? dateText : new Date(dateText);
	if (Number.isNaN(d.getTime())) return false;
	return d.getFullYear() === currentYear && d.getMonth() === currentMonth;
};

const ideas = lifeEntries
	.filter((entry) => isIn(entry.id, "ideas"))
	.filter((entry) => !entry.id.toLowerCase().includes("readme"))
	.map((entry) => entry.data);

// 已完成：有 completedAt
const ideasDone = ideas
	.filter((item) => item.completedAt)
	.sort((a, b) => (b.completedAt || "").toString().localeCompare((a.completedAt || "").toString()));

// 待完成：没有 completedAt
const ideasTodo = ideas
	.filter((item) => !item.completedAt)
	.sort((a, b) => (b.createdAt || "").toString().localeCompare((a.createdAt || "").toString()));

const thisMonthIdeasDone = ideas.filter(
	(item) => item.completedAt && isSameMonth(item.completedAt)
).length;
const ideasCount = ideas.length;
const doneCount = ideasDone.length;
const todoCount = ideasTodo.length;
---

<MainGridLayout title="奇思妙想" description="随手记录的灵感与创意">
	<div class="life-page flex w-full flex-col gap-5">
		<a href="/life/" class="back-btn mb-2 inline-flex items-center gap-1 text-sm text-[var(--content-meta)] hover:text-[var(--primary)]">
			<span>←</span> 返回生活
		</a>
		<!-- 导航栏 -->
		<div class="nav-tabs-wrapper" id="life-nav-wrapper">
			<div class="nav-container">
				<a href={url("/life/")} class="nav-tab nav-tab-home" data-category-name="生活">
					<Icon name="material-symbols:favorite" class="tab-icon" />
					<span class="tab-label">生活</span>
				</a>
				<div class="nav-tabs-scroll" id="life-nav-tabs-scroll">
					<div class="nav-tabs" id="life-nav-tabs">
						{navItems.map(item => (
							<a href={url(item.href)} class="nav-tab" data-category-name={item.label}>
								<Icon name={item.icon} class="tab-icon" />
								<span class="tab-label">{item.label}</span>
							</a>
						))}
					</div>
				</div>
			</div>
		</div>
		<section class="life-section card-base rounded-[var(--radius-large)] p-6">
			<h1 class="mb-2 text-3xl font-bold text-[var(--primary)]">💡 奇思妙想</h1>
			<p class="text-sm text-[var(--content-meta)]">随手记录灵感、短句和可执行的创意想法。</p>

			<div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4">
				<div class="life-stat-card">
					<div class="text-xs text-[var(--content-meta)]">总想法</div>
					<div class="mt-1 text-xl font-bold">{ideasCount}</div>
				</div>
				<div class="life-stat-card">
					<div class="text-xs text-[var(--content-meta)]">已完成</div>
					<div class="mt-1 text-xl font-bold text-emerald-600 dark:text-emerald-400">{doneCount}</div>
				</div>
				<div class="life-stat-card">
					<div class="text-xs text-[var(--content-meta)]">待完成</div>
					<div class="mt-1 text-xl font-bold text-amber-600 dark:text-amber-400">{todoCount}</div>
				</div>
				<div class="life-stat-card">
					<div class="text-xs text-[var(--content-meta)]">本月完成</div>
					<div class="mt-1 text-xl font-bold">{thisMonthIdeasDone}</div>
				</div>
			</div>
		</section>

		<section class="life-section card-base rounded-[var(--radius-large)] p-6">
			<h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-[var(--text-color)]">
				<span class="rounded-lg bg-emerald-100 px-2 py-1 text-base dark:bg-emerald-900/30">✓</span>
				已完成
			</h2>
			<div class="space-y-3">
				{ideasDone.length === 0 ? (
					<div class="rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-6 text-center text-sm text-[var(--content-meta)]">
						暂无已完成的灵感
					</div>
				) : (
					ideasDone.map((item) => (
						<article class="life-data-item rounded-xl border border-emerald-200 bg-emerald-50 p-4 dark:border-emerald-800 dark:bg-emerald-900/20">
							<div class="font-medium leading-relaxed">{item.content}</div>
							<div class="mt-2 flex flex-wrap gap-3 text-xs text-[var(--content-meta)]">
								<span>记录：{formatDate(item.createdAt)}</span>
								<span>完成：{formatDate(item.completedAt)}</span>
								{item.label && <span>标签：{item.label}</span>}
							</div>
						</article>
					))
				)}
			</div>
		</section>

		<section class="life-section card-base rounded-[var(--radius-large)] p-6">
			<h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-[var(--text-color)]">
				<span class="rounded-lg bg-amber-100 px-2 py-1 text-base dark:bg-amber-900/30">○</span>
				待完成
			</h2>
			<div class="space-y-3">
				{ideasTodo.length === 0 ? (
					<div class="rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-6 text-center text-sm text-[var(--content-meta)]">
						暂无待完成的灵感，继续保持思考！
					</div>
				) : (
					ideasTodo.map((item) => (
						<article class="life-data-item rounded-xl border border-amber-200 bg-amber-50 p-4 dark:border-amber-800 dark:bg-amber-900/20">
							<div class="font-medium leading-relaxed">{item.content}</div>
							<div class="mt-2 flex flex-wrap gap-3 text-xs text-[var(--content-meta)]">
								<span>记录：{formatDate(item.createdAt)}</span>
								<span>状态：待完成</span>
								{item.label && <span>标签：{item.label}</span>}
							</div>
						</article>
					))
				)}
			</div>
		</section>
	</div>
</MainGridLayout>

<style>
	.life-page {
		--life-border: color-mix(in srgb, var(--line-divider) 86%, transparent);
	}

	.life-section {
		border: 1px solid var(--life-border);
		box-shadow: 0 10px 30px rgb(0 0 0 / 6%);
		background: color-mix(in srgb, var(--card-bg) 92%, transparent);
	}

	.life-stat-card {
		border: 1px solid var(--life-border);
		background:
			linear-gradient(140deg, color-mix(in srgb, var(--primary) 9%, transparent) 0%, transparent 45%),
			var(--card-bg);
		padding: 0.75rem;
		border-radius: var(--radius-base);
	}

	.life-stat-card > div:first-child {
		font-size: 0.75rem;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		opacity: 0.9;
	}

	.life-data-item {
		border-color: var(--life-border);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.life-data-item:hover {
		transform: translateY(-1px);
		box-shadow: 0 8px 24px rgb(0 0 0 / 7%);
	}

	:global(html.dark) .life-section {
		box-shadow: 0 10px 26px rgb(0 0 0 / 28%);
	}

	:global(html.dark) .life-stat-card {
		background:
			linear-gradient(140deg, color-mix(in srgb, var(--primary) 12%, transparent) 0%, transparent 46%),
			color-mix(in srgb, var(--card-bg) 84%, #000);
	}

	/* ========== 导航栏样式 ========== */
	.nav-tabs-wrapper {
		margin-bottom: 0;
		overflow: hidden;
		position: relative;
	}
	.nav-tabs-wrapper::before,
	.nav-tabs-wrapper::after {
		content: '';
		position: absolute;
		top: 0;
		bottom: 0;
		width: 32px;
		z-index: 2;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.2s;
	}
	.nav-tabs-wrapper::before {
		left: 0;
		background: linear-gradient(to right, var(--card-bg), transparent);
	}
	.nav-tabs-wrapper::after {
		right: 0;
		background: linear-gradient(to left, var(--card-bg), transparent);
	}
	.nav-tabs-wrapper.show-left::before { opacity: 1; }
	.nav-tabs-wrapper.show-right::after { opacity: 1; }

	.nav-container {
		display: flex;
		align-items: center;
		gap: 0;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		border-radius: 12px;
		padding: 6px;
	}

	.nav-tab-home {
		flex-shrink: 0;
		background: var(--card-bg);
	}

	.nav-tabs-scroll {
		flex: 1;
		min-width: 0;
		position: relative;
		overflow: hidden;
	}

	.nav-tabs {
		display: flex;
		gap: 6px;
		padding: 2px;
		overflow-x: auto;
		scroll-behavior: smooth;
		scrollbar-width: none;
		-ms-overflow-style: none;
		-webkit-overflow-scrolling: touch;
	}
	.nav-tabs::-webkit-scrollbar { display: none; }

	.nav-tab {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		padding: 6px 14px;
		border-radius: 8px;
		font-size: 14px;
		font-weight: 500;
		text-decoration: none;
		transition: all 0.2s ease;
		white-space: nowrap;
		background: transparent;
		border: 1.5px solid var(--line-divider);
		color: var(--btn-content);
	}
	.nav-tab:hover {
		border-color: var(--primary);
		color: var(--primary);
		background: transparent;
	}
	.nav-tab[data-active] {
		background: var(--primary);
		border-color: var(--primary);
		color: white;
	}
	.nav-tab[data-active]:hover {
		opacity: 0.9;
		transform: none;
		box-shadow: none;
	}
	.nav-tab:active {
		transform: scale(0.98);
	}
	.tab-icon { font-size: 18px; }

	@media (max-width: 480px) {
		.nav-tab {
			padding: 6px 10px;
			font-size: 13px;
		}
		.tab-icon { font-size: 16px; }
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', initNavTabs);
	document.addEventListener('astro:page-load', initNavTabs);

	function initNavTabs() {
		const wrapper = document.getElementById('life-nav-wrapper');
		const tabsScroll = document.getElementById('life-nav-tabs-scroll');
		const tabs = document.getElementById('life-nav-tabs');

		if (!wrapper || !tabsScroll || !tabs) return;
		if (tabs.dataset.initialized) return;
		tabs.dataset.initialized = 'true';

		const navContainer = tabsScroll.closest('.nav-container');

		function updateActiveNav() {
			const pathname = window.location.pathname;
			const navPills = tabs.querySelectorAll('.nav-tab:not(.nav-tab-home)');

			navPills.forEach(pill => {
				pill.removeAttribute('data-active');
				const href = pill.getAttribute('href');
				if (href && pathname.startsWith(href)) {
					pill.setAttribute('data-active', '');
				}
			});

			const homeTab = tabs.querySelector('.nav-tab-home');
			if (homeTab) {
				homeTab.removeAttribute('data-active');
				if (pathname === '/life/' || pathname === '/life') {
					homeTab.setAttribute('data-active', '');
				}
			}
		}

		updateActiveNav();
		document.addEventListener('swup:contentReplaced', updateActiveNav);

		function scrollToActiveTab() {
			const activeTab = tabs.querySelector('.nav-tab[data-active]');
			if (activeTab) {
				const scrollLeft = activeTab.offsetLeft - tabsScroll.offsetLeft - (tabsScroll.clientWidth - activeTab.offsetWidth) / 2;
				tabs.scrollTo({ left: Math.max(0, scrollLeft), behavior: 'smooth' });
			}
		}

		const originalUpdateActiveNav = updateActiveNav;
		updateActiveNav = function() {
			originalUpdateActiveNav();
			scrollToActiveTab();
		};

		function updateScrollIndicators() {
			const scrollLeft = tabs.scrollLeft;
			const scrollWidth = tabs.scrollWidth;
			const clientWidth = tabs.clientWidth;

			wrapper.classList.toggle('show-left', scrollLeft > 10);
			wrapper.classList.toggle('show-right', scrollLeft < scrollWidth - clientWidth - 10);
		}

		tabs.addEventListener('scroll', updateScrollIndicators);
		window.addEventListener('resize', updateScrollIndicators);
		updateScrollIndicators();

		if (navContainer) {
			navContainer.addEventListener('mouseenter', () => {
				document.body.style.overflow = 'hidden';
			});

			navContainer.addEventListener('mouseleave', () => {
				document.body.style.overflow = '';
			});

			navContainer.addEventListener('wheel', (e) => {
				if (tabs.scrollWidth > tabs.clientWidth) {
					e.stopPropagation();
					tabs.scrollLeft += e.deltaY + e.deltaX;
					updateScrollIndicators();
				}
			}, { capture: true, passive: false });
		}

		let touchStartX = 0;
		let touchScrollLeft = 0;

		tabs.addEventListener('touchstart', (e) => {
			touchStartX = e.touches[0].pageX;
			touchScrollLeft = tabs.scrollLeft;
		}, { passive: true });

		tabs.addEventListener('touchmove', (e) => {
			const touchX = e.touches[0].pageX;
			const walk = (touchStartX - touchX) * 1.5;
			tabs.scrollLeft = touchScrollLeft + walk;
			updateScrollIndicators();
		}, { passive: true });
	}
</script>
