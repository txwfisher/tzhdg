---
import { getCollection, getEntry, render } from "astro:content";
import Comment from "@components/comment/index.astro";
import Markdown from "@components/common/Markdown.astro";
import { Icon } from "astro-icon/components";
import Danmaku from "@/components/guestbook/Danmaku.astro";
import { commentConfig } from "@/config";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const guestbookPost = await getEntry("spec", "guestbook");

if (!guestbookPost) {
	throw new Error("guestbook page content not found");
}

const { Content } = await render(guestbookPost);

// 检查评论系统是否启用
const isCommentEnabled = commentConfig?.type && commentConfig.type !== "none";

// 获取弹幕数据
const danmuEntries = await getCollection("danmu");
const danmuComments = danmuEntries.map((entry) => ({
	nickname: entry.data.nickname,
	content: entry.body.trim(),
	time: entry.data.time,
}));
---

<MainGridLayout title="留言板" description="有什么想说的，留个言吧~">
  <div class="guestbook-container">
    <!-- 侧边装饰光晕 -->
    <div class="sidebar-glow left"></div>
    <div class="sidebar-glow right"></div>

    <!-- 顶部标题卡片 -->
    <div class="header-card">
      <a 
        href="/moments/" 
        class="back-link"
      >
        <Icon name="material-symbols:arrow-left-rounded" class="back-icon" />
        <span>返回动态</span>
      </a>

      <div class="header-main">
        <div class="header-icon">
          <Icon name="material-symbols:edit-note" class="icon" />
        </div>
        <div class="header-text">
          <h1 class="header-title">留言板</h1>
          <p class="header-desc">有什么想说的，留个言吧~</p>
        </div>
      </div>

      <!-- 统计信息 -->
      <div class="header-stats">
        <div class="stat-item">
          <span class="stat-value">{danmuComments.length}</span>
          <span class="stat-label">留言</span>
        </div>
      </div>

      <!-- 装饰元素 -->
      <div class="header-decoration">
        <div class="deco-circle circle-1"></div>
        <div class="deco-circle circle-2"></div>
        <div class="deco-circle circle-3"></div>
      </div>
    </div>

    <!-- 留言板说明卡片 -->
    <div class="content-card">
      <div class="card-inner">
        <Markdown class="guestbook-content">
          <Content />
        </Markdown>
      </div>
    </div>

    <!-- 弹幕留言展示 -->
    <Danmaku comments={danmuComments} />

    <!-- 评论区 -->
    <div class="comments-card">
      <div class="card-inner">
        <div class="comments-header">
          <div class="comments-title-wrap">
            <Icon name="material-symbols:chat-bubble-outline" class="comments-icon" />
            <h2 class="comments-title">留言列表</h2>
          </div>
          <span class="comments-hint">
            <Icon name="material-symbols:edit-rounded" class="hint-icon" />
            写下你的留言
          </span>
        </div>
        
        {isCommentEnabled ? (
          <Comment post={guestbookPost} customPath="/guestbook/" />
        ) : (
          <div class="no-comments">
            <div class="no-comments-icon">
              <Icon name="material-symbols:sentiment-neutral-outline" />
            </div>
            <p>评论系统未配置</p>
            <span class="no-comments-hint">请联系站长开启评论功能</span>
          </div>
        )}
      </div>
    </div>

    <!-- 底部装饰 -->
    <div class="footer-decoration">
      <div class="footer-line"></div>
      <span class="footer-text">感谢每一位访客的留言</span>
      <div class="footer-line"></div>
    </div>
  </div>
</MainGridLayout>

<style>
  .guestbook-container {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 16px 40px;
  }

  /* 侧边装饰光晕 */
  .sidebar-glow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 400px;
    height: 400px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .sidebar-glow.left {
    left: -200px;
    background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
    opacity: 0.1;
  }

  .sidebar-glow.right {
    right: -200px;
    background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
    opacity: 0.06;
  }

  /* 顶部标题卡片 */
  .header-card {
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 24px 28px;
    margin-bottom: 20px;
    overflow: hidden;
    z-index: 1;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--content-meta);
    font-size: 14px;
    margin-bottom: 16px;
    transition: color 0.2s;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--primary);
  }

  .back-icon {
    font-size: 20px;
    transition: transform 0.2s;
  }

  .back-link:hover .back-icon {
    transform: translateX(-3px);
  }

  .header-main {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--primary)/15, var(--primary)/5);
    border-radius: 16px;
    flex-shrink: 0;
  }

  .header-icon .icon {
    font-size: 28px;
    color: var(--primary);
  }

  .header-text {
    flex: 1;
  }

  .header-title {
    font-size: 26px;
    font-weight: 700;
    color: var(--text-color);
    margin-bottom: 4px;
  }

  .header-desc {
    font-size: 14px;
    color: var(--content-meta);
  }

  /* 统计信息 */
  .header-stats {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px dashed var(--border);
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .stat-value {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 16px;
    font-weight: 600;
    color: var(--text-color);
  }

  .stat-label {
    font-size: 12px;
    color: var(--content-meta);
  }

  /* 装饰圆圈 */
  .header-decoration {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 120px;
    height: 120px;
    pointer-events: none;
  }

  .deco-circle {
    position: absolute;
    border-radius: 50%;
    background: var(--primary);
  }

  .circle-1 {
    width: 80px;
    height: 80px;
    top: 0;
    right: 20px;
    opacity: 0.05;
  }

  .circle-2 {
    width: 50px;
    height: 50px;
    top: 40px;
    right: 60px;
    opacity: 0.07;
  }

  .circle-3 {
    width: 30px;
    height: 30px;
    top: 80px;
    right: 30px;
    opacity: 0.09;
  }

  /* 内容卡片 */
  .content-card {
    margin-bottom: 20px;
    z-index: 1;
    position: relative;
  }

  .card-inner {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 24px;
    transition: all 0.3s ease;
  }

  .content-card .card-inner:hover {
    border-color: var(--primary)/20;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }

  .guestbook-content :global(h1),
  .guestbook-content :global(h2),
  .guestbook-content :global(h3) {
    color: var(--text-color);
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .guestbook-content :global(p) {
    color: var(--content-text);
    line-height: 1.8;
    margin-bottom: 1em;
  }

  .guestbook-content :global(p:last-child) {
    margin-bottom: 0;
  }

  /* 评论区卡片 */
  .comments-card {
    z-index: 1;
    position: relative;
  }

  .comments-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .comments-title-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .comments-icon {
    font-size: 22px;
    color: var(--primary);
  }

  .comments-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-color);
  }

  .comments-hint {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--content-meta);
    padding: 6px 12px;
    background: var(--bg-color);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.2s;
  }

  .comments-hint:hover {
    background: var(--primary)/5;
    border-color: var(--primary)/30;
    color: var(--primary);
  }

  .hint-icon {
    font-size: 14px;
  }

  .no-comments {
    text-align: center;
    padding: 48px 24px;
    color: var(--content-meta);
  }

  .no-comments-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-color);
    border-radius: 50%;
    font-size: 36px;
    opacity: 0.5;
  }

  .no-comments p {
    font-size: 15px;
    margin-bottom: 4px;
  }

  .no-comments-hint {
    font-size: 12px;
    opacity: 0.7;
  }

  /* 底部装饰 */
  .footer-decoration {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 40px;
    padding: 20px 0;
  }

  .footer-line {
    flex: 1;
    max-width: 100px;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border), transparent);
  }

  .footer-text {
    font-size: 12px;
    color: var(--content-meta);
    white-space: nowrap;
  }

  /* 响应式 */
  @media (max-width: 640px) {
    .header-card {
      padding: 20px;
      border-radius: 20px;
    }

    .header-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
    }

    .header-icon .icon {
      font-size: 24px;
    }

    .header-title {
      font-size: 22px;
    }

    .card-inner {
      padding: 20px;
      border-radius: 16px;
    }

    .comments-hint span:not(.hint-icon) {
      display: none;
    }

    .header-stats {
      gap: 16px;
    }

    .stat-label {
      display: none;
    }
  }
</style>
