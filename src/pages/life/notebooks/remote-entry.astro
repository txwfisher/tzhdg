---
import Comment from "@components/comment/index.astro";
import { externalNotebooksConfig } from "@/config/externalNotebooksConfig";
// 远程笔记阅读页 - 从 Gist 加载单篇笔记内容，样式与本地笔记完全一致
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="云端笔记">
	<div class="diary-detail-page">
		<article class="diary-paper">
			<a id="back-link" href="/life/notebooks/" class="diary-paper-back">
				<span>←</span>
				<span>返回笔记本</span>
			</a>

			<h1 id="entry-title" class="diary-paper-title">加载中...</h1>

			<div id="entry-content" class="diary-paper-content custom-md"></div>

			<div class="diary-paper-footer">
				<div id="entry-tags" class="diary-tags"></div>
				<span id="entry-date" class="diary-date-final"></span>
			</div>
		</article>

		<Comment customPath="/life/notebooks/remote-entry/" />
	</div>

	<script is:inline
		data-gists={JSON.stringify(externalNotebooksConfig.notebookGists || {})}>
		(function() {
			var _s = document.currentScript;
			var GISTS = JSON.parse(_s.getAttribute("data-gists") || "{}");

			var params = new URLSearchParams(window.location.search);
			var NOTEBOOK = params.get("nb");
			var ENTRY_ID = params.get("id");

			if (!NOTEBOOK || !ENTRY_ID) {
				document.getElementById("entry-title").textContent = "无效的笔记链接";
				return;
			}

			var GIST_ID = GISTS[NOTEBOOK];
			if (!GIST_ID) {
				document.getElementById("entry-title").textContent = "该笔记本未配置 Gist";
				return;
			}

			// 设置返回链接
			document.getElementById("back-link").href = "/life/notebooks/" + encodeURIComponent(NOTEBOOK) + "/";
			document.getElementById("back-link").querySelector("span:last-child").textContent = "返回 " + NOTEBOOK;

			// 从 Gist 加载笔记
			var rawUrl = "https://gist.githubusercontent.com/raw/" + GIST_ID + "?t=" + Date.now();

			fetch(rawUrl)
				.then(function(r) { if (!r.ok) throw new Error("加载失败"); return r.text(); })
				.then(function(text) {
					var entries = JSON.parse(text);
					var entry = entries.find(function(e) { return e.id === ENTRY_ID; });
					if (!entry) {
						document.getElementById("entry-title").textContent = "未找到该笔记";
						return;
					}

					document.title = (entry.title || "笔记") + " - " + NOTEBOOK;
					document.getElementById("entry-title").textContent = entry.title || "无标题";

					// 渲染 Markdown
					var md = entry.content || "";
					var html = renderMarkdown(md);
					document.getElementById("entry-content").innerHTML = html;

					// 标签
					var tagsEl = document.getElementById("entry-tags");
					tagsEl.innerHTML = "";
					(entry.tags || []).forEach(function(tag) {
						var span = document.createElement("span");
						span.className = "diary-tag";
						span.textContent = "#" + tag;
						tagsEl.appendChild(span);
					});

					// 日期
					var date = entry.date || "";
					if (date) {
						document.getElementById("entry-date").textContent = new Date(date).toLocaleDateString("zh-CN", {
							year: "numeric", month: "long", day: "numeric", weekday: "long"
						});
					}
				})
				.catch(function(e) {
					document.getElementById("entry-title").textContent = "加载失败";
					document.getElementById("entry-content").innerHTML = '<p style="color:var(--content-meta);">' + e.message + '</p>';
				});

			function esc(t) { var d = document.createElement("div"); d.textContent = t; return d.innerHTML; }

			function renderMarkdown(md) {
				var html = md;
				// 代码块
				html = html.replace(/```(\w*)\n([\s\S]*?)```/g, function(m, l, c) {
					return '<pre><code>' + esc(c) + '</code></pre>';
				});
				// 行内代码
				html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
				// 标题
				html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
				html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
				html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
				// 粗体、斜体
				html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
				html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
				// 图片、链接
				html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1">');
				html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank">$1</a>');
				// 引用
				html = html.replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>');
				// 列表
				html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
				html = html.replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>');
				// 分割线
				html = html.replace(/^---$/gm, '<hr>');
				// 段落
				html = html.replace(/\n\n/g, '</p><p>');
				html = html.replace(/\n/g, '<br>');
				html = '<p>' + html + '</p>';
				// 清理
				html = html.replace(/<p>\s*<\/p>/g, '');
				html = html.replace(/<p>\s*(<h[1-6]>)/g, '$1');
				html = html.replace(/(<\/h[1-6]>)\s*<\/p>/g, '$1');
				html = html.replace(/<p>\s*(<pre>)/g, '$1');
				html = html.replace(/(<\/pre>)\s*<\/p>/g, '$1');
				html = html.replace(/<p>\s*(<ul>)/g, '$1');
				html = html.replace(/(<\/ul>)\s*<\/p>/g, '$1');
				html = html.replace(/<p>\s*(<blockquote>)/g, '$1');
				html = html.replace(/(<\/blockquote>)\s*<\/p>/g, '$1');
				html = html.replace(/<p>\s*(<hr>)/g, '$1');
				html = html.replace(/(<hr>)\s*<\/p>/g, '$1');
				return html;
			}
		})();
	</script>
</MainGridLayout>

<style>
	.diary-detail-page { max-width: 48rem; margin: 0 auto; }
	.diary-paper { background: var(--page-bg); color: var(--deep-text); padding: 2rem 0.75rem; }
	@media (min-width: 768px) { .diary-paper { padding: 2rem 1.25rem; } }

	.diary-paper-back {
		display: inline-flex; align-items: center; gap: 0.4rem;
		font-size: 0.85rem; color: var(--content-meta); text-decoration: none;
		margin-bottom: 2rem; transition: color 0.2s;
	}
	.diary-paper-back:hover { color: var(--primary); }

	.diary-paper-title { font-size: 1.75rem; font-weight: 700; color: var(--deep-text); margin: 0 0 2rem; line-height: 1.4; }

	.diary-paper-content { font-size: 1rem; line-height: 1.9; }
	.diary-paper-content :global(p) { margin: 0 0 1.25rem; }
	.diary-paper-content :global(h1) { font-size: 1.5rem; font-weight: 700; margin: 2rem 0 1rem; }
	.diary-paper-content :global(h2) { font-size: 1.25rem; font-weight: 700; margin: 1.75rem 0 0.75rem; }
	.diary-paper-content :global(h3) { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
	.diary-paper-content :global(blockquote) { border-left: 3px solid var(--primary); padding-left: 1em; margin: 0 0 1.25rem; color: var(--content-meta); }
	.diary-paper-content :global(pre) { background: var(--codeblock-bg, #f6f8fa); padding: 0.75em; overflow-x: auto; margin: 0 0 1.25rem; font-size: 0.875rem; }
	.diary-paper-content :global(code) { font-family: 'JetBrains Mono', monospace; font-size: 0.875em; }
	.diary-paper-content :global(pre code) { background: none; padding: 0; }
	.diary-paper-content :global(img) { max-width: 100%; border-radius: 0.5rem; margin: 0.5rem 0; }
	.diary-paper-content :global(a) { color: var(--primary); }
	.diary-paper-content :global(hr) { border: none; border-top: 1px solid var(--line-divider); margin: 2rem 0; }
	.diary-paper-content :global(ul), .diary-paper-content :global(ol) { padding-left: 1.5em; margin: 0 0 1.25rem; }
	.diary-paper-content :global(li) { margin-bottom: 0.25rem; line-height: 1.8; }
	.diary-paper-content :global(table) { width: 100%; border-collapse: collapse; margin: 0 0 1.25rem; }
	.diary-paper-content :global(th), .diary-paper-content :global(td) { border: 1px solid var(--line-divider); padding: 0.4em 0.6em; text-align: left; }
	.diary-paper-content :global(th) { background: var(--hover); font-weight: 600; }

	.diary-paper-footer {
		display: flex; align-items: flex-end; justify-content: space-between;
		margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--line-divider);
	}
	.diary-date-final { font-size: 0.85rem; color: var(--content-meta); text-align: right; font-style: italic; }
	.diary-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
	.diary-tag { padding: 0.25rem 0.75rem; background: var(--btn-regular-bg-hover); border-radius: 9999px; font-size: 0.75rem; color: var(--content-meta); }
</style>

