---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import type { ImageMetadata } from "astro";
import * as path from "node:path";

// 预加载笔记本文件夹内的封面图片
const notebookCoverFiles = import.meta.glob<ImageMetadata>(
	"../../content/life/notebooks/**/*.{jpg,jpeg,png,webp,avif,gif,svg}",
	{ import: "default" },
);

const allEntries = await getCollection("notebooks");

const sortByDateDesc = <T extends Record<string, unknown>>(list: T[], field: keyof T) =>
	[...list].sort((a, b) => {
		const aDate = a[field] instanceof Date ? a[field]!.getTime() : 0;
		const bDate = b[field] instanceof Date ? b[field]!.getTime() : 0;
		return bDate - aDate;
	});

	const notebooks = allEntries.map((entry) => {
		const normalizedId = entry.id.replace(/\\/g, "/");
		if (normalizedId === "readme" || normalizedId === "readme.md") {
			return null;
		}
		const isNotebookRoot = normalizedId.match(/^([^/]+)\/(_index|_index\.md|_index\.json)$/) || normalizedId.match(/^([^/]+)\/_index$/);

		if (!isNotebookRoot) {
			return null;
		}

		const folderName = isNotebookRoot[1];

		const folderEntries = allEntries.filter((item) => {
			const itemId = item.id.replace(/\\/g, "/");
			const isIndexFile = itemId === `${folderName}/_index` ||
			                    itemId === `${folderName}/_index.md` ||
			                    itemId === `${folderName}/_index.json`;
			return itemId.startsWith(`${folderName}/`) && !isIndexFile;
		});

		const sortedEntries = sortByDateDesc(folderEntries.map((e) => e.data), "date");
		const latestEntry = sortedEntries[0];

		return {
			id: entry.id,
			name: entry.data.name,
			cover: entry.data.cover,
			summary: entry.data.summary,
			entries: folderEntries.length,
			updatedAt: latestEntry?.date instanceof Date ? latestEntry.date : new Date(0),
			selfPath: `/life/notebooks/${folderName}/`,
			folderName,
		};
	}).filter(Boolean);

// 解析封面图：本地图片 → Astro ImageMetadata，URL → 直接使用
const notebooksWithCovers = await Promise.all(
	notebooks
		.filter((b) => b !== null)
		.map(async (book) => {
			let coverSrc: string | null = null;
			const rawCover = book.cover as string | undefined;
			if (rawCover) {
				if (rawCover.startsWith("http://") || rawCover.startsWith("https://")) {
					coverSrc = rawCover;
				} else {
					const imageKey = path
						.normalize(path.join("../../content/life/notebooks", book.folderName, rawCover))
						.replace(/\\/g, "/");
					const loader = notebookCoverFiles[imageKey];
					if (loader) {
						try {
							const img = await loader();
							coverSrc = img.src;
						} catch {
							coverSrc = null;
						}
					}
				}
			}
			return { ...book, coverSrc };
		}),
);

const sortedNotebooks = sortByDateDesc(notebooksWithCovers, "updatedAt");
---

<MainGridLayout title="笔记本" description="成长日记、学习复盘、灵感随笔">
	<div class="diary-page flex w-full flex-col gap-6">
		<!-- 笔记本网格 -->
		<section>
			{sortedNotebooks.length === 0 ? (
				<div class="diary-empty">
					<div class="text-6xl mb-4">📖</div>
					<h3 class="text-xl font-semibold mb-2 text-[var(--text-color)]">还没有日记本</h3>
					<p class="text-sm text-[var(--content-meta)]">开始记录你的第一篇日记吧！</p>
					<div class="mt-6 p-4 rounded-xl bg-[var(--btn-regular-bg)] text-left text-sm">
						<p class="text-[var(--text-color)] mb-2">创建步骤：</p>
						<ol class="text-[var(--content-meta)] space-y-1 list-decimal list-inside">
							<li>在 <code class="px-1 rounded bg-[var(--btn-regular-bg-hover)] font-mono">src/content/life/notebooks/</code> 下创建文件夹</li>
							<li>在文件夹内创建 <code class="px-1 rounded bg-[var(--btn-regular-bg-hover)] font-mono">_index.json</code> 文件</li>
							<li>在文件夹内创建 <code class="px-1 rounded bg-[var(--btn-regular-bg-hover)] font-mono">*.md</code> 文件作为日记条目</li>
						</ol>
					</div>
				</div>
			) : (
				<div class="diary-grid">
					{sortedNotebooks.map((book) => (
						<a
							href={book.selfPath}
							class="diary-notebook group"
						>
							{/* 封面图 */}
							<div class="diary-cover-img-area">
								{book.coverSrc ? (
									<img
										src={book.coverSrc}
										alt={book.name || "笔记本封面"}
										class="diary-cover-img"
										loading="lazy"
									/>
								) : (
									<div class="diary-cover-placeholder">
										<span class="diary-cover-placeholder-icon">📔</span>
									</div>
								)}
							</div>

							{/* 封面文字内容 */}
							<div class="diary-cover-text">
								{/* 标签 */}
								<div class="flex items-center gap-2 mb-2">
									<span class="px-2 py-0.5 rounded-full text-xs font-medium diary-cover-tag">
										笔记
									</span>
									<span class="text-xs diary-cover-meta">
										{book.entries} 篇
									</span>
								</div>

								{/* 笔记本名称 */}
								<h3 class="text-lg font-bold diary-cover-name">
									{book.name || "未命名笔记本"}
								</h3>

								{/* 描述 */}
								<p class="text-sm diary-cover-desc line-clamp-2 mt-1">
									{book.summary || "暂无描述"}
								</p>
							</div>

							{/* 底部信息条 */}
							<div class="diary-notebook-footer">
								<span class="text-xs">
									{book.updatedAt instanceof Date ? book.updatedAt.toISOString().split("T")[0] : "未更新"}
								</span>
								<Icon name="material-symbols:chevron-right-rounded" class="text-base transition-transform group-hover:translate-x-1" />
							</div>
						</a>
					))}
				</div>
			)}
		</section>

		<!-- 装饰页脚 -->
		<section class="text-center py-4">
			<p class="text-sm text-[var(--content-meta)] opacity-50">
				✨ 每一页都是成长的足迹
			</p>
		</section>
	</div>
</MainGridLayout>

<style>
	/* 日记本网格 — 等大卡片 */
	.diary-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.5rem;
	}

	/* 日记本卡片 */
	.diary-notebook {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		border-radius: var(--radius-xl);
		overflow: hidden;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.diary-notebook:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
	}

	/* ===== 封面图区域 ===== */
	.diary-cover-img-area {
		position: relative;
		aspect-ratio: 2 / 1;
		overflow: hidden;
		background: linear-gradient(135deg, var(--card-bg) 0%, color-mix(in srgb, var(--primary) 8%, var(--card-bg)) 100%);
	}

	.diary-cover-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.diary-notebook:hover .diary-cover-img {
		transform: scale(1.06);
	}

	/* 无封面时的占位 */
	.diary-cover-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, var(--card-bg) 0%, color-mix(in srgb, var(--primary) 12%, var(--card-bg)) 100%);
	}

	.diary-cover-placeholder-icon {
		font-size: 3.5rem;
		opacity: 0.35;
		transition: all 0.3s ease;
	}

	.diary-notebook:hover .diary-cover-placeholder-icon {
		opacity: 0.55;
		transform: scale(1.1);
	}

	/* ===== 封面文字 ===== */
	.diary-cover-text {
		position: relative;
		padding: 1.25rem 1.25rem 0.75rem;
	}

	.diary-cover-tag {
		background: color-mix(in srgb, var(--primary) 20%, transparent);
		color: var(--primary);
	}

	.diary-cover-meta {
		color: var(--content-meta);
	}

	.diary-cover-name {
		color: var(--text-color);
		line-height: 1.3;
	}

	.diary-notebook:hover .diary-cover-name {
		color: var(--primary);
	}

	.diary-cover-desc {
		color: var(--content-meta);
		line-height: 1.5;
	}

	/* ===== 底部信息条 ===== */
	.diary-notebook-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1.25rem;
		margin-top: auto;
		border-top: 1px solid var(--line-divider);
		color: var(--content-meta);
	}

	/* 空状态 */
	.diary-empty {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 4rem 2rem;
		background: var(--card-bg);
		border: 2px dashed var(--line-divider);
		border-radius: var(--radius-3xl);
	}

	/* 行数限制 */
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
