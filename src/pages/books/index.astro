---
import { Icon } from "astro-icon/components";
import Bookshelf from "@/components/pages/books/Bookshelf.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { formatDateI18nWithTime } from "@/utils/date-utils";
import { removeFileExtension } from "@/utils/url-utils";
import Comment from "@components/comment/index.astro";
import { getCollection } from "astro:content";

if (!siteConfig.pages.books) {
	return Astro.redirect("/404/");
}

const buildTime = formatDateI18nWithTime(new Date());

const customBangumi = await getCollection("bangumi");

const bookItems = customBangumi
	.filter((item) => item.data.category === "book")
	.sort((a, b) => {
		const dateA = a.data.published?.getTime() || 0;
		const dateB = b.data.published?.getTime() || 0;
		return dateB - dateA;
	})
	.map((item) => {
		const imageSrc = typeof item.data.image === "string" ? item.data.image : item.data.image.src;
		const slug = removeFileExtension(item.id);
		const link = `/books/${slug}/`;

		return {
			title: item.data.title,
			coverImage: imageSrc,
			link,
			status: item.data.status,
			score: item.data.score || 0,
		};
	});

const readingCount = bookItems.filter((b) => b.status === 3).length;
const readCount = bookItems.filter((b) => b.status === 2).length;
const wishCount = bookItems.filter((b) => b.status === 1).length;
---

<MainGridLayout title={i18n(I18nKey.booksTitle)} description={i18n(I18nKey.booksSubtitle)}>
	<div class="books-page-wrapper flex w-full overflow-hidden relative min-h-32">
		<div data-pagefind-body class="card-base z-10 px-6 pt-8 pb-8 relative w-full">
					<!-- Page header -->
		<header class="books-header relative w-full mb-6">
			<div class="flex items-center gap-3 mb-3">
				<div class="w-12 h-12 rounded-2xl bg-black dark:bg-white flex items-center justify-center">
					<Icon name="material-symbols:auto-stories" class="text-[1.4rem] text-white dark:text-black" />
				</div>
				<div>
					<h1 data-pagefind-meta="title" data-pagefind-weight="10" class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
						{i18n(I18nKey.booksTitle)}
					</h1>
				</div>
			</div>
			<p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
				{i18n(I18nKey.booksSubtitle)}
			</p>
			<div class="flex items-center gap-4 mt-2">
				<p class="text-xs text-neutral-400 dark:text-neutral-500">
					{i18n(I18nKey.bangumiLastUpdated)} {buildTime}
				</p>
				<div class="flex items-center gap-3 text-xs text-neutral-500 dark:text-neutral-400">
					<span class="flex items-center gap-1">
						<span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span>
						{i18n(I18nKey.bookshelfRead)} {readCount}
					</span>
					<span class="flex items-center gap-1">
						<span class="w-2 h-2 rounded-full bg-amber-500 inline-block"></span>
						{i18n(I18nKey.bookshelfReading)} {readingCount}
					</span>
					<span class="flex items-center gap-1">
						<span class="w-2 h-2 rounded-full bg-sky-500 inline-block"></span>
						{i18n(I18nKey.bookshelfWantRead)} {wishCount}
					</span>
				</div>
			</div>
		</header>

			{bookItems.length > 0 ? (
				<Bookshelf books={bookItems} />
			) : (
				<div class="w-full p-12 text-center">
					<Icon name="material-symbols:auto-stories" class="text-6xl text-neutral-300 dark:text-neutral-600 mb-4" />
					<p class="text-neutral-500 dark:text-neutral-400">{i18n(I18nKey.booksNoData)}</p>
				</div>
			)}
		</div>
	</div>

	<Comment customPath="/books/" />
</MainGridLayout>

<style>
	.books-page-wrapper {
		border-radius: var(--radius-large);
	}

	.books-header {
		animation: fadeSlideIn 0.4s ease-[var(--ease-standard)] both;
	}

	.books-icon {
		transition: transform 0.2s ease-[var(--ease-standard)];
	}
	.books-icon:hover {
		transform: scale(1.05);
	}

	@keyframes fadeSlideIn {
		from { opacity: 0; transform: translateY(8px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (max-width: 640px) {
		.card-base {
			padding-left: 1rem;
			padding-right: 1rem;
			padding-top: 1.5rem;
			padding-bottom: 1.5rem;
		}
	}
</style>
