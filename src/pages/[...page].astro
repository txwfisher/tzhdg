---
import type { GetStaticPaths } from "astro";
import HomeDataLayer from "@components/layout/HomeDataLayer.astro";
import HomeHero from "@components/layout/HomeHero.astro";
import HomePortfolioShutterLayer from "@components/layout/HomePortfolioShutterLayer.astro";
import HomeTicker from "@components/layout/HomeTicker.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getSortedPosts();
	return paginate(allBlogPosts, { pageSize: allBlogPosts.length });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<MainGridLayout>
	<div class="home-page home-page--motion-pending">
		<HomeHero />
		<HomeTicker />
		<div class="home-data-stack">
			<HomeDataLayer />
			<HomePortfolioShutterLayer />
		</div>
	</div>
</MainGridLayout>
