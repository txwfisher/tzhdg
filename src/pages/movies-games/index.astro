---
import { getCollection } from "astro:content";
import Comment from "@components/comment/index.astro";
import { Icon } from "astro-icon/components";
import ClientPagination from "@/components/common/ClientPagination.astro";
import MovieGameCard from "@/components/pages/movies-games/MovieGameCard.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { formatDateI18nWithTime } from "@/utils/date-utils";
import { removeFileExtension } from "@/utils/url-utils";

if (!siteConfig.pages.moviesGames) {
	return Astro.redirect("/404/");
}

const buildTime = formatDateI18nWithTime(new Date());

const customBangumi = await getCollection("bangumi");

const statusMap: Record<number, string> = {
	1: "wish",
	2: "collect",
	3: "doing",
	4: "on_hold",
	5: "dropped",
};

interface MgItem {
	subject_id: number;
	subject_type: number;
	rate: number;
	type: number;
	comment: string | null;
	tags: string[];
	ep_status: number;
	vol_status: number;
	updated_at: string;
	private: boolean;
	link: string;
	subject: {
		id: number;
		type: number;
		name: string;
		name_cn: string;
		short_summary: string;
		images: {
			medium: string;
			large: string;
			common: string;
			small: string;
			grid: string;
		};
		volumes: number;
		eps: number;
		collection_total: number;
		score: number;
		rank: number;
		tags: any[];
	};
	_subcategory?: string;
}

const mgItems: MgItem[] = customBangumi
	.filter((item) => ["anime", "game", "real"].includes(item.data.category))
	.map((item) => {
		const { data, id } = item;
		const imageSrc =
			typeof data.image === "string" ? data.image : data.image.src;

		const finalLink = "/bangumi/" + removeFileExtension(id) + "/";

		const subjectTypeMap: Record<string, number> = {
			anime: 2,
			game: 4,
			real: 6,
		};

		const subcategory = (data as any).subcategory as string | undefined;

		return {
			subject_id: 0,
			subject_type: subjectTypeMap[data.category] || 2,
			rate: data.score || 0,
			type: data.status,
			comment: data.comment || null,
			tags: data.tags || [],
			ep_status: 0,
			vol_status: 0,
			updated_at: data.published?.toISOString() || new Date().toISOString(),
			private: false,
			link: finalLink,
			_subcategory: subcategory,
			subject: {
				id: 0,
				type: subjectTypeMap[data.category] || 2,
				name: data.title,
				name_cn: data.name_cn || data.title,
				short_summary: "",
				images: {
					medium: imageSrc,
					large: imageSrc,
					common: imageSrc,
					small: imageSrc,
					grid: imageSrc,
				},
				volumes: 0,
				eps: 0,
				collection_total: 0,
				score: data.score || 0,
				rank: 0,
				tags: [],
			},
		};
	})
	.sort(
		(a, b) =>
			new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime(),
	);

function getItemSubcategory(item: MgItem): string {
	if (item._subcategory) return item._subcategory;
	const tags = item.tags || [];
	if (tags.some((t: string) => t.includes("纪录"))) return "documentary";
	if (tags.some((t: string) => t.includes("动漫") || t.includes("动画")))
		return "anime";
	if (tags.some((t: string) => t.includes("电视剧") || t.includes("剧集")))
		return "tv";
	return "movie";
}

type TabKey = "all" | "movie" | "tv" | "anime" | "documentary" | "game";

const tabConfig: { key: TabKey; i18nKey: I18nKey }[] = [
	{ key: "all", i18nKey: I18nKey.moviesGamesTabAll },
	{ key: "movie", i18nKey: I18nKey.moviesGamesTabMovie },
	{ key: "tv", i18nKey: I18nKey.moviesGamesTabTV },
	{ key: "anime", i18nKey: I18nKey.moviesGamesTabAnime },
	{ key: "documentary", i18nKey: I18nKey.moviesGamesTabDocumentary },
	{ key: "game", i18nKey: I18nKey.moviesGamesTabGame },
];

interface SectionData {
	tabKey: string;
	tabName: string;
	tabCount: number;
	items: MgItem[];
	filters: { value: string; label: string; count: number }[];
}

const sections: SectionData[] = [];

for (const tc of tabConfig) {
	const items =
		tc.key === "all"
			? mgItems
			: mgItems.filter((item) => {
					if (tc.key === "game") return item.subject_type === 4;
					if (item.subject_type === 4) return false;
					return getItemSubcategory(item) === tc.key;
				});

	if (tc.key !== "all" && items.length === 0) continue;

	const statusCounts: Record<string, number> = {};
	for (const item of items) {
		const s = statusMap[item.type] || "unknown";
		statusCounts[s] = (statusCounts[s] || 0) + 1;
	}

	const filters = [
		{
			value: "all",
			label: i18n(I18nKey.bangumiFilterAll),
			count: items.length,
		},
		{
			value: "collect",
			label: i18n(I18nKey.bangumiFilterWatched),
			count: statusCounts.collect || 0,
		},
		{
			value: "doing",
			label: i18n(I18nKey.bangumiFilterWatching),
			count: statusCounts.doing || 0,
		},
		{
			value: "wish",
			label: i18n(I18nKey.bangumiFilterWish),
			count: statusCounts.wish || 0,
		},
		{
			value: "on_hold",
			label: i18n(I18nKey.bangumiFilterOnHold),
			count: statusCounts.on_hold || 0,
		},
		{
			value: "dropped",
			label: i18n(I18nKey.bangumiFilterDropped),
			count: statusCounts.dropped || 0,
		},
	].filter((f) => f.value === "all" || f.count > 0);

	sections.push({
		tabKey: tc.key,
		tabName: i18n(tc.i18nKey),
		tabCount: items.length,
		items,
		filters,
	});
}

const activeTab = sections[0]?.tabKey || "all";
---

<MainGridLayout title={i18n(I18nKey.moviesGamesTitle)} description={i18n(I18nKey.moviesGamesSubtitle)}>
	<div class="mg-page-wrapper flex w-full overflow-hidden relative min-h-32">
		<div data-pagefind-body class="card-base z-10 px-6 pt-8 pb-8 relative w-full">
			<!-- Page header -->
			<header class="mg-header relative w-full mb-8">
				<div class="flex items-center gap-3 mb-4">
					<div class="mg-icon flex items-center justify-center w-12 h-12 rounded-2xl bg-[var(--primary)]/10 dark:bg-[var(--primary)]/15 border border-[var(--primary)]/20 shadow-sm">
						<Icon name="material-symbols:movie-outline-rounded" class="text-[1.4rem] text-[var(--primary)]" />
					</div>
					<div>
						<h1 data-pagefind-meta="title" data-pagefind-weight="10" class="">
							{i18n(I18nKey.moviesGamesTitle)}
						</h1>
					</div>
				</div>
				<p class="text-sm text-[var(--content-meta)] leading-relaxed pl-[3.5rem]">
					{i18n(I18nKey.moviesGamesSubtitle)}
				</p>
				<p class="text-xs text-[var(--content-meta)] opacity-60 mt-1.5 pl-[3.5rem]">
					{i18n(I18nKey.bangumiLastUpdated)} {buildTime}
				</p>
			</header>

			{mgItems.length > 0 ? (
				<>
					<!-- Tab Navigation -->
					<div class="mg-tabs-wrapper mb-6">
						<nav class="tools-tab-pill" data-mg-tab-nav aria-label="Tabs">
							<div class="tools-tab-indicator" data-mg-tab-indicator></div>
							{sections.map((sec) => (
								<button
									class:list={[
										"tools-tab-btn",
										sec.tabKey === activeTab
											? "tools-tab-btn-active"
											: "tools-tab-btn-inactive",
									]}
									data-tab={sec.tabKey}
									type="button"
								>
									<span>{sec.tabName}</span>
									<span class="tools-tab-badge">{sec.tabCount}</span>
								</button>
							))}
						</nav>
					</div>

					<!-- Sections -->
					{sections.map((sec) => (
						<div class:list={["mg-section", { "hidden": sec.tabKey !== activeTab }]} data-section={sec.tabKey}>
							{sec.items.length > 0 ? (
								<>
									<!-- Filters -->
									<div class="mg-filter-wrapper tools-tab-pill mb-5" data-mg-filter-nav={sec.tabKey}>
										<div class="tools-tab-indicator" data-mg-filter-indicator={sec.tabKey}></div>
										{sec.filters.map((filter) => (
											<button
												class:list={[
													"tools-tab-btn mg-filter-btn",
													filter.value === "all"
														? "tools-tab-btn-active"
														: "tools-tab-btn-inactive",
												]}
												data-filter={filter.value}
												data-section={sec.tabKey}
												type="button"
											>
												<span>{filter.label}</span>
												<span class="tools-tab-badge">{filter.count}</span>
											</button>
										))}
									</div>

									<!-- Grid -->
									<div class="mg-grid grid grid-cols-3 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-5">
										{sec.items.map((item: MgItem) => (
											<div
												class="mg-item"
												data-item-section={sec.tabKey}
												data-item-status={statusMap[item.type] || "unknown"}
											>
												<MovieGameCard item={item as any} link={item.link} />
											</div>
										))}
									</div>

									<ClientPagination
										totalItems={sec.items.length}
										itemsPerPage={12}
										itemsPerPageMobile={6}
										currentPage={1}
										sectionId={sec.tabKey}
									/>
								</>
							) : (
								<div class="flex flex-col items-center justify-center py-16 text-center">
									<p class="text-sm text-[var(--content-meta)]">{i18n(I18nKey.moviesGamesNoData)}</p>
								</div>
							)}
						</div>
					))}
				</>
			) : (
				<div class="flex flex-col items-center justify-center py-20 text-center">
					<div class="inline-flex items-center justify-center w-14 h-14 bg-[var(--btn-regular-bg)] rounded-2xl mb-4 border border-[var(--line-divider)]">
						<Icon name="material-symbols:movie-outline" class="w-7 h-7 text-[var(--content-meta)]" />
					</div>
					<h3 class="text-base font-medium text-[var(--deep-text)] dark:text-[var(--title-active)] mb-1.5">
						{i18n(I18nKey.moviesGamesNoData)}
					</h3>
				</div>
			)}
		</div>
	</div>
<Comment customPath="/movies-games/" />

<script is:inline>
	(function() {
		function updateIndicator(indicator, btn) {
			if (!indicator || !btn) return;
			indicator.style.left = btn.offsetLeft + 'px';
			indicator.style.top = btn.offsetTop + 'px';
			indicator.style.width = btn.offsetWidth + 'px';
			indicator.style.height = btn.offsetHeight + 'px';
			indicator.style.opacity = '1';
		}

		function activateBtn(btns, target, indicator) {
			btns.forEach(function(btn) {
				btn.classList.remove('tools-tab-btn-active');
				btn.classList.add('tools-tab-btn-inactive');
				btn.disabled = false;
			});
			target.classList.remove('tools-tab-btn-inactive');
			target.classList.add('tools-tab-btn-active');
			target.disabled = true;
			if (indicator) {
				requestAnimationFrame(function() { updateIndicator(indicator, target); });
			}
		}

		function initIndicators() {
			var tabNav = document.querySelector('[data-mg-tab-nav]');
			var tabIndicator = document.querySelector('[data-mg-tab-indicator]');
			if (tabNav && tabIndicator) {
				var activeTab = tabNav.querySelector('.tools-tab-btn-active');
				if (activeTab) requestAnimationFrame(function() { updateIndicator(tabIndicator, activeTab); });
			}
			document.querySelectorAll('[data-mg-filter-indicator]').forEach(function(indicator) {
				var section = indicator.getAttribute('data-mg-filter-indicator');
				var nav = document.querySelector('[data-mg-filter-nav="' + section + '"]');
				if (nav) {
					var activeFilter = nav.querySelector('.tools-tab-btn-active');
					if (activeFilter) requestAnimationFrame(function() { updateIndicator(indicator, activeFilter); });
				}
			});
		}

		initIndicators();
		document.addEventListener('astro:page-load', initIndicators);
		document.addEventListener('swup:content:replace', function() { setTimeout(initIndicators, 50); });
		window.addEventListener('resize', initIndicators);

		document.addEventListener('click', function(e) {
			var tab = e.target.closest('[data-tab]');
			if (tab) {
				var targetTab = tab.dataset.tab;
				var tabNav = tab.closest('[data-mg-tab-nav]');
				var tabIndicator = tabNav ? tabNav.querySelector('[data-mg-tab-indicator]') : null;
				activateBtn(Array.from(tabNav.querySelectorAll('[data-tab]')), tab, tabIndicator);
				document.querySelectorAll('[data-section]').forEach(function(section) {
					section.classList.toggle('hidden', section.dataset.section !== targetTab);
				});
				// 初始化新 section 的筛选指示器
				var newFilterIndicator = document.querySelector('[data-mg-filter-indicator="' + targetTab + '"]');
				var newFilterNav = document.querySelector('[data-mg-filter-nav="' + targetTab + '"]');
				if (newFilterIndicator && newFilterNav) {
					var activeFilter = newFilterNav.querySelector('.tools-tab-btn-active');
					if (activeFilter) {
						// 强制重置指示器位置
						newFilterIndicator.style.opacity = '0';
						requestAnimationFrame(function() {
							updateIndicator(newFilterIndicator, activeFilter);
						});
					}
				}
				return;
			}

			var filterBtn = e.target.closest('.mg-filter-btn');
			if (filterBtn) {
				var filter = filterBtn.dataset.filter;
				var sid = filterBtn.dataset.section;
				var filterNav = filterBtn.closest('[data-mg-filter-nav]');
				var filterIndicator = filterNav ? filterNav.querySelector('[data-mg-filter-indicator]') : null;
				activateBtn(Array.from(filterNav.querySelectorAll('.mg-filter-btn')), filterBtn, filterIndicator);
				document.querySelectorAll('[data-item-section="' + sid + '"]').forEach(function(item) {
					var match = filter === 'all' || item.dataset.itemStatus === filter;
					item.classList.toggle('hidden', !match);
					item.style.display = match ? 'block' : 'none';
				});
				var pagination = document.querySelector('[data-pagination-section="' + sid + '"]');
				if (pagination) {
					var visibleItems = document.querySelectorAll('[data-item-section="' + sid + '"]:not(.hidden)');
					pagination.dispatchEvent(new CustomEvent('updatePagination', {
						detail: { visibleCount: visibleItems.length }
					}));
				}
			}
		});
	})();
</script>
</MainGridLayout>

<style>
	.mg-page-wrapper {
		border-radius: var(--radius-large);
	}

	.mg-header {
		animation: fadeSlideIn 0.4s ease-[var(--ease-standard)] both;
	}

	.mg-icon {
		transition: transform 0.2s ease-[var(--ease-standard)];
	}
	.mg-icon:hover {
		transform: scale(1.05);
	}

	@keyframes fadeSlideIn {
		from { opacity: 0; transform: translateY(8px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.mg-section {
		animation: fadeIn 0.3s ease-[var(--ease-standard)] both;
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	/* 胶囊按钮样式（复用 changelog 风格） */
	.tools-tab-pill {
		position: relative;
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		padding: 0.375rem;
		border-radius: 1rem;
		border: 2px solid #000;
	}
	:root.dark .tools-tab-pill {
		border-color: #fff;
	}

	.tools-tab-indicator {
		position: absolute;
		border-radius: 9999px;
		background: #000;
		transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1),
					top 0.3s cubic-bezier(0.4, 0, 0.2, 1),
					width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
					height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		opacity: 0;
		pointer-events: none;
		z-index: 0;
	}
	:root.dark .tools-tab-indicator {
		background: #fff;
	}

	.tools-tab-btn {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.375rem 0.875rem;
		border: none;
		border-radius: 9999px;
		font-size: 0.8125rem;
		font-weight: 500;
		white-space: nowrap;
		cursor: pointer;
		background: transparent;
		transition: color 0.2s;
		flex-shrink: 0;
		font-family: inherit;
	}

	.tools-tab-btn-active {
		color: #fff;
		cursor: default;
	}
	:root.dark .tools-tab-btn-active {
		color: #000;
	}

	.tools-tab-btn-inactive {
		color: #000;
	}
	.tools-tab-btn-inactive:hover {
		opacity: 0.7;
	}
	:root.dark .tools-tab-btn-inactive {
		color: #fff;
	}

	.tools-tab-badge {
		font-size: 0.65rem;
		padding: 0.0625rem 0.375rem;
		border-radius: 9999px;
		background: oklch(0.92 0 0);
		color: oklch(0.35 0 0);
		line-height: 1.4;
	}
	:root.dark .tools-tab-badge {
		background: oklch(0.25 0 0);
		color: oklch(0.65 0 0);
	}

	.tools-tab-btn-active .tools-tab-badge {
		background: rgba(255, 255, 255, 0.25);
		color: #fff;
	}
	:root.dark .tools-tab-btn-active .tools-tab-badge {
		background: rgba(0, 0, 0, 0.2);
		color: #000;
	}

	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}

	@media (max-width: 640px) {
		.card-base {
			padding-left: 1rem;
			padding-right: 1rem;
			padding-top: 1.5rem;
			padding-bottom: 1.5rem;
		}
	}
</style>
