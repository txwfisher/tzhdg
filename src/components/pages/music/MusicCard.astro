---
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import type { UserSubjectCollection } from "@/types/bangumi";

interface Props {
	item: UserSubjectCollection;
}

const { item } = Astro.props;

const getStatusColor = (type: number) => {
	switch (type) {
		case 1: return "bg-sky-500/80";
		case 2: return "bg-emerald-500/80";
		case 3: return "bg-amber-500/80";
		case 4: return "bg-violet-500/80";
		case 5: return "bg-rose-400/80";
		default: return "bg-gray-500/80";
	}
};

const getStatusText = (type: number) => {
	switch (type) {
		case 1: return i18n(I18nKey.bangumiStatusMusicWish);
		case 2: return i18n(I18nKey.bangumiStatusMusicListened);
		case 3: return i18n(I18nKey.bangumiStatusMusicListening);
		case 4: return i18n(I18nKey.bangumiStatusOnHold);
		case 5: return i18n(I18nKey.bangumiStatusDropped);
		default: return i18n(I18nKey.bangumiStatusUnknown);
	}
};

const title = item.subject.name_cn || item.subject.name;
const rawScore = item.subject.score ?? 0;
const scoreText = rawScore > 0 ? `${rawScore}`.replace(/\.0$/, "") : "";
const hasScore = rawScore > 0;
---

<div class="mc-card group">
	<div class="mc-cover">
		<img
			src={item.subject?.images?.medium || ""}
			alt={title}
			class="mc-img"
			loading="lazy"
		/>

		<span class={`mc-status ${getStatusColor(item.type)}`}>
			{getStatusText(item.type)}
		</span>

		{hasScore && (
			<span class="mc-score">
				<svg class="mc-star" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
				{scoreText}
			</span>
		)}

		<div class="mc-gradient" />

		<div class="mc-info">
			<h3 class="mc-title">{title}</h3>
		</div>

		{item.comment && (
			<div class="mc-overlay">
				<p class="mc-comment">{item.comment}</p>
			</div>
		)}
	</div>
</div>

<style>
	.mc-card {
		display: block;
		border-radius: var(--radius-large);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: transform 0.22s cubic-bezier(.23,1,.32,1),
		            box-shadow 0.22s cubic-bezier(.23,1,.32,1);
	}
	.mc-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 25px -6px rgba(0,0,0,.12), 0 0 0 1px var(--primary);
	}
	:global(html.dark) .mc-card:hover {
		box-shadow: 0 8px 25px -6px rgba(0,0,0,.35), 0 0 0 1px var(--primary);
	}

	.mc-cover {
		position: relative;
		aspect-ratio: 1/1;
		background: var(--btn-regular-bg);
		overflow: hidden;
	}
	.mc-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.5s cubic-bezier(.23,1,.32,1);
	}
	.mc-card:hover .mc-img {
		transform: scale(1.06);
	}

	.mc-gradient {
		position: absolute;
		inset: auto 0 0 0;
		height: 50%;
		background: linear-gradient(to top, rgba(0,0,0,.65) 0%, rgba(0,0,0,.2) 50%, transparent 100%);
		pointer-events: none;
		z-index: 1;
	}

	.mc-status {
		position: absolute;
		top: 8px;
		left: 8px;
		padding: 3px 10px;
		border-radius: 9999px;
		font-size: 10px;
		font-weight: 600;
		letter-spacing: .04em;
		color: #fff;
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		z-index: 3;
	}

	.mc-score {
		position: absolute;
		top: 8px;
		right: 8px;
		display: flex;
		align-items: center;
		gap: 3px;
		padding: 3px 8px 3px 6px;
		border-radius: 9999px;
		background: rgba(0,0,0,.48);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		font-size: 11px;
		font-weight: 700;
		color: #fff;
		z-index: 3;
	}
	.mc-star {
		width: 11px;
		height: 11px;
		color: #fbbf24;
		flex-shrink: 0;
	}

	.mc-info {
		position: absolute;
		inset: auto 0 0 0;
		z-index: 2;
		padding: 0 10px 10px;
		pointer-events: none;
	}

	.mc-title {
		font-size: 14px;
		font-weight: 700;
		line-height: 1.4;
		color: #fff;
		margin: 0;
		text-shadow: 0 1px 3px rgba(0,0,0,.4);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.mc-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0,0,0,.76);
		backdrop-filter: blur(3px);
		-webkit-backdrop-filter: blur(3px);
		opacity: 0;
		transition: opacity .25s ease;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: 16px;
		pointer-events: none;
		z-index: 20;
	}
	.mc-card:hover .mc-overlay {
		opacity: 1;
	}
	.mc-comment {
		font-size: 12px;
		line-height: 1.7;
		color: rgba(255,255,255,.92);
		margin: auto 0 0;
		width: 100%;
		display: -webkit-box;
		-webkit-line-clamp: 5;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 640px) {
		.mc-status {
			top: 5px;
			left: 5px;
			padding: 2px 7px;
			font-size: 9px;
		}
		.mc-score {
			top: 5px;
			right: 5px;
			padding: 2px 7px 2px 5px;
			font-size: 10px;
		}
		.mc-info {
			padding: 0 8px 8px;
		}
		.mc-title {
			font-size: 13px;
		}
	}
</style>
