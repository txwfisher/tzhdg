---
interface Post {
  id: string;
  data: { title: string; published: Date };
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

function formatYmd(d: Date): string {
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
}

const now = new Date();
const currentYear = now.getFullYear();
const postCountByDate = new Map<string, number>();
const yearsSet = new Set<number>();
for (const p of posts) {
  const key = formatYmd(p.data.published);
  postCountByDate.set(key, (postCountByDate.get(key) || 0) + 1);
  yearsSet.add(p.data.published.getFullYear());
}

const availableYears = Array.from(yearsSet).sort((a, b) => b - a);
const defaultYear = availableYears[0] ?? currentYear;

function getLevel(count: number, maxCount: number): number {
  if (count === 0) return 0;
  if (maxCount <= 1) return 1;
  const r = count / maxCount;
  if (r <= 0.25) return 1;
  if (r <= 0.5) return 2;
  if (r <= 0.75) return 3;
  return 4;
}

interface Cell { key: string; count: number; level: number; visible: boolean }

function buildYearGrid(year: number): Cell[][] {
  const startDate = new Date(year, 0, 1);
  const endDate = new Date(year, 11, 31);
  const startDay = startDate.getDay();
  const startOffset = startDay === 0 ? -6 : 1 - startDay;
  startDate.setDate(startDate.getDate() + startOffset);
  const maxCount = Math.max(1, ...Array.from(postCountByDate.values()));
  const weeks: Cell[][] = [];
  let current = new Date(startDate);
  while (current <= endDate) {
    const week: Cell[] = [];
    for (let i = 0; i < 7; i++) {
      const key = formatYmd(current);
      const count = postCountByDate.get(key) || 0;
      week.push({ key, count, level: current.getFullYear() === year ? getLevel(count, maxCount) : 0, visible: current.getFullYear() === year });
      current.setDate(current.getDate() + 1);
    }
    weeks.push(week);
  }
  return weeks;
}

const monthLabels = ["1月","2月","3月","4月","5月","6月","7月","8月","9月","10月","11月","12月"];

function getMonthBoundaries(year: number) {
  const b: { label: string; weekIndex: number }[] = [];
  for (let m = 0; m < 12; m++) {
    const firstDay = new Date(year, m, 1);
    const startDay = firstDay.getDay();
    const startOffset = startDay === 0 ? -6 : 1 - startDay;
    const weekStart = new Date(firstDay);
    weekStart.setDate(firstDay.getDate() + startOffset);
    const yearStart = new Date(year, 0, 1);
    const yStartDay = yearStart.getDay();
    const yStartOffset = yStartDay === 0 ? -6 : 1 - yStartDay;
    yearStart.setDate(yearStart.getDate() + yStartOffset);
    const weekIndex = Math.round((weekStart.getTime() - yearStart.getTime()) / (7 * 86400000));
    b.push({ label: monthLabels[m], weekIndex });
  }
  return b;
}

interface YearData { year: number; weeks: Cell[][]; monthBoundaries: { label: string; weekIndex: number }[] }
const allYearsData: YearData[] = availableYears.map(y => ({ year: y, weeks: buildYearGrid(y), monthBoundaries: getMonthBoundaries(y) }));
---

<div class="archive-heatmap mb-6" id="archive-heatmap">
  <div class="flex items-center justify-end mb-4">
    <div class="heatmap-year-nav">
      {allYearsData.map((yd) => (
        <button class="heatmap-year-btn" data-active={yd.year === defaultYear ? "" : undefined} data-year={yd.year}>{yd.year}</button>
      ))}
    </div>
  </div>

  {allYearsData.map((yd) => (
    <div class="heatmap-year" data-year={yd.year} hidden={yd.year !== defaultYear}>
      <div class="heatmap-body">
        <div class="heatmap-months">
          {yd.monthBoundaries.map((mb, i) => (
            <span class="heatmap-month-label" style={`grid-column: ${mb.weekIndex + 1} / span ${i < yd.monthBoundaries.length - 1 ? yd.monthBoundaries[i + 1].weekIndex - mb.weekIndex : 3}`}>{mb.label}</span>
          ))}
        </div>
        <div class="heatmap-grid-wrap">
          <div class="heatmap-days">
            <span class="heatmap-day-label"></span><span class="heatmap-day-label">一</span><span class="heatmap-day-label"></span><span class="heatmap-day-label">三</span><span class="heatmap-day-label"></span><span class="heatmap-day-label">五</span><span class="heatmap-day-label"></span>
          </div>
          <div class="heatmap-grid">
            {yd.weeks.map((week) => (
              <div class="heatmap-week">
                {week.map((cell) => (
                  <div class={`heatmap-cell level-${cell.level}`} title={cell.visible ? `${cell.key} · ${cell.count} 篇` : ""} style={cell.visible ? "" : "visibility:hidden"}></div>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  ))}
  <div class="heatmap-legend">
    <span class="heatmap-legend-label">少</span>
    <div class="heatmap-cell level-0"></div><div class="heatmap-cell level-1"></div><div class="heatmap-cell level-2"></div><div class="heatmap-cell level-3"></div><div class="heatmap-cell level-4"></div>
    <span class="heatmap-legend-label">多</span>
  </div>
</div>

<script>
  const container = document.getElementById("archive-heatmap");
  if (container) {
    container.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(".heatmap-year-btn") as HTMLElement | null;
      if (!btn) return;
      const year = btn.getAttribute("data-year");
      if (!year) return;
      container.querySelectorAll(".heatmap-year-btn").forEach((b) => b.removeAttribute("data-active"));
      btn.setAttribute("data-active", "");
      container.querySelectorAll(".heatmap-year").forEach((el) => { (el as HTMLElement).hidden = el.getAttribute("data-year") !== year; });
    });
  }
</script>

<style>
.archive-heatmap { --cell-size: 14px; --cell-gap: 3px; }
.heatmap-year-nav { display: flex; gap: 6px; flex-wrap: wrap; }
.heatmap-year-btn { font-size: 0.8rem; font-weight: 600; padding: 0.15rem 0.6rem; border-radius: 0.375rem; border: 1px solid var(--line-color, oklch(0.82 0 0)); background: transparent; color: var(--content-meta); cursor: pointer; transition: all 0.15s ease; }
.heatmap-year-btn:hover { border-color: var(--primary); color: var(--primary); }
.heatmap-year-btn[data-active] { background: var(--primary); color: white; border-color: var(--primary); }
:global(.dark) .heatmap-year-btn[data-active] { color: black; }
.heatmap-body { margin-top: 0.5rem; }
.heatmap-months { display: grid; grid-template-columns: repeat(53, var(--cell-size)); gap: var(--cell-gap); margin-bottom: 4px; padding-left: calc(var(--cell-size) + var(--cell-gap)); }
.heatmap-month-label { font-size: 0.65rem; color: var(--content-meta); white-space: nowrap; }
.heatmap-grid-wrap { display: flex; gap: var(--cell-gap); }
.heatmap-days { display: grid; grid-template-rows: repeat(7, var(--cell-size)); gap: var(--cell-gap); flex-shrink: 0; }
.heatmap-day-label { font-size: 0.6rem; color: var(--content-meta); line-height: var(--cell-size); text-align: center; }
.heatmap-grid { display: flex; gap: var(--cell-gap); overflow-x: auto; padding-bottom: 2px; }
.heatmap-week { display: grid; grid-template-rows: repeat(7, var(--cell-size)); gap: var(--cell-gap); flex-shrink: 0; }
.heatmap-cell { width: var(--cell-size); height: var(--cell-size); border-radius: 3px; background: var(--line-color, oklch(0.92 0 0)); transition: background 0.15s ease, transform 0.15s ease; }
.heatmap-cell:hover { transform: scale(1.3); outline: 2px solid var(--deep-text); z-index: 2; position: relative; }
.heatmap-cell.level-0 { background: oklch(0.92 0 0); }
:global(.dark) .heatmap-cell.level-0 { background: oklch(0.22 0 0); }
.heatmap-cell.level-1 { background: oklch(0.85 0.04 160); }
:global(.dark) .heatmap-cell.level-1 { background: oklch(0.25 0.03 160); }
.heatmap-cell.level-2 { background: oklch(0.72 0.08 160); }
:global(.dark) .heatmap-cell.level-2 { background: oklch(0.33 0.06 160); }
.heatmap-cell.level-3 { background: oklch(0.55 0.12 160); }
:global(.dark) .heatmap-cell.level-3 { background: oklch(0.42 0.1 160); }
.heatmap-cell.level-4 { background: oklch(0.38 0.15 160); }
:global(.dark) .heatmap-cell.level-4 { background: oklch(0.52 0.14 160); }
.heatmap-legend { display: flex; align-items: center; gap: 4px; margin-top: 0.75rem; justify-content: flex-end; }
.heatmap-legend .heatmap-cell { width: 12px; height: 12px; }
.heatmap-legend-label { font-size: 0.6rem; color: var(--content-meta); margin: 0 4px; }
@media (max-width: 640px) { .archive-heatmap { --cell-size: 11px; --cell-gap: 2px; } }
</style>
