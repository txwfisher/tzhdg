---
import { Icon } from "astro-icon/components";

interface Props {
	description: string;
	descriptionSource?: "manual" | "ai" | string;
}

const { description, descriptionSource } = Astro.props;

const sourceLabel = descriptionSource === "manual" ? "人工编写" : "AI 摘要";
const iconName =
	descriptionSource === "manual"
		? "material-symbols:edit-note-rounded"
		: "material-symbols:psychiatry-rounded";
---

<div
  id="ai-summary"
  class="ai-summary card-base rounded-xl mb-6 onload-animation"
>
  <div class="ai-summary-inner">
    <div class="ai-summary-header">
      <div class="ai-summary-icon">
        <Icon name={iconName} class="text-lg" />
      </div>
      <span class="ai-summary-label">{sourceLabel}</span>
    </div>
    <p id="ai-summary-text" class="ai-summary-text" data-full-text={description}>
    </p>
  </div>
</div>

<script is:inline>
  (function typewriter() {
    const el = document.getElementById("ai-summary-text");
    if (!el) return;

    const fullText = el.getAttribute("data-full-text") || "";
    if (!fullText) return;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (prefersReducedMotion) {
      el.textContent = fullText;
      return;
    }

    let hasRun = false;
    const speed = 45; // ms per character

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !hasRun) {
            hasRun = true;
            observer.unobserve(el);
            startTyping();
          }
        }
      },
      { threshold: 0.3 }
    );

    observer.observe(el);

    function startTyping() {
      let i = 0;
      el.textContent = "";

      function tick() {
        if (i < fullText.length) {
          el.textContent += fullText.charAt(i);
          i++;
          const delay =
            fullText.charAt(i - 1) === "。" ||
            fullText.charAt(i - 1) === "！" ||
            fullText.charAt(i - 1) === "？" ||
            fullText.charAt(i - 1) === "…"
              ? speed * 3
              : fullText.charAt(i - 1) === "，" ||
                  fullText.charAt(i - 1) === "、"
                ? speed * 2
                : speed;
          setTimeout(tick, delay);
        }
      }

      tick();
    }
  })();
</script>

<style>
  .ai-summary {
    border: 1px solid color-mix(in srgb, var(--line-divider) 86%, transparent);
    background: color-mix(in srgb, var(--card-bg) 94%, transparent);
    overflow: hidden;
  }

  .ai-summary-inner {
    padding: 1rem 1.25rem;
  }

  .ai-summary-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.625rem;
  }

  .ai-summary-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--primary) 14%, transparent);
    color: var(--primary);
  }

  .ai-summary-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--primary);
  }

  .ai-summary-text {
    font-size: 0.925rem;
    line-height: 1.75;
    color: var(--deep-text);
    min-height: 1.75em;
  }

  :global(html.dark) .ai-summary-text {
    color: var(--deep-text);
  }
</style>
