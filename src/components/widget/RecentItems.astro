---
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { getCollection } from "astro:content";
import { getPostUrlBySlug, url } from "@/utils/url-utils";
import { processCoverImageSync } from "@/utils/image-utils";
import { i18n } from "@/i18n/translation";
import I18nKey from "@/i18n/i18nKey";
import { Icon } from "astro-icon/components";

const posts = await getCollection("posts", ({ data }) => {
	return import.meta.env.PROD ? data.draft !== true : true;
});
const moments = await getCollection("moments");
const bangumi = await getCollection("bangumi");
const workoutEntries = await getCollection("lifeWorkout");
const sleepEntries = await getCollection("lifeSleep");
const foodEntries = await getCollection("lifeFood");
const ideas = await getCollection("life");
const notebooksEntries = await getCollection("notebooks");
const checkinEntries = await getCollection("checkin");
const routinesEntries = await getCollection("routines");

// 辅助函数
const isIn = (entryId: string, folder: string) =>
	entryId.replace(/\\/g, "/").startsWith(`${folder}/`);

// 获取想法数据
const lifeIdeas = ideas.filter((entry) => isIn(entry.id, "ideas"));
const completedIdeas = lifeIdeas.filter((item) => item.data.completedAt);

// 转换所有项为统一格式
const allItems = [
	...posts.map((p) => ({
		type: "post",
		title: p.data.title,
		date: p.data.published,
		url: getPostUrlBySlug(p.id),
		image: processCoverImageSync(p.data.image || "api", p.id),
		id: p.id,
	})),
	...moments.map((m) => {
		// 提取摘要作为标题
		let title = m.body || "";
		title = title.replace(/[#*`]/g, "").trim(); // 移除 markdown 符号
		if (title.length > 40) title = `${title.substring(0, 40)}...`;
		if (!title) title = i18n(I18nKey.moments) || "日常动态";

		let image = "";
		if (Array.isArray(m.data.images) && m.data.images.length > 0) {
			image =
				typeof m.data.images[0] === "string"
					? m.data.images[0]
					: (m.data.images[0] as any).src;
		} else if (typeof m.data.images === "string") {
			image = m.data.images;
		}

		return {
			type: "moment",
			title: title,
			date: m.data.published,
			url: `/moments/#${m.id}`,
			image: image,
			id: m.id,
		};
	}),
	...bangumi.map((b) => ({
		type: "bangumi",
		title: b.data.title,
		date: b.data.published || new Date(0),
		url: b.data.link || "/bangumi/",
		image:
			typeof b.data.image === "string"
				? b.data.image
				: (b.data.image as any).src,
		id: b.id,
	})),
	// 生活动态 - 运动
	...workoutEntries.slice(0, 2).map((w) => ({
		type: "life-workout",
		title: `运动: ${w.data.workoutType || "锻炼"} - ${w.data.runKm || 0}km`,
		date: w.data.date,
		url: "/life/health/",
		image: "https://re.tsh520.cn/zl/life-workout.webp",
		id: w.id,
	})),
	// 生活动态 - 睡眠
	...sleepEntries.slice(0, 2).map((s) => ({
		type: "life-sleep",
		title: `睡眠: ${s.data.sleepHours || 0}小时`,
		date: s.data.date,
		url: "/life/health/",
		image: "https://re.tsh520.cn/zl/life-sleep.webp",
		id: s.id,
	})),
	// 生活动态 - 饮食
	...foodEntries.slice(0, 2).map((f) => ({
		type: "life-food",
		title: `饮食记录`,
		date: f.data.date,
		url: "/life/health/",
		image: "https://re.tsh520.cn/zl/life-food.webp",
		id: f.id,
	})),
	// 生活动态 - 想法
	...completedIdeas.slice(0, 2).map((i) => ({
		type: "life-idea",
		title: `想法: ${(i.data.content || "").slice(0, 20)}...`,
		date: i.data.completedAt || i.data.createdAt || new Date(),
		url: "/life/ideas/",
		image: "https://re.tsh520.cn/zl/life-idea.webp",
		id: i.id,
	})),
	// 生活动态 - 日记
	...notebooksEntries.slice(0, 2).map((n) => ({
		type: "life-notebook",
		title: `日记: ${n.data.name || "未命名"}`,
		date: n.data.date || new Date(),
		url: "/life/notebooks/",
		image: "https://re.tsh520.cn/zl/life-notebook.webp",
		id: n.id,
	})),
	// 生活动态 - 打卡
	...checkinEntries.slice(0, 2).map((c) => ({
		type: "life-checkin",
		title: `打卡: ${c.data.name}`,
		date: c.data.checkins?.[c.data.checkins.length - 1] || new Date(),
		url: "/life/checkin/",
		image: "https://re.tsh520.cn/zl/life-checkin.webp",
		id: c.id,
	})),
	// 生活动态 - 规划
	...routinesEntries.slice(0, 2).map((r) => ({
		type: "life-routine",
		title: `规划: ${r.data.name}`,
		date: r.data.updatedAt instanceof Date ? r.data.updatedAt : new Date(),
		url: "/life/routines/",
		image: "https://re.tsh520.cn/zl/life-routine.webp",
		id: r.id,
	})),
];

// 排序并获取前 8 个（留位置给生活动态）
const recentItems = allItems
	.sort((a, b) => b.date.getTime() - a.date.getTime())
	.slice(0, 8);

const defaultImage = "https://re.0824.uk/zl/tx.webp";

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout name={i18n(I18nKey.recentItems)} id="recent-items" class={className} style={style}>
  <Icon name="material-symbols:history" slot="title-icon" class="text-xl" />
  <div class="flex flex-col gap-3 py-1">
    {recentItems.map(item => (
      <a href={item.url} class="flex gap-3 group items-center transition-all">
        <div class="w-14 h-14 shrink-0 rounded-lg overflow-hidden bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 shadow-sm transition-transform group-hover:scale-105 group-active:scale-95">
          <img 
            src={item.image || (item.type === 'moment' ? 'https://re.0824.uk/zl/tx.webp' : defaultImage)} 
            alt={item.title} 
            class="w-full h-full object-cover"
            onerror={`this.onerror=null;this.src='${item.type === 'moment' ? 'https://re.0824.uk/zl/tx.webp' : defaultImage}';`}
            loading="lazy"
          />
        </div>
        <div class="flex flex-col min-w-0 flex-1">
          <div class="text-sm font-bold text-neutral-700 dark:text-neutral-200 line-clamp-2 leading-snug group-hover:text-(--primary) transition-colors">
            {item.title}
          </div>
          <div class="text-[10px] text-neutral-400 mt-1.5 flex items-center justify-between pr-1">
            <div class="flex items-center gap-1">
              <Icon name="material-symbols:calendar-today-outline" class="text-xs" />
              {item.date.toISOString().substring(0, 10)}
            </div>
            <span class={`px-1.5 py-0.5 rounded-md text-[10px] uppercase tracking-wider font-bold ${
              item.type === 'post' ? 'bg-amber-500 text-white' :
              item.type === 'moment' ? 'bg-(--primary) text-white' :
              item.type === 'bangumi' ? 'bg-red-500 text-white' :
              'bg-emerald-600 text-white'
            }`}>
              {item.type === 'post' ? i18n(I18nKey.recentPosts) : item.type === 'moment' ? i18n(I18nKey.recentMoments) : item.type === 'bangumi' ? i18n(I18nKey.recentLife) : '最新生活'}
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>
</WidgetLayout>
