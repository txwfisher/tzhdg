---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

// 获取生活相关 collection
const lifeEntries = await getCollection("life");
const notebookEntries = await getCollection("notebooks");
const routinesEntries = await getCollection("routines");

// 辅助函数
const isIn = (entryId: string, folder: string) =>
	entryId.replace(/\\/g, "/").startsWith(`${folder}/`);

// 统计地点
const places = lifeEntries
	.filter((entry) => isIn(entry.id, "places"))
	.map((e) => e.data);
const placesCount = places.length;
const visitedCities = new Set(places.map((p) => p.city).filter(Boolean)).size;

// 统计笔记本（排除 _index 文件）
const notebookFolders = new Set(
	notebookEntries
		.map((e) => {
			const id = e.id.replace(/\\/g, "/");
			const match = id.match(/^([^/]+)\//);
			return match ? match[1] : null;
		})
		.filter(Boolean),
);
const notebooksCount = notebookFolders.size;

// 统计日常规划
const routinesCount = routinesEntries.length;

// 格式化数字
function formatNumber(num: number): string {
	return num.toLocaleString();
}

// 构建统计数据
const stats = [
	{
		icon: "material-symbols:apartment",
		label: "去过城市",
		value: visitedCities,
	},
	{
		icon: "material-symbols:book-outline",
		label: "笔记本数",
		value: notebooksCount,
	},
	{
		icon: "material-symbols:location-on-outline",
		label: "足迹记录",
		value: placesCount,
	},
	{
		icon: "material-symbols:schedule-outline",
		label: "日常规划",
		value: routinesCount,
	},
];
---

<WidgetLayout name="生活统计" id="life-stats" class={className} style={style}>
	<div class="flex flex-col gap-2">
		{stats.map((stat) => (
			<div class="flex items-center justify-between px-3 py-1.5">
				<div class="flex items-center gap-2.5">
					<div class="text-(--primary) text-xl">
						<Icon name={stat.icon} />
					</div>
					<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm">
						{stat.label}
					</span>
				</div>
				<div class="flex items-center">
					<span class="text-base font-bold text-neutral-900 dark:text-neutral-100">
						{stat.value}
					</span>
					{stat.suffix && (
						<span class="text-sm text-neutral-500 dark:text-neutral-400 ml-1">
							{stat.suffix}
						</span>
					)}
				</div>
			</div>
		))}
	</div>
</WidgetLayout>
