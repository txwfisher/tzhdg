---
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { getCollection } from "astro:content";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

// 获取生活相关 collection
const lifeEntries = await getCollection("life");
const workoutEntries = await getCollection("lifeWorkout");
const sleepEntries = await getCollection("lifeSleep");
const foodEntries = await getCollection("lifeFood");
const notebookEntries = await getCollection("notebooks");
const checkinEntries = await getCollection("checkin");
const routinesEntries = await getCollection("routines");

// 辅助函数
const isIn = (entryId: string, folder: string) =>
	entryId.replace(/\\/g, "/").startsWith(`${folder}/`);

// 统计想法
const ideas = lifeEntries.filter((entry) => isIn(entry.id, "ideas")).map((e) => e.data);
const ideasDone = ideas.filter((item) => item.status === "done").length;
const ideasTotal = ideas.length;

// 统计打卡
const checkinCount = checkinEntries.length;
const totalCheckinCount = checkinEntries.reduce((acc, item) => acc + (item.data.count || 0), 0);

// 统计运动
const workouts = workoutEntries.map((e) => e.data);
const workoutCount = workouts.length;
const totalRunKm = workouts.reduce((acc, w) => acc + (w.runKm || 0), 0);
const totalWorkoutMins = workouts.reduce((acc, w) => acc + (w.workoutMinutes || 0), 0);

// 统计睡眠
const sleeps = sleepEntries.map((e) => e.data);
const sleepCount = sleeps.length;
const avgSleepHours = sleepCount > 0
	? sleeps.reduce((acc, s) => acc + (s.sleepHours || 0), 0) / sleepCount
	: 0;
const avgSleepQuality = sleepCount > 0
	? sleeps.reduce((acc, s) => acc + (s.sleepQuality || 3), 0) / sleepCount
	: 0;

// 统计饮食
const foods = foodEntries.map((e) => e.data);
const foodCount = foods.length;

// 统计地点
const places = lifeEntries.filter((entry) => isIn(entry.id, "places")).map((e) => e.data);
const placesCount = places.length;
const visitedCities = new Set(places.map((p) => p.city).filter(Boolean)).size;

// 统计笔记本（排除 _index 文件）
const notebookFolders = new Set(
	notebookEntries
		.map((e) => {
			const id = e.id.replace(/\\/g, "/");
			const match = id.match(/^([^/]+)\//);
			return match ? match[1] : null;
		})
		.filter(Boolean)
);
const notebooksCount = notebookFolders.size;

// 统计日常规划
const routinesCount = routinesEntries.length;

// 格式化数字
function formatNumber(num: number): string {
	return num.toLocaleString();
}

// 构建统计数据
const stats = [
	{
		icon: "material-symbols:favorite-outline",
		label: "想法完成",
		value: `${ideasDone}/${ideasTotal}`,
	},
	{
		icon: "material-symbols:straighten",
		label: "跑步里程",
		value: `${formatNumber(Math.round(totalRunKm * 10) / 10)} km`,
	},
	{
		icon: "material-symbols:timer-outline",
		label: "运动时长",
		value: `${formatNumber(totalWorkoutMins)} 分钟`,
	},
	{
		icon: "material-symbols:star-outline",
		label: "睡眠质量",
		value: avgSleepQuality.toFixed(1),
	},
	{
		icon: "material-symbols:apartment",
		label: "去过城市",
		value: visitedCities,
	},
	{
		icon: "material-symbols:book-outline",
		label: "笔记本数",
		value: notebooksCount,
	},
	{
		icon: "material-symbols:check-circle-outline",
		label: "打卡项目",
		value: checkinCount,
	},
	{
		icon: "material-symbols:event-available-outline",
		label: "打卡总数",
		value: formatNumber(totalCheckinCount),
	},
	{
		icon: "material-symbols:schedule-outline",
		label: "日常规划",
		value: routinesCount,
	},
];
---

<WidgetLayout name="生活统计" id="life-stats" class={className} style={style}>
	<div class="flex flex-col gap-2">
		{stats.map((stat) => (
			<div class="flex items-center justify-between px-3 py-1.5">
				<div class="flex items-center gap-2.5">
					<div class="text-(--primary) text-xl">
						<Icon name={stat.icon} />
					</div>
					<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm">
						{stat.label}
					</span>
				</div>
				<div class="flex items-center">
					<span class="text-base font-bold text-neutral-900 dark:text-neutral-100">
						{stat.value}
					</span>
					{stat.suffix && (
						<span class="text-sm text-neutral-500 dark:text-neutral-400 ml-1">
							{stat.suffix}
						</span>
					)}
				</div>
			</div>
		))}
	</div>
</WidgetLayout>