---
interface DataPoint {
	label: string;
	value: number;
}

interface Props {
	data: DataPoint[];
	label: string;
	color?: string;
	height?: number;
}

const { data, label, color = "var(--primary)", height = 80 } = Astro.props;

const maxVal = Math.max(...data.map((d) => d.value), 1);
const points = data
	.map((d, i) => {
		const x = (i / Math.max(data.length - 1, 1)) * 100;
		const y = 100 - (d.value / maxVal) * 100;
		return `${x},${y}`;
	})
	.join(" ");

const areaPoints = `0,100 ${points} 100,100`;
---

<div class="mini-chart">
  <div class="chart-header">
    <span class="chart-label">{label}</span>
    <span class="chart-latest">
      {data.length > 0 ? data[data.length - 1].value : 0}
    </span>
  </div>
  <svg viewBox="0 0 100 100" preserveAspectRatio="none" style={`height: ${height}px`}>
    <defs>
      <linearGradient id={`gradient-${label.replace(/\s/g, '')}`} x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color={color} stop-opacity="0.3" />
        <stop offset="100%" stop-color={color} stop-opacity="0.05" />
      </linearGradient>
    </defs>
    <polygon
      class="chart-area"
      points={areaPoints}
      fill={`url(#gradient-${label.replace(/\s/g, '')})`}
    />
    <polyline
      class="chart-line"
      points={points}
      stroke={color}
      fill="none"
    />
    {data.length > 0 && (
      <circle
        class="chart-dot"
        cx="100"
        cy={100 - (data[data.length - 1].value / maxVal) * 100}
        r="4"
        fill={color}
      />
    )}
  </svg>
  <div class="chart-footer">
    <span class="chart-range">
      {data.length > 0 ? data[0].label : ''} - {data.length > 0 ? data[data.length - 1].label : ''}
    </span>
  </div>
</div>

<style>
  .mini-chart {
    padding: 0.75rem;
    border: 1px solid var(--life-border);
    border-radius: var(--radius-large);
    background: var(--card-bg);
  }

  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .chart-label {
    font-size: 0.75rem;
    color: var(--content-meta);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .chart-latest {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-color);
  }

  svg {
    width: 100%;
    display: block;
  }

  .chart-line {
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .chart-dot {
    filter: drop-shadow(0 0 3px var(--primary));
  }

  .chart-footer {
    margin-top: 0.25rem;
    text-align: right;
  }

  .chart-range {
    font-size: 0.65rem;
    color: var(--content-meta);
    opacity: 0.7;
  }
</style>
