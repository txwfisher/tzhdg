<div
	id="page-loader"
	class="page-loader page-loader--visible"
	role="status"
	aria-live="polite"
	aria-label="Page loading"
>
	<div
		aria-label="Running animation"
		role="img"
		class="page-loader__animation"
	>
		<img
			src="/assets/images/loading/feibi-loading.webp"
			alt=""
			class="page-loader__image"
			width="960"
			height="540"
			decoding="async"
		/>
	</div>
	<span class="page-loader__sr-only">Loading</span>
</div>
