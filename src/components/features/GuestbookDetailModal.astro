---
---

<dialog id="guestbook-detail-modal" class="gb-detail-modal">
  <div class="gb-detail-overlay" data-close-detail></div>
  <div class="gb-detail-panel">
    <div class="corner-mark top-left"></div>
    <div class="corner-mark top-right"></div>
    <div class="corner-mark bottom-left"></div>
    <div class="corner-mark bottom-right"></div>

    <div class="detail-header">
      <div class="header-bg"></div>
      <div class="header-content">
        <div class="author-info">
          <div class="author-avatar"></div>
          <span class="author-name" id="detail-author"></span>
        </div>
        <span class="message-time" id="detail-time"></span>
      </div>
      <button class="btn-close" data-close-detail aria-label="关闭">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="detail-body">
      <div class="body-line"></div>
      <div class="body-content">
        <p class="detail-text" id="detail-content"></p>
      </div>
    </div>

    <div class="card-footer"></div>
  </div>
</dialog>

<script>
  function initModal() {
    const modal = document.getElementById('guestbook-detail-modal') as HTMLDialogElement | null;
    if (!modal) return;
    function close() { modal!.close(); document.body.style.overflow = ''; }

    window.addEventListener('guestbook:open-detail', (e) => {
      const card = (e as CustomEvent).detail;
      if (!card) return;
      document.getElementById('detail-author')!.textContent = card.author;
      document.getElementById('detail-time')!.textContent = card.time;
      document.getElementById('detail-content')!.textContent = card.content;
      modal.showModal();
      document.body.style.overflow = 'hidden';
    });

    modal.querySelectorAll('[data-close-detail]').forEach((el: Element) => el.addEventListener('click', close));
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
    modal.addEventListener('cancel', (e) => { e.preventDefault(); close(); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initModal);
  } else {
    initModal();
  }
  document.addEventListener('astro:page-load', initModal);
  document.addEventListener('swup:contentReplaced', initModal);
</script>

<style>
  .gb-detail-modal {
    position: fixed; inset: 0; z-index: 99999;
    display: none; align-items: center; justify-content: center;
    padding: 1rem; border: none; background: transparent;
    width: 100%; height: 100%; max-width: 100%; max-height: 100%; overflow: visible;
  }
  .gb-detail-modal[open] { display: flex; }
  .gb-detail-modal::backdrop { background: transparent; }

  .gb-detail-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.5); backdrop-filter: blur(6px); z-index: -1;
    animation: gbFadeIn 0.2s ease-out;
  }
  :root.dark .gb-detail-overlay { background: rgba(0,0,0,0.75); }

  .gb-detail-panel {
    position: relative; width: 90%; max-width: 720px;
    background: #fff; border: 2px solid #18181b; border-radius: 0.5rem;
    overflow: hidden; display: flex; flex-direction: column;
    animation: gbSlideIn 0.25s cubic-bezier(0.22,0.68,0.25,1);
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
  }
  :root.dark .gb-detail-panel {
    background: #1c1c1e; border-color: #3f3f46;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.05);
  }

  @keyframes gbFadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes gbSlideIn { from { opacity: 0; transform: scale(0.92) translateY(12px); } to { opacity: 1; transform: scale(1) translateY(0); } }

  .corner-mark {
    position: absolute; width: 0.5rem; height: 0.5rem; border-radius: 50%;
    border: 1px solid #18181b; background: #f4f4f5; z-index: 20;
  }
  :root.dark .corner-mark { border-color: #3f3f46; background: #27272a; }
  .corner-mark::after {
    content: ""; position: absolute; inset: 0; margin: auto;
    width: 60%; height: 1px; background: #18181b; transform: rotate(45deg);
  }
  :root.dark .corner-mark::after { background: #52525b; }
  .corner-mark.top-left { top: 0.5rem; left: 0.5rem; }
  .corner-mark.top-right { top: 0.5rem; right: 0.5rem; }
  .corner-mark.bottom-left { bottom: 0.5rem; left: 0.5rem; }
  .corner-mark.bottom-right { bottom: 0.5rem; right: 0.5rem; }

  .detail-header {
    position: relative; height: 4rem; border-bottom: 2px solid #18181b;
    padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; overflow: hidden;
  }
  :root.dark .detail-header { border-color: #3f3f46; }
  .header-bg {
    position: absolute; inset: 0; opacity: 0.06; pointer-events: none;
    background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, #18181b 5px, #18181b 10px);
  }
  :root.dark .header-bg {
    background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, #fafafa 5px, #fafafa 10px);
  }
  .header-content {
    position: relative; z-index: 10; display: flex; align-items: center;
    justify-content: space-between; width: 100%;
  }
  .author-info { display: flex; align-items: center; gap: 0.5rem; }
  .author-avatar {
    width: 0.75rem; height: 0.75rem; background: #18181b; border-radius: 0.125rem;
    animation: pulse 2s cubic-bezier(0.4,0,0.6,1) infinite;
  }
  :root.dark .author-avatar { background: #fafafa; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
  .author-name {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.15em;
    text-transform: uppercase; color: #18181b;
  }
  :root.dark .author-name { color: #fafafa; }
  .message-time {
    font-size: 0.65rem; font-family: ui-monospace,monospace; opacity: 0.6; color: #52525b;
  }
  :root.dark .message-time { color: #a1a1aa; }

  .detail-body { position: relative; padding: 2rem; display: flex; overflow: hidden; }
  .body-line { position: absolute; left: 1rem; top: 1.5rem; bottom: 1.5rem; width: 1px; background: #d4d4d8; }
  :root.dark .body-line { background: #3f3f46; }
  .body-content { padding-left: 1rem; flex: 1; display: flex; flex-direction: column; overflow: hidden; }
  .detail-text {
    font-size: 1rem; line-height: 1.9; font-family: ui-monospace,monospace;
    color: #52525b; white-space: pre-wrap; word-break: break-word;
    max-height: 60vh; overflow-y: auto;
  }
  :root.dark .detail-text { color: #d4d4d8; }

  .card-footer {
    height: 2.5rem; border-top: 2px solid #18181b; display: flex;
    align-items: center; padding: 0 2rem; background: #18181b;
  }
  :root.dark .card-footer { border-color: #3f3f46; background: #fafafa; }

  .btn-close {
    position: absolute; top: 0.75rem; right: 0.75rem; z-index: 20;
    width: 1.5rem; height: 1.5rem; background: none; border: none; cursor: pointer;
    color: #52525b; padding: 0; display: flex; align-items: center; justify-content: center; transition: color 0.2s;
  }
  :root.dark .btn-close { color: #a1a1aa; }
  .btn-close:hover { color: #18181b; }
  :root.dark .btn-close:hover { color: #fafafa; }
  .btn-close svg { width: 1rem; height: 1rem; }

  @media (max-width: 640px) {
    .gb-detail-panel { max-width: 100%; width: 95%; }
    .detail-body { padding: 1.25rem; }
    .detail-text { font-size: 0.9rem; }
    .detail-header { padding: 0 1.25rem; }
    .card-footer { padding: 0 1.25rem; }
  }
</style>
