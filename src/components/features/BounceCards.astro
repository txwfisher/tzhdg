---
interface Props {
	images?: string[];
	containerWidth?: number;
	containerHeight?: number;
	animationDelay?: number;
	animationStagger?: number;
	enableHover?: boolean;
	transformStyles?: string[];
	id?: string;
}

const {
	images = [],
	containerWidth = 400,
	containerHeight = 400,
	animationDelay = 0.5,
	animationStagger = 0.06,
	enableHover = true,
	transformStyles: customTransforms,
	id: customId,
} = Astro.props;

const defaultTransforms = [
	"rotate(10deg) translate(-170px)",
	"rotate(5deg) translate(-85px)",
	"rotate(-3deg)",
	"rotate(-10deg) translate(85px)",
	"rotate(2deg) translate(170px)",
];

const transforms =
	customTransforms || defaultTransforms.slice(0, images.length);
const widgetId = customId || `bc-${Math.random().toString(36).substring(2, 9)}`;
---

<div
  class="bounce-cards-container"
  id={widgetId}
  style={`width: ${containerWidth}px; height: ${containerHeight}px;`}
  data-hover={enableHover ? "true" : "false"}
  data-transforms={JSON.stringify(transforms)}
>
  {images.map((src, idx) => (
    <div
      class={`bounce-card`}
      data-index={idx}
      data-base-transform={transforms[idx] ?? "none"}
      style={`transform: ${transforms[idx] ?? "none"}; animation-delay: ${animationDelay + idx * animationStagger}s;`}
    >
      <img src={src} alt="" loading="lazy" />
    </div>
  ))}
</div>

<style>
  .bounce-cards-container {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .bounce-card {
    position: absolute;
    width: 200px;
    aspect-ratio: 1;
    border: 5px solid #fff;
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    animation: bounce-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  :root.dark .bounce-card {
    border-color: #2a2a2e;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
  }

  .bounce-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes bounce-in {
    0% { scale: 0; opacity: 0; }
    60% { scale: 1.1; opacity: 1; }
    100% { scale: 1; opacity: 1; }
  }
</style>

<script>
  import { gsap } from "gsap";

  function bindHover(container: HTMLElement) {
    if (container.dataset.hover !== "true") return;
    if ((container as any)._hoverBound) return;
    (container as any)._hoverBound = true;

    const cards = container.querySelectorAll(".bounce-card");

    cards.forEach((card) => {
      const el = card as HTMLElement;
      const idx = parseInt(el.dataset.index || "0");

      el.addEventListener("mouseenter", () => {
        cards.forEach((c) => {
          const target = c as HTMLElement;
          const i = parseInt(target.dataset.index || "0");
          const baseTransform = target.dataset.baseTransform || "none";

          gsap.killTweensOf(target);

          if (i === idx) {
            const noRotation = baseTransform.replace(/rotate\([\s\S]*?\)/, "rotate(0deg)");
            gsap.to(target, {
              transform: noRotation,
              duration: 0.4,
              ease: "back.out(1.4)",
              overwrite: "auto",
            });
          } else {
            const offsetX = i < idx ? -80 : 80;
            const translateRegex = /translate\(([-0-9.]+)px\)/;
            const match = baseTransform.match(translateRegex);
            let pushedTransform: string;
            if (match) {
              const newX = parseFloat(match[1]) + offsetX;
              pushedTransform = baseTransform.replace(translateRegex, `translate(${newX}px)`);
            } else {
              pushedTransform = baseTransform === "none"
                ? `translate(${offsetX}px)`
                : `${baseTransform} translate(${offsetX}px)`;
            }

            const distance = Math.abs(idx - i);
            gsap.to(target, {
              transform: pushedTransform,
              duration: 0.4,
              ease: "back.out(1.4)",
              delay: distance * 0.05,
              overwrite: "auto",
            });
          }
        });
      });

      el.addEventListener("mouseleave", () => {
        cards.forEach((c) => {
          const target = c as HTMLElement;
          const baseTransform = target.dataset.baseTransform || "none";
          gsap.killTweensOf(target);
          gsap.to(target, {
            transform: baseTransform,
            duration: 0.4,
            ease: "back.out(1.4)",
            overwrite: "auto",
          });
        });
      });
    });
  }

  function initAll() {
    document.querySelectorAll(".bounce-cards-container").forEach((el) => {
      bindHover(el as HTMLElement);
    });
  }

  // 首次加载
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAll);
  } else {
    initAll();
  }

  // Swup 页面切换后重新初始化
  document.addEventListener("astro:page-load", initAll);
</script>
