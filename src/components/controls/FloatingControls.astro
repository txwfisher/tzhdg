---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import PostDirectoryList from "@/components/widget/PostDirectoryList.astro";
import { getTagList } from "@/utils/content-utils";
import { getTagUrl, url } from "@/utils/url-utils";

interface Props {
	currentSlug?: string;
}

const { currentSlug = "" } = Astro.props;
const isPostPage = Boolean(currentSlug);
const sortedTags = (await getTagList()).sort((a, b) => b.count - a.count);

function tagHue(name: string): number {
	let hash = 0;
	for (let i = 0; i < name.length; i++) {
		hash = name.charCodeAt(i) + ((hash << 5) - hash);
	}
	return Math.abs(hash % 360);
}
---

<div
	class="fab-container"
	id="fab-container"
	data-home-url={url("/")}
	data-notebook-url={url("/life/notebooks/")}
>
	<div class="fab-menu" id="fab-menu">
		<button
			class="fab-item"
			type="button"
			data-fab-action="posts"
			aria-label="全部文章"
			title="全部文章"
		>
			<Icon name="material-symbols:account-tree-outline-rounded" />
		</button>
		<button
			class:list={["fab-item", { hide: !isPostPage }]}
			type="button"
			data-fab-action="toc"
			aria-label={i18n(I18nKey.tableOfContents)}
			title={i18n(I18nKey.tableOfContents)}
		>
			<Icon name="material-symbols:format-list-bulleted-rounded" />
		</button>
		<button
			class="fab-item"
			type="button"
			data-fab-action="tags"
			aria-label={i18n(I18nKey.tags)}
			title={i18n(I18nKey.tags)}
		>
			<Icon name="material-symbols:label-outline-rounded" />
		</button>
		<button
			class:list={["fab-item", { hide: !isPostPage }]}
			type="button"
			data-fab-action="comment"
			aria-label="评论区"
			title="评论区"
		>
			<Icon name="material-symbols:chat-bubble-outline-rounded" />
		</button>
		<button
			class="fab-item"
			type="button"
			data-fab-action="notebook"
			aria-label="笔记本"
			title="笔记本"
		>
			<Icon name="material-symbols:book-outline-rounded" />
		</button>
		<button
			class="fab-item"
			type="button"
			data-fab-action="home"
			aria-label={i18n(I18nKey.home)}
			title={i18n(I18nKey.home)}
		>
			<Icon name="material-symbols:home-outline-rounded" />
		</button>
		<button
			class="fab-item"
			type="button"
			data-fab-action="top"
			aria-label="回到顶部"
			title="回到顶部"
		>
			<Icon name="material-symbols:keyboard-arrow-up-rounded" />
		</button>
	</div>

	<button
		class="fab-trigger"
		id="fab-trigger"
		type="button"
		data-fab-action="toggle"
		aria-label="快捷操作"
		title="快捷操作"
		aria-expanded="false"
	>
		<Icon name="material-symbols:apps" />
	</button>

	<div
		id="floating-posts-panel"
		class="fab-panel fab-panel-side hide"
		aria-label="全部文章"
	>
		<div class="fab-panel-header">
			<h3>
				<Icon name="material-symbols:account-tree-outline-rounded" />
				<span>全部文章</span>
			</h3>
			<button
				type="button"
				data-fab-action="close-posts"
				aria-label="关闭全部文章"
				class="btn-plain rounded-lg h-8 w-8 active:scale-90"
			>
				<Icon name="material-symbols:close" />
			</button>
		</div>
		<div class="fab-panel-body">
			<PostDirectoryList currentSlug={currentSlug} />
		</div>
	</div>

	<div
		id="floating-toc-panel"
		class="fab-panel fab-panel-side hide"
		aria-label={i18n(I18nKey.tableOfContents)}
	>
		<div class="fab-panel-header">
			<h3>
				<Icon name="material-symbols:format-list-bulleted-rounded" />
				<span>{i18n(I18nKey.tableOfContents)}</span>
			</h3>
			<button
				type="button"
				data-fab-action="close-toc"
				aria-label="关闭目录"
				class="btn-plain rounded-lg h-8 w-8 active:scale-90"
			>
				<Icon name="material-symbols:close" />
			</button>
		</div>
		<div class="toc-scroll-container fab-panel-body">
			<div class="toc-content" id="floating-toc-content"></div>
		</div>
	</div>

	<div
		id="floating-tags-panel"
		class="fab-panel fab-panel-bottom hide"
		aria-label={i18n(I18nKey.tags)}
	>
		<div class="fab-panel-header">
			<h3>
				<Icon name="material-symbols:label-outline-rounded" />
				<span>所有标签</span>
			</h3>
			<button
				type="button"
				data-fab-action="close-tags"
				aria-label="关闭标签"
				class="btn-plain rounded-lg h-8 w-8 active:scale-90"
			>
				<Icon name="material-symbols:close" />
			</button>
		</div>
		<div class="tags-scroll-container fab-panel-body">
			<div class="floating-tags-content">
				{sortedTags.map((tag) => {
					const hue = tagHue(tag.name);
					return (
						<a
							href={getTagUrl(tag.name)}
							class="floating-tag-chip"
							style={`--tag-hue: ${hue}; --tag-light: oklch(0.92 0.04 ${hue}); --tag-dark: oklch(0.25 0.04 ${hue})`}
						>
							<span class="floating-tag-name">{tag.name}</span>
							<span class="floating-tag-count">{tag.count}</span>
						</a>
					);
				})}
			</div>
		</div>
	</div>
</div>

<style>
	.fab-container {
		position: fixed;
		z-index: 1000;
		right: 1rem;
		bottom: 4rem;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.55rem;
	}

	.fab-menu {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.5rem;
		opacity: 0;
		transform: translateY(10px) scale(0.98);
		pointer-events: none;
		visibility: hidden;
		transition:
			opacity 0.2s ease,
			transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
			visibility 0s 0.25s;
	}

	.fab-container.expanded .fab-menu {
		opacity: 1;
		transform: translateY(0) scale(1);
		pointer-events: auto;
		visibility: visible;
		transition:
			opacity 0.2s ease,
			transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
			visibility 0s 0s;
	}

	.fab-item,
	.fab-trigger {
		width: 3rem;
		height: 3rem;
		border-radius: 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		border: 1px solid rgba(0, 0, 0, 0.1);
		background: var(--card-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		cursor: pointer;
		pointer-events: auto;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			color 0.2s ease,
			background-color 0.2s ease;
	}

	.fab-item {
		color: var(--primary);
		font-size: 1.45rem;
	}

	.fab-trigger {
		color: var(--deep-text);
		font-size: 1.55rem;
	}

	.fab-item:hover,
	.fab-trigger:hover {
		color: var(--primary);
		transform: translateY(-1px) scale(1.04);
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15);
	}

	.fab-item:active,
	.fab-trigger:active {
		transform: scale(0.92);
	}

    .fab-item.hide { display: none !important; }
	.fab-container.expanded .fab-trigger {
		color: var(--primary);
		transform: rotate(45deg);
	}


	html.dark .fab-item,
	html.dark .fab-trigger {
		border-color: rgba(255, 255, 255, 0.15);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
	}

	html.dark .fab-item:hover,
	html.dark .fab-trigger:hover {
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
	}

	.fab-panel {
		width: 22rem;
		max-width: calc(100vw - 2rem);
		max-height: min(34rem, calc(100vh - 8rem));
		overflow: hidden;
		border-radius: 1rem;
		border: 1px solid rgba(0, 0, 0, 0.08);
		background: var(--card-bg);
		box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.18);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		z-index: 1001;
	}

	html.dark .fab-panel {
		border-color: rgba(255, 255, 255, 0.12);
		box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.35);
	}

	.fab-panel-side {
		position: absolute;
		right: calc(100% + 0.75rem);
		bottom: 0;
		transform: translateX(10px);
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 0.25s ease,
			transform 0.25s ease,
			visibility 0s 0.25s;
	}

	.fab-panel-bottom {
		position: fixed;
		left: 50%;
		bottom: 5.5rem;
		transform: translateX(-50%) translateY(16px);
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 0.25s ease,
			transform 0.25s ease,
			visibility 0s 0.25s;
	}

	.fab-panel-side.show {
		transform: translateX(0);
		opacity: 1;
		pointer-events: auto;
		visibility: visible;
		transition:
			opacity 0.25s ease,
			transform 0.25s ease,
			visibility 0s 0s;
	}

	.fab-panel-bottom.show {
		transform: translateX(-50%) translateY(0);
		opacity: 1;
		pointer-events: auto;
		visibility: visible;
		transition:
			opacity 0.25s ease,
			transform 0.25s ease,
			visibility 0s 0s;
	}

	.fab-panel.hide {
		opacity: 0;
		pointer-events: none;
		visibility: hidden;
	}

	.fab-panel-header {
		position: sticky;
		top: 0;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.85rem 1rem;
		border-bottom: 1px solid var(--line-divider);
		background: var(--card-bg);
	}

	.fab-panel-header h3 {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		margin: 0;
		min-width: 0;
		color: var(--primary);
		font-size: 1rem;
		font-weight: 800;
		line-height: 1.2;
	}

	.fab-panel-header svg {
		font-size: 1.25rem;
		flex: 0 0 auto;
	}

	.fab-panel-body {
		max-height: calc(min(34rem, 100vh - 8rem) - 3.75rem);
		overflow-y: auto;
		padding: 0.75rem;
	}

	.toc-scroll-container,
	.tags-scroll-container {
		max-height: calc(min(34rem, 100vh - 8rem) - 3.75rem);
	}

	.floating-tags-content {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.floating-tag-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.4rem 0.7rem;
		border-radius: 0.6rem;
		font-size: 0.85rem;
		font-weight: 500;
		line-height: 1.3;
		text-decoration: none;
		color: var(--deep-text);
		background: var(--tag-light);
		border: 1px solid transparent;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease;
	}

	.floating-tag-chip:hover {
		transform: translateY(-1px);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		border-color: var(--primary);
		color: var(--primary);
	}

	.floating-tag-chip:active {
		transform: scale(0.96);
	}

	.floating-tag-count {
		min-width: 1.2rem;
		padding: 0.1rem 0.4rem;
		border-radius: 999px;
		background: rgba(0, 0, 0, 0.06);
		font-size: 0.7rem;
		font-weight: 700;
		text-align: center;
		opacity: 0.6;
	}

	html.dark .floating-tag-chip {
		background: var(--tag-dark);
	}

	html.dark .floating-tag-count {
		background: rgba(255, 255, 255, 0.1);
	}

	@media (max-width: 768px) {
		.fab-container {
			right: 0.75rem;
			bottom: 4rem;
		}

		.fab-trigger,
		.fab-item {
			width: 2.75rem;
			height: 2.75rem;
			border-radius: 0.875rem;
			font-size: 1.35rem;
		}

		.fab-panel-side,
		.fab-panel-bottom {
			position: fixed;
			left: 50%;
			right: auto;
			bottom: 5.25rem;
			width: calc(100vw - 1.25rem);
			max-height: min(34rem, calc(100vh - 7rem));
			transform: translateX(-50%) translateY(16px);
		}

		.fab-panel-side.show,
		.fab-panel-bottom.show {
			transform: translateX(-50%) translateY(0);
		}
	}

	@media (max-width: 480px) {
		.fab-container {
			right: 0.5rem;
			bottom: 4rem;
		}

		.fab-trigger,
		.fab-item {
			width: 2.5rem;
			height: 2.5rem;
			border-radius: 0.75rem;
			font-size: 1.22rem;
		}

		.fab-panel-header {
			padding: 0.75rem 0.85rem;
		}

		.fab-panel-body {
			padding: 0.65rem;
		}
	}
</style>

<script is:inline>
	(function () {
		var script = document.currentScript;
		var localRoot = script && script.parentElement;
		var initialContainer = localRoot
			? localRoot.querySelector(".fab-container")
			: document.querySelector(".fab-container");

		if (initialContainer) {
			document.querySelectorAll(".fab-container").forEach(function (item) {
				if (item !== initialContainer) item.remove();
			});
			if (initialContainer.parentElement !== document.body) {
				document.body.appendChild(initialContainer);
			}
			window.__fireflyFabContainer = initialContainer;
		}

		function getContainer() {
			return window.__fireflyFabContainer || document.querySelector(".fab-container");
		}

		function isPostPage() {
			return window.location.pathname.replace(/\/$/, "").indexOf("/posts/") === 0;
		}

		function setExpanded(container, expanded) {
			if (!container) return;
			container.classList.toggle("expanded", expanded);
			var trigger = container.querySelector("[data-fab-action='toggle']");
			if (trigger) trigger.setAttribute("aria-expanded", expanded ? "true" : "false");
		}

		function closePanel(id) {
			var panel = document.getElementById(id);
			if (!panel) return;
			panel.classList.remove("show");
			panel.classList.add("hide");
		}

		function closePanels(exceptId) {
			["floating-posts-panel", "floating-toc-panel", "floating-tags-panel"].forEach(function (id) {
				if (id !== exceptId) closePanel(id);
			});
		}

		function togglePanel(id) {
			var panel = document.getElementById(id);
			if (!panel) return;
			var shouldShow = panel.classList.contains("hide") || !panel.classList.contains("show");
			closePanels(shouldShow ? id : "");
			panel.classList.toggle("hide", !shouldShow);
			panel.classList.toggle("show", shouldShow);
		}

		function navigateTo(url) {
			if (!url) return;
			if (window.swup) {
				window.swup.navigate(url);
			} else {
				window.location.href = url;
			}
		}

		function refreshFloatingControls() {
			var container = getContainer();
			if (!container) return;

			var onPost = isPostPage();
			var onHome = window.location.pathname === "/" || window.location.pathname === "";
			var toc = container.querySelector("[data-fab-action='toc']");
			var comment = container.querySelector("[data-fab-action='comment']");
			var home = container.querySelector("[data-fab-action='home']");
			if (toc) toc.classList.toggle("hide", !onPost);
			if (comment) comment.classList.toggle("hide", !onPost);
			if (home) home.classList.toggle("hide", onHome);
			if (!onPost) closePanel("floating-toc-panel");
			setExpanded(container, false);
		}

		window.fireflyRefreshFloatingControls = refreshFloatingControls;

		if (!window.__fireflyFloatingControlsBound) {
			window.__fireflyFloatingControlsBound = true;

			document.addEventListener("click", function (event) {
				var target = event.target instanceof Element ? event.target : null;
				if (!target) return;

				var actionButton = target.closest("[data-fab-action]");
				var container = getContainer();

				if (actionButton) {
					var action = actionButton.getAttribute("data-fab-action");
					container = actionButton.closest(".fab-container") || container;

					if (!container || !action) return;
					event.stopPropagation();

					if (action === "toggle") {
						setExpanded(container, !container.classList.contains("expanded"));
						return;
					}

					setExpanded(container, false);

					if (action === "top") {
						window.scroll({ top: 0, behavior: "smooth" });
						return;
					}

					if (action === "home") {
						navigateTo(container.dataset.homeUrl || "/");
						return;
					}

					if (action === "notebook") {
						navigateTo(container.dataset.notebookUrl || "/life/notebooks/");
						return;
					}

					if (action === "comment") {
						var commentTarget =
							document.getElementById("scissor-divider") ||
							document.querySelector("[id*='comment']");
						if (commentTarget) {
							commentTarget.scrollIntoView({ behavior: "smooth", block: "start" });
						} else {
							window.scrollTo({ top: document.body.scrollHeight * 0.85, behavior: "smooth" });
						}
						return;
					}

					if (action === "posts") {
						togglePanel("floating-posts-panel");
						if (window.fireflyUpdatePostDirectories) {
							setTimeout(window.fireflyUpdatePostDirectories, 30);
						}
						return;
					}

					if (action === "toc") {
						togglePanel("floating-toc-panel");
						return;
					}

					if (action === "tags") {
						togglePanel("floating-tags-panel");
						return;
					}

					if (action === "close-posts") {
						closePanel("floating-posts-panel");
						return;
					}

					if (action === "close-toc") {
						closePanel("floating-toc-panel");
						return;
					}

					if (action === "close-tags") {
						closePanel("floating-tags-panel");
					}
					return;
				}

				if (!container) return;

				var clickedPanel = target.closest(".fab-panel");
				if (!container.contains(target)) {
					setExpanded(container, false);
				}
				if (!clickedPanel && !target.closest(".fab-container")) {
					closePanels("");
				}
			});

			document.addEventListener("astro:page-load", function () {
				setTimeout(refreshFloatingControls, 60);
			});
			document.addEventListener("swup:contentReplaced", function () {
				setTimeout(refreshFloatingControls, 60);
			});
			window.addEventListener("popstate", function () {
				setTimeout(refreshFloatingControls, 60);
			});
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", refreshFloatingControls, { once: true });
		} else {
			setTimeout(refreshFloatingControls, 0);
		}
	})();
</script>

<script>
	import { TOCManager } from "@/utils/tocUtils";

	const floatingTOCState = ((window as any).__fireflyFloatingTOC ??= {
		manager: null,
	});

	function initFloatingTOC() {
		const tocContent = document.getElementById("floating-toc-content");
		if (!tocContent) return;

		try {
			if (floatingTOCState.manager) {
				floatingTOCState.manager.cleanup();
			}

			floatingTOCState.manager = new TOCManager({
				contentId: "floating-toc-content",
				indicatorId: "floating-active-indicator",
				maxLevel: 3,
				scrollOffset: 80,
			});
			floatingTOCState.manager.init();
		} catch (error) {
			console.error("Floating TOC init failed:", error);
		}
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initFloatingTOC);
	} else {
		initFloatingTOC();
	}

	document.addEventListener("astro:page-load", () => {
		setTimeout(initFloatingTOC, 100);
	});
	document.addEventListener("swup:contentReplaced", () => {
		setTimeout(initFloatingTOC, 100);
	});
</script>
