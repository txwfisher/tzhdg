---
import { Icon } from "astro-icon/components";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	links: NavBarLink[];
	siteTitle?: string;
	siteLogo?: string;
}

const { siteTitle = "博客导航", siteLogo } = Astro.props;

const mobileExcludeUrls = ["/archive/", "/categories/"];

const processedLinks = Astro.props.links
	.filter((link: NavBarLink) => {
		const linkUrl = link.url || "";
		return !mobileExcludeUrls.includes(linkUrl);
	})
	.map((link: NavBarLink) => ({
		...link,
		children: link.children?.map((child: NavBarLink | LinkPreset): NavBarLink => {
			if (typeof child === "number") return LinkPresets[child];
			return child;
		}),
	}));
---

<div id="nav-menu-overlay" class="nav-drawer-overlay"></div>

<div
	id="nav-menu-panel"
	class="nav-drawer-panel"
	data-drawer-side="right"
	data-menu-open="false"
	role="dialog"
	aria-modal="true"
	aria-label="导航菜单"
	aria-hidden="true"
>
	<!-- 头部 -->
	<div class="nav-drawer-header">
		<span class="nav-drawer-title">{siteTitle}</span>
		<button class="nav-drawer-close" aria-label="关闭菜单" id="nav-menu-close">
			<Icon name="material-symbols:close" class="text-xl" />
		</button>
	</div>

	<!-- 菜单列表 -->
	<nav class="nav-drawer-content">
		{processedLinks.map((link) => (
			<div>
				{link.children && link.children.length > 0 ? (
					<div class="nav-drawer-dropdown" data-mobile-dropdown>
						<button
							class="nav-drawer-link"
							data-mobile-dropdown-trigger
							aria-expanded="false"
						>
							{link.icon && <Icon name={link.icon} class="nav-drawer-link-icon" />}
							<span class="nav-drawer-link-text">{link.name}</span>
							<Icon name="material-symbols:chevron-right-rounded" class="nav-drawer-arrow" />
						</button>
						<div class="nav-drawer-submenu" data-mobile-submenu>
							{link.children.map((child) => (
								<a
									href={child.external ? child.url : url(child.url)}
									class="nav-drawer-sublink"
									target={child.external ? "_blank" : undefined}
								>
									{child.icon && <Icon name={child.icon} class="nav-drawer-link-icon sub-icon" />}
									<span>{child.name}</span>
								</a>
							))}
						</div>
					</div>
				) : (
					<a
						href={link.external ? link.url : url(link.url)}
						class="nav-drawer-link"
						target={link.external ? "_blank" : undefined}
					>
						{link.icon && <Icon name={link.icon} class="nav-drawer-link-icon" />}
						<span class="nav-drawer-link-text">{link.name}</span>
					</a>
				)}
			</div>
		))}
	</nav>
</div>

<style>
	@reference "../../styles/main.css";

	/* 遮罩 */
	.nav-drawer-overlay {
		position: fixed; inset: 0; z-index: 998;
		background: rgba(0, 0, 0, 0.35);
		opacity: 0; visibility: hidden; pointer-events: none;
		transition: opacity 0.25s ease, visibility 0.25s ease;
	}
	.nav-drawer-overlay.active {
		opacity: 1; visibility: visible; pointer-events: auto;
	}

	/* 面板 */
	.nav-drawer-panel {
		position: fixed; top: 0; right: 0; bottom: 0;
		width: min(82vw, 20rem);
		height: 100dvh;
		background: var(--page-bg);
		box-shadow: -8px 0 30px rgba(0, 0, 0, 0.1);
		transform: translate3d(100%, 0, 0);
		transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 999;
		display: flex; flex-direction: column;
	}
	.nav-drawer-panel[data-menu-open="true"] { transform: translate3d(0, 0, 0); }

	.nav-drawer-panel[data-drawer-side="left"] {
		left: 0; right: auto;
		box-shadow: 8px 0 30px rgba(0, 0, 0, 0.1);
		transform: translate3d(-100%, 0, 0);
	}
	.nav-drawer-panel[data-drawer-side="left"][data-menu-open="true"] { transform: translate3d(0, 0, 0); }

	@media (min-width: 1024px) {
		.nav-drawer-overlay, .nav-drawer-panel { display: none !important; }
	}

	@media (max-width: 420px) {
		.nav-drawer-panel { width: min(88vw, 18rem); }
	}

	/* 头部 */
	.nav-drawer-header {
		display: flex; align-items: center; justify-content: space-between;
		padding: 1rem 1.25rem;
		border-bottom: 1px solid var(--line-divider);
		flex-shrink: 0;
	}
	.nav-drawer-title {
		font-size: 1rem; font-weight: 600;
		color: var(--text-color);
	}
	.nav-drawer-close {
		display: flex; align-items: center; justify-content: center;
		width: 2.25rem; height: 2.25rem; border-radius: 0.5rem;
		color: var(--content-meta);
		transition: background 0.15s, color 0.15s;
	}
	.nav-drawer-close:hover { background: var(--btn-regular-bg); color: var(--text-color); }

	/* 内容区 */
	.nav-drawer-content {
		flex: 1; overflow-y: auto; padding: 0.5rem 0.75rem;
	}

	/* 链接项 */
	.nav-drawer-link {
		display: flex; align-items: center; gap: 0.625rem;
		width: 100%; padding: 0.7rem 0.75rem;
		border-radius: 0.5rem;
		font-size: 0.9375rem; font-weight: 500;
		color: var(--text-color); text-decoration: none;
		transition: background 0.15s, color 0.15s;
		cursor: pointer;
	}
	.nav-drawer-link:hover { background: var(--btn-regular-bg); }
	.nav-drawer-link:active { background: var(--btn-regular-bg-active); }

	.nav-drawer-link-icon {
		font-size: 1.25rem; color: var(--content-meta); flex-shrink: 0;
		transition: color 0.15s;
	}
	.nav-drawer-link:hover .nav-drawer-link-icon { color: var(--primary); }

	.nav-drawer-link-text { flex: 1; text-align: left; }

	.nav-drawer-arrow {
		font-size: 1.2rem; color: var(--content-meta); flex-shrink: 0;
		transition: transform 0.2s ease, color 0.15s;
	}
	.nav-drawer-dropdown[data-expanded="true"] .nav-drawer-arrow {
		transform: rotate(90deg); color: var(--primary);
	}
	.nav-drawer-dropdown[data-expanded="true"] > .nav-drawer-link {
		color: var(--primary); background: var(--btn-regular-bg);
	}

	/* 子菜单 */
	.nav-drawer-submenu {
		max-height: 0; overflow: hidden;
		transition: max-height 0.25s ease;
		padding-left: 2.25rem;
	}
	.nav-drawer-dropdown[data-expanded="true"] .nav-drawer-submenu {
		max-height: 20rem;
	}

	.nav-drawer-sublink {
		display: flex; align-items: center; gap: 0.5rem;
		padding: 0.55rem 0.75rem;
		border-radius: 0.375rem;
		font-size: 0.875rem; font-weight: 400;
		color: var(--content-meta); text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}
	.nav-drawer-sublink:hover { background: var(--btn-regular-bg); color: var(--primary); }
	.nav-drawer-sublink:active { background: var(--btn-regular-bg-active); }

	.sub-icon { font-size: 1.1rem !important; }

	/* 暗色 */
	:global(html.dark) .nav-drawer-panel {
		box-shadow: -8px 0 30px rgba(0, 0, 0, 0.35);
	}
	:global(html.dark) .nav-drawer-link-icon { color: var(--content-meta); }
</style>

<script>
	let isMenuOpen = false;
	let pageTransitionTimer;

	function getPanel() { return document.getElementById("nav-menu-panel"); }
	function getOverlay() { return document.getElementById("nav-menu-overlay"); }
	function getSwitch() { return document.getElementById("nav-menu-switch"); }

	function ensureMenuPortal() {
		var panel = getPanel();
		var overlay = getOverlay();
		if (!panel || !overlay || !document.body) return;
		var portal = document.getElementById("nav-menu-portal");
		if (!portal) {
			portal = document.createElement("div");
			portal.id = "nav-menu-portal";
			document.body.appendChild(portal);
		}
		if (overlay.parentElement !== portal) portal.appendChild(overlay);
		if (panel.parentElement !== portal) portal.appendChild(panel);
	}

	function resetDropdowns() {
		var list = document.querySelectorAll("[data-mobile-dropdown]");
		for (var i = 0; i < list.length; i++) {
			list[i].setAttribute("data-expanded", "false");
			var t = list[i].querySelector("[data-mobile-dropdown-trigger]");
			if (t) t.setAttribute("aria-expanded", "false");
		}
	}

	function openMenu() {
		ensureMenuPortal();
		resetDropdowns();
		var panel = getPanel();
		var overlay = getOverlay();
		if (panel) { panel.setAttribute("data-menu-open", "true"); panel.removeAttribute("aria-hidden"); }
		if (overlay) overlay.classList.add("active");
		document.body.style.overflow = "hidden";
		isMenuOpen = true;
	}

	function closeMenu() {
		var panel = getPanel();
		var overlay = getOverlay();
		var btn = getSwitch();
		if (panel) {
			panel.setAttribute("data-menu-open", "false");
			panel.setAttribute("aria-hidden", "true");
		}
		if (overlay) overlay.classList.remove("active");
		document.body.style.overflow = "";
		isMenuOpen = false;
		resetDropdowns();
	}

	function toggleMenu() { isMenuOpen ? closeMenu() : openMenu(); }

	function handleDropdownClick(e) {
		var trigger = e.target.closest("[data-mobile-dropdown-trigger]");
		if (!trigger) return;
		e.preventDefault();
		var dd = trigger.closest("[data-mobile-dropdown]");
		if (!dd) return;
		var expanded = dd.getAttribute("data-expanded") === "true";
		// 收起其他
		var all = document.querySelectorAll("[data-mobile-dropdown]");
		for (var i = 0; i < all.length; i++) {
			if (all[i] !== dd) {
				all[i].setAttribute("data-expanded", "false");
				var ot = all[i].querySelector("[data-mobile-dropdown-trigger]");
				if (ot) ot.setAttribute("aria-expanded", "false");
			}
		}
		dd.setAttribute("data-expanded", String(!expanded));
		trigger.setAttribute("aria-expanded", String(!expanded));
	}

	function handleClick(e) {
		var el = e.target;
		if (el.closest("#nav-menu-switch")) { e.preventDefault(); e.stopPropagation(); toggleMenu(); return; }
		if (el.id === "nav-menu-overlay" || el.classList.contains("nav-drawer-overlay")) { e.preventDefault(); closeMenu(); return; }
		if (el.closest("#nav-menu-close")) { e.preventDefault(); closeMenu(); return; }
		if (el.closest("[data-mobile-dropdown-trigger]")) { handleDropdownClick(e); return; }
		if (isMenuOpen) {
			var panel = getPanel();
			var btn = getSwitch();
			if (!el.closest("[data-mobile-dropdown]")) resetDropdowns();
			if (panel && !panel.contains(el) && (!btn || !btn.contains(el))) {
				if (!el.closest("[data-mobile-submenu]")) closeMenu();
			}
		}
	}

	function handleKeydown(e) { if (e.key === "Escape" && isMenuOpen) closeMenu(); }

	function bindSwitch() {
		var btn = getSwitch();
		if (!btn) return;
		var clone = btn.cloneNode(true);
		btn.parentNode.replaceChild(clone, btn);
		clone.addEventListener("click", function(e) { e.preventDefault(); e.stopPropagation(); toggleMenu(); });
	}

	function init() {
		isMenuOpen = false;
		ensureMenuPortal();
		bindSwitch();
		document.removeEventListener("click", handleClick);
		document.removeEventListener("keydown", handleKeydown);
		document.addEventListener("click", handleClick);
		document.addEventListener("keydown", handleKeydown);
	}

	function onLoad() { init(); }

	function onPageTransition() {
		closeMenu();
		if (pageTransitionTimer) clearTimeout(pageTransitionTimer);
		pageTransitionTimer = setTimeout(function() { init(); pageTransitionTimer = null; }, 80);
	}

	document.addEventListener("astro:page-load", onLoad);
	document.addEventListener("swup:page:view", onPageTransition);
	document.addEventListener("swup:contentReplaced", onPageTransition);
	if (document.readyState === "complete" || document.readyState === "interactive") onLoad();

	window.openNavMenu = openMenu;
	window.closeNavMenu = closeMenu;
	window.toggleNavMenu = toggleMenu;
</script>
