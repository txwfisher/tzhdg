---
import { Icon } from "astro-icon/components";
import ImageWrapper from "@/components/common/ImageWrapper.astro";
import { profileConfig } from "@/config/profileConfig";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { url } from "@/utils/url-utils";
import { getCollection } from "astro:content";
import { getTagList } from "@/utils/content-utils";

interface Props {
	links: NavBarLink[];
	siteTitle?: string;
	siteLogo?: string;
}

const { siteTitle } = Astro.props;

const mobileExcludeUrls = ["/archive/", "/categories/"];

const processedLinks = Astro.props.links
	.filter((link: NavBarLink) => {
		return !mobileExcludeUrls.includes(link.url || "");
	})
	.map((link: NavBarLink) => ({
		...link,
		children: link.children?.map((child: NavBarLink | LinkPreset): NavBarLink => {
			if (typeof child === "number") return LinkPresets[child];
			return child;
		}),
	}));

// Profile stats
const posts = await getCollection("posts", ({ data }) => {
	return import.meta.env.PROD ? data.draft !== true : true;
});
const tags = await getTagList();
const moments = await getCollection("moments");

const stats = [
	{ label: "文章", count: posts.length },
	{ label: "标签", count: tags.length },
	{ label: "动态", count: moments.length },
];

const githubLink = profileConfig.links.find((item) => item.name === "GitHub")?.url || "#";
---

<div id="nav-menu-overlay" class="menu-overlay"></div>

<div
	id="nav-menu-panel"
	class="menu-panel"
	data-menu-open="false"
	role="dialog"
	aria-modal="true"
	aria-label="导航菜单"
	aria-hidden="true"
>
	<!-- Profile Card Section -->
	<div class="menu-profile">
		<div class="flex flex-col items-center">
			<!-- Avatar -->
			<a
				aria-label="Go to About Page"
				href={url("/about/")}
				class="group relative block w-20 h-20 mb-3 rounded-full overflow-hidden border-2 border-white dark:border-neutral-700 shadow-md active:scale-95 transition-all flex-shrink-0"
			>
				<div class="absolute inset-0 z-10 flex items-center justify-center opacity-0 group-hover:opacity-100 bg-black/30 transition-opacity pointer-events-none">
					<Icon name="material-symbols:account-circle" class="text-white text-2xl" />
				</div>
				<ImageWrapper
					src={profileConfig.avatar || ""}
					alt="Profile Image"
					class="w-full h-full object-cover"
					loading="eager"
					fetchpriority="high"
					widths={[150]}
					sizes="150px"
				/>
			</a>

			<!-- Name & Bio -->
			<div class="text-center mb-2">
				<div class="font-bold text-lg text-neutral-800 dark:text-neutral-100 mb-0.5">
					{profileConfig.name}
				</div>
				<div class="text-xs text-neutral-500 dark:text-neutral-400">
					{profileConfig.bio}
				</div>
			</div>

			<!-- Stats -->
			<div class="flex w-full justify-around py-3 border-y border-neutral-100 dark:border-neutral-800 my-2">
				{stats.map(stat => (
					<div class="flex flex-col items-center">
						<div class="text-[10px] text-neutral-500 dark:text-neutral-400 mb-0.5">{stat.label}</div>
						<div class="text-base font-bold text-neutral-800 dark:text-neutral-100 leading-none">{stat.count}</div>
					</div>
				))}
			</div>

			<!-- CTA Button -->
			<a
				href={githubLink}
				target="_blank"
				class="btn-regular w-full py-2 rounded-xl bg-(--primary) text-white dark:text-neutral-900 text-sm font-bold flex items-center justify-center gap-1.5 mb-3 hover:opacity-90 active:scale-95 transition-all"
			>
				<Icon name="material-symbols:sports-esports" class="text-lg" />
				前往小窝~
			</a>

			<!-- Social Icons -->
			<div class="flex flex-wrap gap-3 justify-center">
				{profileConfig.links.map(item => (
					<a
						rel="me"
						aria-label={item.name}
						href={item.url}
						target={item.url.startsWith("mailto:") ? "_self" : "_blank"}
						class="text-neutral-500 hover:text-(--primary) transition-colors transform hover:scale-110 active:scale-90"
					>
						<Icon name={item.icon} class="text-[1.2rem]" />
					</a>
				))}
			</div>
		</div>
	</div>

	<!-- Divider -->
	<div class="border-t border-neutral-100 dark:border-neutral-800"></div>

	<!-- Navigation Links -->
	<nav class="menu-nav">
		{processedLinks.map((link) => (
			<div>
				{link.children && link.children.length > 0 ? (
					<div class="menu-dropdown" data-mobile-dropdown>
						<button
							class="menu-link"
							data-mobile-dropdown-trigger
							aria-expanded="false"
						>
							{link.icon && <Icon name={link.icon} class="menu-link-icon" />}
							<span class="menu-link-text">{link.name}</span>
							<Icon name="material-symbols:chevron-right-rounded" class="menu-arrow" />
						</button>
						<div class="menu-submenu" data-mobile-submenu>
							{link.children.map((child) => (
								<a
									href={child.external ? child.url : url(child.url)}
									class="menu-sublink"
									target={child.external ? "_blank" : undefined}
								>
									{child.icon && <Icon name={child.icon} class="menu-link-icon sub-icon" />}
									<span>{child.name}</span>
								</a>
							))}
						</div>
					</div>
				) : (
					<a
						href={link.external ? link.url : url(link.url)}
						class="menu-link"
						target={link.external ? "_blank" : undefined}
					>
						{link.icon && <Icon name={link.icon} class="menu-link-icon" />}
						<span class="menu-link-text">{link.name}</span>
					</a>
				)}
			</div>
		))}
	</nav>
</div>

<style>
	/* Overlay */
	.menu-overlay {
		position: fixed; inset: 0; z-index: 998;
		background: rgba(0, 0, 0, 0.35);
		opacity: 0; visibility: hidden; pointer-events: none;
		transition: opacity 0.3s ease, visibility 0.3s ease;
	}
	.menu-overlay.active {
		opacity: 1; visibility: visible; pointer-events: auto;
	}

	/* Panel */
	.menu-panel {
		position: fixed; top: 0; right: 0; bottom: 0;
		width: min(82vw, 20rem);
		height: 100dvh;
		background: var(--page-bg);
		box-shadow: -8px 0 30px rgba(0, 0, 0, 0.1);
		transform: translate3d(100%, 0, 0);
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 999;
		display: flex; flex-direction: column;
		overflow: hidden;
	}
	.menu-panel[data-menu-open="true"] { transform: translate3d(0, 0, 0); }

	html.dark .menu-panel {
		box-shadow: -8px 0 30px rgba(0, 0, 0, 0.35);
	}

	@media (min-width: 1024px) {
		.menu-overlay, .menu-panel { display: none !important; }
	}

	@media (max-width: 420px) {
		.menu-panel { width: min(88vw, 18rem); }
	}

	/* ── Profile Section ── */
	.menu-profile {
		flex-shrink: 0;
		padding: 1.25rem 1.25rem 1rem;
	}

	/* ── Navigation ── */
	.menu-nav {
		flex: 1; overflow-y: auto;
		padding: 0.5rem 0.75rem;
		-webkit-overflow-scrolling: touch;
	}

	.menu-link {
		display: flex; align-items: center; gap: 0.625rem;
		width: 100%; padding: 0.7rem 0.75rem;
		border-radius: 0.5rem;
		font-size: 0.9375rem; font-weight: 500;
		color: var(--deep-text); text-decoration: none;
		transition: background 0.15s, color 0.15s;
		cursor: pointer; background: none; border: none;
		text-align: left;
	}
	.menu-link:hover { background: var(--btn-regular-bg); }
	.menu-link:active { background: var(--btn-regular-bg-active); }

	.menu-link-icon {
		font-size: 1.25rem; color: var(--content-meta); flex-shrink: 0;
		transition: color 0.15s;
	}
	.menu-link:hover .menu-link-icon { color: var(--primary); }
	.menu-link-text { flex: 1; text-align: left; }

	.menu-arrow {
		font-size: 1.2rem; color: var(--content-meta); flex-shrink: 0;
		transition: transform 0.2s ease, color 0.15s;
	}
	.menu-dropdown[data-expanded="true"] .menu-arrow {
		transform: rotate(90deg); color: var(--primary);
	}
	.menu-dropdown[data-expanded="true"] > .menu-link {
		color: var(--primary); background: var(--btn-regular-bg);
	}

	/* Submenu */
	.menu-submenu {
		max-height: 0; overflow: hidden;
		transition: max-height 0.25s ease;
		padding-left: 2.25rem;
	}
	.menu-dropdown[data-expanded="true"] .menu-submenu { max-height: 20rem; }

	.menu-sublink {
		display: flex; align-items: center; gap: 0.5rem;
		padding: 0.55rem 0.75rem;
		border-radius: 0.375rem;
		font-size: 0.875rem; font-weight: 400;
		color: var(--content-meta); text-decoration: none;
		transition: background 0.15s, color 0.15s;
	}
	.menu-sublink:hover { background: var(--btn-regular-bg); color: var(--primary); }
	.menu-sublink:active { background: var(--btn-regular-bg-active); }
	.sub-icon { font-size: 1.1rem !important; }

	html.dark .nav-drawer-link-icon { color: var(--content-meta); }
</style>

<script>
	var isMenuOpen = false;
	var pageTransitionTimer;

	function getPanel() { return document.getElementById("nav-menu-panel"); }
	function getOverlay() { return document.getElementById("nav-menu-overlay"); }
	function getSwitch() { return document.getElementById("nav-menu-switch"); }

	function ensureMenuPortal() {
		var panel = getPanel();
		var overlay = getOverlay();
		if (!panel || !overlay || !document.body) return;
		var portal = document.getElementById("nav-menu-portal");
		if (!portal) {
			portal = document.createElement("div");
			portal.id = "nav-menu-portal";
			document.body.appendChild(portal);
		}
		if (overlay.parentElement !== portal) portal.appendChild(overlay);
		if (panel.parentElement !== portal) portal.appendChild(panel);
	}

	function resetDropdowns() {
		var list = document.querySelectorAll("[data-mobile-dropdown]");
		for (var i = 0; i < list.length; i++) {
			list[i].setAttribute("data-expanded", "false");
			var t = list[i].querySelector("[data-mobile-dropdown-trigger]");
			if (t) t.setAttribute("aria-expanded", "false");
		}
	}

	function openMenu() {
		ensureMenuPortal();
		resetDropdowns();
		var panel = getPanel();
		var overlay = getOverlay();
		var btn = getSwitch();
		if (panel) { panel.setAttribute("data-menu-open", "true"); panel.removeAttribute("aria-hidden"); }
		if (overlay) overlay.classList.add("active");
		if (btn) btn.classList.add("hamburger-open");
		document.body.style.overflow = "hidden";
		isMenuOpen = true;
	}

	function closeMenu() {
		var panel = getPanel();
		var overlay = getOverlay();
		var btn = getSwitch();
		if (panel) {
			panel.setAttribute("data-menu-open", "false");
			panel.setAttribute("aria-hidden", "true");
		}
		if (overlay) overlay.classList.remove("active");
		if (btn) btn.classList.remove("hamburger-open");
		document.body.style.overflow = "";
		isMenuOpen = false;
		resetDropdowns();
	}

	function toggleMenu() { isMenuOpen ? closeMenu() : openMenu(); }

	function handleDropdownClick(e) {
		var trigger = e.target.closest("[data-mobile-dropdown-trigger]");
		if (!trigger) return;
		e.preventDefault();
		var dd = trigger.closest("[data-mobile-dropdown]");
		if (!dd) return;
		var expanded = dd.getAttribute("data-expanded") === "true";
		var all = document.querySelectorAll("[data-mobile-dropdown]");
		for (var i = 0; i < all.length; i++) {
			if (all[i] !== dd) {
				all[i].setAttribute("data-expanded", "false");
				var ot = all[i].querySelector("[data-mobile-dropdown-trigger]");
				if (ot) ot.setAttribute("aria-expanded", "false");
			}
		}
		dd.setAttribute("data-expanded", String(!expanded));
		trigger.setAttribute("aria-expanded", String(!expanded));
	}

	function handleClick(e) {
		var el = e.target;
		if (el.closest("#nav-menu-switch")) { e.preventDefault(); e.stopPropagation(); toggleMenu(); return; }
		if (el.id === "nav-menu-overlay" || el.classList.contains("menu-overlay")) { e.preventDefault(); closeMenu(); return; }
		if (el.closest("[data-mobile-dropdown-trigger]")) { handleDropdownClick(e); return; }
		if (isMenuOpen) {
			var panel = getPanel();
			var btn = getSwitch();
			if (panel && !panel.contains(el) && (!btn || !btn.contains(el))) {
				closeMenu();
			}
		}
	}

	function handleKeydown(e) { if (e.key === "Escape" && isMenuOpen) closeMenu(); }

	// 全局事件委托，用标志位防止脚本因 Swup 导航被重复执行时多次注册
	if (!window.__navMenuListenersReady) {
		window.__navMenuListenersReady = true;
		document.addEventListener("click", handleClick);
		document.addEventListener("keydown", handleKeydown);
	}

	function init() {
		isMenuOpen = false;
		var btn = getSwitch();
		if (btn) btn.classList.remove("hamburger-open");
		ensureMenuPortal();
		// 事件监听器在脚本首次执行时已注册（下方），这里不再 remove/add，
		// 避免生产打包后因函数引用不一致导致重复/丢失绑定
	}

	function onLoad() { init(); }

	function onPageTransition() {
		closeMenu();
		if (pageTransitionTimer) clearTimeout(pageTransitionTimer);
		pageTransitionTimer = setTimeout(function() { init(); pageTransitionTimer = null; }, 80);
	}

	document.addEventListener("astro:page-load", onLoad);
	document.addEventListener("swup:page:view", onPageTransition);
	document.addEventListener("swup:contentReplaced", onPageTransition);
	if (document.readyState === "complete" || document.readyState === "interactive") onLoad();

	window.openNavMenu = openMenu;
	window.closeNavMenu = closeMenu;
	window.toggleNavMenu = toggleMenu;
</script>
