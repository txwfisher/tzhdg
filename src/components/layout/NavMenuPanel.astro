---
import { Icon } from "astro-icon/components";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	links: NavBarLink[];
	siteTitle?: string;
	siteLogo?: string;
}

const { siteTitle = "博客导航", siteLogo } = Astro.props;

const processedLinks = Astro.props.links.map((link: NavBarLink) => ({
	...link,
	children: link.children?.map((child: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof child === "number") {
			return LinkPresets[child];
		}
		return child;
	}),
}));
---

<!-- 全屏遮罩层 -->
<div id="nav-menu-overlay" class="nav-fullscreen-overlay"></div>

<!-- 全屏菜单面板 -->
<div
	id="nav-menu-panel"
	class="nav-fullscreen-panel"
	data-menu-open="false"
	role="dialog"
	aria-modal="true"
	aria-label="导航菜单"
	aria-hidden="true"
>
	<!-- 顶部区域 -->
	<div class="nav-fullscreen-header">
		<div class="nav-fullscreen-brand">
			{siteLogo ? (
				<img src={siteLogo} alt={siteTitle} class="nav-fullscreen-logo" />
			) : (
				<div class="nav-fullscreen-logo-placeholder">
					<Icon name="material-symbols:home-rounded" class="text-2xl" />
				</div>
			)}
			<span class="nav-fullscreen-title">{siteTitle}</span>
		</div>
		<button class="nav-fullscreen-close" aria-label="关闭菜单" id="nav-menu-close">
			<Icon name="material-symbols:close" class="text-xl" />
		</button>
	</div>

	<!-- 菜单内容 -->
	<div class="nav-fullscreen-content">
		<nav class="nav-fullscreen-nav">
			{processedLinks.map((link, index) => (
				<div class="nav-fullscreen-item-wrapper" style={`--item-delay: ${index * 50}ms`}>
					{link.children && link.children.length > 0 ? (
						<!-- 有子菜单的项目 -->
						<div class="nav-fullscreen-dropdown" data-mobile-dropdown>
							<button
								class="nav-fullscreen-link nav-fullscreen-dropdown-trigger"
								data-mobile-dropdown-trigger
								aria-expanded="false"
							>
								<span class="nav-fullscreen-link-content">
									{link.icon && (
										<span class="nav-fullscreen-link-icon">
											<Icon name={link.icon} />
										</span>
									)}
									<span class="nav-fullscreen-link-text">{link.name}</span>
								</span>
								<Icon
									name="material-symbols:chevron-right-rounded"
									class="nav-fullscreen-arrow transition-transform duration-300"
								/>
							</button>
							<div class="nav-fullscreen-submenu" data-mobile-submenu>
								{link.children.map((child) => (
									<a
										href={child.external ? child.url : url(child.url)}
										class="nav-fullscreen-sublink"
										target={child.external ? "_blank" : undefined}
									>
										<span class="nav-fullscreen-link-content">
											{child.icon && (
												<span class="nav-fullscreen-link-icon nav-fullscreen-sublink-icon">
													<Icon name={child.icon} />
												</span>
											)}
											<span>{child.name}</span>
										</span>
										{child.external && (
											<Icon
												name="fa-solid:arrow-up-right-from-square"
												class="text-[10px] opacity-40"
											/>
										)}
									</a>
								))}
							</div>
						</div>
					) : (
						<!-- 普通链接项目 -->
						<a
							href={link.external ? link.url : url(link.url)}
							class="nav-fullscreen-link"
							target={link.external ? "_blank" : undefined}
						>
							<span class="nav-fullscreen-link-content">
								{link.icon && (
									<span class="nav-fullscreen-link-icon">
										<Icon name={link.icon} />
									</span>
								)}
								<span class="nav-fullscreen-link-text">{link.name}</span>
							</span>
							{link.external && (
								<Icon
									name="fa-solid:arrow-up-right-from-square"
									class="text-[10px] opacity-40"
								/>
							)}
						</a>
					)}
				</div>
			))}
		</nav>
	</div>

	<!-- 底部装饰 -->
	<div class="nav-fullscreen-footer">
		<div class="nav-fullscreen-footer-decoration"></div>
	</div>
</div>

<style>
	@reference "../../styles/main.css";

	/* ============================================
	 * 全屏遮罩层
	 * ============================================ */
	.nav-fullscreen-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		z-index: 998;
		opacity: 0;
		transition: opacity 0.3s ease;
		pointer-events: none;
	}

	.nav-fullscreen-overlay.active {
		display: block;
		opacity: 1;
		pointer-events: auto;
	}

	/* ============================================
	 * 全屏菜单面板
	 * ============================================ */
	.nav-fullscreen-panel {
		position: fixed !important;
		inset: 0 !important;
		width: 100vw !important;
		height: 100dvh !important;
		background: var(--page-bg);
		transform: translateX(100%);
		transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
		z-index: 999 !important;
		display: flex !important;
		flex-direction: column;
		overflow: hidden;
	}

	.nav-fullscreen-panel[data-menu-open="true"] {
		transform: translateX(0);
	}

	/* 桌面端隐藏全屏菜单 */
	@media (min-width: 1024px) {
		.nav-fullscreen-overlay,
		.nav-fullscreen-panel {
			display: none !important;
		}
	}

	/* ============================================
	 * 顶部区域
	 * ============================================ */
	.nav-fullscreen-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.25rem 1.5rem;
		border-bottom: 1px solid var(--line-divider);
		flex-shrink: 0;
	}

	.nav-fullscreen-brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.nav-fullscreen-logo {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.625rem;
		object-fit: cover;
	}

	.nav-fullscreen-logo-placeholder {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.625rem;
		background: var(--btn-regular-bg);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary);
	}

	.nav-fullscreen-title {
		font-weight: 600;
		font-size: 1.125rem;
		color: var(--text-primary);
	}

	.nav-fullscreen-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.625rem;
		color: var(--text-secondary);
		transition: background-color 0.2s ease, color 0.2s ease;
		cursor: pointer;
	}

	.nav-fullscreen-close:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-fullscreen-close:active {
		background: var(--btn-plain-bg-active);
	}

	/* ============================================
	 * 菜单内容
	 * ============================================ */
	.nav-fullscreen-content {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		padding: 1rem 1rem 2rem;
	}

	.nav-fullscreen-nav {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	/* ============================================
	 * 菜单项动画
	 * ============================================ */
	.nav-fullscreen-item-wrapper {
		opacity: 0;
		transform: translateX(20px);
		transition:
			opacity 0.4s ease var(--item-delay),
			transform 0.4s cubic-bezier(0.4, 0, 0.2, 1) var(--item-delay) !important;
	}

	.nav-fullscreen-panel[data-menu-open="true"] .nav-fullscreen-item-wrapper {
		opacity: 1;
		transform: translateX(0);
	}

	/* ============================================
	 * 菜单链接
	 * ============================================ */
	.nav-fullscreen-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.875rem 1rem;
		border-radius: 0.75rem;
		color: var(--text-primary);
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.15s ease;
		font-weight: 500;
	}

	.nav-fullscreen-link:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-fullscreen-link:active {
		background: var(--btn-plain-bg-active);
		transform: scale(0.98);
	}

	.nav-fullscreen-link-content {
		display: flex;
		align-items: center;
		gap: 0.875rem;
	}

	.nav-fullscreen-link-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.5rem;
		background: var(--btn-regular-bg);
		color: var(--text-secondary);
		font-size: 1.125rem;
		transition:
			background-color 0.2s ease,
			color 0.2s ease;
	}

	.nav-fullscreen-link:hover .nav-fullscreen-link-icon {
		background: var(--primary);
		color: white;
	}

	.nav-fullscreen-link-text {
		font-size: 1rem;
	}

	.nav-fullscreen-arrow {
		color: var(--text-tertiary);
		font-size: 1.25rem;
	}

	/* ============================================
	 * 子菜单
	 * ============================================ */
	.nav-fullscreen-dropdown {
		width: 100%;
	}

	.nav-fullscreen-dropdown-trigger {
		width: 100%;
		cursor: pointer;
	}

	.nav-fullscreen-dropdown[data-expanded="true"] .nav-fullscreen-arrow {
		transform: rotate(90deg);
	}

	.nav-fullscreen-submenu {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease-in-out, padding 0.3s ease;
		padding-left: 0.5rem;
	}

	.nav-fullscreen-dropdown[data-expanded="true"] .nav-fullscreen-submenu {
		max-height: 500px;
		padding-left: 3.25rem;
	}

	.nav-fullscreen-sublink {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem;
		border-radius: 0.625rem;
		color: var(--text-secondary);
		transition:
			background-color 0.2s ease,
			color 0.2s ease;
		font-size: 0.9375rem;
	}

	.nav-fullscreen-sublink:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-fullscreen-sublink:active {
		background: var(--btn-plain-bg-active);
	}

	.nav-fullscreen-sublink-icon {
		width: 1.75rem;
		height: 1.75rem;
		font-size: 0.875rem;
	}

	/* ============================================
	 * 底部装饰
	 * ============================================ */
	.nav-fullscreen-footer {
		padding: 1.5rem;
		flex-shrink: 0;
	}

	.nav-fullscreen-footer-decoration {
		height: 4px;
		width: 40px;
		margin: 0 auto;
		background: var(--line-divider);
		border-radius: 2px;
	}

	/* ============================================
	 * 暗色模式
	 * ============================================ */
	:global(.dark) .nav-fullscreen-panel {
		background: var(--page-bg);
	}
</style>

<script>
	(function () {
		let clickHandler: ((e: MouseEvent) => void) | null = null;
		let keydownHandler: ((e: KeyboardEvent) => void) | null = null;

		function openMenu() {
			const panel = document.getElementById("nav-menu-panel");
			const overlay = document.getElementById("nav-menu-overlay");
			if (panel) {
				panel.setAttribute("data-menu-open", "true");
				panel.removeAttribute("aria-hidden");
				document.body.style.overflow = "hidden";
			}
			if (overlay) {
				overlay.classList.add("active");
			}
		}

		function closeMenu() {
			const panel = document.getElementById("nav-menu-panel");
			const overlay = document.getElementById("nav-menu-overlay");
			if (panel) {
				panel.setAttribute("data-menu-open", "false");
				const closeBtn = panel.querySelector("#nav-menu-close");
				const menuSwitch = document.getElementById("nav-menu-switch");
				if (document.activeElement && panel.contains(document.activeElement)) {
					menuSwitch ? menuSwitch.focus() : closeBtn ? closeBtn.blur() : null;
				}
				panel.setAttribute("aria-hidden", "true");
				document.body.style.overflow = "";
			}
			if (overlay) {
				overlay.classList.remove("active");
			}
		}

		function toggleMenu() {
			const panel = document.getElementById("nav-menu-panel");
			if (!panel) {
				return;
			}
			const isOpen = panel.getAttribute("data-menu-open") === "true";
			if (isOpen) {
				closeMenu();
			} else {
				openMenu();
			}
		}

		function handleDropdownClick(e: Event) {
			const target = e.target as Node | null;
			if (!target) return;
			const trigger = (target as Element).closest?.(
				"[data-mobile-dropdown-trigger]"
			);
			if (!trigger) return;

			e.preventDefault();
			const dropdown = (trigger as Element).closest?.("[data-mobile-dropdown]");
			if (!dropdown) return;

			const isExpanded =
				(dropdown as Element).getAttribute("data-expanded") === "true";

			document
				.querySelectorAll("[data-mobile-dropdown]")
				.forEach(function (other) {
					if (other !== dropdown) {
						(other as Element).setAttribute("data-expanded", "false");
						const otherTrigger = (other as Element).querySelector(
							"[data-mobile-dropdown-trigger]"
						);
						if (otherTrigger) {
							(otherTrigger as Element).setAttribute(
								"aria-expanded",
								"false"
							);
						}
					}
				});

			(dropdown as Element).setAttribute("data-expanded", (!isExpanded).toString());
			(trigger as Element).setAttribute("aria-expanded", (!isExpanded).toString());
		}

		function handleClick(e: MouseEvent) {
			const target = e.target as Node | null;
			if (!target) return;

			if ((target as Element).closest?.("#nav-menu-switch")) {
				e.preventDefault();
				e.stopPropagation();
				toggleMenu();
				return;
			}

			const targetEl = target as Element;
			if (
				targetEl.id === "nav-menu-overlay" ||
				targetEl.classList?.contains("nav-fullscreen-overlay")
			) {
				e.preventDefault();
				closeMenu();
				return;
			}

			if ((target as Element).closest?.("#nav-menu-close")) {
				e.preventDefault();
				closeMenu();
				return;
			}

			if ((target as Element).closest?.("[data-mobile-dropdown-trigger]")) {
				handleDropdownClick(e);
				return;
			}
		}

		function handleKeydown(e: KeyboardEvent) {
			if (e.key === "Escape") {
				const panel = document.getElementById("nav-menu-panel");
				if (panel && panel.getAttribute("data-menu-open") === "true") {
					closeMenu();
				}
			}
		}

		function init() {
			if (clickHandler) {
				document.removeEventListener("click", clickHandler);
			}
			if (keydownHandler) {
				document.removeEventListener("keydown", keydownHandler);
			}

			clickHandler = handleClick;
			keydownHandler = handleKeydown;

			document.addEventListener("click", clickHandler);
			document.addEventListener("keydown", keydownHandler);
		}

		function onPageTransition() {
			closeMenu();
			init();
		}

		document.addEventListener("astro:page-load", init);
		document.addEventListener("swup:contentReplaced", onPageTransition);
		document.addEventListener("swup:page:view", onPageTransition);

		if (document.readyState === "complete" || document.readyState === "interactive") {
			init();
		}

		window.openNavMenu = openMenu;
		window.closeNavMenu = closeMenu;
		window.toggleNavMenu = toggleMenu;
	})();
</script>
