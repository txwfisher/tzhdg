---
import { Icon } from "astro-icon/components";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	links: NavBarLink[];
}

// 处理links中的LinkPreset转换
const processedLinks = Astro.props.links.map((link: NavBarLink) => ({
	...link,
	children: link.children?.map((child: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof child === "number") {
			return LinkPresets[child];
		}
		return child;
	}),
}));
---

<!-- 抽屉菜单遮罩层 -->
<div id="nav-menu-overlay" class="nav-drawer-overlay"></div>

<!-- 抽屉菜单面板 -->
<div id="nav-menu-panel" class="nav-drawer-panel" data-menu-open="false" role="dialog" aria-modal="true" aria-label="导航菜单" aria-hidden="true">
	<!-- 抽屉头部 -->
	<div class="nav-drawer-header">
		<span class="nav-drawer-title">菜单</span>
		<button 
			class="nav-drawer-close" 
			aria-label="关闭菜单"
			id="nav-menu-close"
		>
			<Icon name="material-symbols:close-rounded" class="text-[1.5rem]" />
		</button>
	</div>
	
	<!-- 菜单内容 -->
	<div class="nav-drawer-content">
		{processedLinks.map((link, index) => (
			<div class="nav-drawer-item-wrapper" style={`--item-delay: ${index * 60}ms`}>
				{link.children && link.children.length > 0 ? (
					<!-- 有子菜单的项目 -->
					<div class="nav-drawer-dropdown" data-mobile-dropdown>
						<button 
							class="nav-drawer-link nav-drawer-dropdown-trigger"
							data-mobile-dropdown-trigger
							aria-expanded="false"
						>
							<span class="nav-drawer-link-content">
								{link.icon && <Icon name={link.icon} class="text-[1.25rem]" />}
								<span>{link.name}</span>
							</span>
							<Icon 
								name="material-symbols:keyboard-arrow-down-rounded"
								class="nav-drawer-arrow transition-transform duration-300"
							/>
						</button>
						<div class="nav-drawer-submenu" data-mobile-submenu>
							{link.children.map((child) => (
								<a href={child.external ? child.url : url(child.url)} 
								   class="nav-drawer-sublink"
								   target={child.external ? "_blank" : null}
								>
									<span class="nav-drawer-link-content">
										{child.icon && <Icon name={child.icon} class="text-[1.1rem]" />}
										<span>{child.name}</span>
									</span>
									{child.external && (
										<Icon name="fa7-solid:arrow-up-right-from-square" class="text-[0.75rem] opacity-50" />
									)}
								</a>
							))}
						</div>
					</div>
				) : (
					<!-- 普通链接项目 -->
					<a 
						href={link.external ? link.url : url(link.url)} 
						class="nav-drawer-link"
						target={link.external ? "_blank" : null}
					>
						<span class="nav-drawer-link-content">
							{link.icon && <Icon name={link.icon} class="text-[1.25rem]" />}
							<span>{link.name}</span>
						</span>
						{link.external && (
							<Icon name="fa7-solid:arrow-up-right-from-square" class="text-[0.75rem] opacity-50" />
						)}
					</a>
				)}
			</div>
		))}
	</div>
</div>

<style>
	@reference "../../styles/main.css";

	/* ============================================
	 * 抽屉遮罩层
	 * ============================================ */
	.nav-drawer-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: transparent;
		z-index: 998;
		pointer-events: none;
		transition: opacity 0.35s ease;
	}

	.nav-drawer-overlay.active {
	}

	/* ============================================
	 * 抽屉面板 - 仅移动端显示
	 * ============================================ */
	.nav-drawer-panel {
		position: fixed !important;
		top: 0 !important;
		right: 0 !important;
		bottom: 0 !important;
		width: min(320px, 85vw);
		height: 100dvh;
		background: var(--card-bg);
		transform: translateX(100%);
		transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 999 !important;
		display: flex !important;
		flex-direction: column;
		overflow: hidden;
	}

	.nav-drawer-panel[data-menu-open="true"] {
		transform: translateX(0) !important;
	}

	/* 覆盖 float-panel-closed 的样式 */
	.nav-drawer-panel.float-panel-closed {
		opacity: 1 !important;
		pointer-events: auto !important;
	}

	.nav-drawer-panel.float-panel-closed * {
		pointer-events: auto !important;
	}

	/* 桌面端隐藏抽屉 */
	@media (min-width: 1024px) {
		.nav-drawer-overlay,
		.nav-drawer-panel {
			display: none;
		}
	}

	/* ============================================
	 * 抽屉头部
	 * ============================================ */
	.nav-drawer-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.25rem;
		border-bottom: 1px solid var(--line-divider);
		flex-shrink: 0;
	}

	.nav-drawer-title {
		font-weight: 700;
		font-size: 1.125rem;
		color: var(--text-primary);
	}

	.nav-drawer-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.5rem;
		color: var(--text-secondary);
		transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
		cursor: pointer;
	}

	.nav-drawer-close:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-drawer-close:active {
		transform: scale(0.95);
	}

	/* ============================================
	 * 菜单内容
	 * ============================================ */
	.nav-drawer-content {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		padding: 0.75rem 0.75rem 1.5rem;
		min-height: 0;
	}

	/* ============================================
	 * 菜单项淡入动画
	 * ============================================ */
	.nav-drawer-item-wrapper {
		opacity: 0 !important;
		transform: translateX(20px) !important;
		transition: 
			opacity 0.4s ease var(--item-delay),
			transform 0.4s cubic-bezier(0.4, 0, 0.2, 1) var(--item-delay) !important;
	}

	.nav-drawer-panel[data-menu-open="true"] .nav-drawer-item-wrapper {
		opacity: 1 !important;
		transform: translateX(0) !important;
	}

	/* ============================================
	 * 菜单链接
	 * ============================================ */
	.nav-drawer-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.875rem 1rem;
		border-radius: 0.625rem;
		color: var(--text-primary);
		transition: background-color 0.2s ease, color 0.2s ease;
		font-weight: 500;
	}

	.nav-drawer-link:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-drawer-link:active {
		background: var(--btn-plain-bg-active);
	}

	.nav-drawer-link-content {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	/* ============================================
	 * 子菜单
	 * ============================================ */
	.nav-drawer-dropdown {
		margin-bottom: 0.25rem;
	}

	.nav-drawer-dropdown-trigger {
		width: 100%;
		cursor: pointer;
	}

	.nav-drawer-dropdown-trigger .nav-drawer-arrow {
		color: var(--text-tertiary);
	}

	.nav-drawer-dropdown[data-expanded="true"] .nav-drawer-arrow {
		transform: rotate(180deg);
	}

	.nav-drawer-submenu {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease-in-out;
	}

	.nav-drawer-dropdown[data-expanded="true"] .nav-drawer-submenu {
		max-height: 500px;
	}

	.nav-drawer-sublink {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem 0.75rem 2.5rem;
		border-radius: 0.5rem;
		color: var(--text-secondary);
		transition: background-color 0.2s ease, color 0.2s ease;
		font-weight: 400;
		font-size: 0.9375rem;
	}

	.nav-drawer-sublink:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-drawer-sublink:active {
		background: var(--btn-plain-bg-active);
	}

	/* ============================================
	 * 暗色模式适配
	 * ============================================ */
	:global(.dark) .nav-drawer-panel {
		background: var(--card-bg);
	}
</style>

<script>
// 移动端菜单控制器 - 使用 data 属性控制状态
(function() {
    // 打开菜单
    function openMenu() {
        const panel = document.getElementById('nav-menu-panel');
        const overlay = document.getElementById('nav-menu-overlay');
        if (panel) {
            panel.setAttribute('data-menu-open', 'true');
            panel.removeAttribute('aria-hidden');
            document.body.style.overflow = 'hidden';
        }
        if (overlay) {
            overlay.classList.add('active');
        }
    }

    // 关闭菜单
    function closeMenu() {
        const panel = document.getElementById('nav-menu-panel');
        const overlay = document.getElementById('nav-menu-overlay');
        if (panel) {
            panel.setAttribute('data-menu-open', 'false');
            // 关闭前把焦点移到触发按钮，避免 aria-hidden 与 focus 冲突
            const closeBtn = panel.querySelector('#nav-menu-close');
            const menuSwitch = document.getElementById('nav-menu-switch');
            if (document.activeElement && panel.contains(document.activeElement)) {
                menuSwitch ? menuSwitch.focus() : closeBtn ? closeBtn.blur() : null;
            }
            panel.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }
        if (overlay) {
            overlay.classList.remove('active');
        }
    }

    // 切换菜单状态
    function toggleMenu() {
        console.log('[Menu] toggleMenu called');
        const panel = document.getElementById('nav-menu-panel');
        if (!panel) {
            console.log('[Menu] panel not found in toggleMenu!');
            return;
        }

        const isOpen = panel.getAttribute('data-menu-open') === 'true';

        if (isOpen) {
            closeMenu();
        } else {
            openMenu();
        }
    }

    // 处理子菜单点击
    function handleDropdownClick(e) {
        const trigger = e.target.closest('[data-mobile-dropdown-trigger]');
        if (!trigger) return;

        e.preventDefault();
        const dropdown = trigger.closest('[data-mobile-dropdown]');
        if (!dropdown) return;

        const isExpanded = dropdown.getAttribute('data-expanded') === 'true';

        // 关闭其他子菜单
        document.querySelectorAll('[data-mobile-dropdown]').forEach(function(other) {
            if (other !== dropdown) {
                other.setAttribute('data-expanded', 'false');
                const otherTrigger = other.querySelector('[data-mobile-dropdown-trigger]');
                if (otherTrigger) {
                    otherTrigger.setAttribute('aria-expanded', 'false');
                }
            }
        });

        // 切换当前子菜单
        dropdown.setAttribute('data-expanded', (!isExpanded).toString());
        trigger.setAttribute('aria-expanded', (!isExpanded).toString());
    }

    // 事件处理函数
    function handleClick(e) {
        // 菜单按钮点击
        if (e.target.closest('#nav-menu-switch')) {
            e.preventDefault();
            e.stopPropagation();
            toggleMenu();
            return;
        }

        // 遮罩层点击 - 关闭菜单
        if (e.target.id === 'nav-menu-overlay' || e.target.classList.contains('nav-drawer-overlay')) {
            e.preventDefault();
            closeMenu();
            return;
        }

        // 关闭按钮点击
        if (e.target.closest('#nav-menu-close')) {
            e.preventDefault();
            closeMenu();
            return;
        }

        // 子菜单触发器点击
        if (e.target.closest('[data-mobile-dropdown-trigger]')) {
            handleDropdownClick(e);
            return;
        }
    }

    // ESC 键处理
    function handleKeydown(e) {
        if (e.key === 'Escape') {
            const panel = document.getElementById('nav-menu-panel');
            if (panel && panel.getAttribute('data-menu-open') === 'true') {
                closeMenu();
            }
        }
    }

    // 初始化函数
    function init() {
        document.addEventListener('click', handleClick);
        document.addEventListener('keydown', handleKeydown);
    }

    // 页面切换后关闭菜单并重新初始化
    function onPageTransition() {
        closeMenu();
        // 移除旧监听器，避免重复注册
        document.removeEventListener('click', handleClick);
        document.removeEventListener('keydown', handleKeydown);
        // 重新初始化
        init();
    }

    // 初始化
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    // Swup 事件监听
    document.addEventListener('swup:page:view', onPageTransition);
    document.addEventListener('swup:content:replace', onPageTransition);

    // 暴露到全局
    window.openNavMenu = openMenu;
    window.closeNavMenu = closeMenu;
    window.toggleNavMenu = toggleMenu;
})();
</script>
