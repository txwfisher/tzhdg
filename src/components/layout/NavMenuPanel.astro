---
import { Icon } from "astro-icon/components";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	links: NavBarLink[];
	siteTitle?: string;
	siteLogo?: string;
}

const { siteTitle = "博客导航", siteLogo } = Astro.props;

const processedLinks = Astro.props.links.map((link: NavBarLink) => ({
	...link,
	children: link.children?.map((child: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof child === "number") {
			return LinkPresets[child];
		}
		return child;
	}),
}));
---

<!-- 抽屉遮罩层 -->
<div id="nav-menu-overlay" class="nav-drawer-overlay"></div>

<!-- 抽屉菜单面板 -->
<div
	id="nav-menu-panel"
	class="nav-drawer-panel"
	data-drawer-side="right"
	data-menu-open="false"
	role="dialog"
	aria-modal="true"
	aria-label="导航菜单"
	aria-hidden="true"
>
	<!-- 顶部区域 -->
	<div class="nav-drawer-header">
		<div class="nav-drawer-brand">
			{siteLogo ? (
				<img src={siteLogo} alt={siteTitle} class="nav-drawer-logo" />
			) : (
				<div class="nav-drawer-logo-placeholder">
					<Icon name="material-symbols:home-rounded" class="text-2xl" />
				</div>
			)}
			<span class="nav-drawer-title">{siteTitle}</span>
		</div>
		<button class="nav-drawer-close" aria-label="关闭菜单" id="nav-menu-close">
			<Icon name="material-symbols:close" class="text-xl" />
		</button>
	</div>

	<!-- 菜单内容 -->
	<div class="nav-drawer-content">
		<nav class="nav-drawer-nav">
			{processedLinks.map((link, index) => (
				<div class="nav-drawer-item-wrapper" style={`--item-delay: ${index * 50}ms`}>
					{link.children && link.children.length > 0 ? (
						<!-- 有子菜单的项目 -->
						<div class="nav-drawer-dropdown" data-mobile-dropdown>
							<button
								class="nav-drawer-link nav-drawer-dropdown-trigger"
								data-mobile-dropdown-trigger
								aria-expanded="false"
							>
								<span class="nav-drawer-link-content">
									{link.icon && (
										<span class="nav-drawer-link-icon">
											<Icon name={link.icon} />
										</span>
									)}
									<span class="nav-drawer-link-text">{link.name}</span>
								</span>
								<Icon
									name="material-symbols:chevron-right-rounded"
									class="nav-drawer-arrow transition-transform duration-300"
								/>
							</button>
							<div class="nav-drawer-submenu" data-mobile-submenu>
								{link.children.map((child) => (
									<a
										href={child.external ? child.url : url(child.url)}
										class="nav-drawer-sublink"
										target={child.external ? "_blank" : undefined}
									>
										<span class="nav-drawer-link-content">
											{child.icon && (
												<span class="nav-drawer-link-icon nav-drawer-sublink-icon">
													<Icon name={child.icon} />
												</span>
											)}
											<span>{child.name}</span>
										</span>
										{child.external && (
											<Icon
												name="fa-solid:arrow-up-right-from-square"
												class="text-[10px] opacity-40"
											/>
										)}
									</a>
								))}
							</div>
						</div>
					) : (
						<!-- 普通链接项目 -->
						<a
							href={link.external ? link.url : url(link.url)}
							class="nav-drawer-link"
							target={link.external ? "_blank" : undefined}
						>
							<span class="nav-drawer-link-content">
								{link.icon && (
									<span class="nav-drawer-link-icon">
										<Icon name={link.icon} />
									</span>
								)}
								<span class="nav-drawer-link-text">{link.name}</span>
							</span>
							{link.external && (
								<Icon
									name="fa-solid:arrow-up-right-from-square"
									class="text-[10px] opacity-40"
								/>
							)}
						</a>
					)}
				</div>
			))}
		</nav>
	</div>

	<!-- 底部装饰 -->
	<div class="nav-drawer-footer">
		<div class="nav-drawer-footer-decoration"></div>
	</div>
</div>

<style>
	@reference "../../styles/main.css";

	/* ============================================
	 * 抽屉遮罩层
	 * ============================================ */
	.nav-drawer-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.38);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		z-index: 998;
		opacity: 0;
		transition: opacity 0.3s ease, visibility 0.3s ease;
		visibility: hidden;
		pointer-events: none;
	}

	.nav-drawer-overlay.active {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}

	/* ============================================
	 * 抽屉菜单面板
	 * ============================================ */
	.nav-drawer-panel {
		position: fixed !important;
		top: 0 !important;
		right: 0 !important;
		bottom: 0 !important;
		width: min(86vw, 23rem) !important;
		height: 100dvh !important;
		background: color-mix(in srgb, var(--page-bg) 96%, transparent);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		border-left: 1px solid var(--line-divider);
		box-shadow: -18px 0 40px rgba(0, 0, 0, 0.16);
		transform: translate3d(100%, 0, 0);
		transition: transform 0.36s cubic-bezier(0.32, 0.72, 0, 1);
		z-index: 999 !important;
		display: flex !important;
		flex-direction: column;
		overflow: hidden;
		will-change: transform;
	}

	.nav-drawer-panel[data-menu-open="true"] {
		transform: translate3d(0, 0, 0);
	}

	.nav-drawer-panel[data-drawer-side="left"] {
		left: 0 !important;
		right: auto !important;
		border-right: 1px solid var(--line-divider);
		border-left: 0;
		box-shadow: 18px 0 40px rgba(0, 0, 0, 0.16);
		transform: translate3d(-100%, 0, 0);
	}

	.nav-drawer-panel[data-drawer-side="left"][data-menu-open="true"] {
		transform: translate3d(0, 0, 0);
	}

	/* 桌面端隐藏抽屉菜单 */
	@media (min-width: 1024px) {
		.nav-drawer-overlay,
		.nav-drawer-panel {
			display: none !important;
		}
	}

	@media (max-width: 420px) {
		.nav-drawer-panel {
			width: min(90vw, 22rem) !important;
		}
	}

	/* ============================================
	 * 顶部区域
	 * ============================================ */
	.nav-drawer-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.25rem 1.5rem;
		border-bottom: 1px solid var(--line-divider);
		flex-shrink: 0;
	}

	.nav-drawer-brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		min-width: 0;
	}

	.nav-drawer-logo {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.625rem;
		object-fit: cover;
	}

	.nav-drawer-logo-placeholder {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.625rem;
		background: var(--btn-regular-bg);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary);
	}

	.nav-drawer-title {
		font-weight: 600;
		font-size: 1.125rem;
		color: var(--text-color);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.nav-drawer-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.625rem;
		background: var(--btn-regular-bg);
		color: var(--content-meta);
		transition: background-color 0.2s ease, color 0.2s ease;
		cursor: pointer;
	}

	.nav-drawer-close:hover {
		background: var(--primary);
		color: white;
	}

	.nav-drawer-close:active {
		background: var(--btn-plain-bg-active);
	}

	/* ============================================
	 * 菜单内容
	 * ============================================ */
	.nav-drawer-content {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		padding: 1rem 1rem 2rem;
	}

	.nav-drawer-nav {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	/* ============================================
	 * 菜单项动画
	 * ============================================ */
	.nav-drawer-item-wrapper {
		opacity: 0;
		transform: translateX(16px);
		transition:
			opacity 0.4s ease var(--item-delay),
			transform 0.4s cubic-bezier(0.4, 0, 0.2, 1) var(--item-delay) !important;
	}

	.nav-drawer-panel[data-menu-open="true"] .nav-drawer-item-wrapper {
		opacity: 1;
		transform: translateX(0);
	}

	/* ============================================
	 * 菜单链接
	 * ============================================ */
	.nav-drawer-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.875rem 1rem;
		border-radius: 0.75rem;
		background: var(--bg-secondary);
		color: var(--text-color);
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.15s ease;
		font-weight: 500;
	}

	.nav-drawer-link:hover {
		background: var(--btn-regular-bg-hover);
		color: var(--primary);
	}

	.nav-drawer-link:active {
		background: var(--btn-plain-bg-active);
		transform: scale(0.98);
	}

	.nav-drawer-link-content {
		display: flex;
		align-items: center;
		gap: 0.875rem;
		min-width: 0;
	}

	.nav-drawer-link-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.5rem;
		background: var(--btn-regular-bg);
		color: var(--content-meta);
		font-size: 1.125rem;
		transition:
			background-color 0.2s ease,
			color 0.2s ease;
	}

	.nav-drawer-link:hover .nav-drawer-link-icon {
		background: var(--primary);
		color: white;
	}

	.nav-drawer-link-text {
		font-size: 1rem;
	}

	.nav-drawer-arrow {
		color: var(--text-tertiary);
		font-size: 1.25rem;
	}

	/* ============================================
	 * 子菜单
	 * ============================================ */
	.nav-drawer-dropdown {
		width: 100%;
	}

	.nav-drawer-dropdown-trigger {
		width: 100%;
		cursor: pointer;
	}

	.nav-drawer-dropdown[data-expanded="true"] .nav-drawer-arrow {
		transform: rotate(90deg);
	}

	.nav-drawer-submenu {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease-in-out, padding 0.3s ease;
		padding-left: 0.5rem;
	}

	.nav-drawer-dropdown[data-expanded="true"] .nav-drawer-submenu {
		max-height: 500px;
		padding-left: 2.75rem;
	}

	.nav-drawer-sublink {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem;
		border-radius: 0.625rem;
		color: var(--text-color);
		transition:
			background-color 0.2s ease,
			color 0.2s ease;
		font-size: 0.9375rem;
	}

	.nav-drawer-sublink:hover {
		background: var(--btn-regular-bg-hover);
		color: var(--primary);
	}

	.nav-drawer-sublink:active {
		background: var(--btn-regular-bg-active);
	}

	.nav-drawer-sublink-icon {
		width: 1.75rem;
		height: 1.75rem;
		font-size: 0.875rem;
	}

	/* ============================================
	 * 底部装饰
	 * ============================================ */
	.nav-drawer-footer {
		padding: 1.5rem;
		flex-shrink: 0;
	}

	.nav-drawer-footer-decoration {
		height: 4px;
		width: 40px;
		margin: 0 auto;
		background: var(--line-divider);
		border-radius: 2px;
	}

	/* ============================================
	 * 暗色模式 - 使用更强选择器确保生效
	 * ============================================ */
		/* ============================================
	 * 暗色模式
	 * ============================================ */
	:global(html.dark) .nav-drawer-panel {
		background: color-mix(in srgb, var(--page-bg) 94%, transparent);
		box-shadow: -18px 0 40px rgba(0, 0, 0, 0.34);
	}

	:global(html.dark) .nav-drawer-title {
		color: var(--text-color) !important;
	}

	:global(html.dark) .nav-drawer-close {
		color: var(--text-color) !important;
		background: var(--btn-regular-bg) !important;
	}

	:global(html.dark) .nav-drawer-link,
	:global(html.dark) .nav-drawer-sublink {
		color: var(--text-color) !important;
		background: var(--bg-secondary) !important;
	}

	:global(html.dark) .nav-drawer-link-icon {
		color: var(--content-meta) !important;
		background: var(--btn-regular-bg) !important;
	}
</style>

<script>
	// 移动端菜单按钮和面板控制脚本
	// 独立于 Swup，始终可用

	let isMenuOpen = false;
	const MENU_PORTAL_ID = "nav-menu-portal";

	function getPanel() {
		return document.getElementById("nav-menu-panel");
	}

	function getOverlay() {
		return document.getElementById("nav-menu-overlay");
	}

	function getSwitch() {
		return document.getElementById("nav-menu-switch");
	}

	function getCloseBtn() {
		const panel = getPanel();
		return panel ? panel.querySelector("#nav-menu-close") : null;
	}

	function ensureMenuPortal() {
		const panel = getPanel();
		const overlay = getOverlay();
		if (!panel || !overlay || !document.body) return;

		let portal = document.getElementById(MENU_PORTAL_ID);
		if (!portal) {
			portal = document.createElement("div");
			portal.id = MENU_PORTAL_ID;
			portal.setAttribute("data-nav-menu-portal", "");
			document.body.appendChild(portal);
		}

		if (overlay.parentElement !== portal) {
			portal.appendChild(overlay);
		}
		if (panel.parentElement !== portal) {
			portal.appendChild(panel);
		}
	}

	function openMenu() {
		ensureMenuPortal();
		const panel = getPanel();
		const overlay = getOverlay();
		if (panel) {
			panel.setAttribute("data-menu-open", "true");
			panel.removeAttribute("aria-hidden");
		}
		if (overlay) {
			overlay.classList.add("active");
		}
		document.body.classList.add("nav-menu-open");
		document.body.style.overflow = "hidden";
		isMenuOpen = true;
	}

	function closeMenu() {
		const panel = getPanel();
		const overlay = getOverlay();
		const switchBtn = getSwitch();
		if (panel) {
			panel.setAttribute("data-menu-open", "false");
			panel.setAttribute("aria-hidden", "true");
			if (document.activeElement && panel.contains(document.activeElement)) {
				if (switchBtn) {
					(switchBtn as HTMLElement).focus();
				} else {
					const closeBtn = getCloseBtn();
					if (closeBtn instanceof HTMLElement) {
						closeBtn.blur();
					}
				}
			}
		}
		if (overlay) {
			overlay.classList.remove("active");
		}
		document.body.classList.remove("nav-menu-open");
		document.body.style.overflow = "";
		isMenuOpen = false;
	}

	function toggleMenu() {
		if (isMenuOpen) {
			closeMenu();
		} else {
			openMenu();
		}
	}

	function handleDropdownClick(e: Event) {
		const target = e.target as Node | null;
		if (!target) return;
		const trigger = (target as Element).closest?.("[data-mobile-dropdown-trigger]");
		if (!trigger) return;

		e.preventDefault();
		const dropdown = (trigger as Element).closest?.("[data-mobile-dropdown]");
		if (!dropdown) return;

		const isExpanded = (dropdown as Element).getAttribute("data-expanded") === "true";

		document.querySelectorAll("[data-mobile-dropdown]").forEach((other) => {
			if (other !== dropdown) {
				(other as Element).setAttribute("data-expanded", "false");
				const otherTrigger = (other as Element).querySelector("[data-mobile-dropdown-trigger]");
				if (otherTrigger) {
					(otherTrigger as Element).setAttribute("aria-expanded", "false");
				}
			}
		});

		(dropdown as Element).setAttribute("data-expanded", String(!isExpanded));
		(trigger as Element).setAttribute("aria-expanded", String(!isExpanded));
	}

	function handleClick(e: MouseEvent) {
		const target = e.target as Node | null;
		if (!target) return;

		const targetEl = target as Element;

		// 检查是否点击了菜单开关按钮
		if (targetEl.closest?.("#nav-menu-switch")) {
			e.preventDefault();
			e.stopPropagation();
			toggleMenu();
			return;
		}

		// 检查是否点击了遮罩层
		if (targetEl.id === "nav-menu-overlay" || targetEl.classList?.contains("nav-drawer-overlay")) {
			e.preventDefault();
			closeMenu();
			return;
		}

		// 检查是否点击了关闭按钮
		if (targetEl.closest?.("#nav-menu-close")) {
			e.preventDefault();
			closeMenu();
			return;
		}

		// 检查是否点击了下拉菜单触发器
		if (targetEl.closest?.("[data-mobile-dropdown-trigger]")) {
			handleDropdownClick(e);
			return;
		}

		// 如果菜单是打开的
		if (isMenuOpen) {
			const panel = getPanel();
			const switchBtn = getSwitch();

			// 点击菜单内部但不在任何下拉菜单内 → 关闭所有展开的下拉
			const insideDropdown = targetEl.closest?.("[data-mobile-dropdown]");
			if (!insideDropdown) {
				document.querySelectorAll("[data-mobile-dropdown]").forEach((dd) => {
					(dd as Element).setAttribute("data-expanded", "false");
					const ddTrigger = (dd as Element).querySelector("[data-mobile-dropdown-trigger]");
					if (ddTrigger) {
						(ddTrigger as Element).setAttribute("aria-expanded", "false");
					}
				});
			}

			// 检查是否点击了菜单外部
			if (panel && !panel.contains(targetEl) && (!switchBtn || !switchBtn.contains(targetEl))) {
				const submenuTrigger = targetEl.closest?.("[data-mobile-submenu]");
				if (!submenuTrigger) {
					closeMenu();
				}
			}
		}
	}

	function handleKeydown(e: KeyboardEvent) {
		if (e.key === "Escape" && isMenuOpen) {
			closeMenu();
		}
	}

	// 直接在按钮上绑定点击事件作为主要交互方式
	function bindDirectClick() {
		const switchBtn = getSwitch();
		if (switchBtn) {
			// 移除旧的事件监听（如果有）
			const newBtn = switchBtn.cloneNode(true) as HTMLElement;
			switchBtn.parentNode?.replaceChild(newBtn, switchBtn);

			// 添加新的直接点击事件
			newBtn.addEventListener("click", (e) => {
				e.preventDefault();
				e.stopPropagation();
				toggleMenu();
			});
		}
	}

	function init() {
		// 重置状态
		isMenuOpen = false;
		ensureMenuPortal();

		// 绑定直接点击事件
		bindDirectClick();

		// 绑定全局点击事件（用于关闭菜单和处理子菜单）
		document.removeEventListener("click", handleClick);
		document.removeEventListener("keydown", handleKeydown);
		document.addEventListener("click", handleClick);
		document.addEventListener("keydown", handleKeydown);
	}

	// 页面加载时初始化
	function onLoad() {
		init();
	}

	// Swup 页面切换后重新初始化
	function onPageTransition() {
		// 关闭菜单
		closeMenu();
		// 延迟一点确保 DOM 已更新
		setTimeout(init, 50);
	}

	// 监听事件
	document.addEventListener("astro:page-load", onLoad);
	document.addEventListener("swup:page:view", onPageTransition);
	document.addEventListener("swup:contentReplaced", onPageTransition);

	// 如果页面已经加载完成，立即初始化
	if (document.readyState === "complete" || document.readyState === "interactive") {
		onLoad();
	}

	// 暴露全局方法
	(window as any).openNavMenu = openMenu;
	(window as any).closeNavMenu = closeMenu;
	(window as any).toggleNavMenu = toggleMenu;
</script>
