---
import { getCollection } from "astro:content";
import { announcementConfig, profileConfig } from "@/config";
import { getPostUrlBySlug } from "@/utils/url-utils";

// 收集统计
const summaryParts: string[] = [];

// 欢迎语（位置由客户端 JS 填入）
summaryParts.push(`[欢迎] 欢迎来自远方的朋友！`);

// 公告
if (announcementConfig.content) {
	summaryParts.push(`[公告] ${announcementConfig.content}`);
}

// 最近三天更新统计
const threeDaysAgo = new Date();
threeDaysAgo.setDate(threeDaysAgo.getDate() - 3);

const updateParts: string[] = [];

try {
	const posts = await getCollection("posts", ({ data }) =>
		import.meta.env.PROD ? data.draft !== true : true,
	);
	const count = posts.filter((p) => new Date(p.data.published) >= threeDaysAgo).length;
	if (count > 0) updateParts.push(`${count} 篇文章`);
} catch {}

try {
	const moments = await getCollection("moments");
	const count = moments.filter((m) => new Date(m.data.published) >= threeDaysAgo).length;
	if (count > 0) updateParts.push(`${count} 条动态`);
} catch {}

try {
	const bangumi = await getCollection("bangumi");
	const count = bangumi.filter((b) => b.data.published && new Date(b.data.published) >= threeDaysAgo).length;
	if (count > 0) updateParts.push(`${count} 部影视`);
} catch {}

try {
	const notebooks = await getCollection("notebooks");
	const count = notebooks.filter((n) => !n.id.includes("_index") && n.data.date && new Date(n.data.date) >= threeDaysAgo).length;
	if (count > 0) updateParts.push(`${count} 篇笔记`);
} catch {}

try {
	const changelog = await getCollection("changelog");
	const count = changelog.filter((c) => new Date(c.data.date) >= threeDaysAgo).length;
	if (count > 0) updateParts.push(`${count} 条日志`);
} catch {}

if (updateParts.length > 0) {
	summaryParts.push(`[更新] 最近三天更新了 ${updateParts.join("、")}`);
} else {
	summaryParts.push("[更新] 最近三天暂无更新");
}

const tickerContent = summaryParts.join(" \u00d7 ");
---

{
	tickerContent && (
		<section class="home-ticker" aria-label="公告跑马灯" id="home-ticker">
			<div class="home-ticker__inner">
				<div class="home-ticker__track" id="home-ticker-track">
				{Array.from({ length: 4 }).map(() => (
					<span class="home-ticker__text">{tickerContent}</span>
				))}
				</div>
			</div>
		</section>
	)
}

<script>
	function initHomeTicker() {
		const track = document.getElementById("home-ticker-track") as HTMLElement | null;
		if (!track) return;

		const SPEED = 100;
		const trackWidth = track.scrollWidth;
		const distance = trackWidth / 2;
		const duration = distance / SPEED;
		track.style.animationDuration = `${Math.max(duration, 4)}s`;
	}

	function updateTickerLocation() {
		if (!navigator.onLine) return;
		fetch("https://api.bigdatacloud.net/data/reverse-geocode-client?localityLanguage=zh")
			.then((r) => r.json())
			.then((data) => {
				const parts = [data.principalSubdivision, data.city].filter(Boolean);
				const loc = parts.slice(0, 2).join(" ");
				if (!loc) return;
				document.querySelectorAll(".home-ticker__text").forEach((el) => {
					el.textContent = (el.textContent || "").replace(/欢迎来自远方的朋友/g, `欢迎来自 ${loc} 的朋友`);
				});
			})
			.catch(() => {});
	}

	initHomeTicker();
	updateTickerLocation();
	document.addEventListener("astro:page-load", () => {
		initHomeTicker();
		updateTickerLocation();
	});
</script>
