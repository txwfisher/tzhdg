---
import { Icon } from "astro-icon/components";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { getSortedPosts } from "@utils/content-utils";
import { getPostUrlBySlug, removeFileExtension } from "@utils/url-utils";

interface Props {
    currentSlug: string;
    currentTags: string[];
    currentCategory?: string;
    maxCount?: number;
}

const { currentSlug, currentTags, currentCategory, maxCount = 5 } = Astro.props;

// 获取所有文章
const allPosts = await getSortedPosts();

// 过滤掉当前文章
const otherPosts = allPosts.filter((post) => {
    const slug = removeFileExtension(post.id);
    return slug !== currentSlug;
});

// 计算相关度：优先同分类，其次标签重叠度
function calculateRelevance(post: any): { score: number; sameCategory: boolean } {
    let score = 0;
    const sameCategory = !!(currentCategory && post.data.category === currentCategory);

    // 同分类权重最高
    if (sameCategory) {
        score += 100;
    }

    // 共享标签，每个 +5 分
    if (post.data.tags && Array.isArray(post.data.tags)) {
        const sharedTags = post.data.tags.filter((tag: string) =>
            currentTags.includes(tag)
        );
        score += sharedTags.length * 5;
    }

    return { score, sameCategory };
}

// 计算所有文章的相关度
const allRelated = otherPosts
    .map((post) => {
        const { score, sameCategory } = calculateRelevance(post);
        return { post, score, sameCategory };
    });

// 同分类文章：按得分降序，再按最新排序
const sameCategoryPosts = allRelated
    .filter((item) => item.sameCategory)
    .sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        return new Date(b.post.data.published).getTime() - new Date(a.post.data.published).getTime();
    })
    .slice(0, maxCount);

// 其他相关文章（不同分类但有共享标签）
const tagOnlyPosts = allRelated
    .filter((item) => !item.sameCategory && item.score > 0)
    .sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        return new Date(b.post.data.published).getTime() - new Date(a.post.data.published).getTime();
    });

// 合并结果：同分类优先 → 标签相关 → 最新文章补足
let relatedPosts = [...sameCategoryPosts];

// 同分类不够，从标签相关中补充
if (relatedPosts.length < maxCount) {
    const existingSlugs = new Set(relatedPosts.map((item) => removeFileExtension(item.post.id)));
    for (const item of tagOnlyPosts) {
        const slug = removeFileExtension(item.post.id);
        if (!existingSlugs.has(slug)) {
            relatedPosts.push(item);
            existingSlugs.add(slug);
            if (relatedPosts.length >= maxCount) break;
        }
    }
}

// 还不够，用最新文章填充
if (relatedPosts.length < maxCount) {
    const existingSlugs = new Set(relatedPosts.map((item) => removeFileExtension(item.post.id)));
    const latestPosts = otherPosts
        .filter((post) => {
            const slug = removeFileExtension(post.id);
            return !existingSlugs.has(slug);
        })
        .sort((a, b) => new Date(b.data.published).getTime() - new Date(a.data.published).getTime())
        .slice(0, maxCount - relatedPosts.length);

    latestPosts.forEach((post) => {
        relatedPosts.push({ post, score: 0, sameCategory: false });
    });
}
---

{relatedPosts.length > 0 && (
    <div class="related-posts card-base px-5 py-4 mb-4">
        <div class="flex items-center gap-2 mb-3">
            <Icon name="material-symbols:auto-awesome" class="text-lg text-(--primary)" />
            <h3 class="text-base font-bold text-neutral-900 dark:text-neutral-100">
                {i18n(I18nKey.relatedPosts)}
            </h3>
        </div>
        <div class="grid grid-cols-1 divide-y divide-neutral-100 dark:divide-neutral-800">
            {relatedPosts.map(({ post, score }, idx) => {
                const slug = removeFileExtension(post.id);
                const postUrl = getPostUrlBySlug(slug);
                return (
                    <a
                        href={postUrl}
                        class="group flex items-center gap-3 py-2.5 hover:bg-(--btn-plain-bg-hover) dark:hover:bg-(--btn-plain-bg-hover-dark) -mx-2 px-2 rounded-md transition-colors"
                    >
                        {/* 序号 */}
                        <span class="flex-shrink-0 w-5 h-5 rounded-full bg-(--primary)/10 text-(--primary) flex items-center justify-center text-[11px] font-semibold">
                            {idx + 1}
                        </span>

                        {/* 标题 + 标签 */}
                        <span class="flex-1 min-w-0 flex items-center gap-2">
                            <span class="text-sm text-neutral-700 dark:text-neutral-300 line-clamp-1 group-hover:text-(--primary) transition-colors">
                                {post.data.title}
                            </span>
                            {post.data.tags && post.data.tags.length > 0 && (
                                <span class="hidden sm:flex flex-shrink-0 gap-1">
                                    {post.data.tags.slice(0, 2).map((tag: string) => (
                                        <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400 whitespace-nowrap">
                                            #{tag}
                                        </span>
                                    ))}
                                </span>
                            )}
                        </span>

                        {/* 分类标签 */}
                        {post.data.category && (
                            <span class="flex-shrink-0 px-2 py-0.5 rounded-full text-[10px] font-medium bg-(--primary)/8 text-(--primary) whitespace-nowrap">
                                {post.data.category}
                            </span>
                        )}
                    </a>
                );
            })}
        </div>
    </div>
)}

<style>
    .related-posts {
        animation: fadeInUp 0.4s ease-out;
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
