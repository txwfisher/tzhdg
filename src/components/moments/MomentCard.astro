---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import { formatDateToYYYYMMDD } from "@/utils/date-utils";
import { getTagUrl } from "@/utils/url-utils";
import Markdown from "@/components/common/Markdown.astro";
import { Image } from "astro:assets";

interface Props {
	moment: CollectionEntry<"moments">;
}

const { moment } = Astro.props;
const { Content } = await render(moment);
const { author, avatar, published, images, tags, location, device } =
	moment.data;

// 获取 moments 资产目录下的所有图片
const momentAssets = import.meta.glob<{ default: ImageMetadata }>(
	"../../content/moments/assets/*.{jpeg,jpg,png,gif,webp,avif}",
	{ eager: true },
);

// 解析图片路径
const parseImages = (imagesData: any): (string | ImageMetadata)[] => {
	let rawPaths: string[] = [];
	if (Array.isArray(imagesData)) {
		rawPaths = imagesData.map((img) =>
			typeof img === "string" ? img : img.src || img,
		);
	} else if (typeof imagesData === "string" && imagesData.trim()) {
		rawPaths = imagesData
			.split(/[,;]/)
			.map((img) => img.trim())
			.filter((img) => img);
	}

	return Array.from(new Set(rawPaths))
		.map((img) => {
			if (
				img.startsWith("http://") ||
				img.startsWith("https://") ||
				img.startsWith("/")
			) {
				return img;
			}

			const cleanPath = img.replace(/^\.\//, "");
			if (cleanPath.startsWith("assets/")) {
				const fileName = cleanPath.replace("assets/", "");
				for (const path in momentAssets) {
					if (path.endsWith(fileName)) {
						return momentAssets[path].default;
					}
				}
			}
			return img;
		})
		.filter((img) => img);
};

// 计算图片网格列数
const getGridCols = (count: number) => {
	if (count === 1) return 1;
	if (count === 2 || count === 4) return 2;
	return 3;
};

const momentId = moment.id;
const imagesArray = parseImages(images);
const maxImages = 9;
const displayImages = imagesArray.slice(0, maxImages);
const remainingCount = imagesArray.length - maxImages;
const hiddenImages = imagesArray.slice(maxImages);

const getImgSrc = (img: string | ImageMetadata): string => {
	if (typeof img === "string") return img;
	return img.src;
};

// 相对时间
const formatTimeAgo = (date: Date): string => {
	const now = new Date();
	const diff = now.getTime() - date.getTime();
	const minutes = Math.floor(diff / 60000);
	const hours = Math.floor(diff / 3600000);
	const days = Math.floor(diff / 86400000);

	if (minutes < 1) return "刚刚";
	if (minutes < 60) return `${minutes}分钟前`;
	if (hours < 24) return `${hours}小时前`;
	if (days < 30) return `${days}天前`;
	return formatDateToYYYYMMDD(date);
};
---

<div id={moment.id} class="moment-card group">
	<!-- 卡片头部：头像 + 用户信息 -->
	<div class="card-header">
		<div class="card-avatar">
			{avatar ? (
				<img
					src={avatar}
					alt={author}
					class="avatar-img"
					loading="lazy"
				/>
			) : (
				<img
					src="/avatar.png"
					alt={author}
					class="avatar-img"
					loading="lazy"
					onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22%23999%22><circle cx=%2212%22 cy=%228%22 r=%224%22/><path d=%22M20 21a8 8 0 1 0-16 0%22/></svg>'"
				/>
			)}
		</div>
		<div class="card-user-info">
			<div class="user-row">
				<span class="user-name">{author || "匿名"}</span>
			</div>
			<div class="meta-row">
				<time
					datetime={published.toISOString()}
					title={formatDateToYYYYMMDD(published)}
				>
					{formatTimeAgo(published)}
				</time>
				{location && (
					<>
						<span class="meta-dot">·</span>
						<span class="location">
							<Icon
								name="material-symbols:location-on-outline"
								class="location-icon"
							/>
							{location}
						</span>
					</>
				)}
			</div>
		</div>
	</div>

	<!-- 内容 -->
	<div class="card-content">
		<div
			class="moment-markdown text-[var(--text-color)] text-[0.9375rem] leading-[1.75]"
		>
			<Markdown class="moment-markdown-content">
				<Content />
			</Markdown>
		</div>
	</div>

	<!-- 图片 -->
	{imagesArray && imagesArray.length > 0 && (
		<div
			class={`card-images image-cols-${getGridCols(imagesArray.length)} ${imagesArray.length === 1 ? "single-image" : ""}`}
		>
			{displayImages.map((img, index) => {
				const imgSrc = getImgSrc(img);
				const isMoreTrigger = index === maxImages - 1 && remainingCount > 0;

				return (
					<div class={`image-item ${isMoreTrigger ? "has-more" : ""}`}>
						{typeof img === "string" ? (
							<img
								src={img}
								alt="Moment image"
								class="image-img"
								loading="lazy"
								data-fancybox={`gallery-${moment.id}`}
								data-src={imgSrc}
							/>
						) : (
							<Image
								src={img}
								alt="Moment image"
								class="image-img"
								loading="lazy"
								data-fancybox={`gallery-${moment.id}`}
								data-src={imgSrc}
							/>
						)}

						{isMoreTrigger && (
							<div class="more-overlay">
								<span class="more-text">+{remainingCount + 1}</span>
							</div>
						)}
					</div>
				);
			})}
		</div>
	)}

	<!-- 底部标签 -->
	{tags && tags.length > 0 && (
		<div class="card-tags">
			{tags.map((tag) => (
				<a href={getTagUrl(tag)} class="tag-item">
					#{tag.trim()}
				</a>
			))}
		</div>
	)}
</div>

<style>
	@reference "../../styles/main.css";

	/* ============================================
	 * 卡片主体
	 * ============================================ */
	.moment-card {
		background: var(--card-bg);
		border-radius: var(--radius-large);
		padding: 1rem;
		box-shadow: var(--shadow-sm);
		border: 1px solid var(--border);
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.moment-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-1px);
	}

	/* ============================================
	 * 卡片头部
	 * ============================================ */
	.card-header {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		margin-bottom: 0.75rem;
	}

	/* 头像 */
	.card-avatar {
		flex-shrink: 0;
	}

	.avatar-img {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid var(--primary);
		box-sizing: border-box;
	}

	.card-user-info {
		flex: 1;
		min-width: 0;
	}

	.user-row {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		margin-bottom: 0.125rem;
	}

	.user-name {
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--primary);
	}

	.meta-row {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.75rem;
		color: var(--content-meta);
	}

	.meta-dot {
		opacity: 0.5;
	}

	.location {
		display: inline-flex;
		align-items: center;
		gap: 0.125rem;
		max-width: 120px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.location-icon {
		font-size: 0.875rem;
		flex-shrink: 0;
	}

	/* ============================================
	 * 内容区域
	 * ============================================ */
	.card-content {
		margin-bottom: 0.75rem;
	}

	.moment-markdown :global(p) {
		margin-bottom: 0.375rem;
		word-break: break-word;
	}

	.moment-markdown :global(p:last-child) {
		margin-bottom: 0;
	}

	.moment-markdown :global(img) {
		border-radius: var(--radius);
		margin: 0.5rem 0;
		max-width: 100%;
	}

	/* ============================================
	 * 图片网格
	 * ============================================ */
	.card-images {
		display: grid;
		gap: 0.375rem;
		margin-bottom: 0.75rem;
	}

	.image-cols-1 {
		grid-template-columns: 1fr;
		max-width: 400px;
	}

	.image-cols-2 {
		grid-template-columns: repeat(2, 1fr);
	}

	.image-cols-3 {
		grid-template-columns: repeat(3, 1fr);
	}

	.image-item {
		position: relative;
		border-radius: var(--radius);
		overflow: hidden;
		cursor: pointer;
		background: var(--bg-secondary);
		aspect-ratio: 1;
	}

	.single-image .image-item {
		aspect-ratio: auto;
		border-radius: var(--radius-large);
	}

	.image-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.image-item:hover .image-img {
		transform: scale(1.03);
	}

	.has-more .image-img {
		filter: brightness(0.6);
	}

	.more-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.more-text {
		font-size: 1.5rem;
		font-weight: 700;
		color: white;
		text-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
	}

	/* ============================================
	 * 标签 - 胶囊描边样式
	 * ============================================ */
	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		padding-top: 0.625rem;
		border-top: 1px solid var(--border);
	}

	.tag-item {
		padding: 0.25rem 0.625rem;
		background: transparent;
		border: 1px solid var(--primary);
		border-radius: 9999px;
		font-size: 0.75rem;
		color: var(--primary);
		transition: all 0.2s ease;
	}

	.tag-item:hover {
		background: color-mix(in srgb, var(--primary) 10%, transparent);
	}

	/* ============================================
	 * 响应式
	 * ============================================ */
	@media (max-width: 480px) {
		.moment-card {
			padding: 0.875rem;
			border-radius: var(--radius);
		}

		.avatar-img {
			width: 2.25rem;
			height: 2.25rem;
		}

		.user-name {
			font-size: 0.875rem;
		}

		.meta-row {
			font-size: 0.6875rem;
		}

		.location {
			max-width: 80px;
		}

		.card-images {
			gap: 0.25rem;
		}

		.more-text {
			font-size: 1.25rem;
		}
	}
</style>
